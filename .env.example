# Google Analytics (Astro site tag)
PUBLIC_GA_ID=G-XXXXXXXXXX

# API Keys (if needed)
# GEMINI_API_KEY=your_api_key_here

# ── SEO Command Center ──────────────────────────────────────────
# Service account JSON key (download from Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_KEY=./scripts/credentials/service-account.json

# Google API key (for GBP unauthenticated reads)
GOOGLE_API_KEY=your_google_api_key_here

# Google Search Console — verified site URL
GSC_SITE_URL=https://dryspacewaterproofing.ca

# Google Analytics 4 — property ID (format: properties/XXXXXXXX)
GA4_PROPERTY_ID=properties/XXXXXXXX

# Google Business Profile — account and location IDs
GBP_ACCOUNT_ID=accounts/XXXXXXXX
GBP_LOCATION_ID=locations/XXXXXXXX