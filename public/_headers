# Security Headers Configuration for Spaders Waterproofing
# Netlify _headers file format

/*
  # Content Security Policy - Secure but flexible for modern web apps
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://code.tidio.co https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://api.tidio.co https://*.googleapis.com; frame-src 'self' https://www.youtube.com https://www.google.com; media-src 'self' https:; worker-src 'self' blob:
  
  # Security Headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  
  # HSTS - Enforce HTTPS
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Cache Control for static assets
  Cache-Control: public, max-age=31536000, immutable

# HTML pages - shorter cache
/*.html
  Cache-Control: public, max-age=0, must-revalidate
  
# Service Worker
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
  
# API routes - no cache
/api/*
  Cache-Control: no-cache, no-store, must-revalidate
  
# Images - long cache
/images/*
  Cache-Control: public, max-age=31536000, immutable
  
# CSS and JS - versioned cache
/*.css
  Cache-Control: public, max-age=31536000, immutable
  
/*.js
  Cache-Control: public, max-age=31536000, immutable