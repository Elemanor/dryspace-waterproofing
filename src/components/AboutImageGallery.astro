---
// About page image gallery component
---

<section class="py-12 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-slate-900 mb-4 uppercase">
        Our Work & Expertise
      </h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">
        25 years of excellence in waterproofing and foundation repair
      </p>
    </div>
    
    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <!-- Team at Work -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/professional-team.webp" 
          alt="Dryspace professional team at work"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Expert Team</h3>
          <p class="text-sm text-slate-600">Our certified professionals bringing decades of experience to every project</p>
        </div>
      </div>
      
      <!-- Quality Workmanship -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/exterior-waterproofing-toronto in process (1).webp" 
          alt="Quality waterproofing work in progress"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Quality Craftsmanship</h3>
          <p class="text-sm text-slate-600">Attention to detail in every waterproofing project we undertake</p>
        </div>
      </div>
      
      <!-- Advanced Equipment -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/excavation-process.webp" 
          alt="Advanced waterproofing equipment"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Modern Equipment</h3>
          <p class="text-sm text-slate-600">State-of-the-art tools and technology for efficient solutions</p>
        </div>
      </div>
      
      <!-- Safety First -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/excavation-safety.webp" 
          alt="Safety measures at work site"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Safety First</h3>
          <p class="text-sm text-slate-600">WSIB compliant with comprehensive safety protocols</p>
        </div>
      </div>
      
      <!-- Warranty Work -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/dryspace_exterior_waterproofing_warranty.webp" 
          alt="25-year warranty waterproofing"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Lifetime Warranty</h3>
          <p class="text-sm text-slate-600">Every project backed by our transferable lifetime warranty</p>
        </div>
      </div>
      
      <!-- Community Service -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/dryspace_excellence.webp" 
          alt="Community involvement"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Community Focused</h3>
          <p class="text-sm text-slate-600">Proudly serving Toronto and GTA communities since 1999</p>
        </div>
      </div>
    </div>
    
    <!-- Certifications Visual -->
    <div class="bg-white rounded-lg shadow-md p-8">
      <h3 class="text-2xl font-bold text-slate-900 mb-6 text-center uppercase">
        Our Certifications & Memberships
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-amber-500 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-black">A+</span>
          </div>
          <p class="text-sm text-slate-600">BBB Rating</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-navy-900 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">WSIB</span>
          </div>
          <p class="text-sm text-slate-600">Fully Insured</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-cyan-600 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">25Y</span>
          </div>
          <p class="text-sm text-slate-600">Warranty</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-cyan-600 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">✓</span>
          </div>
          <p class="text-sm text-slate-600">Licensed</p>
        </div>
      </div>
    </div>
  </div>
</section>