---
export interface Props {
  topic: string;
}

const { topic } = Astro.props;

// Map blog topics to relevant images
const blogImages = {
  'waterproofing-cost': [
    {
      src: '/images/exterior-waterproofing-toronto in process (1).webp',
      alt: 'Exterior waterproofing excavation and membrane installation in Toronto',
      caption: 'Full exterior excavation and waterproofing'
    },
    {
      src: '/images/interior-waterproofing.webp',
      alt: 'Interior waterproofing drainage system and vapor barrier installation',
      caption: 'Interior drainage system installation'
    },
    {
      src: '/images/dryspace_exterior_waterproofing_warranty.webp',
      alt: 'Completed basement waterproofing project covered by 25-year transferable warranty',
      caption: 'Professional installation with warranty'
    }
  ],
  
  'foundation-repair': [
    {
      src: '/images/structural foundation crack.webp',
      alt: 'Severe structural foundation crack requiring professional repair in Toronto',
      caption: 'Major structural crack requiring repair'
    },
    {
      src: '/images/crack on foundation wall due winter freeze .webp',
      alt: 'Foundation wall crack caused by winter freeze-thaw cycles in Toronto',
      caption: 'Winter freeze-thaw damage'
    },
    {
      src: '/images/crack_repair.webp',
      alt: 'Professional foundation crack injection repair using epoxy sealant',
      caption: 'Professional foundation repair work'
    }
  ],
  
  'basement-leaking': [
    {
      src: '/images/wet walls.webp',
      alt: 'Water seepage and moisture damage on basement foundation walls',
      caption: 'Water infiltration through walls'
    },
    {
      src: '/images/cove leak.webp',
      alt: 'Water leaking through basement floor cove joint requiring interior drainage',
      caption: 'Common cove joint water seepage'
    },
    {
      src: '/images/waterp on the floor.webp',
      alt: 'Flooded basement with standing water requiring emergency waterproofing service',
      caption: 'Severe water damage requiring attention'
    }
  ],
  
  'sump-pump': [
    {
      src: '/images/sump-pump.webp',
      alt: 'Professional sump pump installation with discharge pipe in Toronto basement',
      caption: 'Professional sump pump system'
    },
    {
      src: '/images/sump pump with back up.webp',
      alt: 'Sump pump with battery backup system for emergency power outage protection',
      caption: 'Emergency battery backup for power outages'
    },
    {
      src: '/images/placing new sump pump.webp',
      alt: 'Installing new sump pump in basement sump pit with proper gravel base',
      caption: 'Regular maintenance ensures reliability'
    }
  ],
  
  'french-drain': [
    {
      src: '/images/drains.webp',
      alt: 'French drain and weeping tile installation around Toronto home foundation',
      caption: 'Proper French drain installation'
    },
    {
      src: '/images/perforated drain.webp',
      alt: 'Perforated weeping tile pipe for foundation perimeter drainage system',
      caption: 'Complete weeping tile perimeter drainage'
    },
    {
      src: '/images/dimpled membrane on base of footing.webp',
      alt: 'Dimpled drainage membrane installed at foundation footing with clear stone backfill',
      caption: 'Proper gravel for optimal drainage'
    }
  ],
  
  'efflorescence': [
    {
      src: '/images/Efflorescence.webp',
      alt: 'White efflorescence mineral deposits on basement wall indicating moisture problems',
      caption: 'Efflorescence mineral deposits'
    },
    {
      src: '/images/wet walls.webp',
      alt: 'Moisture damage signs',
      caption: 'Chronic moisture problems'
    },
    {
      src: '/images/spalling.webp',
      alt: 'Concrete spalling and salt deposits from chronic water infiltration',
      caption: 'Mineral salts from water infiltration'
    }
  ],
  
  'musty-smell': [
    {
      src: '/images/mold.webp',
      alt: 'Black mold growth on basement walls from high humidity and water damage',
      caption: 'Mold causing musty odors'
    },
    {
      src: '/images/basement-water-leak-inspection.webp',
      alt: 'Professional moisture detection and basement leak inspection with specialized equipment',
      caption: 'Professional moisture detection'
    },
    {
      src: '/images/wetcove.webp',
      alt: 'Wet basement cove joint showing active water seepage and flooding',
      caption: 'Commercial dehumidification equipment'
    }
  ],
  
  'diy-vs-pro': [
    {
      src: '/images/damprofiing.webp',
      alt: 'Failed DIY dampproofing showing common waterproofing mistakes',
      caption: 'Common DIY waterproofing mistakes'
    },
    {
      src: '/images/exterior-waterproofing-toronto in process (2).webp',
      alt: 'Licensed professional waterproofing crew excavating Toronto home foundation',
      caption: 'Experienced professional crew'
    },
    {
      src: '/images/dryspace_exterior_waterproofing_warranty.webp',
      alt: 'Professional exterior waterproofing backed by transferable 25-year warranty',
      caption: '25-year warranty on professional work'
    }
  ]
