---
// Contact page image gallery component
---

<section class="py-12 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-bold text-slate-900 mb-4 uppercase">
        Why Choose Dryspace Waterproofing
      </h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">
        See our professional team in action and the quality of our work
      </p>
    </div>
    
    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
      <!-- Professional Team -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/professional-team.webp" 
          alt="Dryspace professional waterproofing team"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Professional Team</h3>
          <p class="text-sm text-slate-600">Certified experts ready to solve your waterproofing needs</p>
        </div>
      </div>
      
      <!-- Emergency Response -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/emergency-response.webp" 
          alt="24/7 emergency waterproofing response"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace basement waterproofing in process.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">24/7 Emergency Service</h3>
          <p class="text-sm text-slate-600">Fast response time for urgent waterproofing situations</p>
        </div>
      </div>
      
      <!-- Quality Equipment -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/excavation-process.webp" 
          alt="Professional waterproofing equipment"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Modern Equipment</h3>
          <p class="text-sm text-slate-600">Latest technology for efficient waterproofing solutions</p>
        </div>
      </div>
      
      <!-- Customer Service -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/customer-consultation.webp" 
          alt="Waterproofing consultation with customer"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
          onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Free Consultations</h3>
          <p class="text-sm text-slate-600">Detailed inspections and honest recommendations</p>
        </div>
      </div>
      
      <!-- Warranty Protected -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/dryspace_exterior_waterproofing_warranty.webp" 
          alt="25-year transferable warranty"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">Lifetime Warranty</h3>
          <p class="text-sm text-slate-600">25-year transferable warranty on all major work</p>
        </div>
      </div>
      
      <!-- Service Areas -->
      <div class="bg-white rounded-lg shadow-md overflow-hidden">
        <img 
          src="/images/dryspace-location.webp" 
          alt="Service coverage across Greater Toronto Area"
          loading="lazy"
          class="w-full h-64 object-cover" width="400" height="256" decoding="async"
        />
        <div class="p-4">
          <h3 class="font-bold text-slate-900 mb-2">GTA-Wide Coverage</h3>
          <p class="text-sm text-slate-600">Serving all of Greater Toronto Area since 1999</p>
        </div>
      </div>
    </div>
    
    <!-- Process Images -->
    <div class="bg-white rounded-lg shadow-md p-8">
      <h3 class="text-2xl font-bold text-slate-900 mb-6 text-center uppercase">
        Our Inspection Process
      </h3>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Step 1 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 overflow-hidden rounded-lg">
            <img 
              src="/images/foundation-inspection.webp" 
              alt="Foundation inspection process"
              loading="lazy"
              class="w-full h-full object-cover" width="600" height="400" decoding="async"
              onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
            />
          </div>
          <h4 class="font-bold text-slate-900 mb-2">1. Inspection</h4>
          <p class="text-sm text-slate-600">Thorough assessment of your property</p>
        </div>
        
        <!-- Step 2 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 overflow-hidden rounded-lg">
            <img 
              src="/images/waterproofing-plan.webp" 
              alt="Custom waterproofing plan"
              loading="lazy"
              class="w-full h-full object-cover" width="600" height="400" decoding="async"
              onerror="this.onerror=null; this.src='/images/dryspace basement waterproofing in process.webp';"
            />
          </div>
          <h4 class="font-bold text-slate-900 mb-2">2. Planning</h4>
          <p class="text-sm text-slate-600">Custom solution for your needs</p>
        </div>
        
        <!-- Step 3 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 overflow-hidden rounded-lg">
            <img 
              src="/images/waterproofing-quote.webp" 
              alt="Transparent pricing quote"
              loading="lazy"
              class="w-full h-full object-cover" width="600" height="400" decoding="async"
              onerror="this.onerror=null; this.src='/images/dryspace_excellence.webp';"
            />
          </div>
          <h4 class="font-bold text-slate-900 mb-2">3. Quote</h4>
          <p class="text-sm text-slate-600">Clear, detailed pricing</p>
        </div>
        
        <!-- Step 4 -->
        <div class="text-center">
          <div class="w-32 h-32 mx-auto mb-4 overflow-hidden rounded-lg">
            <img 
              src="/images/professional-waterproofing.webp" 
              alt="Professional waterproofing service"
              loading="lazy"
              class="w-full h-full object-cover" width="600" height="400" decoding="async"
              onerror="this.onerror=null; this.src='/images/exterior-waterproofing-toronto in process (1).webp';"
            />
          </div>
          <h4 class="font-bold text-slate-900 mb-2">4. Service</h4>
          <p class="text-sm text-slate-600">Professional execution</p>
        </div>
      </div>
    </div>
    
    <!-- Trust Badges Visual -->
    <div class="mt-12 bg-white rounded-lg shadow-md p-8">
      <h3 class="text-2xl font-bold text-slate-900 mb-6 text-center uppercase">
        Licensed, Insured & Certified
      </h3>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6">
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-amber-500 rounded-full flex items-center justify-center">
            <span class="text-2xl font-bold text-black">A+</span>
          </div>
          <p class="text-sm text-slate-600">BBB Rating</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-navy-900 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">WSIB</span>
          </div>
          <p class="text-sm text-slate-600">Fully Insured</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-cyan-600 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">25Y</span>
          </div>
          <p class="text-sm text-slate-600">Warranty</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-cyan-600 rounded-full flex items-center justify-center">
            <span class="text-white text-3xl">✓</span>
          </div>
          <p class="text-sm text-slate-600">Licensed</p>
        </div>
        <div class="text-center">
          <div class="w-20 h-20 mx-auto mb-3 bg-red-600 rounded-full flex items-center justify-center">
            <span class="text-white font-bold">24/7</span>
          </div>
          <p class="text-sm text-slate-600">Emergency</p>
        </div>
      </div>
    </div>
  </div>
</section>