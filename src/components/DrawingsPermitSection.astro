---
// Professional Drawings & Permit Service Section - Side by Side
---

<section class="py-16 bg-gradient-to-br from-blue-50 to-gray-50">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        Professional Drawings & Permit Management
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        We handle all technical drawings and City of Toronto permits - No hassle, 100% compliant
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-stretch">
      <!-- Left Side - Technical Drawings -->
      <div class="bg-white rounded-xl shadow-xl overflow-hidden">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 p-6">
          <h3 class="text-2xl font-bold text-slate-900 flex items-center">
            <svg class="w-8 h-8 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
            </svg>
            Technical Drawings
          </h3>
          <p class="text-cyan-100">Professional CAD drawings for permit approval</p>
        </div>
        
        <div class="p-6">
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Site Plans</h4>
                <p class="text-slate-500 text-sm">Detailed property layout showing drainage routes, sump locations, and backwater valve placement</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Cross-Section Drawings</h4>
                <p class="text-slate-500 text-sm">Foundation details, waterproofing membrane layers, and drainage system specifications</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Plumbing Schematics</h4>
                <p class="text-slate-500 text-sm">Sump pump discharge routing, backwater valve integration, and connection points</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Elevation Drawings</h4>
                <p class="text-slate-500 text-sm">Grade levels, slope calculations, and surface water management plans</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <svg class="w-5 h-5 text-cyan-600" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Detail Drawings</h4>
                <p class="text-slate-500 text-sm">Connection details, waterproofing terminations, and critical junction points</p>
              </div>
            </div>
          </div>

          <div class="mt-6 p-4 bg-cyan-50 rounded-lg">
            <p class="text-sm font-semibold text-cyan-800 mb-2">All Drawings Include:</p>
            <ul class="text-sm text-cyan-700 space-y-1">
              <li>• Engineer stamp when required</li>
              <li>• City of Toronto format compliance</li>
              <li>• Digital & print copies</li>
              <li>• Revision support if needed</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Right Side - Permit Service -->
      <div class="bg-white rounded-xl shadow-xl overflow-hidden">
        <div class="bg-gradient-to-r from-green-600 to-green-700 p-6">
          <h3 class="text-2xl font-bold text-slate-900 flex items-center">
            <svg class="w-8 h-8 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Complete Permit Service
          </h3>
          <p class="text-cyan-100">We handle everything from application to final approval</p>
        </div>

        <div class="p-6">
          <div class="space-y-4">
            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <span class="block w-5 h-5 text-center text-cyan-600 font-bold text-sm">1</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Application Preparation</h4>
                <p class="text-slate-500 text-sm">Complete all City forms, compile required documents, prepare application package</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <span class="block w-5 h-5 text-center text-cyan-600 font-bold text-sm">2</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Submission & Tracking</h4>
                <p class="text-slate-500 text-sm">Submit to City of Toronto, track progress, respond to any reviewer comments</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <span class="block w-5 h-5 text-center text-cyan-600 font-bold text-sm">3</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Ontario One Call</h4>
                <p class="text-slate-500 text-sm">Coordinate utility locates for exterior work (5 business days)</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <span class="block w-5 h-5 text-center text-cyan-600 font-bold text-sm">4</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Inspection Scheduling</h4>
                <p class="text-slate-500 text-sm">Book rough-in and final inspections at optimal project stages</p>
              </div>
            </div>

            <div class="flex items-start">
              <div class="bg-cyan-50 rounded-full p-2 mr-3 mt-1">
                <span class="block w-5 h-5 text-center text-cyan-600 font-bold text-sm">5</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Compliance & Closure</h4>
                <p class="text-slate-500 text-sm">Ensure all requirements met, obtain final approval, close permit properly</p>
              </div>
            </div>
          </div>

          <div class="mt-6 p-4 bg-cyan-50 rounded-lg">
            <p class="text-sm font-semibold text-cyan-800 mb-2">Permit Types We Handle:</p>
            <ul class="text-sm text-cyan-700 space-y-1">
              <li>• Building permits (underpinning)</li>
              <li>• Plumbing permits (sump pumps)</li>
              <li>• Drain permits (backwater valves)</li>
              <li>• Site alteration permits</li>
            </ul>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Stats Bar -->
    <div class="mt-12 bg-white rounded-xl shadow-lg p-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <div class="text-3xl font-bold text-orange-600">2-3</div>
          <div class="text-sm text-slate-500">Days Permit Approval</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-600">100%</div>
          <div class="text-sm text-slate-500">Approval Rate</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-600">$0</div>
          <div class="text-sm text-slate-500">Hidden Fees</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-orange-600">25yr</div>
          <div class="text-sm text-slate-500">Permit Experience</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-8">
      <p class="text-lg text-slate-600 mb-4">
        Don't let permits delay your waterproofing project - Let our experts handle it
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-inspection" class="inline-block px-6 py-3 bg-orange-600 text-white rounded-lg font-semibold hover:bg-orange-700 transition-colors">
          Get Started Today
        </a>
        <a href="/contact" class="inline-block px-6 py-3 bg-slate-600 text-white rounded-lg font-semibold hover:bg-slate-700 transition-colors">
          Ask About Permits
        </a>
      </div>
    </div>
  </div>
</section>