---
const features = [
  {
    title: "Lightning Fast",
    description: "Experience blazing fast performance with our optimized infrastructure",
    icon: "M13 10V3L4 14h7v7l9-11h-7z"
  },
  {
    title: "Secure by Default",
    description: "Enterprise-grade security to protect your data and privacy",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"
  },
  {
    title: "Easy Integration",
    description: "Seamlessly integrate with your existing tools and workflows",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
  },
  {
    title: "24/7 Support",
    description: "Round-the-clock support to help you succeed",
    icon: "M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
  },
  {
    title: "Analytics Dashboard",
    description: "Comprehensive insights and analytics at your fingertips",
    icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
  },
  {
    title: "Global Scale",
    description: "Scale globally with our distributed infrastructure",
    icon: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
  }
];
---

<section id="features" class="py-20 bg-slate-800">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-5xl font-bold mb-4 text-white">Powerful Features</h2>
      <p class="text-xl text-slate-300 max-w-2xl mx-auto">
        Everything you need to build modern applications with confidence
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature) => (
        <div class="card bg-slate-900 shadow-xl hover:shadow-2xl transition-all duration-300 border border-slate-700 hover:border-purple-500">
          <div class="card-body">
            <div class="w-12 h-12 bg-purple-600/20 rounded-lg flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 text-purple-400">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="card-title text-2xl mb-2 text-white">{feature.title}</h3>
            <p class="text-slate-400">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>