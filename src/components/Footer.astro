---
const currentYear = new Date().getFullYear();

const footerLinks = {
  services: [
    { name: 'Exterior Waterproofing', href: '/services/exterior-waterproofing' },
    { name: 'Interior Waterproofing', href: '/services/interior-waterproofing' },
    { name: 'Foundation Repair', href: '/services/foundation-repair' },
    { name: 'Sump Pump Installation', href: '/services/sump-pump-installation' },
    { name: 'Underpinning', href: '/services/underpinning' },
    { name: 'Concrete Works', href: '/services/concrete-works' },
    { name: 'Emergency Service', href: '/emergency' },
  ],
  areas: [
    { name: 'Toronto', href: '/locations/toronto' },
    { name: 'Mississauga', href: '/locations/mississauga' },
    { name: 'Brampton', href: '/locations/brampton' },
    { name: 'Vaughan', href: '/locations/vaughan' },
    { name: 'Markham', href: '/locations/markham' },
    { name: 'All Service Areas', href: '/service-areas' },
  ],
  resources: [
    { name: 'Smart Monitor', href: '/smart-monitor' },
    { name: 'Cost Calculator', href: '/tools/waterproofing-cost-calculator' },
    { name: 'Crack Analyzer', href: '/tools/crack-analyzer' },
    { name: 'Basement Health Quiz', href: '/tools/basement-health-quiz' },
    { name: 'Sump Pump Selector', href: '/tools/sump-pump-selector' },
    { name: 'Insurance Claim Writer', href: '/tools/insurance-claim-writer' },
    { name: 'Flood Risk Checker', href: '/tools/flood-risk-checker' },
    { name: 'Permit Checker', href: '/tools/permit-checker' },
    { name: 'Method Comparison', href: '/tools/method-comparison' },
    { name: 'Second Unit Planner', href: '/second-unit' },
    { name: 'Blog & Guides', href: '/blog' },
    { name: 'Case Studies', href: '/case-studies' },
    { name: 'Government Rebates', href: '/government-rebates' },
    { name: 'Financing', href: '/financing' },
    { name: 'Warranty', href: '/warranty' },
  ],
  company: [
    { name: 'About Us', href: '/about' },
    { name: 'Contact', href: '/contact' },
    { name: 'Free Inspection', href: '/free-inspection' },
    { name: 'Gallery', href: '/gallery' },
    { name: 'Privacy Policy', href: '/privacy' },
    { name: 'Terms of Service', href: '/terms' },
  ],
};

const certifications = [
  { label: 'BBB A+ Rated', icon: 'badge' },
  { label: 'HomeStars Verified', icon: 'star' },
  { label: 'WSIB Compliant', icon: 'shield' },
  { label: 'Licensed & Insured', icon: 'certificate' },
  { label: '$5M Liability', icon: 'protect' },
];
---

<footer class="bg-navy-900 text-slate-400">
  <!-- Trust Certifications Banner -->
  <div class="border-b border-white/5">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-wrap items-center justify-center gap-6 lg:gap-10">
        {certifications.map((cert) => (
          <div class="flex items-center gap-2 text-sm font-medium text-white/70 transition-colors hover:text-white">
            <svg class="h-4 w-4 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            {cert.label}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-6 gap-10 lg:gap-8">
      <!-- Company Info -->
      <div class="lg:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <svg class="h-7 w-7 text-cyan-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 007.92 12.446A9 9 0 1112 2.992z" /><path d="M12 3v3m0 12v3m-4.5-9H3m18 0h-4.5" stroke-linecap="round" /></svg>
          <div>
            <p class="text-xl font-bold text-white tracking-tight">DRYSPACE</p>
            <p class="text-[10px] font-semibold uppercase tracking-[0.15em] text-cyan-400">Waterproofing & Foundation</p>
          </div>
        </div>
        <p class="text-sm leading-relaxed mb-6 max-w-sm">
          Toronto's trusted waterproofing and foundation repair experts since 1999. Protecting GTA homes with a 25-year transferable warranty and industry-leading solutions.
        </p>
        <div class="space-y-3">
          <a href="tel:437-545-0067" class="group block">
            <span class="text-[11px] font-semibold uppercase tracking-[0.15em] text-cyan-400">24/7 Emergency Hotline</span>
            <span class="block text-2xl font-bold text-white group-hover:text-amber-400 transition-colors">437-545-0067</span>
          </a>
        </div>
        <!-- Social links -->
        <div class="flex items-center gap-3 mt-6">
          <a href="https://www.facebook.com/dryspaceca" class="flex items-center justify-center h-9 w-9 rounded-lg bg-white/5 text-slate-400 transition-colors hover:bg-cyan-500/10 hover:text-cyan-400" aria-label="Facebook">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/dryspaceca" class="flex items-center justify-center h-9 w-9 rounded-lg bg-white/5 text-slate-400 transition-colors hover:bg-cyan-500/10 hover:text-cyan-400" aria-label="Instagram">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/dryspace" class="flex items-center justify-center h-9 w-9 rounded-lg bg-white/5 text-slate-400 transition-colors hover:bg-cyan-500/10 hover:text-cyan-400" aria-label="LinkedIn">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-white mb-4">Services</h3>
        <ul class="space-y-2.5">
          {footerLinks.services.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service Areas -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-white mb-4">Service Areas</h3>
        <ul class="space-y-2.5">
          {footerLinks.areas.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-white mb-4">Resources</h3>
        <ul class="space-y-2.5">
          {footerLinks.resources.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-[0.15em] text-white mb-4">Company</h3>
        <ul class="space-y-2.5">
          {footerLinks.company.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-slate-400 hover:text-cyan-400 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-white/5">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-slate-500">
          &copy; {currentYear} Dryspace Waterproofing & Foundation Repair. All rights reserved.
        </p>
        <div class="flex items-center gap-4 text-xs text-slate-500">
          <a href="/privacy" class="hover:text-slate-300 transition-colors">Privacy Policy</a>
          <span class="text-slate-700">&bull;</span>
          <a href="/terms" class="hover:text-slate-300 transition-colors">Terms of Service</a>
          <span class="text-slate-700">&bull;</span>
          <a href="/sitemap.xml" class="hover:text-slate-300 transition-colors">Sitemap</a>
        </div>
      </div>
    </div>
  </div>
</footer>
