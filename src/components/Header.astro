---
import Logo from './Logo.astro';
import MobileMenu from './MobileMenu.astro';
import ThemeToggle from './ThemeToggle.astro';

const navigation = [
  {
    name: 'Services',
    href: '/services',
    dropdown: [
      { name: 'Exterior Waterproofing', href: '/services/exterior-waterproofing' },
      { name: 'Interior Waterproofing', href: '/services/interior-waterproofing' },
      { name: 'Foundation Repair', href: '/services/foundation-repair' },
      { name: 'Sump Pump Installation', href: '/services/sump-pump-installation' },
      { name: 'Weeping Tile', href: '/services/weeping-tile' },
      { name: 'Underpinning', href: '/services/underpinning' },
      { name: 'Emergency Service', href: '/services/emergency-waterproofing' },
      { name: 'View All Services', href: '/services', highlight: true },
    ]
  },
  {
    name: 'Locations',
    href: '/service-areas',
    dropdown: [
      { name: 'Toronto', href: '/locations/toronto' },
      { name: 'Mississauga', href: '/locations/mississauga' },
      { name: 'Brampton', href: '/locations/brampton' },
      { name: 'Vaughan', href: '/locations/vaughan' },
      { name: 'Markham', href: '/locations/markham' },
      { name: 'View All Areas', href: '/service-areas', highlight: true },
    ]
  },
  {
    name: 'Resources',
    href: '#',
    dropdown: [
      { name: 'Cost Calculator', href: '/tools/waterproofing-cost-calculator' },
      { name: 'Maintenance Guide', href: '/tools/maintenance-schedule' },
      { name: 'Blog', href: '/blog' },
      { name: 'Case Studies', href: '/case-studies' },
      { name: 'FAQs', href: '/faq' },
    ]
  },
  { name: 'About', href: '/about' },
  { name: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 w-full bg-white border-b-2 border-slate-200">
  <!-- Top Bar -->
  <div class="hidden md:block bg-navy-900 text-white">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between py-2 text-sm">
        <div class="flex items-center gap-6">
          <span>24/7 Emergency Service</span>
          <span class="text-slate-400">•</span>
          <a href="tel:437-545-0067" class="hover:text-amber-400 transition-colors font-semibold">
            437-545-0067
          </a>
        </div>
        <div class="flex items-center gap-4">
          <span>25-Year Warranty</span>
          <span class="text-slate-400">|</span>
          <span>Government Rebates Available</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Navigation -->
  <nav class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Company Name -->
      <div class="flex-shrink-0">
        <a href="/" class="block">
          <div class="text-2xl font-bold text-slate-900">DRYSPACE</div>
          <div class="text-xs text-slate-500 uppercase tracking-wider">Waterproofing Experts</div>
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center space-x-1">
        {navigation.map((item) => (
          <div class="relative group">
            {item.dropdown ? (
              <>
                <button
                  class={`px-4 py-2 text-slate-600 hover:text-cyan-700 font-medium transition-colors flex items-center gap-1 ${
                    currentPath.startsWith(item.href) && item.href !== '#' ? 'text-cyan-700' : ''
                  }`}
                >
                  {item.name}
                  <span class="text-xs ml-1">▼</span>
                </button>
                <div class="absolute left-0 mt-0 w-64 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform group-hover:translate-y-0 translate-y-2">
                  <div class="bg-white shadow-xl border border-slate-200 py-2 mt-2">
                    {item.dropdown.map((subItem) => (
                      <a
                        href={subItem.href}
                        class={`block px-4 py-2 text-sm hover:bg-slate-50 transition-colors ${
                          subItem.highlight 
                            ? 'text-cyan-700 font-semibold border-t border-slate-100 mt-2 pt-3' 
                            : 'text-slate-600'
                        } ${currentPath === subItem.href ? 'bg-slate-50' : ''}`}
                      >
                        {subItem.name}
                      </a>
                    ))}
                  </div>
                </div>
              </>
            ) : (
              <a
                href={item.href}
                class={`px-4 py-2 text-slate-600 hover:text-cyan-700 font-medium transition-colors ${
                  currentPath === item.href ? 'text-cyan-700' : ''
                }`}
              >
                {item.name}
              </a>
            )}
          </div>
        ))}
      </div>

      <!-- Right Side Actions -->
      <div class="hidden md:flex items-center gap-4">
        <a 
          href="/free-inspection" 
          class="bg-amber-500 text-black px-6 py-3 font-bold hover:bg-amber-400 transition-colors"
        >
          FREE ESTIMATE
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <div class="md:hidden">
        <MobileMenu navigation={navigation} />
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    transition: transform 0.3s ease-in-out;
  }
  
  .hide-header {
    transform: translateY(-100%);
  }
</style>

<script>
  // Hide/show header on scroll
  let lastScrollTop = 0;
  const header = document.querySelector('header');
  
  window.addEventListener('scroll', () => {
    const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    
    if (scrollTop > lastScrollTop && scrollTop > 100) {
      header?.classList.add('hide-header');
    } else {
      header?.classList.remove('hide-header');
    }
    
    lastScrollTop = scrollTop <= 0 ? 0 : scrollTop;
  }, false);
</script>