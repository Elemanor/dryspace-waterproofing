---
// Professional Hero Component - Dryspace Waterproofing
---

<section class="hero-professional">
  <!-- Professional Background -->
  <div class="hero-bg-layer">
    <div class="bg-texture"></div>
    <div class="bg-gradient"></div>
  </div>
  
  <!-- Main Container -->
  <div class="hero-container">
    <!-- Top Bar - Trust Indicators -->
    <div class="top-bar">
      <div class="top-bar-inner">
        <div class="emergency-notice">
          <i class="fa-solid fa-exclamation-triangle"></i>
          <span>24/7 Emergency Response Available</span>
        </div>
        <div class="certifications">
          <span class="cert-item">Licensed & Insured</span>
          <span class="cert-divider">•</span>
          <span class="cert-item">WSIB Coverage</span>
          <span class="cert-divider">•</span>
          <span class="cert-item">BBB A+ Rating</span>
        </div>
      </div>
    </div>
    
    <!-- Main Content Grid -->
    <div class="hero-grid">
      <!-- Left Content -->
      <div class="content-section">
        <div class="content-wrapper">
          <!-- Company Badge -->
          <div class="company-badge">
            <span class="badge-text">Established 1999</span>
            <span class="badge-separator">|</span>
            <span class="badge-location">Toronto & GTA</span>
          </div>
          
          <!-- Main Headline -->
          <h1 class="main-headline">
            Professional Basement
            <span class="highlight">Waterproofing</span>
            Contractors
          </h1>
          
          <!-- Value Proposition -->
          <p class="value-statement">
            Protecting Toronto homes from water damage for over 25 years. 
            Our certified technicians deliver permanent solutions backed by 
            industry-leading warranties.
          </p>
          
          <!-- Service Highlights with SVG Icons -->
          <div class="service-highlights">
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" width="24" height="24">
                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
                <path d="M8 12l2 2 4-4" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span>Free Professional Inspection</span>
            </div>
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" width="24" height="24">
                <rect x="3" y="7" width="18" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="2"/>
                <path d="M8 7V5a2 2 0 012-2h4a2 2 0 012 2v2" stroke="currentColor" stroke-width="2" fill="none"/>
              </svg>
              <span>Licensed Master Technicians</span>
            </div>
            <div class="highlight-item">
              <svg class="highlight-icon" viewBox="0 0 24 24" width="24" height="24">
                <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" fill="none" stroke="currentColor" stroke-width="2"/>
              </svg>
              <span>Lifetime Transferable Warranty</span>
            </div>
          </div>
          
          <!-- CTA Section -->
          <div class="cta-section">
            <button class="btn-primary">
              Schedule Free Inspection
              <i class="fa-solid fa-arrow-right"></i>
            </button>
            <div class="phone-section">
              <a href="tel:4375450067" class="phone-number">
                <i class="fa-solid fa-phone"></i>
                (437) 545-0067
              </a>
              <span class="phone-label">Speak with an expert now</span>
            </div>
          </div>
          
          <!-- Trust Metrics -->
          <div class="trust-metrics">
            <div class="metric">
              <span class="metric-value">2,547</span>
              <span class="metric-label">Projects Completed</span>
            </div>
            <div class="metric">
              <span class="metric-value">100%</span>
              <span class="metric-label">Satisfaction Rate</span>
            </div>
            <div class="metric">
              <span class="metric-value">25+</span>
              <span class="metric-label">Years Experience</span>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Right Visual Section -->
      <div class="visual-section">
        <!-- Main Project Image -->
        <div class="project-showcase">
          <div class="showcase-main">
            <picture>
              <source media="(max-width: 768px)" srcset="/assets/waterproofing/dryspace_hero_mobile.webp">
              <img src="/assets/waterproofing/dryspace_hero_desktop.webp" alt="Professional waterproofing services" class="main-image" / width="1920" height="1080" decoding="async">
            </picture>
            <div class="image-overlay">
              <span class="overlay-label">Our Team at Work</span>
            </div>
            
            <!-- Professional Callouts -->
            <div class="callout callout-1">
              <div class="callout-line"></div>
              <div class="callout-content">
                <span class="callout-title">Membrane Installation</span>
                <span class="callout-text">Commercial-grade waterproofing</span>
              </div>
            </div>
            
            <div class="callout callout-2">
              <div class="callout-line"></div>
              <div class="callout-content">
                <span class="callout-title">Foundation Repair</span>
                <span class="callout-text">Structural reinforcement</span>
              </div>
            </div>
          </div>
          
          <!-- Secondary Images Grid -->
          <div class="showcase-grid">
            <div class="grid-item">
              <img src="/assets/waterproofing/basement-water-leak-inspection.webp" alt="Professional basement inspection" loading="lazy" / width="800" height="600" decoding="async">
              <span class="grid-label">Inspection Process</span>
            </div>
            <div class="grid-item">
              <img src="/assets/waterproofing/exterior-waterproofing-toronto in process (1).webp" alt="Waterproofing installation process" loading="lazy" / width="800" height="600" decoding="async">
              <span class="grid-label">Installation</span>
            </div>
            <div class="grid-item">
              <img src="/assets/waterproofing/dryspace_excellence.webp" alt="Excellence in waterproofing" loading="lazy" / width="800" height="600" decoding="async">
              <span class="grid-label">Finished Result</span>
            </div>
          </div>
        </div>
        
        <!-- Professional Badges -->
        <div class="certification-badges">
          <div class="cert-badge">
            <svg viewBox="0 0 100 100" class="cert-svg">
              <circle cx="50" cy="50" r="45" fill="none" stroke="#D4AF37" stroke-width="2"/>
              <text x="50" y="45" text-anchor="middle" font-size="12" fill="#fff">CERTIFIED</text>
              <text x="50" y="60" text-anchor="middle" font-size="10" fill="#fff">INSTALLER</text>
            </svg>
          </div>
          <div class="cert-badge">
            <svg viewBox="0 0 100 100" class="cert-svg">
              <rect x="10" y="10" width="80" height="80" fill="none" stroke="#4A7C59" stroke-width="2"/>
              <text x="50" y="45" text-anchor="middle" font-size="12" fill="#fff">25 YEAR</text>
              <text x="50" y="60" text-anchor="middle" font-size="10" fill="#fff">WARRANTY</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom Info Bar -->
    <div class="info-bar">
      <div class="info-bar-inner">
        <div class="info-item">
          <i class="fa-solid fa-truck"></i>
          <span>Same Day Service Available</span>
        </div>
        <div class="info-item">
          <i class="fa-solid fa-clipboard-check"></i>
          <span>Free Written Estimates</span>
        </div>
        <div class="info-item">
          <i class="fa-solid fa-hand-holding-dollar"></i>
          <span>Flexible Financing Options</span>
        </div>
        <div class="info-item">
          <i class="fa-solid fa-shield-check"></i>
          <span>Fully Licensed & Insured</span>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Process Preview Section -->
  <div class="process-preview">
    <div class="process-inner">
      <h2 class="process-title">Our Professional Process</h2>
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">01</div>
          <img src="/assets/waterproofing/basement-water-leak-inspection.webp" alt="Professional basement inspection" loading="lazy" / width="800" height="600" decoding="async">
          <h3>Detailed Inspection</h3>
          <p>Comprehensive assessment by certified technicians</p>
        </div>
        <div class="process-step">
          <div class="step-number">02</div>
          <img src="/assets/waterproofing/waterproofing diagram with basement sump pump weeping tile and exterior drainage.webp" alt="Waterproofing solution planning" loading="lazy" / width="800" height="600" decoding="async">
          <h3>Custom Solution</h3>
          <p>Tailored waterproofing plan for your property</p>
        </div>
        <div class="process-step">
          <div class="step-number">03</div>
          <img src="/assets/waterproofing/exterior-waterproofing-toronto in process (1).webp" alt="Professional waterproofing installation" loading="lazy" / width="800" height="600" decoding="async">
          <h3>Professional Installation</h3>
          <p>Expert execution with minimal disruption</p>
        </div>
        <div class="process-step">
          <div class="step-number">04</div>
          <img src="/assets/waterproofing/dryspace_exterior_waterproofing_warranty.webp" alt="Waterproofing warranty coverage" loading="lazy" / width="800" height="600" decoding="async">
          <h3>Lifetime Protection</h3>
          <p>Comprehensive warranty and ongoing support</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-professional {
    position: relative;
    background: var(--bg-dark-900);
    overflow: hidden;
  }
  
  /* Background */
  .hero-bg-layer {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  
  .bg-texture {
    position: absolute;
    inset: 0;
    background-image: 
      repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.01) 35px, rgba(255,255,255,.01) 70px);
    opacity: 0.5;
  }
  
  .bg-gradient {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at top right, rgba(212, 175, 55, 0.05) 0%, transparent 50%),
                radial-gradient(ellipse at bottom left, rgba(27, 54, 93, 0.08) 0%, transparent 50%);
  }
  
  /* Container */
  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  /* Top Bar */
  .top-bar {
    background: rgba(22, 27, 34, 0.95);
    border-bottom: 1px solid rgba(212, 175, 55, 0.2);
    padding: 0.75rem 2rem;
  }
  
  .top-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  
  .emergency-notice {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
  }
  
  .emergency-notice i {
    animation: pulse 2s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  
  .certifications {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #808080;
    font-size: 0.875rem;
  }
  
  .cert-divider {
    color: #404040;
  }
  
  /* Main Grid */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 4rem;
    padding: 4rem 2rem;
    align-items: center;
    min-height: calc(100vh - 200px);
  }
  
  /* Content Section */
  .content-wrapper {
    max-width: 600px;
  }
  
  .company-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: rgba(212, 175, 55, 0.05);
    border: 1px solid rgba(212, 175, 55, 0.2);
    border-radius: 4px;
    margin-bottom: 2rem;
    font-size: 0.875rem;
    color: var(--color-primary);
    font-weight: 500;
    letter-spacing: 0.025em;
  }
  
  .badge-separator {
    opacity: 0.3;
  }
  
  .main-headline {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 700;
    line-height: 1.1;
    color: #ffffff;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }
  
  .highlight {
    color: var(--color-primary);
    display: block;
  }
  
  .value-statement {
    font-size: 1.125rem;
    line-height: 1.7;
    color: #b0b0b0;
    margin-bottom: 2rem;
  }
  
  /* Service Highlights */
  .service-highlights {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  
  .highlight-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #e0e0e0;
    font-size: 0.95rem;
  }
  
  .highlight-icon {
    width: 20px;
    height: 20px;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  
  /* CTA Section */
  .cta-section {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: white;
    border: none;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .btn-primary:hover {
    background: var(--color-warning);
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
  }
  
  .phone-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .phone-number {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #ffffff;
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .phone-number:hover {
    color: var(--color-primary);
  }
  
  .phone-label {
    font-size: 0.875rem;
    color: #808080;
  }
  
  /* Trust Metrics */
  .trust-metrics {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .metric {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .metric-value {
    font-size: 2rem;
    font-weight: 800;
    color: #ffffff;
  }
  
  .metric-label {
    font-size: 0.875rem;
    color: #808080;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Visual Section */
  .visual-section {
    position: relative;
  }
  
  .project-showcase {
    position: relative;
  }
  
  .showcase-main {
    position: relative;
    margin-bottom: 1rem;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
  }
  
  .main-image {
    width: 100%;
    height: 450px;
    object-fit: cover;
  }
  
  .image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
  }
  
  .overlay-label {
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  /* Professional Callouts */
  .callout {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  
  .callout-1 {
    top: 30%;
    left: -50px;
  }
  
  .callout-2 {
    top: 60%;
    right: -50px;
  }
  
  .callout-line {
    width: 50px;
    height: 2px;
    background: var(--color-primary);
    position: relative;
  }
  
  .callout-line::after {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
    top: 50%;
    transform: translateY(-50%);
  }
  
  .callout-1 .callout-line::after {
    right: 0;
  }
  
  .callout-2 .callout-line::after {
    left: 0;
  }
  
  .callout-content {
    background: rgba(0, 0, 0, 0.9);
    padding: 0.75rem 1rem;
    border: 1px solid rgba(255, 107, 53, 0.3);
    border-radius: 4px;
  }
  
  .callout-title {
    display: block;
    color: var(--color-primary);
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
  }
  
  .callout-text {
    display: block;
    color: #b0b0b0;
    font-size: 0.75rem;
  }
  
  /* Showcase Grid */
  .showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  
  .grid-item {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
  }
  
  .grid-item img {
    width: 100%;
    height: 120px;
    object-fit: cover;
  }
  
  .grid-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0.5rem;
    background: rgba(0, 0, 0, 0.8);
    color: #ffffff;
    font-size: 0.75rem;
    font-weight: 500;
  }
  
  /* Certification Badges */
  .certification-badges {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 1rem;
  }
  
  .cert-badge {
    width: 80px;
    height: 80px;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
  }
  
  .cert-svg {
    width: 100%;
    height: 100%;
  }
  
  /* Info Bar */
  .info-bar {
    background: rgba(22, 27, 34, 0.95);
    border-top: 1px solid rgba(212, 175, 55, 0.2);
    padding: 1.5rem 2rem;
  }
  
  .info-bar-inner {
    display: flex;
    justify-content: space-around;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .info-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #b0b0b0;
    font-size: 0.875rem;
  }
  
  .info-item i {
    color: var(--color-primary);
    font-size: 1.125rem;
  }
  
  /* Process Preview */
  .process-preview {
    background: linear-gradient(180deg, var(--bg-dark-900) 0%, var(--bg-dark-800) 100%);
    padding: 4rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .process-inner {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .process-title {
    font-size: 2rem;
    font-weight: 700;
    color: #ffffff;
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }
  
  .process-step {
    position: relative;
    text-align: center;
  }
  
  .step-number {
    position: absolute;
    top: -10px;
    left: -10px;
    width: 40px;
    height: 40px;
    background: var(--color-primary);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.875rem;
    border-radius: 4px;
    z-index: 1;
  }
  
  .process-step img {
    width: 100%;
    height: 150px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  
  .process-step h3 {
    font-size: 1.125rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 0.5rem;
  }
  
  .process-step p {
    font-size: 0.875rem;
    color: #808080;
    line-height: 1.5;
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .callout {
      display: none;
    }
    
    .certification-badges {
      position: static;
      justify-content: center;
      margin-top: 2rem;
    }
    
    .process-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (max-width: 768px) {
    .top-bar-inner {
      flex-direction: column;
      gap: 0.5rem;
    }
    
    .main-headline {
      font-size: 2rem;
    }
    
    .cta-section {
      flex-direction: column;
      align-items: stretch;
    }
    
    .trust-metrics {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    
    .showcase-grid {
      grid-template-columns: 1fr;
    }
    
    .info-bar-inner {
      flex-direction: column;
      gap: 1rem;
    }
    
    .process-steps {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Simple professional animations
  document.addEventListener('DOMContentLoaded', () => {
    // Animate metrics on scroll
    const observerOptions = {
      threshold: 0.5,
      rootMargin: '0px'
    };
    
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, observerOptions);
    
    // Observe elements
    document.querySelectorAll('.metric-value').forEach(el => {
      observer.observe(el);
    });
  });
</script>