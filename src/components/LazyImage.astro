---
// SuperClaude Lazy Loading Image Component
// Using Observer Pattern for intersection detection
export interface Props {
  src: string;
  alt: string;
  class?: string;
  width?: number;
  height?: number;
  loading?: 'lazy' | 'eager';
  sizes?: string;
  srcset?: string;
}

const { 
  src, 
  alt, 
  class: className = '', 
  width, 
  height,
  loading = 'lazy',
  sizes,
  srcset
} = Astro.props;

// Convert to WebP if not already
const webpSrc = src.endsWith('.webp') ? src : src.replace(/\.(jpg|jpeg|png)$/i, '.webp');

// Generate srcset for responsive images
const generateSrcset = (baseSrc: string) => {
  if (srcset) return srcset;
  
  const name = baseSrc.substring(0, baseSrc.lastIndexOf('.'));
  const ext = '.webp';
  
  return `
    ${name}-400w${ext} 400w,
    ${name}-800w${ext} 800w,
    ${name}-1200w${ext} 1200w,
    ${baseSrc} 1600w
  `.trim();
};

// Default sizes for responsive images
const defaultSizes = sizes || '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw';
---

<div class={`lazy-image-wrapper ${className}`} data-lazy>
  <img
    src={webpSrc}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    class="lazy-image opacity-0 transition-opacity duration-500"
    data-src={webpSrc}
    sizes={defaultSizes}
    srcset={generateSrcset(webpSrc)}
  />
  <noscript>
    <img
      src={webpSrc}
      alt={alt}
      width={width}
      height={height}
      class={className}
    />
  </noscript>
</div>

<script>
  // SuperClaude Lazy Loading Implementation
  // Using Intersection Observer for performance
  
  document.addEventListener('DOMContentLoaded', () => {
    const lazyImages = document.querySelectorAll('.lazy-image');
    
    if ('IntersectionObserver' in window) {
      const imageObserver = new IntersectionObserver((entries, observer) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const img = entry.target as HTMLImageElement;
            
            // Load the image
            if (img.dataset.src) {
              img.src = img.dataset.src;
              img.classList.remove('opacity-0');
              img.classList.add('opacity-100');
            }
            
            // Mark parent as loaded
            const wrapper = img.closest('[data-lazy]');
            if (wrapper) {
              wrapper.classList.add('loaded');
            }
            
            // Stop observing this image
            observer.unobserve(img);
          }
        });
      }, {
        rootMargin: '50px 0px', // Start loading 50px before visible
        threshold: 0.01
      });
      
      lazyImages.forEach(img => imageObserver.observe(img));
    } else {
      // Fallback for browsers without IntersectionObserver
      lazyImages.forEach(img => {
        const imgElement = img as HTMLImageElement;
        if (imgElement.dataset.src) {
          imgElement.src = imgElement.dataset.src;
          imgElement.classList.remove('opacity-0');
          imgElement.classList.add('opacity-100');
        }
      });
    }
  });
</script>

<style>
  .lazy-image-wrapper {
    position: relative;
    overflow: hidden;
    background-color: #f3f4f6;
  }
  
  .lazy-image {
    width: 100%;
    height: auto;
    display: block;
  }
  
  .lazy-image-wrapper::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      90deg,
      #f3f4f6 0%,
      #e5e7eb 50%,
      #f3f4f6 100%
    );
    animation: shimmer 2s infinite;
    z-index: 1;
  }
  
  .lazy-image-wrapper.loaded::before {
    display: none;
  }
  
  @keyframes shimmer {
    0% {
      transform: translateX(-100%);
    }
    100% {
      transform: translateX(100%);
    }
  }
</style>