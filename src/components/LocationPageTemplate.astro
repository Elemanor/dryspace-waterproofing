---
export interface Props {
  location: {
    city: string;
    title: string;
    description: string;
    heroImage: string;
    population: string;
    established: string;
    avgHomeAge: string;
  };
  content: {
    introduction: string;
    localChallenges: Array<{
      title: string;
      description: string;
      icon: string;
    }>;
    neighborhoods: string[];
    whyChooseUs: string[];
    localStats: Array<{
      value: string;
      label: string;
    }>;
    recentProjects: Array<{
      title: string;
      description: string;
      image: string;
    }>;
  };
}

const { location, content } = Astro.props;
---

<!-- Hero Section with City Skyline -->
<section class="relative min-h-[70vh] flex items-center bg-gradient-to-br from-blue-900 via-gray-900 to-blue-900">
  <div class="absolute inset-0 opacity-40">
    <img src={location.heroImage} alt={`${location.city} skyline`} class="w-full h-full object-cover" width="600" height="400" decoding="async" />
  </div>
  <div class="relative z-10 container mx-auto px-4 py-20">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 bg-red-600 text-white px-4 py-2 rounded-full mb-6 animate-pulse">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="font-semibold">24/7 Emergency Service in {location.city}</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
        {location.title}
      </h1>
      
      <p class="text-xl text-slate-300 mb-8 leading-relaxed">
        {location.description}
      </p>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <div class="text-3xl mb-1">🏘️</div>
          <div class="text-sm text-slate-300">Population</div>
          <div class="text-lg font-bold text-white">{location.population}</div>
        </div>
        <div class="bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <div class="text-3xl mb-1">🏠</div>
          <div class="text-sm text-slate-300">Avg Home Age</div>
          <div class="text-lg font-bold text-white">{location.avgHomeAge}</div>
        </div>
        <div class="bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <div class="text-3xl mb-1">⏱️</div>
          <div class="text-sm text-slate-300">Response Time</div>
          <div class="text-lg font-bold text-white">< 2 Hours</div>
        </div>
        <div class="bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <div class="text-3xl mb-1">🛡️</div>
          <div class="text-sm text-slate-300">Serving Since</div>
          <div class="text-lg font-bold text-white">{location.established}</div>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/free-inspection" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-cyan-600 rounded-lg hover:bg-cyan-700 transition-all transform hover:scale-105">
          Get Free {location.city} Quote
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:437-545-0067" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-red-600 rounded-lg hover:bg-red-700 transition-all">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Emergency: 437-545-0067
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Introduction Section -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 mb-8">Waterproofing Services in {location.city}</h2>
      <div class="prose prose-lg max-w-none text-slate-500 leading-relaxed">
        <p>{content.introduction}</p>
      </div>
      
      <!-- Quick Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-12">
        {content.localStats.map((stat) => (
          <div class="text-center">
            <div class="text-3xl font-bold text-cyan-600 mb-2">{stat.value}</div>
            <div class="text-sm text-slate-500">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- Local Challenges Section -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">{location.city}'s Unique Waterproofing Challenges</h2>
      <p class="text-lg text-slate-500">Local conditions require specialized solutions</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {content.localChallenges.map((challenge) => (
        <div class="bg-white rounded-xl p-8 shadow-lg hover:shadow-2xl transition-all">
          <div class="text-5xl mb-4">{challenge.icon}</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{challenge.title}</h3>
          <p class="text-slate-500">{challenge.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Neighborhoods Section -->
<section class="py-20 bg-cyan-50">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 mb-8 text-center">Serving All {location.city} Neighborhoods</h2>
      <p class="text-lg text-slate-500 text-center mb-12">
        We provide waterproofing services throughout {location.city}, with local teams ready to respond quickly to your area.
      </p>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {content.neighborhoods.map((neighborhood) => (
          <div class="bg-white rounded-lg px-4 py-3 text-center shadow-md hover:shadow-lg transition-all">
            <span class="text-slate-600 font-medium">{neighborhood}</span>
          </div>
        ))}
      </div>
      
      <div class="text-center mt-8">
        <p class="text-slate-500 italic">
          Don't see your neighborhood? We serve all of {location.city} and surrounding areas. 
          <a href="/contact" class="text-cyan-600 hover:underline">Contact us</a> for service.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- Services Grid -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Our Services in {location.city}</h2>
      <p class="text-lg text-slate-500">Complete waterproofing solutions for {location.city} homes</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <a href="/services/exterior-waterproofing" class="group">
        <div class="bg-slate-50 rounded-xl p-8 hover:bg-cyan-50 transition-all">
          <div class="text-4xl mb-4">💧</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-cyan-600">Exterior Waterproofing</h3>
          <p class="text-slate-500">Complete foundation protection from outside</p>
          <div class="mt-4 text-cyan-600 font-semibold">Learn more →</div>
        </div>
      </a>
      
      <a href="/services/interior-waterproofing" class="group">
        <div class="bg-slate-50 rounded-xl p-8 hover:bg-cyan-50 transition-all">
          <div class="text-4xl mb-4">🏠</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-cyan-600">Interior Waterproofing</h3>
          <p class="text-slate-500">Interior drainage and moisture barriers</p>
          <div class="mt-4 text-cyan-600 font-semibold">Learn more →</div>
        </div>
      </a>
      
      <a href="/services/foundation-repair" class="group">
        <div class="bg-slate-50 rounded-xl p-8 hover:bg-cyan-50 transition-all">
          <div class="text-4xl mb-4">🔧</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-cyan-600">Foundation Repair</h3>
          <p class="text-slate-500">Crack repair and structural solutions</p>
          <div class="mt-4 text-cyan-600 font-semibold">Learn more →</div>
        </div>
      </a>
      
      <a href="/services/sump-pump-installation" class="group">
        <div class="bg-slate-50 rounded-xl p-8 hover:bg-cyan-50 transition-all">
          <div class="text-4xl mb-4">⚡</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-cyan-600">Sump Pump Installation</h3>
          <p class="text-slate-500">Professional sump pump systems</p>
          <div class="mt-4 text-cyan-600 font-semibold">Learn more →</div>
        </div>
      </a>
      
      <a href="/services/weeping-tile" class="group">
        <div class="bg-slate-50 rounded-xl p-8 hover:bg-cyan-50 transition-all">
          <div class="text-4xl mb-4">🚿</div>
          <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-cyan-600">Weeping Tile System</h3>
          <p class="text-slate-500">French drain installation and repair</p>
          <div class="mt-4 text-cyan-600 font-semibold">Learn more →</div>
        </div>
      </a>
      
      <a href="/emergency" class="group">
        <div class="bg-red-50 rounded-xl p-8 hover:bg-red-100 transition-all border-2 border-red-200">
          <div class="text-4xl mb-4">🚨</div>
          <h3 class="text-xl font-bold text-red-900 mb-2">24/7 Emergency</h3>
          <p class="text-red-700">Immediate flood response</p>
          <div class="mt-4 text-red-600 font-semibold">Get help now →</div>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Recent Projects -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Recent Projects in {location.city}</h2>
      <p class="text-lg text-slate-500">See our quality work in your area</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {content.recentProjects.map((project) => (
        <div class="bg-white rounded-xl overflow-hidden shadow-lg hover:shadow-2xl transition-all">
          <img src={project.image} alt={project.title} class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async" />
          <div class="p-6">
            <h3 class="text-xl font-bold text-slate-900 mb-2">{project.title}</h3>
            <p class="text-slate-500">{project.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Why Choose Us -->
<section class="py-20 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-4">Why {location.city} Homeowners Choose Dryspace</h2>
      <p class="text-xl opacity-90">Local expertise with proven results</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {content.whyChooseUs.map((reason, index) => (
        <div class="bg-white/10 backdrop-blur rounded-xl p-6">
          <div class="text-3xl mb-4">
            {['🏆', '🏡', '💰', '📞', '⭐', '🛡️'][index]}
          </div>
          <p class="text-lg">{reason}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Local Testimonials -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">What {location.city} Residents Say</h2>
      <p class="text-lg text-slate-500">Real reviews from your neighbors</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-slate-50 rounded-xl p-8">
        <div class="flex mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-amber-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-slate-500 mb-4">"Excellent service! They fixed our basement flooding issue permanently. The team was professional and the warranty gives us peace of mind."</p>
        <p class="font-semibold text-slate-900">John D., Downtown {location.city}</p>
      </div>
      
      <div class="bg-slate-50 rounded-xl p-8">
        <div class="flex mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-amber-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-slate-500 mb-4">"After the spring floods, they responded within an hour. Saved our basement and helped with insurance. Highly recommend!"</p>
        <p class="font-semibold text-slate-900">Sarah M., North {location.city}</p>
      </div>
      
      <div class="bg-slate-50 rounded-xl p-8">
        <div class="flex mb-4">
          {[1,2,3,4,5].map(() => (
            <svg class="w-5 h-5 text-amber-400 fill-current" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
          ))}
        </div>
        <p class="text-slate-500 mb-4">"Fair pricing, excellent work, and they cleaned up perfectly. The government rebate assistance was a huge help too!"</p>
        <p class="font-semibold text-slate-900">Mike R., East {location.city}</p>
      </div>
    </div>
  </div>
</section>