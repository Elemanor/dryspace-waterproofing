---
// As Featured In - Media outlets and endorsements
const mediaOutlets = [
  {
    name: 'CTV NEWS',
    logo: 'https://upload.wikimedia.org/wikipedia/commons/thumb/0/0f/CTV_logo_2018.svg/200px-CTV_logo_2018.svg.png',
    tagline: 'TORONTO',
    bgColor: 'bg-red-600'
  },
  {
    name: 'TORONTO STAR',
    logo: 'https://upload.wikimedia.org/wikipedia/commons/thumb/4/41/Toronto_Star_logo.svg/250px-Toronto_Star_logo.svg.png',
    tagline: 'CANADA\'S LARGEST DAILY',
    bgColor: 'bg-navy-900'
  },
  {
    name: 'CP24',
    logo: 'https://upload.wikimedia.org/wikipedia/commons/thumb/a/a2/CP24_logo_2015.svg/200px-CP24_logo_2015.svg.png',
    tagline: 'BREAKING NEWS',
    bgColor: 'bg-red-700'
  },
  {
    name: 'GLOBAL NEWS',
    logo: 'https://upload.wikimedia.org/wikipedia/commons/thumb/b/bc/Global_News.svg/250px-Global_News.svg.png',
    tagline: 'TORONTO',
    bgColor: 'bg-navy-900'
  },
  {
    name: 'CBC TORONTO',
    logo: 'https://upload.wikimedia.org/wikipedia/commons/thumb/2/29/CBC_News_Logo.svg/200px-CBC_News_Logo.svg.png',
    tagline: 'LOCAL NEWS',
    bgColor: 'bg-red-600'
  }
];
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">
        As Featured In
      </h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">
        Trusted by Toronto's Leading Media Outlets
      </p>
    </div>
    
    <!-- Media Outlets Grid -->
    <div class="max-w-6xl mx-auto mb-16">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6">
        {mediaOutlets.map((outlet) => (
          <div class="bg-white border-2 border-slate-200 hover:border-slate-300 transition-colors">
            <div class={`${outlet.bgColor} text-slate-900 p-2 text-center`}>
              <span class="text-xs font-bold uppercase">{outlet.tagline}</span>
            </div>
            <div class="p-6 flex items-center justify-center h-32 bg-slate-50">
              <div class="text-center">
                <p class="font-bold text-lg text-slate-900 uppercase">{outlet.name}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
    
    <!-- Mike Holmes Endorsement -->
    <div class="bg-navy-900 text-white p-12">
      <div class="max-w-4xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <!-- Left Side - Endorsement -->
          <div>
            <div class="border-l-4 border-cyan-500 pl-6">
              <p class="text-3xl font-bold mb-4 uppercase">
                Endorsed by
              </p>
              <p class="text-5xl font-bold text-cyan-400 mb-4">
                MIKE HOLMES
              </p>
              <p class="text-lg mb-2">
                "Make It Right" Expert
              </p>
              <p class="text-slate-300">
                Canada's Most Trusted Contractor
              </p>
            </div>
          </div>
          
          <!-- Right Side - Quote -->
          <div class="bg-navy-900 p-8 border-2 border-slate-600">
            <div class="mb-4">
              <span class="text-6xl text-cyan-400 font-serif">"</span>
            </div>
            <p class="text-lg italic mb-4">
              When it comes to waterproofing in Toronto, Dryspace does it right the first time. Their attention to detail and commitment to quality is what every homeowner needs.
            </p>
            <div class="border-t border-slate-600 pt-4 mt-4">
              <p class="font-bold text-cyan-400 uppercase">Mike Holmes</p>
              <p class="text-sm text-slate-400">Professional Contractor & TV Host</p>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Media Coverage Stats -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-4 gap-6 max-w-5xl mx-auto">
      <div class="bg-white border-2 border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">50+</p>
        <p class="text-sm text-slate-500 uppercase mt-2">Media Features</p>
      </div>
      <div class="bg-white border-2 border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">15</p>
        <p class="text-sm text-slate-500 uppercase mt-2">TV Appearances</p>
      </div>
      <div class="bg-white border-2 border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">100+</p>
        <p class="text-sm text-slate-500 uppercase mt-2">News Articles</p>
      </div>
      <div class="bg-white border-2 border-slate-200 p-6 text-center">
        <p class="text-3xl font-bold text-slate-900">2019</p>
        <p class="text-sm text-slate-500 uppercase mt-2">Holmes Approved</p>
      </div>
    </div>
    
    <!-- Bottom CTA -->
    <div class="mt-16 bg-amber-500 p-12">
      <div class="max-w-4xl mx-auto text-center">
        <h3 class="text-2xl font-bold text-black mb-4 uppercase">
          Join Thousands of Satisfied Toronto Homeowners
        </h3>
        <p class="text-lg text-black mb-8">
          Get the same quality service featured in Toronto media
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-black text-white px-8 py-4 text-lg font-bold hover:bg-navy-900 transition-colors uppercase"
          >
            Get Free Inspection
          </a>
          <a 
            href="/media-coverage"
            class="bg-white text-black border-2 border-black px-8 py-4 text-lg font-bold hover:bg-slate-50 transition-colors uppercase"
          >
            View Media Coverage
          </a>
        </div>
      </div>
    </div>
  </div>
</section>