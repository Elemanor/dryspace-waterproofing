---
// Premium Waterproofing Membranes Comparison - Side by Side
---

<section class="py-16 bg-gradient-to-br from-gray-50 to-white">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        Premium Waterproofing Membrane Solutions
      </h2>
      <p class="text-xl text-slate-600 max-w-3xl mx-auto">
        Choose the right protection for your foundation - Both exceed Ontario Building Code requirements
      </p>
    </div>

    <div class="grid lg:grid-cols-2 gap-8 items-stretch">
      <!-- Left Side - Aqua Bloc 720-38 -->
      <div class="bg-white rounded-xl shadow-xl overflow-hidden border-2 border-cyan-500">
        <div class="bg-gradient-to-r from-green-600 to-green-700 p-6">
          <div class="flex items-center justify-between">
            <h3 class="text-2xl font-bold text-slate-900">
              Aqua Bloc 720-38
            </h3>
            <span class="bg-white text-cyan-600 px-3 py-1 rounded-full text-sm font-bold">
              ECO-FRIENDLY
            </span>
          </div>
          <p class="text-cyan-100 mt-2">Low-Emitting Liquid Rubber Membrane</p>
        </div>
        
        <div class="p-6">
          <!-- Product Image/Visual -->
          <div class="mb-6 relative">
            <img src="/assets/waterproofing/waterproofing membrane dumpproofing aqua block.webp" 
                 alt="Aqua Bloc membrane application" 
                 class="w-full h-48 object-cover rounded-lg shadow-md" / width="800" height="600" loading="lazy" decoding="async">
            <div class="absolute top-2 right-2 bg-cyan-600 text-white px-2 py-1 rounded text-xs font-bold">
              LEED Certified
            </div>
          </div>

          <!-- Key Features -->
          <div class="space-y-3 mb-6">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">100% Seamless Protection</h4>
                <p class="text-sm text-slate-500">Spray-applied liquid forms continuous barrier with no joints</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Ultra-Low VOC Emissions</h4>
                <p class="text-sm text-slate-500">Safe for occupied spaces, no harmful off-gassing</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Self-Healing Technology</h4>
                <p class="text-sm text-slate-500">Automatically seals minor punctures and cracks</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">60+ Year Life Expectancy</h4>
                <p class="text-sm text-slate-500">Maintains flexibility and adhesion for decades</p>
              </div>
            </div>
          </div>

          <!-- Technical Specs -->
          <div class="bg-cyan-50 rounded-lg p-4 mb-6">
            <h4 class="font-bold text-slate-900 mb-3">Technical Specifications</h4>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div>
                <span class="text-slate-500">Thickness:</span>
                <span class="font-semibold text-slate-900"> 38 mils (1mm)</span>
              </div>
              <div>
                <span class="text-slate-500">Coverage:</span>
                <span class="font-semibold text-slate-900"> 50 sq.ft/gal</span>
              </div>
              <div>
                <span class="text-slate-500">Elongation:</span>
                <span class="font-semibold text-slate-900"> 1200%</span>
              </div>
              <div>
                <span class="text-slate-500">Permeability:</span>
                <span class="font-semibold text-slate-900"> 0.05 perms</span>
              </div>
              <div>
                <span class="text-slate-500">Application:</span>
                <span class="font-semibold text-slate-900"> Spray/Roller</span>
              </div>
              <div>
                <span class="text-slate-500">Cure Time:</span>
                <span class="font-semibold text-slate-900"> 24-48 hours</span>
              </div>
            </div>
          </div>

          <!-- Best For -->
          <div class="border-t pt-4">
            <h4 class="font-bold text-slate-900 mb-2">Best For:</h4>
            <ul class="text-sm text-slate-600 space-y-1">
              <li>• New construction & renovations</li>
              <li>• Complex foundation geometries</li>
              <li>• Green building projects (LEED)</li>
              <li>• Chemical-sensitive occupants</li>
              <li>• Areas requiring monolithic protection</li>
            </ul>
          </div>

          <!-- Price Range -->
          <div class="mt-6 p-4 bg-gradient-to-r from-green-100 to-green-50 rounded-lg">
            <div class="flex justify-between items-center">
              <span class="text-sm font-semibold text-slate-600">Investment Range:</span>
              <span class="text-lg font-bold text-cyan-600">$12-15/sq.ft installed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Right Side - Delta-MS -->
      <div class="bg-white rounded-xl shadow-xl overflow-hidden border-2 border-cyan-500">
        <div class="bg-gradient-to-r from-blue-600 to-blue-700 p-6">
          <div class="flex items-center justify-between">
            <h3 class="text-2xl font-bold text-slate-900">
              Delta-MS
            </h3>
            <span class="bg-white text-cyan-600 px-3 py-1 rounded-full text-sm font-bold">
              PREMIUM
            </span>
          </div>
          <p class="text-cyan-100 mt-2">High-Performance Dimpled Membrane System</p>
        </div>

        <div class="p-6">
          <!-- Product Image/Visual -->
          <div class="mb-6 relative">
            <img src="/assets/waterproofing/dimpled membrane texture.webp" 
                 alt="Delta-MS dimpled membrane" 
                 class="w-full h-48 object-cover rounded-lg shadow-md" / width="800" height="600" loading="lazy" decoding="async">
            <div class="absolute top-2 right-2 bg-cyan-600 text-white px-2 py-1 rounded text-xs font-bold">
              Industry Leader
            </div>
          </div>

          <!-- Key Features -->
          <div class="space-y-3 mb-6">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Air-Gap Technology</h4>
                <p class="text-sm text-slate-500">Creates ventilation space, prevents moisture buildup</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Superior Compressive Strength</h4>
                <p class="text-sm text-slate-500">5,200 PSF - withstands extreme soil pressure</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Drainage Capacity</h4>
                <p class="text-sm text-slate-500">15 gallons/minute per linear foot</p>
              </div>
            </div>

            <div class="flex items-start">
              <svg class="w-5 h-5 text-cyan-600 mt-0.5 mr-2 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <div>
                <h4 class="font-semibold text-slate-900">Mechanical Protection</h4>
                <p class="text-sm text-slate-500">Shields waterproofing during backfill</p>
              </div>
            </div>
          </div>

          <!-- Technical Specs -->
          <div class="bg-cyan-50 rounded-lg p-4 mb-6">
            <h4 class="font-bold text-slate-900 mb-3">Technical Specifications</h4>
            <div class="grid grid-cols-2 gap-2 text-sm">
              <div>
                <span class="text-slate-500">Height:</span>
                <span class="font-semibold text-slate-900"> 5/16" (8mm)</span>
              </div>
              <div>
                <span class="text-slate-500">Roll Size:</span>
                <span class="font-semibold text-slate-900"> 6.5' x 65.6'</span>
              </div>
              <div>
                <span class="text-slate-500">Material:</span>
                <span class="font-semibold text-slate-900"> Virgin HDPE</span>
              </div>
              <div>
                <span class="text-slate-500">Temperature:</span>
                <span class="font-semibold text-slate-900"> -30°C to +80°C</span>
              </div>
              <div>
                <span class="text-slate-500">Installation:</span>
                <span class="font-semibold text-slate-900"> Mechanical</span>
              </div>
              <div>
                <span class="text-slate-500">UV Resistant:</span>
                <span class="font-semibold text-slate-900"> Yes (3 months)</span>
              </div>
            </div>
          </div>

          <!-- Best For -->
          <div class="border-t pt-4">
            <h4 class="font-bold text-slate-900 mb-2">Best For:</h4>
            <ul class="text-sm text-slate-600 space-y-1">
              <li>• High water table conditions</li>
              <li>• Clay soil environments</li>
              <li>• Retrofit applications</li>
              <li>• Below-grade walls & floors</li>
              <li>• Projects requiring immediate backfill</li>
            </ul>
          </div>

          <!-- Price Range -->
          <div class="mt-6 p-4 bg-gradient-to-r from-blue-100 to-blue-50 rounded-lg">
            <div class="flex justify-between items-center">
              <span class="text-sm font-semibold text-slate-600">Investment Range:</span>
              <span class="text-lg font-bold text-cyan-600">$8-12/sq.ft installed</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="mt-12 bg-white rounded-xl shadow-lg overflow-hidden">
      <div class="bg-gradient-to-r from-gray-700 to-gray-800 p-4">
        <h3 class="text-xl font-bold text-slate-900 text-center">Quick Comparison</h3>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-slate-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase tracking-wider">Feature</th>
              <th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase tracking-wider">Aqua Bloc 720-38</th>
              <th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase tracking-wider">Delta-MS</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Application Method</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Spray/Roller (Seamless)</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Sheet (Overlapped)</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Environmental Impact</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center text-cyan-600 font-semibold">Ultra-Low VOC ✓</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Standard</td>
            </tr>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Drainage Capability</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Waterproof Barrier</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center text-cyan-600 font-semibold">Superior Drainage ✓</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Installation Speed</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Moderate (cure time)</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center text-cyan-600 font-semibold">Fast ✓</td>
            </tr>
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Crack Bridging</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center text-cyan-600 font-semibold">Self-Healing ✓</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Limited</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">Warranty</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Lifetime</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-center">Lifetime</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-12">
      <p class="text-lg text-slate-600 mb-6">
        Not sure which membrane is right for your project? Our experts will assess your specific needs.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/free-inspection" class="inline-block px-8 py-3 bg-orange-600 text-white rounded-lg font-semibold hover:bg-orange-700 transition-colors">
          Get Expert Recommendation
        </a>
        <a href="tel:4375450067" class="inline-block px-8 py-3 bg-slate-600 text-white rounded-lg font-semibold hover:bg-slate-700 transition-colors">
          Call to Discuss Options
        </a>
      </div>
    </div>
  </div>
</section>