---
// Problem Identifier Component - Professional Contractor Style
const problems = [
  {
    id: 'water-pooling',
    title: 'STANDING WATER',
    severity: 'EMERGENCY',
    severityColor: 'bg-red-600',
    image: '/images/waterp on the floor.webp',
    symptoms: [
      'Puddles on basement floor',
      'Water seeping through walls',
      'Wet spots after rain',
      'Visible water streams'
    ],
    causes: [
      'Hydrostatic pressure',
      'Foundation cracks',
      'Poor drainage',
      'High water table'
    ],
    solution: 'IMMEDIATE WATERPROOFING REQUIRED',
    timeframe: '24-48 HOURS',
    cost: '$5,000 - $15,000'
  },
  {
    id: 'foundation-cracks',
    title: 'FOUNDATION CRACKS',
    severity: 'HIGH PRIORITY',
    severityColor: 'bg-orange-600',
    image: '/images/crack.webp',
    symptoms: [
      'Visible cracks in walls',
      'Stair-step cracks in blocks',
      'Horizontal cracks',
      'Widening gaps over time'
    ],
    causes: [
      'Settling foundation',
      'Frost damage',
      'Water pressure',
      'Soil movement'
    ],
    solution: 'CRACK INJECTION & REINFORCEMENT',
    timeframe: '1-2 WEEKS',
    cost: '$500 - $5,000'
  },
  {
    id: 'mold-growth',
    title: 'MOLD & MILDEW',
    severity: 'HEALTH HAZARD',
    severityColor: 'bg-orange-600',
    image: '/images/mold.webp',
    symptoms: [
      'Black or green spots',
      'Musty odors',
      'Allergic reactions',
      'Peeling paint'
    ],
    causes: [
      'High humidity (>60%)',
      'Poor ventilation',
      'Water leaks',
      'Condensation'
    ],
    solution: 'MOLD REMEDIATION & MOISTURE CONTROL',
    timeframe: '3-5 DAYS',
    cost: '$2,000 - $8,000'
  },
  {
    id: 'efflorescence',
    title: 'EFFLORESCENCE',
    severity: 'MODERATE',
    severityColor: 'bg-amber-500',
    image: '/images/Efflorescence.webp',
    symptoms: [
      'White powdery deposits',
      'Salt crystals on walls',
      'Chalky residue',
      'Staining on concrete'
    ],
    causes: [
      'Water moving through walls',
      'Mineral deposits',
      'Poor waterproofing',
      'Moisture penetration'
    ],
    solution: 'WATERPROOFING TREATMENT',
    timeframe: '2-4 WEEKS',
    cost: '$3,000 - $10,000'
  },
  {
    id: 'dampness',
    title: 'DAMPNESS & HUMIDITY',
    severity: 'PREVENTIVE',
    severityColor: 'bg-cyan-600',
    image: '/images/basement-water-leak-inspection.webp',
    symptoms: [
      'Condensation on windows',
      'Damp walls',
      'Musty smell',
      'Warped wood'
    ],
    causes: [
      'Poor ventilation',
      'Groundwater seepage',
      'Inadequate vapor barrier',
      'Plumbing leaks'
    ],
    solution: 'DEHUMIDIFICATION SYSTEM',
    timeframe: '1-2 WEEKS',
    cost: '$1,500 - $4,000'
  },
  {
    id: 'bowing-walls',
    title: 'BOWING WALLS',
    severity: 'EMERGENCY',
    severityColor: 'bg-red-600',
    image: '/images/structural foundation crack.webp',
    symptoms: [
      'Walls curving inward',
      'Horizontal cracks',
      'Gaps at floor/ceiling',
      'Doors not closing'
    ],
    causes: [
      'Hydrostatic pressure',
      'Frost pressure',
      'Expansive soil',
      'Poor drainage'
    ],
    solution: 'WALL ANCHORS OR REBUILD',
    timeframe: 'IMMEDIATE',
    cost: '$10,000 - $30,000'
  }
];
---

<section class="bg-slate-50 py-16">
  <div class="container mx-auto px-4">
    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">BASEMENT PROBLEM ASSESSMENT</h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">
        Identify your basement issue below. Each problem requires different solutions and urgency levels.
      </p>
    </div>

    <!-- Emergency Banner -->
    <div class="bg-red-600 text-slate-900 p-6 mb-8">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-2xl font-bold mb-2">EXPERIENCING FLOODING RIGHT NOW?</p>
        <p class="mb-4">Our emergency response team is available 24/7 for immediate water removal</p>
        <a href="tel:437-545-0067" class="inline-block bg-amber-500 text-black px-8 py-3 font-bold text-lg hover:bg-amber-400 transition-colors">
          CALL EMERGENCY LINE: 437-545-0067
        </a>
      </div>
    </div>

    <!-- Problems Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {problems.map((problem) => (
        <div class="bg-white border-2 border-slate-200 hover:border-slate-300 transition-colors overflow-hidden">
          <!-- Severity Header -->
          <div class={`${problem.severityColor} text-slate-900 p-3`}>
            <div class="flex justify-between items-center">
              <span class="font-bold text-sm">{problem.severity}</span>
              <span class="text-xs">{problem.timeframe}</span>
            </div>
          </div>
          
          <!-- Problem Image -->
          <div class="relative h-48 bg-slate-100">
            <img 
              src={problem.image} 
              alt={problem.title}
              class="w-full h-full object-cover" width="600" height="400" decoding="async"
              loading="lazy"
            />
          </div>
          
          <!-- Problem Title -->
          <div class="p-4 border-b-2 border-slate-100">
            <h3 class="text-xl font-bold text-slate-900">{problem.title}</h3>
            <p class="text-sm text-slate-500 mt-1">Est. Cost: {problem.cost}</p>
          </div>
          
          <!-- Content -->
          <div class="p-4 space-y-4">
            <!-- Symptoms -->
            <div>
              <h4 class="font-bold text-slate-900 mb-2 uppercase text-sm">What You See:</h4>
              <ul class="space-y-1">
                {problem.symptoms.map((symptom) => (
                  <li class="text-sm text-slate-600 flex items-start">
                    <span class="mr-2">•</span>
                    <span>{symptom}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <!-- Causes -->
            <div>
              <h4 class="font-bold text-slate-900 mb-2 uppercase text-sm">Common Causes:</h4>
              <ul class="space-y-1">
                {problem.causes.map((cause) => (
                  <li class="text-sm text-slate-600 flex items-start">
                    <span class="mr-2">•</span>
                    <span>{cause}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            <!-- Solution -->
            <div class="pt-4 border-t border-slate-100">
              <p class="font-bold text-slate-900 text-sm">{problem.solution}</p>
            </div>
          </div>
          
          <!-- Learn More Link -->
          <div class="p-4 bg-slate-50 border-t-2 border-slate-100">
            <p class="text-center text-sm text-slate-600 font-medium">
              Professional diagnosis required
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="mt-12 bg-navy-900 text-white p-8">
      <div class="max-w-4xl mx-auto text-center">
        <h3 class="text-2xl font-bold mb-4">NOT SURE WHICH PROBLEM YOU HAVE?</h3>
        <p class="mb-6">Our certified inspectors will diagnose your basement issues for FREE</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/free-inspection" class="bg-amber-500 text-black px-8 py-3 font-bold hover:bg-amber-400 transition-colors">
            SCHEDULE FREE INSPECTION
          </a>
          <a href="tel:437-545-0067" class="border-2 border-white text-white px-8 py-3 font-bold hover:bg-white hover:text-black transition-colors">
            CALL: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </div>
</section>