// Get images for this resource type
const images = resourceImages[resource] || [];

// If no specific match, try to find related images based on page content
const fallbackImages = [
  {
    src: '/images/dryspace_excellence.webp',
    alt: 'Professional waterproofing excellence',
    caption: 'Quality workmanship and attention to detail'
  },
  {
    src: '/images/dryspace_exterior_waterproofing_warranty.webp',
    alt: '25-year warranty waterproofing',
    caption: 'Backed by comprehensive warranty'
  },
