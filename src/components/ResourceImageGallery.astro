    src: '/images/basement_wall_insulation.webp',
    alt: 'Basement wall insulation',
    caption: 'Combined waterproofing and insulation'
  },
  {
    src: '/images/backwatervalve.webp',
    alt: 'Backwater valve installation',
    caption: 'Flood prevention system'
