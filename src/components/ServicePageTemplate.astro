---
export interface Props {
  service: {
    name: string;
    title: string;
    description: string;
    heroImage: string;
    price: string;
    duration: string;
    warranty: string;
  };
  content: {
    introduction: string;
    benefits: string[];
    process: Array<{
      title: string;
      description: string;
      image?: string;
    }>;
    problems: Array<{
      title: string;
      description: string;
      icon: string;
    }>;
    whyUs: string[];
    gallery: string[];
  };
}

const { service, content } = Astro.props;
---

<!-- Hero Section with Background Image -->
<section class="relative min-h-[70vh] flex items-center bg-gradient-to-br from-gray-900 via-blue-900 to-gray-900">
  <div class="absolute inset-0 opacity-30">
    <img src={service.heroImage} alt={service.name} class="w-full h-full object-cover" width="600" height="400" decoding="async" />
  </div>
  <div class="relative z-10 container mx-auto px-4 py-20">
    <div class="max-w-4xl">
      <div class="inline-flex items-center gap-2 bg-cyan-600 text-white px-4 py-2 rounded-full mb-6">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span class="font-semibold">Government Rebates Available</span>
      </div>
      
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">
        {service.title}
      </h1>
      
      <p class="text-xl text-slate-300 mb-8 leading-relaxed">
        {service.description}
      </p>
      
      <div class="flex flex-wrap gap-6 mb-10">
        <div class="flex items-center gap-3 bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <span class="text-3xl">💰</span>
          <div>
            <div class="text-sm text-slate-300">Starting from</div>
            <div class="text-xl font-bold text-slate-900">{service.price}</div>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <span class="text-3xl">⏱️</span>
          <div>
            <div class="text-sm text-slate-300">Completion</div>
            <div class="text-xl font-bold text-slate-900">{service.duration}</div>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-white/10 backdrop-blur px-4 py-3 rounded-lg">
          <span class="text-3xl">🛡️</span>
          <div>
            <div class="text-sm text-slate-300">Warranty</div>
            <div class="text-xl font-bold text-slate-900">{service.warranty}</div>
          </div>
        </div>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/free-inspection" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-cyan-600 rounded-lg hover:bg-cyan-700 transition-all transform hover:scale-105">
          Get Free Inspection
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="tel:437-545-0067" class="inline-flex items-center justify-center px-8 py-4 text-lg font-semibold text-white bg-red-600 rounded-lg hover:bg-red-700 transition-all">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          Call: 437-545-0067
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Introduction Section -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-4xl font-bold text-slate-900 mb-8">Professional {service.name} Services in Toronto & GTA</h2>
      <div class="prose prose-lg max-w-none text-slate-500 leading-relaxed">
        <p>{content.introduction}</p>
      </div>
    </div>
  </div>
</section>

<!-- Common Problems Section -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Problems We Solve</h2>
      <p class="text-lg text-slate-500">Recognize any of these issues? We have the solution.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {content.problems.map((problem) => (
        <div class="bg-white rounded-xl p-8 shadow-lg hover:shadow-2xl transition-all">
          <div class="text-5xl mb-4">{problem.icon}</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">{problem.title}</h3>
          <p class="text-slate-500">{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Benefits Section -->
<section class="py-20 bg-cyan-50">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-4xl font-bold text-slate-900 mb-8">Benefits of Our {service.name}</h2>
        <ul class="space-y-4">
          {content.benefits.map((benefit) => (
            <li class="flex items-start gap-3">
              <svg class="w-6 h-6 text-cyan-500 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-lg text-slate-600">{benefit}</span>
            </li>
          ))}
        </ul>
      </div>
      <div class="relative">
        <img src="/images/dryspace_excellence.webp" alt="Professional waterproofing service benefits and warranty guarantee" class="rounded-2xl shadow-2xl" />
        <div class="absolute -bottom-6 -right-6 bg-cyan-600 text-white p-6 rounded-xl shadow-xl">
          <div class="text-4xl font-bold">25</div>
          <div class="text-sm">Year Warranty</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Detailed Process Section -->
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Our Process</h2>
      <p class="text-lg text-slate-500">Step-by-step approach to ensure perfect results</p>
    </div>
    
    <div class="space-y-20">
      {content.process.map((step, index) => (
        <div class={`grid grid-cols-1 lg:grid-cols-2 gap-12 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-16 h-16 bg-cyan-600 text-slate-900 rounded-full flex items-center justify-center text-2xl font-bold">
                {index + 1}
              </div>
              <h3 class="text-2xl font-bold text-slate-900">{step.title}</h3>
            </div>
            <p class="text-lg text-slate-500 leading-relaxed">{step.description}</p>
          </div>
          <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
            <img src={step.image || '/images/dryspace_excellence.webp'} alt={step.title} class="rounded-xl shadow-xl w-full" />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Why Choose Us Section -->
<section class="py-20 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold mb-4">Why Toronto Homeowners Choose Dryspace</h2>
      <p class="text-xl opacity-90">Experience, expertise, and excellence in every project</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {content.whyUs.map((reason, index) => (
        <div class="bg-white/10 backdrop-blur rounded-xl p-6">
          <div class="text-3xl mb-4">
            {['🏆', '👨‍🔧', '💰', '📞', '⭐', '🛡️'][index]}
          </div>
          <p class="text-lg">{reason}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Gallery Section -->
<section class="py-20 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Recent {service.name} Projects</h2>
      <p class="text-lg text-slate-500">See the quality of our work</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {content.gallery.map((image, index) => (
        <div class="relative group overflow-hidden rounded-xl shadow-lg">
          <img src={image} alt={`Project ${index + 1}`} class="w-full h-64 object-cover group-hover:scale-110 transition-transform duration-300" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
            <div class="absolute bottom-4 left-4 text-slate-900">
              <div class="font-semibold">View Project</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Trust Indicators -->
<section class="py-16 bg-white border-t border-slate-100">
  <div class="container mx-auto px-4">
    <div class="flex flex-wrap items-center justify-center gap-12">
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 text-cyan-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <div>
          <div class="font-bold text-slate-900">Licensed & Insured</div>
          <div class="text-sm text-slate-500">WSIB & $5M Liability</div>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <div>
          <div class="font-bold text-slate-900">Google Verified</div>
          <div class="text-sm text-slate-500">Trusted Since 1999</div>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
        </svg>
        <div>
          <div class="font-bold text-slate-900">25-Year Warranty</div>
          <div class="text-sm text-slate-500">Transferable</div>
        </div>
      </div>
      
      <div class="flex items-center gap-3">
        <svg class="w-8 h-8 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
        </svg>
        <div>
          <div class="font-bold text-slate-900">BBB Accredited</div>
          <div class="text-sm text-slate-500">A+ Rating</div>
        </div>
      </div>
    </div>
  </div>
</section>