---
// Professional Services Grid Component
const services = [
  {
    icon: "fa-solid fa-house-flood-water",
    title: "Interior Waterproofing",
    description: "Complete interior drainage system installation with lifetime warranty",
    features: ["French drain installation", "Vapor barrier systems", "Wall membrane protection", "Floor drainage solutions"],
    price: "$3,500+",
    timeframe: "2-3 days",
    popular: false,
    image: "/images/interior-waterproofing.webp"
  },
  {
    icon: "fa-solid fa-shield-halved",
    title: "Exterior Waterproofing",
    description: "Full exterior excavation and waterproofing membrane application",
    features: ["Foundation excavation", "Waterproof membranes", "Drainage tile systems", "Window well installation"],
    price: "$8,000+",
    timeframe: "4-5 days",
    popular: true,
    image: "/images/exterior-waterproofing-membrane.webp"
  },
  {
    icon: "fa-solid fa-trowel-bricks",
    title: "Foundation Crack Repair",
    description: "Professional injection and sealing of foundation cracks",
    features: ["Epoxy injection", "Polyurethane foam", "Carbon fiber reinforcement", "Structural repairs"],
    price: "$500+",
    timeframe: "Same day",
    popular: false,
    image: "/images/crack.webp"
  },
  {
    icon: "fa-solid fa-water-ladder",
    title: "Sump Pump Installation",
    description: "High-capacity sump pump systems with battery backup",
    features: ["Primary pump system", "Battery backup", "Alarm monitoring", "Annual maintenance"],
    price: "$1,200+",
    timeframe: "1 day",
    popular: false,
    image: "/images/sump-pump.webp"
  },
  {
    icon: "fa-solid fa-house-tsunami",
    title: "Emergency Water Removal",
    description: "24/7 emergency response for basement flooding",
    features: ["Water extraction", "Structural drying", "Mold prevention", "Insurance assistance"],
    price: "Call for pricing",
    timeframe: "Immediate",
    popular: false,
    image: "/images/waterp on the floor.webp"
  },
  {
    icon: "fa-solid fa-clipboard-check",
    title: "Professional Inspection",
    description: "Comprehensive basement assessment with detailed report",
    features: ["Moisture testing", "Thermal imaging", "Written report", "Cost estimate"],
    price: "FREE",
    timeframe: "Same day",
    popular: false,
    image: "/images/dryspace_excellence.webp"
  }
];
---

<section id="services" class="services-professional">
  <div class="services-container">
    <!-- Section Header -->
    <div class="section-header">
      <div class="header-badge">Our Services</div>
      <h2 class="section-title">
        Professional Waterproofing
        <span class="title-accent">Solutions</span>
      </h2>
      <p class="section-subtitle">
        Industry-leading techniques and materials backed by comprehensive warranties
      </p>
    </div>
    
    <!-- Services Grid -->
    <div class="services-grid">
      {services.map((service, index) => (
        <div class={`service-card ${service.popular ? 'popular' : ''}`} style={`--index: ${index}`}>
          {service.popular && (
            <div class="popular-tag">
              <i class="fa-solid fa-star"></i>
              Most Popular
            </div>
          )}
          
          <!-- Service Image -->
          <div class="service-image">
            <img src={service.image} alt={service.title} / width="800" height="600" loading="lazy" decoding="async">
            <div class="image-overlay">
              <div class="overlay-content">
                <i class={service.icon}></i>
              </div>
            </div>
          </div>
          
          <!-- Service Content -->
          <div class="service-content">
            <h3 class="service-title">{service.title}</h3>
            <p class="service-description">{service.description}</p>
            
            <!-- Service Details -->
            <div class="service-details">
              <div class="detail-item">
                <i class="fa-solid fa-dollar-sign"></i>
                <span class="detail-label">Starting at</span>
                <span class="detail-value">{service.price}</span>
              </div>
              <div class="detail-item">
                <i class="fa-solid fa-clock"></i>
                <span class="detail-label">Timeframe</span>
                <span class="detail-value">{service.timeframe}</span>
              </div>
            </div>
            
            <!-- Features List -->
            <ul class="feature-list">
              {service.features.map(feature => (
                <li>
                  <i class="fa-solid fa-check"></i>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
            
            <!-- CTA Button -->
            <button class="service-btn">
              <span>Get Quote</span>
              <i class="fa-solid fa-arrow-right"></i>
            </button>
          </div>
        </div>
      ))}
    </div>
    
    <!-- Bottom CTA Section -->
    <div class="services-cta">
      <div class="cta-content">
        <div class="cta-icon">
          <i class="fa-solid fa-headset"></i>
        </div>
        <div class="cta-text">
          <h3>Need Help Choosing?</h3>
          <p>Our experts will assess your needs and recommend the best solution</p>
        </div>
        <div class="cta-actions">
          <button class="btn-consultation">
            <i class="fa-solid fa-calendar"></i>
            Schedule Consultation
          </button>
          <a href="tel:4375450067" class="btn-call">
            <i class="fa-solid fa-phone"></i>
            (437) 545-0067
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .services-professional {
    padding: 6rem 0;
    background: var(--bg-dark-800);
    position: relative;
  }
  
  .services-professional::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent 0%, 
      rgba(212, 175, 55, 0.3) 50%, 
      transparent 100%
    );
  }
  
  .services-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  
  /* Section Header */
  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }
  
  .header-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(212, 175, 55, 0.1);
    border: 1px solid rgba(212, 175, 55, 0.3);
    color: var(--color-primary);
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }
  
  .section-title {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 700;
    color: var(--text-white);
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  
  .title-accent {
    color: var(--color-primary);
    display: block;
  }
  
  .section-subtitle {
    font-size: 1.125rem;
    color: var(--text-muted);
    max-width: 600px;
    margin: 0 auto;
  }
  
  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }
  
  .service-card {
    position: relative;
    background: var(--bg-dark-700);
    border: 1px solid rgba(212, 175, 55, 0.1);
    overflow: hidden;
    transition: all 0.3s ease;
    animation: fadeInUp 0.8s ease-out backwards;
    animation-delay: calc(0.1s * var(--index));
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .service-card:hover {
    transform: translateY(-5px);
    border-color: rgba(212, 175, 55, 0.3);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }
  
  .service-card.popular {
    border-color: rgba(212, 175, 55, 0.3);
    background: linear-gradient(135deg, var(--bg-dark-700) 0%, rgba(212, 175, 55, 0.05) 100%);
  }
  
  .popular-tag {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: var(--color-primary);
    color: var(--bg-dark-900);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 10;
  }
  
  /* Service Image */
  .service-image {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  
  .service-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .service-card:hover .service-image img {
    transform: scale(1.05);
  }
  
  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(13, 17, 23, 0.4) 0%, rgba(13, 17, 23, 0.8) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  .service-card:hover .image-overlay {
    opacity: 1;
  }
  
  .overlay-content i {
    font-size: 3rem;
    color: var(--color-primary);
  }
  
  /* Service Content */
  .service-content {
    padding: 1.5rem;
  }
  
  .service-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-white);
    margin-bottom: 0.75rem;
  }
  
  .service-description {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  /* Service Details */
  .service-details {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1rem;
    background: rgba(13, 17, 23, 0.5);
    border: 1px solid rgba(212, 175, 55, 0.1);
    margin-bottom: 1.5rem;
  }
  
  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  
  .detail-item i {
    color: var(--color-primary);
    font-size: 1.125rem;
    margin-bottom: 0.25rem;
  }
  
  .detail-label {
    font-size: 0.75rem;
    color: var(--text-dark);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .detail-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-white);
  }
  
  /* Features List */
  .feature-list {
    list-style: none;
    padding: 0;
    margin-bottom: 1.5rem;
  }
  
  .feature-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: var(--text-light);
    font-size: 0.875rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  .feature-list li:last-child {
    border-bottom: none;
  }
  
  .feature-list i {
    color: var(--color-accent);
    font-size: 0.75rem;
    flex-shrink: 0;
  }
  
  /* Service Button */
  .service-btn {
    width: 100%;
    padding: 0.875rem;
    background: transparent;
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    font-weight: 600;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  
  .service-btn::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 100%;
    background: var(--color-primary);
    transition: width 0.3s ease;
    z-index: -1;
  }
  
  .service-btn:hover {
    color: var(--bg-dark-900);
  }
  
  .service-btn:hover::before {
    width: 100%;
  }
  
  .service-btn:hover i {
    transform: translateX(5px);
  }
  
  .service-btn i {
    transition: transform 0.3s ease;
  }
  
  /* Bottom CTA */
  .services-cta {
    background: linear-gradient(135deg, rgba(212, 175, 55, 0.05) 0%, rgba(27, 54, 93, 0.05) 100%);
    border: 1px solid rgba(212, 175, 55, 0.2);
    padding: 3rem;
  }
  
  .cta-content {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .cta-icon {
    width: 80px;
    height: 80px;
    background: var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .cta-icon i {
    font-size: 2rem;
    color: var(--bg-dark-900);
  }
  
  .cta-text {
    flex: 1;
  }
  
  .cta-text h3 {
    font-size: 1.75rem;
    color: var(--text-white);
    margin-bottom: 0.5rem;
  }
  
  .cta-text p {
    color: var(--text-muted);
  }
  
  .cta-actions {
    display: flex;
    gap: 1rem;
  }
  
  .btn-consultation {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: var(--color-primary);
    color: var(--bg-dark-900);
    border: none;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  
  .btn-consultation:hover {
    background: var(--color-warning);
    transform: translateY(-2px);
  }
  
  .btn-call {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2rem;
    background: transparent;
    color: var(--text-white);
    border: 2px solid var(--color-secondary);
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }
  
  .btn-call:hover {
    background: var(--color-secondary);
    transform: translateY(-2px);
  }
  
  /* Responsive */
  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    }
    
    .cta-content {
      flex-direction: column;
      text-align: center;
    }
    
    .cta-actions {
      flex-direction: column;
      width: 100%;
    }
    
    .btn-consultation,
    .btn-call {
      width: 100%;
      justify-content: center;
    }
  }
  
  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    
    .service-details {
      grid-template-columns: 1fr;
    }
  }
</style>