---
// Trust Badges Component - Displays certifications and trust indicators
---

<section class="section section-secondary">
  <div class="container">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-md">
      <!-- BBB Accreditation -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L14.09 8.26L20.18 8.63L15.45 12.97L16.9 19L12 15.27L7.1 19L8.55 12.97L3.82 8.63L9.91 8.26L12 2Z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">BBB Accredited</span>
          <span class="badge-value">A+ Rating</span>
        </div>
      </div>

      <!-- Years in Business -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">Established</span>
          <span class="badge-value">Since 1999</span>
        </div>
      </div>

      <!-- Licensed & Insured -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.53 4.12-3.28 7.79-7 8.94V12H5V6.3l7-3.11v8.8z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">Fully Licensed</span>
          <span class="badge-value">& Insured</span>
        </div>
      </div>

      <!-- WSIB Coverage -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">WSIB</span>
          <span class="badge-value">Coverage</span>
        </div>
      </div>

      <!-- HomeStars Verified -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.11 0 2-.9 2-2V5c0-1.1-.89-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">HomeStars</span>
          <span class="badge-value">Verified Pro</span>
        </div>
      </div>

      <!-- Google Reviews -->
      <div class="trust-badge-card">
        <div class="badge-icon">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="currentColor"/>
          </svg>
        </div>
        <div class="badge-content">
          <span class="badge-label">Google Rating</span>
          <span class="badge-value">4.9/5.0 Stars</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Trust Badge Cards - extends unified design system */
  .trust-badge-card {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md);
    background: var(--color-white);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .trust-badge-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--bg-gradient);
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .trust-badge-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-xl);
  }

  .trust-badge-card:hover::before {
    transform: scaleX(1);
  }

  .badge-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--bg-gradient);
    border-radius: var(--radius-md);
    flex-shrink: 0;
  }

  .badge-icon svg {
    width: 24px;
    height: 24px;
    color: var(--color-white);
  }

  .badge-content {
    display: flex;
    flex-direction: column;
  }

  .badge-label {
    font-size: var(--fs-xs);
    color: var(--color-gray-600);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .badge-value {
    font-size: var(--fs-sm);
    color: var(--color-gray-900);
    font-weight: 700;
    margin-top: 0.125rem;
  }

  /* Dark mode support */
  @media (prefers-color-scheme: dark) {
    .trust-badge-card {
      background: var(--color-gray-800);
    }
    
    .badge-value {
      color: var(--color-white);
    }
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .trust-badge-card {
      padding: var(--space-sm);
    }

    .badge-icon {
      width: 36px;
      height: 36px;
    }
  }

  /* Animation */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .trust-badge-card {
    animation: fadeInUp 0.6s ease forwards;
    opacity: 0;
  }

  .trust-badge-card:nth-child(1) { animation-delay: 0.1s; }
  .trust-badge-card:nth-child(2) { animation-delay: 0.2s; }
  .trust-badge-card:nth-child(3) { animation-delay: 0.3s; }
  .trust-badge-card:nth-child(4) { animation-delay: 0.4s; }
  .trust-badge-card:nth-child(5) { animation-delay: 0.5s; }
  .trust-badge-card:nth-child(6) { animation-delay: 0.6s; }
</style>