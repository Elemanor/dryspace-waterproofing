---
// Unique Value Propositions Component
---

<section class="value-propositions">
  <div class="container">
    <h2>The Dryspace Advantage</h2>
    <p class="section-intro">Why Toronto homeowners choose us over the competition</p>
    
    <div class="propositions-grid">
      <div class="proposition-card flagship">
        <div class="prop-icon">🏆</div>
        <h3>Toronto's Only 25-Year Transferable Warranty</h3>
        <p>Our industry-leading warranty transfers to new homeowners, protecting your investment and increasing resale value.</p>
        <div class="prop-badge">EXCLUSIVE</div>
      </div>
      
      <div class="proposition-card">
        <div class="prop-icon">⚡</div>
        <h3>Same-Day Emergency Response Guarantee</h3>
        <p>Basement flooding? We guarantee arrival within 30 minutes in Toronto core, or your emergency call is free.</p>
        <div class="prop-badge">30 MIN</div>
      </div>
      
      <div class="proposition-card">
        <div class="prop-icon">🔍</div>
        <h3>Free Annual Inspections for Life</h3>
        <p>Every customer receives free yearly basement inspections forever. Catch problems early, prevent costly repairs.</p>
        <div class="prop-badge">LIFETIME</div>
      </div>
      
      <div class="proposition-card">
        <div class="prop-icon">💰</div>
        <h3>Price Match Plus 10% Guarantee</h3>
        <p>Find a lower written quote? We'll match it and take an additional 10% off. Best price, best service, guaranteed.</p>
        <div class="prop-badge">110% MATCH</div>
      </div>
    </div>
    
    <div class="guarantee-seal">
      <img src="/images/satisfaction-guarantee-seal.svg" alt="100% Satisfaction Guarantee" / width="800" height="600" loading="lazy" decoding="async">
      <div class="guarantee-text">
        <h4>100% Satisfaction Guarantee</h4>
        <p>Not happy? We'll make it right or refund your money. No questions asked.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .value-propositions {
    padding: 80px 0;
    background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
    position: relative;
    overflow: hidden;
  }
  
  .value-propositions::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #0077BE, #FF6B35, #00A878);
  }
  
  .value-propositions h2 {
    text-align: center;
    font-size: 42px;
    margin-bottom: 15px;
    color: #333;
  }
  
  .section-intro {
    text-align: center;
    font-size: 20px;
    color: #666;
    margin-bottom: 50px;
  }
  
  .propositions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .proposition-card {
    background: white;
    padding: 35px;
    border-radius: 15px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    text-align: center;
    position: relative;
    transition: all 0.3s;
    border: 2px solid transparent;
  }
  
  .proposition-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.12);
    border-color: #0077BE;
  }
  
  .proposition-card.flagship {
    background: linear-gradient(135deg, #0077BE, #0066a5);
    color: white;
  }
  
  .proposition-card.flagship h3,
  .proposition-card.flagship p {
    color: white;
  }
  
  .prop-icon {
    font-size: 60px;
    margin-bottom: 20px;
    display: block;
    animation: float 3s ease-in-out infinite;
  }
  
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .proposition-card h3 {
    font-size: 22px;
    margin-bottom: 15px;
    color: #333;
    line-height: 1.3;
  }
  
  .proposition-card p {
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
  }
  
  .prop-badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, #FF6B35, #ff5722);
    color: white;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
  }
  
  .guarantee-seal {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 30px;
    margin-top: 60px;
    padding: 40px;
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }
  
  .guarantee-seal img {
    width: 120px;
    height: 120px;
  }
  
  .guarantee-text h4 {
    font-size: 28px;
    margin-bottom: 10px;
    color: #333;
  }
  
  .guarantee-text p {
    font-size: 18px;
    color: #666;
  }
  
  /* Mobile Responsive */
  @media (max-width: 768px) {
    .value-propositions h2 {
      font-size: 32px;
    }
    
    .propositions-grid {
      grid-template-columns: 1fr;
    }
    
    .guarantee-seal {
      flex-direction: column;
      text-align: center;
    }
    
    .prop-badge {
      position: static;
      display: inline-block;
      margin-top: 10px;
    }
  }
</style>