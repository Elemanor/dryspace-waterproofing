---
export interface Props {
  title?: string;
  subtitle?: string;
  showMap?: boolean;
  showForm?: boolean;
  showInfo?: boolean;
}

const {
  title = "Get Your Free Inspection",
  subtitle = "Contact us today for a no-obligation assessment and quote",
  showMap = true,
  showForm = true,
  showInfo = true
} = Astro.props;

const contactInfo = {
  phone: '437-545-0067',
  emergency: '437-545-0067',
  email: 'p.vysotckii@gmail.com',
  address: '123 Waterproofing Way, Toronto, ON M1A 1A1',
  hours: {
    regular: 'Mon-Fri: 7:00 AM - 7:00 PM, Sat-Sun: 8:00 AM - 5:00 PM',
    emergency: '24/7 Emergency Service Available'
  }
};

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Dryspace Waterproofing",
  "description": "Professional waterproofing and foundation repair services in Toronto and GTA",
  "url": "https://dryspacewaterproofing.ca",
  "telephone": contactInfo.phone,
  "email": contactInfo.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "260 Wellesley Street East",
    "addressLocality": "Toronto",
    "addressRegion": "ON",
    "postalCode": "M4X 1G6",
    "addressCountry": "CA"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "07:00",
      "closes": "19:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Saturday", "Sunday"],
      "opens": "08:00",
      "closes": "17:00"
    }
  ],
  "areaServed": [
    "Toronto", "Mississauga", "Brampton", "Vaughan", "Markham",
    "Richmond Hill", "Scarborough", "North York", "Etobicoke"
  ]
};
---

<section class="section">
  <div class="container">
    <!-- Section Header -->
    <div class="section-header">
      <span class="text-cyan-600 dark:text-cyan-400 font-semibold text-sm uppercase tracking-wide">
        Contact Us
      </span>
      <h2 class="h2 section-title text-slate-900 dark:text-white">
        {title}
      </h2>
      <p class="section-subtitle text-slate-600 dark:text-slate-400">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-7xl mx-auto">
      <!-- Contact Information -->
      {showInfo && (
        <div class="space-y-8">
          <!-- Emergency Banner -->
          <div class="bg-red-50 dark:bg-red-900/20 border-2 border-red-200 dark:border-red-800 rounded-xl p-6">
            <div class="flex items-center gap-4">
              <div class="flex-shrink-0">
                <div class="relative">
                  <span class="animate-ping absolute inline-flex h-12 w-12 rounded-full bg-red-400 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-12 w-12 bg-red-500 items-center justify-center">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </span>
                </div>
              </div>
              <div>
                <h3 class="text-lg font-bold text-red-900 dark:text-red-100">24/7 Emergency Service</h3>
                <p class="text-red-700 dark:text-red-300">Water damage? Call immediately!</p>
                <a href={`tel:${contactInfo.emergency}`} class="text-2xl font-bold text-red-600 dark:text-red-400 hover:underline">
                  {contactInfo.emergency}
                </a>
              </div>
            </div>
          </div>

          <!-- Regular Contact Info -->
          <div class="bg-slate-50 dark:bg-navy-900 rounded-xl p-8">
            <h3 class="h3 text-slate-900 dark:text-slate-900">Contact Information</h3>
            
            <div class="space-y-6">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-cyan-50 dark:bg-navy-900 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">Phone</h4>
                  <a href={`tel:${contactInfo.phone}`} class="text-lg text-cyan-600 dark:text-cyan-400 hover:underline">
                    {contactInfo.phone}
                  </a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-cyan-50 dark:bg-navy-900 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">Email</h4>
                  <a href={`mailto:${contactInfo.email}`} class="text-cyan-600 dark:text-cyan-400 hover:underline">
                    {contactInfo.email}
                  </a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-cyan-50 dark:bg-navy-900 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">Office</h4>
                  <p class="text-slate-600 dark:text-slate-400">{contactInfo.address}</p>
                </div>
              </div>

              <!-- Hours -->
              <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-10 h-10 bg-cyan-50 dark:bg-navy-900 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-cyan-600 dark:text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-slate-900 dark:text-white">Business Hours</h4>
                  <p class="text-slate-600 dark:text-slate-400">{contactInfo.hours.regular}</p>
                  <p class="text-red-600 dark:text-red-400 font-semibold mt-1">{contactInfo.hours.emergency}</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Service Areas -->
          <div class="bg-cyan-50 dark:bg-navy-900/20 rounded-xl p-8">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-4">Service Areas</h3>
            <div class="flex flex-wrap gap-2">
              {['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'Scarborough', 'North York', 'Etobicoke', 'Oakville', 'Burlington', 'Hamilton'].map((area) => (
                <span class="bg-white dark:bg-navy-900 px-3 py-1 rounded-full text-sm text-slate-700 dark:text-slate-300">
                  {area}
                </span>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- Contact Form -->
      {showForm && (
        <div class="bg-slate-50 dark:bg-navy-900 rounded-xl p-8">
          <h3 class="h3 text-slate-900 dark:text-slate-900">Request Free Inspection</h3>
          
          <form class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <!-- First Name -->
              <div>
                <label for="firstName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                  First Name *
                </label>
                <input 
                  type="text" 
                  id="firstName" 
                  name="firstName" 
                  required
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-slate-900"
                />
              </div>

              <!-- Last Name -->
              <div>
                <label for="lastName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                  Last Name *
                </label>
                <input 
                  type="text" 
                  id="lastName" 
                  name="lastName" 
                  required
                  class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white"
                />
              </div>
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Email *
              </label>
              <input 
                type="email" 
                id="email" 
                name="email" 
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="phone" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Phone *
              </label>
              <input 
                type="tel" 
                id="phone" 
                name="phone" 
                required
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white"
              />
            </div>

            <!-- Service Type -->
            <div>
              <label for="service" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Service Needed
              </label>
              <select 
                id="service" 
                name="service"
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white"
              >
                <option value="">Select a service...</option>
                <option value="inspection">Free Inspection</option>
                <option value="emergency">Emergency Water Removal</option>
                <option value="interior">Interior Waterproofing</option>
                <option value="exterior">Exterior Waterproofing</option>
                <option value="foundation">Foundation Repair</option>
                <option value="sump-pump">Sump Pump Installation</option>
                <option value="french-drain">French Drain System</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">
                Message
              </label>
              <textarea 
                id="message" 
                name="message" 
                rows={4}
                placeholder="Please describe your waterproofing needs..."
                class="w-full px-4 py-3 border border-slate-300 dark:border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent dark:bg-slate-700 dark:text-white"
              ></textarea>
            </div>

            <!-- Urgency -->
            <div class="flex items-center gap-3">
              <input 
                type="checkbox" 
                id="urgent" 
                name="urgent"
                class="w-5 h-5 text-red-600 border-slate-300 rounded focus:ring-red-500"
              />
              <label for="urgent" class="text-sm text-slate-700 dark:text-slate-300">
                This is an emergency - I need immediate assistance
              </label>
            </div>

            <!-- Submit Button -->
            <button 
              type="submit"
              class="w-full py-4 bg-cyan-600 text-white font-semibold rounded-lg hover:bg-cyan-700 transition-colors duration-300 transform hover:scale-[1.02]"
            >
              Get Free Inspection
            </button>

            <!-- Privacy Notice -->
            <p class="text-xs text-slate-500 dark:text-slate-400 text-center">
              By submitting this form, you agree to our privacy policy and consent to receive communications from Dryspace Waterproofing.
            </p>
          </form>
        </div>
      )}
    </div>

    <!-- Map Section -->
    {showMap && (
      <div class="mt-12">
        <div class="bg-slate-200 dark:bg-navy-900 rounded-xl h-96 flex items-center justify-center">
          <div class="text-center">
            <svg class="w-16 h-16 mx-auto text-slate-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
            </svg>
            <p class="text-slate-600 dark:text-slate-400">Interactive map will be embedded here</p>
            <a 
              href="https://maps.google.com/?q=Dryspace+Waterproofing+Toronto"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center mt-4 text-cyan-600 dark:text-cyan-400 hover:underline"
            >
              View on Google Maps
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    )}
  </div>
</section>

<!-- Local Business Schema -->
<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>