---
export interface Feature {
  icon: string;
  title: string;
  description: string;
  highlight?: boolean;
}

export interface Props {
  title?: string;
  subtitle?: string;
  features?: Feature[];
  columns?: 2 | 3 | 4;
  centered?: boolean;
}

const {
  title = "Why Choose Dryspace Waterproofing",
  subtitle = "Industry-leading expertise, warranties, and customer service that sets us apart",
  columns = 3,
  centered = true,
  features = [
    {
      icon: '🏆',
      title: '25-Year Transferable Warranty',
      description: 'The longest warranty in the GTA. Fully transferable to new owners, adding value to your home.',
      highlight: true
    },
    {
      icon: '🚨',
      title: '24/7 Emergency Response',
      description: 'Water damage doesn\'t wait. Our emergency team responds within 2 hours, any time of day or night.',
      highlight: true
    },
    {
      icon: '💰',
      title: 'Government Rebate Assistance',
      description: 'We help you access up to $3,400 in City of Toronto rebates and handle all the paperwork.',
      highlight: true
    },
    {
      icon: '👨‍👩‍👧‍👦',
      title: 'Family-Owned Since 1999',
      description: 'Three generations of waterproofing expertise. We treat your home like our own.',
      highlight: false
    },
    {
      icon: '🏗️',
      title: 'Licensed & Insured',
      description: 'Fully licensed by the City of Toronto, WSIB covered, and $5 million liability insurance.',
      highlight: false
    },
    {
      icon: '✅',
      title: 'Free Inspection & Quote',
      description: 'No obligation assessment with detailed report, photos, and multiple solution options.',
      highlight: false
    },
    {
      icon: '🔧',
      title: 'All Methods Available',
      description: 'Interior, exterior, French drains, sump pumps - we offer every waterproofing solution.',
      highlight: false
    },
    {
      icon: '📞',
      title: 'Lifetime Support',
      description: 'Annual inspections, maintenance programs, and expert advice whenever you need it.',
      highlight: false
    },
    {
      icon: '💳',
      title: '0% Financing Available',
      description: 'Flexible payment plans with 0% interest for qualified homeowners. No credit check options.',
      highlight: false
    }
  ]
} = Astro.props;

const highlightedFeatures = features.filter(f => f.highlight);
const regularFeatures = features.filter(f => !f.highlight);
---

<section class="section-padding bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class={`${centered ? 'text-center' : ''} max-w-3xl ${centered ? 'mx-auto' : ''} mb-12 lg:mb-16`}>
      <p class="section-label-pill mb-4">Why Choose Us</p>
      <h2 class="text-headline text-slate-900">{title}</h2>
      <p class="mt-4 text-lg text-slate-600 leading-relaxed">{subtitle}</p>
    </div>

    <!-- Highlighted Features -->
    {highlightedFeatures.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 max-w-5xl mx-auto">
        {highlightedFeatures.map((feature) => (
          <div class="relative rounded-2xl border-2 border-cyan-500/30 bg-gradient-to-b from-cyan-50 to-white p-6 shadow-card hover:shadow-card-hover transition-all duration-300 hover:-translate-y-1">
            <span class="absolute -top-2.5 right-4 rounded-full bg-cyan-500 px-3 py-0.5 text-[11px] font-semibold text-white">
              Featured
            </span>
            <div class="text-4xl mb-4">{feature.icon}</div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-sm text-slate-600 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    )}

    <!-- Regular Features Grid -->
    <div class={`grid grid-cols-1 md:grid-cols-2 lg:grid-cols-${columns} gap-6 max-w-6xl mx-auto`}>
      {regularFeatures.map((feature) => (
        <div class="rounded-xl border border-slate-200/60 bg-white p-6 shadow-card transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1">
          <div class="text-3xl mb-3">{feature.icon}</div>
          <h3 class="text-base font-semibold text-slate-900 mb-2">{feature.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>

    <!-- Trust Indicators -->
    <div class="mt-16 pt-12 border-t border-slate-100">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center max-w-4xl mx-auto">
        <div>
          <div class="text-3xl font-bold text-cyan-600 mb-1">25+</div>
          <div class="text-sm text-slate-600">Years Experience</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600 mb-1">15,000+</div>
          <div class="text-sm text-slate-600">Homes Protected</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600 mb-1">A+</div>
          <div class="text-sm text-slate-600">BBB Rating</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600 mb-1">100%</div>
          <div class="text-sm text-slate-600">Satisfaction Rate</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-10">
      <a
        href="/why-choose-us"
        class="inline-flex items-center text-cyan-600 font-semibold hover:text-cyan-700 transition-colors"
      >
        Learn more about our guarantees
        <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
