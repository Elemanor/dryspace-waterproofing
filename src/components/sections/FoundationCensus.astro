---
import type { CityHyperLocal } from '../../data/location-data';

interface Props {
  city: string;
  data: CityHyperLocal['foundationCensus'];
}

const { city, data } = Astro.props;

const maxPct = Math.max(...data.map(d => d.pct));
const dominantEra = data.reduce((a, b) => a.pct > b.pct ? a : b);

const barColors = [
  'bg-cyan-600',
  'bg-cyan-500',
  'bg-cyan-400',
  'bg-cyan-300',
];
---

<section class="py-16 bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="max-w-6xl mx-auto">

      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">
          Foundation Types in {city} Homes by Construction Era
        </h2>
        <div class="max-w-3xl mx-auto bg-cyan-50 border-l-4 border-cyan-500 p-6 text-left speakable">
          <p class="text-lg text-slate-700">
            <strong>{dominantEra.pct}% of {city} homes have {dominantEra.type.toLowerCase()} foundations built in the {dominantEra.era}.</strong> The most common failure mode is {dominantEra.failureMode.toLowerCase().split(',')[0]}. Understanding your home's construction era helps predict waterproofing issues before they become emergencies.
          </p>
        </div>
      </div>

      <div class="space-y-6">
        {data.map((item, index) => (
          <div class="bg-white border-2 border-slate-200 overflow-hidden">
            <!-- Era Header with Percentage Bar -->
            <div class="p-6">
              <div class="flex items-start justify-between gap-4 mb-4">
                <div class="flex-grow">
                  <div class="flex items-center gap-3 mb-2">
                    <span class="text-3xl font-bold text-cyan-600">{item.pct}%</span>
                    <div>
                      <h3 class="text-xl font-bold text-slate-900 uppercase">{item.era}</h3>
                      <p class="text-sm text-slate-500 uppercase">of {city} homes</p>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Percentage Bar -->
              <div class="w-full bg-slate-100 h-4 mb-6">
                <div
                  class={`h-4 ${barColors[index] || 'bg-cyan-500'} transition-all`}
                  style={`width: ${item.pct}%`}
                ></div>
              </div>

              <!-- Details Grid -->
              <div class="grid md:grid-cols-3 gap-6">
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2 uppercase">Foundation Type</h4>
                  <p class="text-slate-700">{item.type}</p>
                </div>
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2 uppercase">Common Failure Mode</h4>
                  <p class="text-slate-700">{item.failureMode}</p>
                </div>
                <div class="bg-cyan-50 border-l-4 border-cyan-500 p-4 -m-0">
                  <h4 class="font-bold text-sm text-cyan-800 mb-2 uppercase">Recommended Fix</h4>
                  <p class="text-slate-700">{item.solution}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 bg-white border-2 border-cyan-200 p-6 text-center">
        <h3 class="text-xl font-bold text-slate-900 mb-2 uppercase">Not Sure What Foundation Type You Have?</h3>
        <p class="text-slate-600 mb-4">Our free assessment includes foundation age identification, condition evaluation, and tailored waterproofing recommendations for your specific {city} home.</p>
        <a href="/free-inspection" class="inline-block bg-cyan-500 text-white px-8 py-3 font-bold hover:bg-cyan-600 transition uppercase">
          Book Free Foundation Assessment
        </a>
      </div>

    </div>
  </div>
</section>
