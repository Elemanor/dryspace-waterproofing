---
export interface GalleryItem {
  before: string;
  after: string;
  title: string;
  description: string;
  service: string;
  location?: string;
}

export interface Props {
  title?: string;
  subtitle?: string;
  items?: GalleryItem[];
  showFilter?: boolean;
}

const {
  title = "Before & After Gallery",
  subtitle = "See the dramatic transformations we've achieved for GTA homeowners",
  showFilter = true,
  items = [
    {
      before: '/images/wet walls.webp',
      after: '/images/interior-waterproofing.webp',
      title: 'Basement Flood Recovery',
      description: 'Complete waterproofing after major flooding. Interior drainage system and sump pump installation.',
      service: 'Interior Waterproofing',
      location: 'Toronto'
    },
    {
      before: '/images/crack.webp',
      after: '/images/crack_repair.webp',
      title: 'Foundation Crack Repair',
      description: 'Structural crack injection and reinforcement. Permanent solution with warranty.',
      service: 'Foundation Repair',
      location: 'Mississauga'
    },
    {
      before: '/images/exterior-waterproofing-toronto in process (1).webp',
      after: '/images/dryspace_exterior_waterproofing_warranty.webp',
      title: 'Exterior Waterproofing',
      description: 'Full excavation, membrane installation, and drainage system. 25-year warranty protection.',
      service: 'Exterior Waterproofing',
      location: 'Vaughan'
    },
    {
      before: '/images/sump pump with water.webp',
      after: '/images/placing new sump pump.webp',
      title: 'Sump Pump System',
      description: 'Triple pump system with battery backup. Never worry about power outages again.',
      service: 'Sump Pump Installation',
      location: 'Brampton'
    },
    {
      before: '/images/gallery/french-drain-before.webp',
      after: '/images/gallery/french-drain-after.webp',
      title: 'French Drain Installation',
      description: 'Interior perimeter drainage system. Captures and redirects water away from foundation.',
      service: 'Drainage Systems',
      location: 'Markham'
    },
    {
      before: '/images/gallery/basement-finishing-before.webp',
      after: '/images/gallery/basement-finishing-after.webp',
      title: 'Waterproof Basement Finishing',
      description: 'Moisture-resistant materials and proper vapor barriers. Beautiful and protected.',
      service: 'Basement Finishing',
      location: 'North York'
    }
  ]
} = Astro.props;

const services = [...new Set(items.map(item => item.service))];
---

<section class="section-padding bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <p class="section-label-pill mb-4">Our Work</p>
      <h2 class="text-headline text-slate-900">{title}</h2>
      <p class="mt-4 text-lg text-slate-600">{subtitle}</p>
    </div>

    <!-- Filter Buttons -->
    {showFilter && (
      <div class="flex flex-wrap justify-center gap-2 mb-10">
        <button
          data-filter="all"
          class="filter-btn rounded-full px-4 py-2 text-sm font-medium transition-all bg-cyan-500 text-white shadow-sm"
        >
          All Projects
        </button>
        {services.map((service) => (
          <button
            data-filter={service}
            class="filter-btn rounded-full px-4 py-2 text-sm font-medium transition-all bg-white text-slate-600 border border-slate-200 hover:border-cyan-200 hover:text-cyan-600"
          >
            {service}
          </button>
        ))}
      </div>
    )}

    <!-- Gallery Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
      {items.map((item) => (
        <div class="gallery-item group" data-service={item.service}>
          <div class="rounded-xl border border-slate-200/60 bg-white shadow-card overflow-hidden transition-all duration-300 hover:shadow-card-hover hover:-translate-y-0.5">
            <!-- Before/After Slider -->
            <div class="relative aspect-[4/3] overflow-hidden">
              <img
                src={item.after}
                alt={`${item.title} - After`}
                class="absolute inset-0 w-full h-full object-cover"
                loading="lazy"
              />
              <div class="before-container absolute inset-0 w-1/2 overflow-hidden border-r-2 border-white">
                <img
                  src={item.before}
                  alt={`${item.title} - Before`}
                  class="absolute inset-0 w-full h-full object-cover"
                  style="width: 200%; max-width: 200%;"
                  loading="lazy"
                />
              </div>
              <div class="slider-handle absolute top-0 bottom-0 w-1 bg-white cursor-ew-resize" style="left: 50%;">
                <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-9 h-9 bg-white rounded-full shadow-float flex items-center justify-center">
                  <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l-3 3 3 3m8-6l3 3-3 3" />
                  </svg>
                </div>
              </div>
              <div class="absolute top-3 left-3 rounded-full bg-navy-900/70 backdrop-blur text-white px-3 py-1 text-xs font-medium">Before</div>
              <div class="absolute top-3 right-3 rounded-full bg-navy-900/70 backdrop-blur text-white px-3 py-1 text-xs font-medium">After</div>
            </div>

            <!-- Content -->
            <div class="p-5">
              <div class="flex items-center justify-between mb-2">
                <span class="inline-flex items-center rounded-full bg-cyan-50 px-2.5 py-0.5 text-xs font-medium text-cyan-700">
                  {item.service}
                </span>
                {item.location && (
                  <span class="text-xs text-slate-400 flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd" /></svg>
                    {item.location}
                  </span>
                )}
              </div>
              <h3 class="text-base font-semibold text-slate-900 mb-1">{item.title}</h3>
              <p class="text-sm text-slate-600 leading-relaxed">{item.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA Section -->
    <div class="text-center mt-12">
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/gallery" class="btn-secondary">
          View Full Gallery
          <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/free-inspection" class="btn-primary">
          Get Free Inspection
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.slider-handle').forEach(handle => {
    let isDown = false;
    const container = handle.closest('.relative');
    const beforeContainer = container?.querySelector('.before-container') as HTMLElement;

    if (!container || !beforeContainer) return;

    const moveSlider = (x: number) => {
      const rect = container.getBoundingClientRect();
      const percent = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
      (handle as HTMLElement).style.left = `${percent}%`;
      beforeContainer.style.width = `${percent}%`;
    };

    handle.addEventListener('mousedown', () => isDown = true);
    document.addEventListener('mouseup', () => isDown = false);
    document.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      moveSlider(e.clientX);
    });

    handle.addEventListener('touchstart', () => isDown = true);
    document.addEventListener('touchend', () => isDown = false);
    document.addEventListener('touchmove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      moveSlider(e.touches[0].clientX);
    });
  });

  const filterBtns = document.querySelectorAll('.filter-btn');
  const galleryItems = document.querySelectorAll('.gallery-item');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-cyan-500', 'text-white', 'shadow-sm');
        b.classList.add('bg-white', 'text-slate-600', 'border', 'border-slate-200');
      });
      btn.classList.remove('bg-white', 'text-slate-600', 'border', 'border-slate-200');
      btn.classList.add('bg-cyan-500', 'text-white', 'shadow-sm');

      const filter = btn.getAttribute('data-filter');
      galleryItems.forEach(item => {
        if (filter === 'all' || item.getAttribute('data-service') === filter) {
          (item as HTMLElement).style.display = 'block';
        } else {
          (item as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .slider-handle {
    touch-action: none;
    user-select: none;
  }
</style>
