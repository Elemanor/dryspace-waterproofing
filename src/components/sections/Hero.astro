---
export interface Props {
  title?: string;
  subtitle?: string;
  backgroundImage?: string;
  primaryCTA?: { text: string; href: string };
  secondaryCTA?: { text: string; href: string };
  badge?: string;
}

const {
  title = "Toronto's Most Trusted Waterproofing Experts",
  subtitle = "Protecting GTA homes from water damage since 1999. <60 minute emergency response, lifetime transferable warranty, and government rebates available.",
  backgroundImage = "/images/exterior_waterproofing.webp",
  primaryCTA = { text: "Get Free Inspection", href: "/free-inspection" },
  secondaryCTA = { text: "Emergency: 437-545-0067", href: "tel:437-545-0067" },
  badge = "$3,400 REBATE AVAILABLE"
} = Astro.props;
---

<section class="relative min-h-[90vh] lg:min-h-screen flex items-center overflow-hidden bg-navy-900">
  <!-- Background image with overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src={backgroundImage}
      alt="Professional waterproofing services"
      class="w-full h-full object-cover opacity-30"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-navy-900 via-navy-900/90 to-navy-900/60"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-navy-900 via-transparent to-navy-900/40"></div>
  </div>

  <!-- Main content -->
  <div class="relative z-10 container mx-auto px-4 sm:px-6 py-20 lg:py-28">
    <div class="grid lg:grid-cols-5 gap-12 items-center">
      <!-- Left: copy -->
      <div class="lg:col-span-3">
        <!-- Badge -->
        {badge && (
          <div class="inline-block mb-6 reveal">
            <span class="inline-flex items-center gap-2 rounded-full bg-amber-500/15 border border-amber-500/30 px-4 py-2 text-sm font-semibold text-amber-400">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 013 3v1a1 1 0 102 0v-1a5 5 0 00-5-5H8.414l1.293-1.293z" clip-rule="evenodd" /></svg>
              {badge}
            </span>
          </div>
        )}

        <!-- Headline -->
        <h1 class="text-display text-white mb-6 reveal reveal-delay-1">
          {title}
        </h1>

        <!-- Subtitle -->
        <p class="text-xl lg:text-2xl text-slate-300 leading-relaxed mb-10 max-w-2xl reveal reveal-delay-2">
          {subtitle}
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mb-10 reveal reveal-delay-3">
          <a
            href={primaryCTA.href}
            class="btn-primary !px-8 !py-4 !text-lg shadow-xl"
          >
            {primaryCTA.text}
          </a>
          <a
            href={secondaryCTA.href}
            class="btn-ghost border-2 border-white/20 !px-8 !py-4 !text-lg"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            {secondaryCTA.text}
          </a>
        </div>

        <!-- Service quick-links -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 reveal reveal-delay-4">
          {[
            { label: "Exterior Waterproofing", href: "/services/exterior-waterproofing" },
            { label: "Foundation Repair", href: "/services/foundation-repair" },
            { label: "Sump Pumps", href: "/services/sump-pump-installation" },
            { label: "Interior Drainage", href: "/services/interior-waterproofing" },
            { label: "Underpinning", href: "/services/underpinning" },
            { label: "French Drains", href: "/services/drainage-solutions" },
          ].map((svc) => (
            <a href={svc.href} class="flex items-center gap-2 text-sm text-white/80 hover:text-cyan-400 transition-colors">
              <svg class="w-4 h-4 text-cyan-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              {svc.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Right: floating trust card -->
      <div class="hidden lg:block lg:col-span-2 reveal reveal-delay-3">
        <div class="rounded-2xl bg-white/5 backdrop-blur-lg border border-white/10 p-8 shadow-glow">
          <div class="text-center mb-6">
            <div class="flex items-center justify-center gap-1 mb-2">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-2xl font-bold text-white">A+</p>
            <p class="text-sm text-slate-400">BBB Accredited</p>
          </div>

          <div class="space-y-4 border-t border-white/10 pt-6">
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-cyan-500/10">
                <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-white">BBB A+ Rating</p>
                <p class="text-xs text-slate-400">Better Business Bureau</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-cyan-500/10">
                <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-white">25-Year Warranty</p>
                <p class="text-xs text-slate-400">Transferable & insured</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-amber-500/10">
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M5 2a2 2 0 00-2 2v14l3.5-2 3.5 2 3.5-2 3.5 2V4a2 2 0 00-2-2H5zm4.707 3.707a1 1 0 00-1.414-1.414l-3 3a1 1 0 000 1.414l3 3a1 1 0 001.414-1.414L8.414 9H10a3 3 0 013 3v1a1 1 0 102 0v-1a5 5 0 00-5-5H8.414l1.293-1.293z" clip-rule="evenodd" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-white">Up to $3,400 Rebate</p>
                <p class="text-xs text-slate-400">Government programs</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <div class="flex items-center justify-center w-10 h-10 rounded-lg bg-cyan-500/10">
                <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
              </div>
              <div>
                <p class="text-sm font-medium text-white">< 60 Min Response</p>
                <p class="text-xs text-slate-400">24/7 emergency service</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce z-10">
    <svg class="w-6 h-6 text-white/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
