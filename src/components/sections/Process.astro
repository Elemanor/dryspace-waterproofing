---
const steps = [
  {
    number: '01',
    title: 'Free Inspection',
    description: 'Certified experts assess your property to identify water issues and recommend solutions.',
    duration: 'Same Day Booking',
    highlight: 'No Obligation',
  },
  {
    number: '02',
    title: 'Detailed Quote',
    description: 'Comprehensive quote with multiple options, financing, and applicable government rebates.',
    duration: 'Within 24 Hours',
    highlight: 'Transparent Pricing',
  },
  {
    number: '03',
    title: 'Professional Installation',
    description: 'Licensed team completes work with minimal disruption. Full cleanup included.',
    duration: '1-5 Days Typical',
    highlight: 'Fully Insured',
  },
  {
    number: '04',
    title: 'Warranty & Support',
    description: '25-year transferable warranty with ongoing maintenance and support.',
    duration: 'Lifetime Support',
    highlight: '25 Year Warranty',
  },
];
---

<section class="section-padding bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <p class="section-label-pill mb-4">How It Works</p>
      <h2 class="text-headline text-slate-900">Our Process</h2>
      <p class="mt-4 text-lg text-slate-600">From inspection to installation, we handle every step professionally</p>
    </div>

    <!-- Steps Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
      {steps.map((step, i) => (
        <div class="relative text-center reveal">
          {/* Connector line */}
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-8 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-gradient-to-r from-cyan-200 to-cyan-100"></div>
          )}

          {/* Step number */}
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-cyan-50 text-cyan-600 text-2xl font-bold mb-4 relative z-10">
            {step.number}
          </div>

          <h3 class="text-lg font-semibold text-slate-900 mb-2">{step.title}</h3>
          <p class="text-sm text-slate-600 leading-relaxed mb-3">{step.description}</p>

          <div class="flex flex-col items-center gap-1">
            <span class="inline-flex items-center rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-700">
              {step.highlight}
            </span>
            <span class="text-xs text-slate-400">{step.duration}</span>
          </div>
        </div>
      ))}
    </div>

    <!-- Process Guarantee -->
    <div class="mt-16 rounded-2xl bg-navy-900 p-8 lg:p-10 text-center max-w-4xl mx-auto">
      <h3 class="text-xl font-bold text-white mb-3">Our Process Guarantee</h3>
      <p class="text-slate-300 leading-relaxed">
        Every project follows our proven 4-step process with complete transparency, professional execution, and our industry-leading 25-year warranty.
      </p>
    </div>
  </div>
</section>
