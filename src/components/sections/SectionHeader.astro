---
export interface Props {
  label?: string;
  title: string;
  description?: string;
  centered?: boolean;
  dark?: boolean;
}

const {
  label,
  title,
  description,
  centered = true,
  dark = false,
} = Astro.props;
---

<div class:list={[centered && "text-center", "max-w-3xl", centered && "mx-auto", "mb-12 lg:mb-16"]}>
  {label && (
    <p class:list={[
      "section-label-pill mb-4",
      dark && "border-cyan-400/20 bg-cyan-400/10 text-cyan-400"
    ]}>
      {label}
    </p>
  )}
  <h2 class:list={[
    "text-headline",
    dark ? "text-white" : "text-slate-900"
  ]}>
    {title}
  </h2>
  {description && (
    <p class:list={[
      "mt-4 text-lg leading-relaxed",
      dark ? "text-slate-300" : "text-slate-600"
    ]}>
      {description}
    </p>
  )}
</div>
