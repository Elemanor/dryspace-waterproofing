---
export interface Props {
  title?: string;
  tiers?: Array<{
    name: string;
    price: string;
    description: string;
    features: string[];
    popular?: boolean;
  }>;
}

const {
  title = "Transparent Pricing",
  tiers = [],
} = Astro.props;
---

<section class="section-padding bg-slate-50">
  <div class="container mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <p class="section-label-pill mb-4">Pricing</p>
      <h2 class="text-headline text-slate-900">{title}</h2>
      <p class="mt-4 text-lg text-slate-600">All prices include materials, labour, and our 25-year transferable warranty.</p>
    </div>

    <div class:list={[
      "grid gap-6 max-w-5xl mx-auto",
      tiers.length === 1 && "grid-cols-1 max-w-md",
      tiers.length === 2 && "grid-cols-1 md:grid-cols-2 max-w-3xl",
      tiers.length >= 3 && "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
    ]}>
      {tiers.map((tier) => (
        <div class:list={[
          "relative rounded-2xl p-8 transition-all duration-300",
          tier.popular
            ? "bg-white border-2 border-cyan-500 shadow-float scale-[1.02]"
            : "bg-white border border-slate-200 shadow-card hover:shadow-card-hover hover:-translate-y-1"
        ]}>
          {tier.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-cyan-500 px-4 py-1 text-xs font-semibold text-white">
              Most Popular
            </span>
          )}
          <h3 class="text-xl font-bold text-slate-900 mb-2">{tier.name}</h3>
          <p class="text-3xl font-bold text-cyan-600 mb-2">{tier.price}</p>
          <p class="text-sm text-slate-500 mb-6">{tier.description}</p>
          <ul class="space-y-3 mb-8">
            {tier.features.map((feature) => (
              <li class="flex items-start gap-2 text-sm text-slate-600">
                <svg class="w-4 h-4 text-cyan-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
          <a href="/free-inspection" class:list={[
            "block text-center rounded-lg py-3 font-semibold transition-all",
            tier.popular
              ? "bg-cyan-500 text-white hover:bg-cyan-600"
              : "bg-slate-100 text-slate-700 hover:bg-slate-200"
          ]}>
            Get Quote
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
