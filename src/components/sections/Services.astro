---
const services = [
  {
    title: 'Exterior Waterproofing',
    description: 'Complete exterior foundation protection with professional membrane installation and drainage systems.',
    image: '/images/exterior-waterproofing-membrane.webp',
    features: [
      'Full excavation to foundation',
      'Waterproof membrane application',
      'French drain installation',
      '25-year transferable warranty'
    ],
    price: 'Starting at $10,000',
    timeframe: '5-7 days',
    href: '/services/exterior-waterproofing',
    popular: false,
  },
  {
    title: 'Interior Waterproofing',
    description: 'Interior drainage systems and moisture barriers to keep your basement dry without exterior excavation.',
    image: '/images/interior-waterproofing.webp',
    features: [
      'Interior weeping tile system',
      'Vapor barrier installation',
      'Sump pump integration',
      'Lifetime warranty available'
    ],
    price: 'Starting at $3,000',
    timeframe: '2-3 days',
    href: '/services/interior-waterproofing',
    popular: true,
  },
  {
    title: 'Foundation Repair',
    description: 'Professional repair of cracks, settling, and structural foundation issues using industry-leading techniques.',
    image: '/images/structural foundation crack.webp',
    features: [
      'Crack injection repair',
      'Wall reinforcement',
      'Structural stabilization',
      'Foundation underpinning'
    ],
    price: 'Starting at $500',
    timeframe: '1-3 days',
    href: '/services/foundation-repair',
    popular: false,
  },
  {
    title: 'Sump Pump Installation',
    description: 'Professional sump pump installation with battery backup systems for continuous flood protection.',
    image: '/images/sump-pump.webp',
    features: [
      'Primary pump installation',
      'Battery backup system',
      'Alarm monitoring',
      'Annual maintenance plans'
    ],
    price: 'Starting at $2,000',
    timeframe: '1 day',
    href: '/services/sump-pump-installation',
    popular: false,
  },
  {
    title: 'French Drain Systems',
    description: 'Efficient water diversion with professionally engineered and installed drainage solutions.',
    image: '/images/drains.webp',
    features: [
      'Perimeter drain installation',
      'Proper grading & slope',
      'Gravel & fabric layers',
      'Discharge system setup'
    ],
    price: 'Starting at $5,000',
    timeframe: '3-5 days',
    href: '/services/french-drain-systems',
    popular: false,
  },
  {
    title: 'Emergency Water Removal',
    description: '24/7 emergency response for basement flooding with immediate water extraction and damage mitigation.',
    image: '/images/waterp on the floor.webp',
    features: [
      '24/7 emergency response',
      'Industrial water extraction',
      'Structural drying',
      'Insurance claim assistance'
    ],
    price: 'Call for emergency rates',
    timeframe: '2-hour response',
    href: '/services/emergency-waterproofing',
    popular: false,
  },
];
---

<section class="section-padding bg-slate-50">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center max-w-3xl mx-auto mb-12 lg:mb-16">
      <p class="section-label-pill mb-4">Our Services</p>
      <h2 class="text-headline text-slate-900">Waterproofing Solutions</h2>
      <p class="mt-4 text-lg text-slate-600">
        Professional waterproofing and foundation repair services backed by industry-leading warranties and certified technicians.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-6xl mx-auto">
      {services.map((service) => (
        <a
          href={service.href}
          class="group relative rounded-xl border border-slate-200/60 bg-white shadow-card overflow-hidden transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1"
        >
          {service.popular && (
            <span class="absolute top-3 right-3 z-10 rounded-full bg-cyan-500 px-3 py-0.5 text-[11px] font-semibold text-white">
              Popular
            </span>
          )}

          <!-- Service Image -->
          <div class="relative h-44 bg-slate-100 overflow-hidden">
            <img
              src={service.image}
              alt={service.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-navy-900/70 to-transparent p-3">
              <span class="inline-flex items-center gap-1 text-xs text-white font-medium">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" /></svg>
                {service.timeframe}
              </span>
            </div>
          </div>

          <!-- Content -->
          <div class="p-5">
            <h3 class="text-base font-semibold text-slate-900 mb-1.5 group-hover:text-cyan-600 transition-colors">
              {service.title}
            </h3>
            <p class="text-xs text-slate-500 mb-3 leading-relaxed">{service.description}</p>

            <!-- Features -->
            <ul class="space-y-1.5 mb-4">
              {service.features.map((feature) => (
                <li class="flex items-start gap-1.5 text-xs text-slate-600">
                  <svg class="w-3.5 h-3.5 text-cyan-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <!-- Price -->
            <p class="text-sm font-bold text-cyan-600 mb-3">{service.price}</p>

            <!-- Learn more -->
            <span class="flex items-center gap-1 text-xs font-medium text-slate-400 group-hover:text-cyan-500 transition-colors">
              Learn more
              <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Bottom CTA Section -->
    <div class="mt-16 rounded-2xl bg-navy-900 p-8 lg:p-12 max-w-5xl mx-auto">
      <div class="text-center">
        <h3 class="text-xl font-bold text-white mb-3">Not Sure Which Service You Need?</h3>
        <p class="text-slate-300 mb-8">Our certified inspectors will assess your situation and recommend the best solution for your home.</p>

        <!-- Service Guarantees -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
          <div class="text-center">
            <p class="text-2xl font-bold text-cyan-400 mb-0.5">25yr</p>
            <p class="text-xs text-slate-400 uppercase tracking-wider">Warranty</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-cyan-400 mb-0.5">24/7</p>
            <p class="text-xs text-slate-400 uppercase tracking-wider">Emergency</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-cyan-400 mb-0.5">100%</p>
            <p class="text-xs text-slate-400 uppercase tracking-wider">Licensed</p>
          </div>
          <div class="text-center">
            <p class="text-2xl font-bold text-cyan-400 mb-0.5">Free</p>
            <p class="text-xs text-slate-400 uppercase tracking-wider">Inspection</p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/free-inspection" class="btn-primary !px-8 !py-4 !text-lg">
            Schedule Free Inspection
          </a>
          <a href="tel:437-545-0067" class="btn-ghost border-2 border-white/20 !px-8 !py-4 !text-lg hover:!bg-white/10">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            Call: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
