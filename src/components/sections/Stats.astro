---
const stats = [
  {
    value: '25',
    label: 'Years in Business',
    description: 'Established 1999',
  },
  {
    value: '15,000+',
    label: 'Projects Completed',
    description: 'Greater Toronto Area',
  },
  {
    value: '100%',
    label: 'Licensed & Insured',
    description: 'WSIB Coverage',
  },
  {
    value: '24/7',
    label: 'Emergency Response',
    description: 'Same Day Service',
  },
];

const certifications = [
  'BBB Accredited A+',
  'Licensed by City of Toronto',
  '$5M Liability Insurance',
  'WSIB Cleared',
  'HomeStars Verified',
  'Google 4.9 Rating',
];
---

<section class="bg-navy-900">
  <!-- Stats Bar -->
  <div class="py-10">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {stats.map((stat, index) => (
          <div class="text-center relative">
            {index > 0 && (
              <div class="hidden md:block absolute left-0 top-1/2 -translate-y-1/2 h-12 w-px bg-white/10 -ml-4"></div>
            )}
            <div class="text-3xl font-bold text-white mb-1">{stat.value}</div>
            <div class="text-xs font-semibold text-cyan-400 uppercase tracking-wider mb-0.5">{stat.label}</div>
            <div class="text-xs text-slate-400">{stat.description}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Certifications Bar -->
  <div class="border-t border-white/10 py-6">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
        {certifications.map((cert, index) => (
          <div class="flex items-center gap-2">
            <svg class="h-3.5 w-3.5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-slate-300 text-xs font-medium">{cert}</span>
            {index < certifications.length - 1 && (
              <span class="text-white/20 hidden md:inline ml-4">|</span>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
