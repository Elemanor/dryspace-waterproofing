---
import { ViewTransitions } from 'astro:transitions';
import Favicons from '../components/Favicons.astro';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;
}

const {
  title = 'DrySpace Waterproofing — Basement Waterproofing Toronto | Foundation Repair',
  description = 'Toronto\'s top-rated basement waterproofing company. Interior & exterior waterproofing, foundation repair, sump pumps, underpinning. 25-year warranty, 24/7 emergency, free inspections. Call 437-545-0067.',
  keywords = 'basement waterproofing toronto, basement waterproofing, waterproofing toronto, foundation repair toronto, sump pump installation, interior waterproofing, exterior waterproofing, underpinning toronto',
  image = '/images/dryspace-og-image.webp',
  canonical,
  noindex = false,
  nofollow = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const siteUrl = 'https://dryspacewaterproofing.ca';
const canonicalURL = canonical || `${siteUrl}${currentPath}`;
const ogImageUrl = `${siteUrl}${image}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0f172a" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    {(noindex || nofollow) && (
      <meta name="robots" content={`${noindex ? 'noindex' : 'index'},${nofollow ? 'nofollow' : 'follow'}`} />
    )}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Dryspace Waterproofing" />
    <meta property="og:locale" content="en_CA" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Geo Meta Tags (Local SEO) -->
    <meta name="geo.region" content="CA-ON" />
    <meta name="geo.placename" content="Toronto" />
    <meta name="geo.position" content="43.653226;-79.3831843" />
    <meta name="ICBM" content="43.653226, -79.3831843" />

    <!-- Preconnect for fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Favicons -->
    <Favicons />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- WebSite Schema with SiteLinks Search -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "DrySpace Waterproofing",
      "url": "https://dryspacewaterproofing.ca",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "https://dryspacewaterproofing.ca/services/{search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Schema.org Structured Data — Enhanced Local SEO -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
      "@id": "https://dryspacewaterproofing.ca/#organization",
      "name": "DrySpace Waterproofing",
      "alternateName": "DrySpace Waterproofing & Foundation Repair",
      "description": "Professional basement waterproofing and foundation repair company serving Toronto and the Greater Toronto Area. Interior & exterior waterproofing, sump pump installation, underpinning, drainage solutions. 25-year warranty, 24/7 emergency service.",
      "image": ogImageUrl,
      "logo": `${siteUrl}/images/dryspace-logo.webp`,
      "url": siteUrl,
      "telephone": "+1-437-545-0067",
      "email": "info@dryspacewaterproofing.ca",
      "priceRange": "$$$",
      "currenciesAccepted": "CAD",
      "paymentAccepted": "Cash, Credit Card, Debit Card, Bank Transfer, Financing",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "260 Wellesley Street East",
        "addressLocality": "Toronto",
        "addressRegion": "ON",
        "postalCode": "M4X 1G6",
        "addressCountry": "CA"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 43.653226,
        "longitude": -79.3831843
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "07:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Sunday",
          "opens": "09:00",
          "closes": "17:00"
        }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "bestRating": "5",
        "ratingCount": "487",
        "reviewCount": "487"
      },
      "sameAs": [
        "https://www.facebook.com/dryspaceca",
        "https://www.instagram.com/dryspaceca",
        "https://www.linkedin.com/company/dryspace",
        "https://www.homestars.com/companies/dryspace-waterproofing",
        "https://www.bbb.org/ca/on/toronto/profile/waterproofing/dryspace-waterproofing"
      ],
      "areaServed": [
        { "@type": "City", "name": "Toronto", "containedInPlace": { "@type": "AdministrativeArea", "name": "Ontario" } },
        { "@type": "City", "name": "Mississauga" },
        { "@type": "City", "name": "Brampton" },
        { "@type": "City", "name": "Vaughan" },
        { "@type": "City", "name": "Markham" },
        { "@type": "City", "name": "Richmond Hill" },
        { "@type": "City", "name": "Oakville" },
        { "@type": "City", "name": "Burlington" },
        { "@type": "City", "name": "Hamilton" },
        { "@type": "City", "name": "Scarborough" },
        { "@type": "City", "name": "North York" },
        { "@type": "City", "name": "Etobicoke" },
        { "@type": "City", "name": "Ajax" },
        { "@type": "City", "name": "Pickering" },
        { "@type": "City", "name": "Whitby" },
        { "@type": "City", "name": "Oshawa" }
      ],
      "knowsAbout": [
        "Basement Waterproofing",
        "Foundation Repair",
        "Sump Pump Installation",
        "Interior Waterproofing",
        "Exterior Waterproofing",
        "Underpinning",
        "French Drain Installation",
        "Backwater Valve Installation",
        "Crawl Space Waterproofing",
        "Foundation Crack Repair"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Basement Waterproofing & Foundation Repair Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Exterior Basement Waterproofing",
              "description": "Complete exterior foundation waterproofing with membrane, drainage, and backfill",
              "url": `${siteUrl}/services/exterior-waterproofing`,
              "areaServed": "Toronto"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Interior Basement Waterproofing",
              "description": "Interior drainage systems, weeping tile, and moisture control for Toronto basements",
              "url": `${siteUrl}/services/interior-waterproofing`,
              "areaServed": "Toronto"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Foundation Crack Repair",
              "description": "Fix cracks, bowing walls, and structural foundation issues",
              "url": `${siteUrl}/services/foundation-repair`,
              "areaServed": "Toronto"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Sump Pump Installation",
              "description": "Professional sump pump installation with battery backup and alarm systems",
              "url": `${siteUrl}/services/sump-pump-installation`,
              "areaServed": "Toronto"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Basement Underpinning",
              "description": "Foundation lowering and structural reinforcement for basement conversions",
              "url": `${siteUrl}/services/underpinning`,
              "areaServed": "Toronto"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Backwater Valve Installation",
              "description": "Prevent sewer backup with professional backwater valve installation",
              "url": `${siteUrl}/services/backwater-valve-installation`,
              "areaServed": "Toronto"
            }
          }
        ]
      }
    })} />
  </head>
  <body class="font-sans antialiased">
    <slot />
    <GoogleAnalytics />

    <!-- Scroll Reveal Observer -->
    <script>
      if (typeof IntersectionObserver !== 'undefined') {
        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));

        // Re-observe after Astro view transitions
        document.addEventListener('astro:page-load', () => {
          document.querySelectorAll('.reveal:not(.revealed)').forEach((el) => observer.observe(el));
        });
      }
    </script>
  </body>
</html>
