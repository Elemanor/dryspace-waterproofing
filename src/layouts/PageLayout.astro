---
import Layout from './Layout.astro';
import ModernHeader from '../components/widgets/ModernHeader.astro';
import Footer from '../components/Footer.astro';
import AnnouncementBar from '../components/AnnouncementBar.astro';

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showAnnouncement?: boolean;
}

const {
  title,
  description,
  keywords,
  image,
  canonical,
  noindex,
  nofollow,
  showAnnouncement = true,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  canonical={canonical}
  noindex={noindex}
  nofollow={nofollow}
>
  <!-- Skip to content for accessibility -->
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:rounded-lg focus:bg-cyan-500 focus:px-4 focus:py-2 focus:text-white focus:shadow-lg">
    Skip to main content
  </a>

  {showAnnouncement && <AnnouncementBar />}
  <ModernHeader />

  <main id="main" class="flex-grow">
    <slot />
  </main>

  <Footer />

  <!-- Sticky Mobile CTA Bar -->
  <div class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-navy-900/95 backdrop-blur-lg border-t border-white/10 px-4 py-3 safe-area-pb">
    <div class="flex gap-2">
      <a
        href="tel:437-545-0067"
        class="flex-1 flex items-center justify-center gap-2 rounded-lg bg-amber-500 py-3 font-semibold text-navy-900 text-sm transition-colors hover:bg-amber-400"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
        </svg>
        Emergency Call
      </a>
      <a
        href="/free-inspection"
        class="flex-1 flex items-center justify-center gap-2 rounded-lg border-2 border-cyan-500 py-3 font-semibold text-cyan-400 text-sm transition-colors hover:bg-cyan-500 hover:text-white"
      >
        Free Inspection
      </a>
    </div>
  </div>
</Layout>

<style>
  main {
    min-height: calc(100vh - 4rem);
    padding-bottom: 5rem; /* Space for mobile sticky CTA */
  }

  @media (min-width: 768px) {
    main {
      padding-bottom: 0;
    }
  }

  /* Safe area for iPhone notch */
  .safe-area-pb {
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
  }
</style>
