---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout 
  title="404 - Page Not Found | Dryspace Waterproofing" 
  description="The page you're looking for doesn't exist. Find our waterproofing services or contact us for help."
  noindex={true}
>
  <section class="error-404">
    <div class="container">
      <div class="error-content">
        <div class="error-icon">
          <i class="fa-solid fa-house-flood-water"></i>
          <span class="water-drops"></span>
        </div>
        
        <h1 class="text-5xl font-bold text-slate-900 uppercase">404 - PAGE NOT FOUND</h1>
        <p class="error-message">Looks like this page got washed away!</p>
        <p class="error-description">
          The page you're looking for doesn't exist or has been moved. 
          Don't worry, we can still help protect your basement from water damage.
        </p>
        
        <div class="error-actions">
          <a href="/" class="btn-primary">
            <i class="fa-solid fa-home"></i>
            Return Home
          </a>
          <a href="tel:4375450067" class="btn-emergency">
            <i class="fa-solid fa-phone"></i>
            Call for Help: (437) 545-0067
          </a>
        </div>
        
        <div class="helpful-links">
          <h2 class="text-4xl font-bold text-slate-900 uppercase">POPULAR PAGES</h2>
          <div class="links-grid">
            <a href="/services/exterior-waterproofing">
              <i class="fa-solid fa-shield-halved"></i>
              Exterior Waterproofing
            </a>
            <a href="/services/interior-waterproofing">
              <i class="fa-solid fa-house-flood-water"></i>
              Interior Waterproofing
            </a>
            <a href="/services/foundation-repair">
              <i class="fa-solid fa-hammer"></i>
              Foundation Repair
            </a>
            <a href="/services/emergency-waterproofing">
              <i class="fa-solid fa-triangle-exclamation"></i>
              Emergency Service
            </a>
            <a href="/free-inspection">
              <i class="fa-solid fa-magnifying-glass"></i>
              Free Inspection
            </a>
            <a href="/government-rebates">
              <i class="fa-solid fa-dollar-sign"></i>
              $3,400 Rebate
            </a>
          </div>
        </div>
        
        <div class="search-section">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">SEARCH OUR SITE</h3>
          <form action="/search" method="get" class="search-form">
            <input 
              type="search" 
              name="q" 
              placeholder="Search for waterproofing services..."
              class="search-input"
            />
            <button type="submit" class="search-btn">
              <i class="fa-solid fa-search"></i>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  
</PageLayout>