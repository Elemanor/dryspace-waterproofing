---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import CTABand from '../components/sections/CTABand.astro';
import TrustBar from '../components/sections/TrustBar.astro';

const whatSetsUsApart = [
  {
    title: 'Hands-On Expertise',
    description: 'Our crews are on-site every day solving real waterproofing problems — no subcontractors, no shortcuts.',
    image: '/images/exterior-waterproofing-toronto in process (1).webp',
    alt: 'Exterior waterproofing excavation in progress'
  },
  {
    title: 'Premium Materials',
    description: 'We use only proven, manufacturer-warranted membranes and drainage systems built to outlast your home.',
    image: '/images/exterior-waterproofing-membrane.webp',
    alt: 'Professional waterproofing membrane installation'
  },
  {
    title: 'Guaranteed Results',
    description: 'Every project is backed by our 25-year transferable warranty — your investment is protected.',
    image: '/images/dryspace_exterior_waterproofing_warranty.webp',
    alt: 'Completed waterproofing project with warranty'
  }
];

const milestones = [
  { year: '1999', event: 'Dryspace Waterproofing founded with just 3 employees' },
  { year: '2005', event: 'Expanded services to cover all of GTA' },
  { year: '2010', event: 'Introduced lifetime transferable warranty program' },
  { year: '2015', event: 'Reached 10,000 satisfied customers milestone' },
  { year: '2020', event: 'Launched 24/7 emergency response service' },
  { year: '2024', event: 'Celebrating 25 years of protecting Toronto homes' }
];

const values = [
  {
    title: 'Integrity First',
    description: 'We provide honest assessments and fair pricing. No upselling, no hidden fees.',
    icon: 'shield'
  },
  {
    title: 'Quality Craftsmanship',
    description: 'Every project is completed to the highest standards using premium materials.',
    icon: 'award'
  },
  {
    title: 'Customer Focus',
    description: 'Your satisfaction drives everything we do, from first call to lifetime warranty.',
    icon: 'heart'
  },
  {
    title: 'Innovation',
    description: 'We invest in the latest technology and techniques to deliver superior results.',
    icon: 'lightbulb'
  }
];

const certifications = [
  'Better Business Bureau A+ Rating',
  'HomeStars Verified Professional',
  'WSIB Coverage & Compliance',
  'City of Toronto Licensed Contractor',
  'Ontario Building Code Certified',
  'Canadian Construction Association Member',
  'Waterproofing Contractors Association',
  'Environmental Protection Certified'
];
---

<PageLayout title="About Dryspace Waterproofing | Toronto's Trusted Basement Experts Since 1999">
  <!-- Hero Section -->
  <section class="bg-gradient-hero section-padding relative overflow-hidden reveal">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 25% 50%, rgba(6,182,212,0.5) 0%, transparent 50%), radial-gradient(circle at 75% 50%, rgba(245,158,11,0.3) 0%, transparent 50%)"></div>
    </div>

    <div class="relative container mx-auto px-4 text-center">
      <h1 class="text-display text-white mb-6">
        Protecting Toronto Homes
        <span class="block text-amber-500 mt-2">Since 1999</span>
      </h1>
      <p class="text-xl text-slate-200 max-w-3xl mx-auto mb-12 leading-relaxed">
        For 25 years, Dryspace Waterproofing has been the trusted choice for Toronto homeowners.
        We're not just contractors – we're your neighbors, committed to keeping your family safe and your home dry.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-3xl mx-auto">
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-lg p-6">
          <div class="text-5xl font-bold text-amber-500 mb-2">25+</div>
          <div class="text-sm uppercase tracking-wide text-slate-300">Years of Service</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-lg p-6">
          <div class="text-5xl font-bold text-cyan-400 mb-2">15,000+</div>
          <div class="text-sm uppercase tracking-wide text-slate-300">Projects Completed</div>
        </div>
        <div class="bg-white/10 backdrop-blur-sm border border-white/20 rounded-lg p-6">
          <div class="text-5xl font-bold text-amber-500 mb-2">100%</div>
          <div class="text-sm uppercase tracking-wide text-slate-300">Satisfaction Rate</div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Our Story Section -->
  <section class="section-padding bg-white reveal">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-headline text-slate-900 mb-6">Our Story</h2>
          <p class="text-lg font-semibold text-slate-900 mb-6">
            Dryspace Waterproofing began with a simple mission: provide honest, reliable waterproofing services
            that Toronto homeowners could trust.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            Founded in 1999 by Michael Spader, a structural engineer who saw too many families dealing with
            preventable water damage, our company was built on the principle that every home deserves proper protection.
          </p>
          <p class="text-slate-600 leading-relaxed mb-4">
            What started as a small team of three dedicated professionals has grown into Toronto's most trusted
            waterproofing company, with over 50 certified technicians and a fleet of 20 service vehicles ready
            to respond 24/7.
          </p>
          <p class="text-slate-600 leading-relaxed mb-8">
            Today, we're proud to be a second-generation family business, with Michael's children now helping
            to lead the company into its next chapter of growth and innovation.
          </p>

          <div class="flex items-start gap-3 mb-8 bg-slate-50 border border-slate-200 rounded-lg p-4">
            <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
            <div>
              <p class="font-semibold text-slate-900">Our Office</p>
              <p class="text-slate-600 text-sm">260 Wellesley Street East, Toronto, ON M4X 1G6</p>
              <p class="text-slate-500 text-xs mt-1">Serving homeowners across the Greater Toronto Area</p>
            </div>
          </div>

          <a href="/contact" class="btn-primary">Get Your Free Inspection</a>
        </div>
        <div class="relative">
          <div class="absolute inset-0 bg-cyan-500/10 rounded-lg transform rotate-3"></div>
          <img
            src="/assets/waterproofing/dryspace_excellence.webp"
            alt="Dryspace excellence award and certification"
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            class="relative rounded-lg shadow-float border border-slate-200"
          />
          <div class="mt-4 text-center text-sm text-slate-500 italic">
            Recognized for excellence in waterproofing services
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission & Values -->
  <section class="section-padding bg-slate-50 reveal">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Our Mission & Values"
        title="Driven by Integrity, Committed to Excellence"
        description="To be Toronto's most trusted partner in basement waterproofing by delivering exceptional service, lasting solutions, and peace of mind to every customer."
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {values.map((value) => (
          <div class="card-interactive bg-white p-8 text-center">
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-cyan-500/10 flex items-center justify-center">
              {value.icon === 'shield' && (
                <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {value.icon === 'award' && (
                <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
                </svg>
              )}
              {value.icon === 'heart' && (
                <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                </svg>
              )}
              {value.icon === 'lightbulb' && (
                <svg class="w-8 h-8 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              )}
            </div>
            <h3 class="text-xl font-bold text-slate-900 uppercase mb-3">{value.title}</h3>
            <p class="text-slate-600 leading-relaxed">{value.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="section-padding bg-white reveal">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 class="text-headline text-slate-900 text-center mb-16">Our Journey</h2>

      <div class="relative">
        <!-- Vertical line -->
        <div class="absolute left-1/2 transform -translate-x-1/2 h-full w-0.5 bg-gradient-to-b from-cyan-500 to-amber-500"></div>

        <div class="space-y-12">
          {milestones.map((milestone, index) => (
            <div class={`flex items-center ${index % 2 === 0 ? 'flex-row' : 'flex-row-reverse'} gap-8`}>
              <div class={`flex-1 ${index % 2 === 0 ? 'text-right' : 'text-left'}`}>
                <div class="inline-block bg-slate-50 border-2 border-slate-200 rounded-lg p-6 shadow-sm hover:shadow-float-hover hover:border-cyan-500 transition-all duration-300">
                  <div class="text-2xl font-bold text-cyan-500 mb-2">{milestone.year}</div>
                  <p class="text-slate-700 leading-relaxed">{milestone.event}</p>
                </div>
              </div>

              <div class="relative z-10">
                <div class="w-4 h-4 rounded-full bg-cyan-500 border-4 border-white shadow-lg"></div>
              </div>

              <div class="flex-1"></div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What Sets Us Apart -->
  <section class="section-padding bg-slate-50 reveal">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="What Sets Us Apart"
        title="Built on Real Work, Not Marketing"
        description="25 years of hands-on waterproofing experience across the Greater Toronto Area"
      />

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        {whatSetsUsApart.map((card) => (
          <div class="card-interactive bg-white overflow-hidden">
            <div class="h-64 bg-slate-200 overflow-hidden">
              <img
                src={card.image}
                alt={card.alt}
                width="800"
                height="600"
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
              />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-bold text-slate-900 uppercase mb-3">{card.title}</h3>
              <p class="text-slate-600 leading-relaxed">{card.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center">
        <p class="text-slate-600 mb-6">Our certified technicians are ready to help protect your home</p>
        <a href="/contact" class="btn-secondary">Get Your Free Inspection</a>
      </div>
    </div>
  </section>

  <!-- Certifications Section -->
  <section class="section-padding bg-white reveal">
    <div class="container mx-auto px-4">
      <h2 class="text-headline text-slate-900 text-center mb-12">Certifications & Memberships</h2>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4">
        {certifications.map((cert) => (
          <div class="flex items-center gap-3 bg-slate-50 border-2 border-slate-200 rounded-lg p-4 hover:border-cyan-500 hover:bg-cyan-50 transition-all duration-300">
            <svg class="w-6 h-6 text-cyan-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-medium text-slate-700">{cert}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Community Section -->
  <section class="section-padding bg-slate-50 reveal">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-headline text-slate-900 mb-6">Giving Back to Toronto</h2>
          <p class="text-lg font-semibold text-slate-900 mb-8">
            We believe in supporting the community that has supported us for 25 years.
          </p>

          <div class="space-y-6">
            <div class="border-l-4 border-cyan-500 pl-6 py-2">
              <h3 class="text-xl font-bold text-slate-900 uppercase mb-2">Habitat for Humanity Toronto</h3>
              <p class="text-slate-600">Providing free waterproofing services for affordable housing projects</p>
            </div>
            <div class="border-l-4 border-cyan-500 pl-6 py-2">
              <h3 class="text-xl font-bold text-slate-900 uppercase mb-2">Senior Citizen Discount Program</h3>
              <p class="text-slate-600">Special rates for Toronto seniors on fixed incomes</p>
            </div>
            <div class="border-l-4 border-cyan-500 pl-6 py-2">
              <h3 class="text-xl font-bold text-slate-900 uppercase mb-2">Emergency Response Fund</h3>
              <p class="text-slate-600">Free emergency pumping for families facing financial hardship</p>
            </div>
            <div class="border-l-4 border-cyan-500 pl-6 py-2">
              <h3 class="text-xl font-bold text-slate-900 uppercase mb-2">Youth Apprenticeship Program</h3>
              <p class="text-slate-600">Training the next generation of waterproofing professionals</p>
            </div>
          </div>
        </div>

        <div class="relative">
          <div class="absolute inset-0 bg-amber-500/10 rounded-lg transform -rotate-3"></div>
          <img
            src="/images/exterior-waterproofing-membrane.webp"
            alt="Community involvement"
            width="800"
            height="600"
            loading="lazy"
            decoding="async"
            class="relative rounded-lg shadow-float border border-slate-200"
          />
          <div class="mt-4 text-center text-sm text-slate-500 italic">
            Dryspace team volunteering at Habitat for Humanity build
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABand
    title="Ready to Experience the Dryspace Difference?"
    subtitle="Join the Toronto homeowners who trust us to protect their homes"
    primaryCTA={{ text: "Schedule Free Inspection", href: "/contact" }}
    secondaryCTA={{ text: "Explore Our Services", href: "/services" }}
  />
</PageLayout>
