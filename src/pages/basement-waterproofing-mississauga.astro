---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>
  <!-- Structured Data -->
  <StructuredData 
    type="Service" 
    data={{
      name: "Basement Waterproofing Mississauga",
      description: "Professional foundation waterproofing services in Mississauga. 24/7 emergency response, 25-year warranty, government rebates available.",
      areaServed: { name: "Mississauga", geo: { latitude: 43.5890, longitude: -79.6441 }}
    }}
  />
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Locations", url: "/service-areas" },
        { name: "Mississauga", url: "/locations/mississauga" },
        { name: "Foundation Protection Services" }
      ]}
    />
  </div>

  <!-- Hero Section -->
  <Hero 
    title="BASEMENT WATERPROOFING MISSISSAUGA"
    subtitle="Mississauga's trusted basement waterproofing experts since 2009. Protecting homes from Credit Valley clay soil and lake moisture. 24/7 emergency response under 45 minutes."
