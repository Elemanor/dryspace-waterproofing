  { name: "Streetsville", projects: "92", commonIssues: "Credit River flooding, heritage homes" },
  { name: "Meadowvale", projects: "118", commonIssues: "Clay soil expansion, 1970s foundations" },
  { name: "Cooksville", projects: "76", commonIssues: "High water table, mixed-use buildings" },
  { name: "Clarkson", projects: "65", commonIssues: "Lake proximity, sandy soil" },
  { name: "Erin Mills", projects: "84", commonIssues: "New development settling" },
  { name: "Lakeview", projects: "58", commonIssues: "Waterfront homes, erosion" },
  { name: "Malton", projects: "45", commonIssues: "Airport area drainage" }
];

const faqs = [
  {
    question: "How much does basement waterproofing cost in Mississauga?",
    answer: "Basement waterproofing in Mississauga typically costs $150-300 per linear foot, or $15,000-30,000 for an average home. Factors include Mississauga's clay soil conditions, proximity to Credit River or Lake Ontario, and specific neighborhood requirements. Government rebates up to $3,400 are available for Mississauga residents."
  },
  {
    question: "Do I need a permit for basement waterproofing in Mississauga?",
    answer: "Yes, most exterior basement waterproofing projects in Mississauga require a building permit from the City of Mississauga Building Department due to excavation exceeding 4 feet. DrySpace handles all City of Mississauga permit applications, drawings, and inspections as part of our service, ensuring compliance with municipal bylaws."
  },
  {
    question: "What causes basement flooding in Mississauga?",
    answer: "Mississauga's unique challenges include Credit Valley clay soil (30-70% clay content), rapid suburban development on former farmland, variable water table (1-4m depth), and proximity to Lake Ontario and Credit River. Spring thaw and summer storms frequently overwhelm older drainage systems in Mississauga neighborhoods."
  },
  {
    question: "How quickly can you respond to Mississauga emergencies?",
    answer: "We guarantee response times under 45 minutes to all Mississauga neighborhoods including Port Credit, Streetsville, Meadowvale, and Cooksville. Our emergency teams are stationed strategically across Mississauga with 24/7 availability, 365 days a year."
  },
  {
    question: "Are there rebates for Mississauga homeowners?",
    answer: "Yes! Mississauga residents can access up to $3,400 through the Basement Flooding Protection Subsidy Program. Additional rebates may be available through Region of Peel programs. We handle all paperwork and applications for you."
  },
  {
    question: "What waterproofing method works best for Mississauga homes?",
    answer: "Due to Mississauga's clay soil and variable water table, we typically recommend exterior waterproofing with proper drainage for homes built before 2000. Newer developments may benefit from interior systems. Each home requires a custom assessment based on location and soil conditions."
  },
  {
    question: "How long does waterproofing take in Mississauga?",
    answer: "Most Mississauga homes require 3-5 days for complete exterior waterproofing, weather permitting. Interior systems can be installed in 1-2 days. We work year-round and adjust our methods for Mississauga's climate conditions."
  },
  {
    question: "Do you service all areas of Mississauga?",
    answer: "Yes, we service all Mississauga neighborhoods from Port Credit to Malton, including Streetsville, Meadowvale, Cooksville, Clarkson, Erin Mills, Lakeview, Churchill Meadows, Lisgar, and Central Erin Mills. Same-day service available."
  },
  {
    question: "What warranty do you offer in Mississauga?",
    answer: "We provide a 25-year transferable warranty on all waterproofing work in Mississauga. This warranty is registered with your property and transfers to new owners, protecting your home's value in Mississauga's competitive real estate market."
  },
  {
    question: "Can you protect finished basements in Mississauga?",
    answer: "Yes, we specialize in protecting finished basements with minimal disruption. Our interior drainage systems can often be installed without removing all finishes. We work with many Mississauga renovation contractors to coordinate repairs."
