const pageTitle = "Basement Waterproofing Mississauga | $3,400 Rebate | 25-Year Warranty";
const pageDescription = "Professional basement waterproofing in Mississauga. Interior & exterior systems from $150/ft. Trusted by Mississauga homeowners, 24/7 emergency response, $3,400 city rebates. Free inspection.";

// Local area data
const mississaugaStats = {
  projectsCompleted: "15yr+",
