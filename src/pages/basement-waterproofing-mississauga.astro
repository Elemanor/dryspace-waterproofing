---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import Process from '../components/sections/Process.astro';
import ContactForm from '../components/ContactForm.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import StructuredData from '../components/StructuredData.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import CostCalculator from '../components/react/CostCalculator.tsx';
import { StatsBar } from '../components/react/StatsBar.tsx';

const pageTitle = "Basement Waterproofing Mississauga | $3,400 Rebate | 25-Year Warranty";
const pageDescription = "Professional basement waterproofing in Mississauga. Interior & exterior systems from $150/ft. Trusted by Mississauga homeowners, 24/7 emergency response, $3,400 city rebates. Free inspection.";

// Local area data
const mississaugaStats = {
  projectsCompleted: "15yr+",
  avgResponseTime: "45 minutes",
  yearsInArea: "15+",
  emergencyCalls: "24/7"
};

const mississaugaNeighborhoods = [
  { name: "Port Credit", projects: "87", commonIssues: "Lake Ontario moisture, older homes" },
  { name: "Streetsville", projects: "92", commonIssues: "Credit River flooding, heritage homes" },
  { name: "Meadowvale", projects: "118", commonIssues: "Clay soil expansion, 1970s foundations" },
  { name: "Cooksville", projects: "76", commonIssues: "High water table, mixed-use buildings" },
  { name: "Clarkson", projects: "65", commonIssues: "Lake proximity, sandy soil" },
  { name: "Erin Mills", projects: "84", commonIssues: "New development settling" },
  { name: "Lakeview", projects: "58", commonIssues: "Waterfront homes, erosion" },
  { name: "Malton", projects: "45", commonIssues: "Airport area drainage" }
];

// FAQ categories for Mississauga page
const faqCategories = [
  {
    name: "Costs & Pricing",
    faqs: [
      { question: "How much does basement waterproofing cost in Mississauga?", answer: "Exterior waterproofing runs $150–$300 per linear foot, and interior drainage systems run $80–$200 per linear foot. A typical Mississauga home costs $15,000–$30,000 for full exterior waterproofing. The final price depends on your home's perimeter length, depth of excavation, soil conditions, and access. We provide free on-site quotes." },
      { question: "Is exterior or interior waterproofing more expensive?", answer: "Exterior is more expensive because it requires excavation around the foundation. Expect $8,000–$25,000+ for exterior versus $4,000–$10,000 for interior drainage. However, exterior waterproofing stops water before it reaches the wall, which makes it the more permanent solution for Mississauga's clay soil." },
      { question: "Are there rebates for basement waterproofing in Mississauga?", answer: "Yes. Mississauga homeowners can apply for up to $3,400 through the Basement Flooding Protection Subsidy Program. Additional Region of Peel programs cover backwater valves and sump pumps. We handle all rebate paperwork as part of our service." },
      { question: "Do you offer financing for waterproofing projects?", answer: "Yes, we offer 0% financing for 12 months (OAC) and longer-term plans. Most homeowners qualify, and we can run an application during the estimate visit." },
      { question: "Does homeowner insurance cover basement waterproofing?", answer: "Preventive waterproofing is generally not covered. However, if you've had water damage, your insurer may cover emergency cleanup and some repairs. We provide detailed documentation for insurance claims and work directly with adjusters when needed." },
      { question: "Why do waterproofing quotes vary so much between companies?", answer: "Scope of work is the main reason. A lower quote may exclude permit costs, proper membrane material, new weeping tile, or a real warranty. Ask every company exactly what's included — materials, permits, warranty terms, and whether they're licensed and insured." }
    ]
  },
  {
    name: "Methods & Solutions",
    faqs: [
      { question: "What is the best waterproofing method for Mississauga homes?", answer: "For homes built before 2000 on clay soil — which includes most of Mississauga — exterior waterproofing with a rubberized membrane and new weeping tile is the most effective long-term solution. Interior drainage systems work well for finished basements or when exterior access is blocked by driveways or additions." },
      { question: "What is the difference between exterior and interior waterproofing?", answer: "Exterior waterproofing stops water outside the foundation wall by applying a membrane and installing drainage at the footing. Interior waterproofing manages water that has already entered by channeling it through a perimeter drain to a sump pump. Exterior addresses the root cause; interior manages the symptom." },
      { question: "What is a weeping tile system?", answer: "Weeping tile is a perforated pipe installed around the base of your foundation that collects groundwater and directs it to a sump pump or storm drain. Older Mississauga homes used clay pipe segments that crack and clog over time. Modern systems use 4-inch PVC pipe wrapped in filter fabric." },
      { question: "Do I need a sump pump?", answer: "If your home has an interior drainage system, or if the water table in your area is high — common in Port Credit, Lakeview, and near the Credit River — a sump pump is essential. We recommend a primary pump with a battery backup so it runs during power outages." },
      { question: "What is a backwater valve and do I need one?", answer: "A backwater valve prevents sewage from backing up into your basement during heavy storms. The Region of Peel recommends them for all homes and offers rebates toward installation. If your home has ever had sewer backup, this is one of the most cost-effective protections you can install." },
      { question: "Can you waterproof a finished basement without tearing everything out?", answer: "In many cases, yes. Interior drainage systems can be installed along the perimeter by removing a strip of flooring near the walls. We try to preserve as much of your finished space as possible and coordinate with renovation contractors when rebuilding is needed." },
      { question: "What is foundation crack injection?", answer: "Crack injection fills foundation wall cracks from the inside using polyurethane or epoxy resin. It's a targeted repair for individual cracks — typically done in a few hours and costing $500–$1,200 per crack. It works best for non-structural shrinkage cracks in poured concrete walls." }
    ]
  },
  {
    name: "Process & Logistics",
    faqs: [
      { question: "How long does basement waterproofing take?", answer: "Exterior waterproofing typically takes 3–5 working days depending on the perimeter length and access. Interior drainage systems take 1–3 days. Crack injection is usually done in a few hours. We provide a timeline during the estimate." },
      { question: "Do I need a permit for waterproofing in Mississauga?", answer: "Most exterior projects require a building permit from the City of Mississauga because excavation exceeds 4 feet. Sump pumps and drainage changes require plumbing permits. We handle all permit applications, fees, and city inspections as part of the project." },
      { question: "Can I stay in my home during the work?", answer: "Yes. For exterior work, the disruption is mainly outside — excavation noise during the day and temporary landscaping removal. For interior work, we section off the basement and control dust. Most clients stay home throughout the project." },
      { question: "What happens during the free inspection?", answer: "One of our inspectors visits your home, checks the interior basement walls and floor for signs of water entry, examines the exterior grading and drainage, and identifies the likely cause. You'll get a written report and quote, typically within 24 hours. No obligation." },
      { question: "Do you restore landscaping after exterior waterproofing?", answer: "We backfill and re-grade the soil after membrane installation, and we'll restore the area to a clean, graded condition. If you had shrubs, gardens, or interlocking brick along the excavation zone, we discuss restoration options upfront so there are no surprises." },
      { question: "What time of year can you do waterproofing?", answer: "We work year-round. Spring and summer are busiest because that's when most homeowners notice water problems. Interior work can be done any time. Exterior excavation is possible in winter with adjusted methods, though spring and fall are ideal." }
    ]
  },
  {
    name: "Mississauga-Specific",
    faqs: [
      { question: "Why do so many Mississauga homes have wet basements?", answer: "Most of Mississauga is built on clay soil that holds water and expands when wet. Homes from the 1960s–1990s received only a tar-based damp-proofing coating that degrades over time. Combine aging foundations with old clay weeping tile and you get water entry — it's the most common call we get in Meadowvale, Cooksville, and Erin Mills." },
      { question: "Which Mississauga neighborhoods have the worst flooding?", answer: "Port Credit and Lakeview have high water tables from Lake Ontario proximity. Streetsville has Credit River flood risk. Meadowvale and Erin Mills sit on heavy clay with aging 1970s–80s drainage. Malton has flat terrain and older infrastructure. Each area has different risk factors, but clay soil is the common thread." },
      { question: "Do you service all of Mississauga?", answer: "Yes — Port Credit, Streetsville, Meadowvale, Cooksville, Erin Mills, Clarkson, Lakeview, Malton, City Centre, Churchill Meadows, Lisgar, Lorne Park, Sheridan, and all surrounding areas. Same-day estimates are available." },
      { question: "Is waterproofing different for homes near the Credit River?", answer: "Homes near the Credit River face higher groundwater and seasonal flooding risk. We typically recommend more robust systems — full exterior membrane with heavy-gauge drainage board, oversized sump pit with battery backup, and sometimes a combination of exterior and interior protection for redundancy." },
      { question: "My Mississauga home was built in the 1970s — does it need waterproofing?", answer: "Homes from that era almost certainly had clay weeping tile and a thin damp-proofing coating, both of which have a 30–40 year service life. If your home is experiencing musty smells, white mineral deposits on basement walls, or visible moisture — those are signs the original protection has failed." },
      { question: "Do heritage homes in Streetsville or Port Credit need special treatment?", answer: "Heritage district properties may need a heritage permit for exterior work. Older stone or block foundations also require different techniques than poured concrete — for example, parging and drainage board instead of peel-and-stick membrane. We've worked on heritage properties in both areas." }
    ]
  },
  {
    name: "Warranty & Emergency",
    faqs: [
      { question: "What does your 25-year warranty cover?", answer: "Our warranty covers all materials and workmanship for waterproofing installations. If a treated area leaks during the warranty period, we repair it at no charge. The warranty is transferable to new homeowners, which adds value if you sell your home." },
      { question: "How fast can you respond to a flooding emergency?", answer: "Our goal is to have a crew on-site within 45 minutes for Mississauga emergencies. We have trucks and equipment staged across the city and operate 24/7, including holidays. Call 437-545-0067 for immediate help." },
      { question: "My basement is flooding right now — what should I do?", answer: "Turn off electricity to the basement if you can do so safely. Don't walk into standing water. Move valuables to higher ground. Take photos for insurance documentation. Then call us at 437-545-0067 — we'll dispatch a crew right away." },
      { question: "Are you licensed and insured?", answer: "Yes. We carry $5 million in liability insurance, are WSIB-compliant, and hold all required municipal licenses. We're also BBB accredited. We can provide proof of insurance and licensing on request." },
      { question: "What if the problem comes back after repair?", answer: "That's what the warranty is for. If an area we've waterproofed develops a leak, we come back and fix it at no cost to you. We also offer annual check-ups to catch potential issues before they become problems." }
    ]
  }
];

// Flat FAQ list for schema
const allFaqs = faqCategories.flatMap(cat => cat.faqs);
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>
  <!-- Structured Data -->
  <StructuredData 
    type="Service" 
    data={{
      name: "Basement Waterproofing Mississauga",
      description: "Professional foundation waterproofing services in Mississauga. 24/7 emergency response, 25-year warranty, government rebates available.",
      areaServed: { name: "Mississauga", geo: { latitude: 43.5890, longitude: -79.6441 }}
    }}
  />
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Locations", url: "/service-areas" },
        { name: "Mississauga", url: "/locations/mississauga" },
        { name: "Foundation Protection Services" }
      ]}
    />
  </div>

  <!-- Hero Section -->
  <Hero 
    title="BASEMENT WATERPROOFING MISSISSAUGA"
    subtitle="Mississauga's trusted basement waterproofing experts. Serving the GTA since 1999 with 15+ years dedicated to Mississauga homes. 24/7 emergency response."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "View Local Projects", href: "#projects" }}
    backgroundImage="/images/mississauga-waterproofing-hero.webp"
    heroImage="/images/mississauga-waterproofing-hero.webp"
    badge="$3,400 REBATE AVAILABLE"
  />

  <!-- Emergency Alert Bar -->
  <div class="bg-red-600 text-white py-3">
    <div class="container mx-auto px-4 text-center">
      <p class="font-semibold">
        🚨 Foundation Flooding Emergency? 
        <a href="/emergency" class="underline font-bold">Get Emergency Help</a>
        - Average response time: 45 minutes to all Mississauga neighborhoods
      </p>
    </div>
  </div>

  <!-- Stats Bar -->
  <section class="py-8 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
        <div>
          <div class="text-3xl font-bold text-cyan-600">Since 1999</div>
          <div class="text-sm text-slate-500">Serving the GTA</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600">45 min</div>
          <div class="text-sm text-slate-500">Emergency Response</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600">$3,400</div>
          <div class="text-sm text-slate-500">Rebates Available</div>
        </div>
        <div>
          <div class="text-3xl font-bold text-cyan-600">25 Year</div>
          <div class="text-sm text-slate-500">Transferable Warranty</div>
        </div>
      </div>
    </div>
  </section>

  <!-- AI-Citable Summary -->
  <section class="py-8 border-b border-slate-200">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Basement Waterproofing in Mississauga — Quick Facts</h2>
        <dl class="grid md:grid-cols-2 gap-x-8 gap-y-3 text-sm speakable">
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Exterior waterproofing cost</dt>
            <dd class="font-bold text-slate-900">$150–$300 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Interior drainage cost</dt>
            <dd class="font-bold text-slate-900">$80–$200 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Average total project cost</dt>
            <dd class="font-bold text-slate-900">$15,000–$30,000</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">City rebate available</dt>
            <dd class="font-bold text-slate-900">Up to $3,400</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Project timeline</dt>
            <dd class="font-bold text-slate-900">3–5 days (exterior)</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Emergency response</dt>
            <dd class="font-bold text-slate-900">Under 45 minutes</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Warranty</dt>
            <dd class="font-bold text-slate-900">25-year transferable</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Building permit required</dt>
            <dd class="font-bold text-slate-900">Yes (exterior excavation)</dd>
          </div>
        </dl>
        <p class="text-xs text-slate-400 mt-3">Prices as of 2026. Costs vary by home size, soil conditions, and scope of work.</p>
      </div>
    </div>
  </section>

  <!-- Why Mississauga Basements Leak -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Why Mississauga Basements Leak</h2>
      <p class="text-center text-slate-600 max-w-2xl mx-auto mb-10">Mississauga has specific soil, climate, and construction factors that cause basement water problems. Understanding the cause determines the right fix.</p>

      <div class="grid md:grid-cols-2 gap-8 mb-12 max-w-4xl mx-auto">
        <img src="/images/why-basements-leak-diagram.webp" alt="Diagram showing how water enters a Mississauga basement through foundation cracks, wall-floor joint, and failed weeping tile" width="640" height="480" class="rounded-xl shadow-lg w-full" loading="lazy" decoding="async" />
        <img src="/images/why-basements-leak-photo.webp" alt="Damp basement wall with foundation crack and water damage in a Mississauga home" width="640" height="480" class="rounded-xl shadow-lg w-full" loading="lazy" decoding="async" />
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Clay Soil</h3>
          <p class="text-sm text-slate-600">Most of Mississauga sits on dense clay soil, particularly in Meadowvale, Erin Mills, and Churchill Meadows. Clay absorbs water and expands significantly, pressing against foundation walls with considerable hydrostatic pressure. When the clay dries, it shrinks and pulls away, creating gaps that channel water directly to the wall.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Freeze-Thaw Cycles</h3>
          <p class="text-sm text-slate-600">Southern Ontario sees frequent freeze-thaw cycles through the winter months. Each cycle expands trapped water in hairline concrete cracks, gradually widening them. Over decades, invisible stress fractures become visible cracks that leak during spring thaw when ground saturation peaks.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Old Weeping Tile</h3>
          <p class="text-sm text-slate-600">Homes built before the late 1980s typically used clay weeping tile — short terracotta pipe segments laid end-to-end around the footing. After 30–40 years, these pipes crack, collapse, or fill with root intrusion and sediment. Once the weeping tile fails, water has no path away from the footing.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Hydrostatic Pressure</h3>
          <p class="text-sm text-slate-600">When soil around the foundation becomes saturated — especially during spring thaw or prolonged rain — water presses against basement walls and up through the floor-wall joint. In Mississauga's clay soil, hydrostatic pressure builds enough force to push water through solid poured concrete.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Poor Lot Grading</h3>
          <p class="text-sm text-slate-600">Many Mississauga tract-built subdivisions from the 1970s–90s have settled unevenly over time, reversing the original grading slope. Instead of directing water away from the foundation, the ground now slopes toward the house. Add short downspout extensions and water pools directly at the foundation wall.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm">
          <h3 class="font-bold text-lg mb-2">Aging Foundation Walls</h3>
          <p class="text-sm text-slate-600">Homes built between 1960 and 1990 received only a thin tar-based damp-proofing coating — not a true waterproofing membrane. After 30–40 years of soil contact, freeze-thaw stress, and UV exposure during backfill settlement, the coating has cracked and peeled away entirely.</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm sm:col-span-2 lg:col-span-1">
          <h3 class="font-bold text-lg mb-2">Heavy Rain &amp; Snowmelt</h3>
          <p class="text-sm text-slate-600">Mississauga receives 834 mm of precipitation annually. Intense summer storms dump 30–50 mm in a single hour. Spring snowmelt in March and April is the highest-risk period — frozen ground prevents absorption, sending melt directly against foundations.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Exterior Waterproofing Process -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Exterior Waterproofing Process</h2>
      <p class="text-center text-slate-600 max-w-2xl mx-auto mb-10">The gold standard for stopping water at the source. Here is what exterior waterproofing looks like on a Mississauga home, step by step.</p>
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/exterior-excavation.webp" alt="Foundation excavation along Mississauga home exposing concrete wall to footing" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">1</span><h3 class="font-bold">Excavation</h3></div>
            <p class="text-sm text-slate-600">Excavate soil to the base of the footing, exposing the full foundation wall. Soil is piled neatly for backfill later.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/exterior-cleaned-wall.webp" alt="Cleaned and inspected concrete foundation wall ready for membrane application" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">2</span><h3 class="font-bold">Clean &amp; Repair</h3></div>
            <p class="text-sm text-slate-600">Wall is cleaned, cracks repaired with hydraulic cement, and the surface prepared for membrane application.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/exterior-drainage-board.webp" alt="Waterproofing membrane and drainage board installed on foundation wall in Mississauga" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">3</span><h3 class="font-bold">Membrane &amp; Drainage</h3></div>
            <p class="text-sm text-slate-600">Rubberized membrane applied, dimpled drainage board installed, and new weeping tile laid in a gravel bed at the footing.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interior Waterproofing Process -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-4">Interior Waterproofing Process</h2>
      <p class="text-center text-slate-600 max-w-2xl mx-auto mb-10">When exterior access is limited by driveways, decks, or landscaping, interior waterproofing captures water before it reaches your living space.</p>
      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/interior-cove-joint.webp" alt="Wall-floor cove joint showing moisture entry point in Mississauga basement" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">1</span><h3 class="font-bold">Identify Entry Point</h3></div>
            <p class="text-sm text-slate-600">Water typically enters at the wall-floor cove joint. This is where hydrostatic pressure pushes water up from beneath the slab.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/interior-drain-installed.webp" alt="Interior French drain system installed along basement wall in Mississauga" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">2</span><h3 class="font-bold">Install Drain System</h3></div>
            <p class="text-sm text-slate-600">A perimeter French drain is installed beneath the floor along the walls, channeling water to a central sump pit.</p>
          </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="/images/interior-sump-system.webp" alt="Sump pump with battery backup system installed in Mississauga basement" width="400" height="300" class="w-full aspect-[4/3] object-cover" loading="lazy" decoding="async" />
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2"><span class="w-7 h-7 rounded-full bg-cyan-100 text-cyan-700 text-xs font-bold flex items-center justify-center">3</span><h3 class="font-bold">Sump Pump &amp; Backup</h3></div>
            <p class="text-sm text-slate-600">A primary submersible pump with battery backup ensures water is discharged away from the foundation, even during power outages.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold mb-6">Who Is the Best Basement Waterproofing Company in Mississauga?</h2>

        <p class="text-lg mb-6 speakable">
