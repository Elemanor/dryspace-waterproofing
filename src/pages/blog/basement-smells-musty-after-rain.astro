---
import PageLayout from '../../layouts/PageLayout.astro';
import BlogImageGallery from '../../components/BlogImageGallery.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const publishDate = new Date('2026-03-05');
const author = 'Dryspace Waterproofing Team';
const readingTime = '12 min read';
---

<PageLayout 
  title="Why Your Basement Smells Musty After Rain - Dryspace Waterproofing"
  description="Discover why your basement develops musty odors after rain and learn proven solutions. Expert guide covering causes, health risks, and professional fixes."
>
  
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Blog", url: "/blog" },
        { name: "Basement Smells Musty After Rain" }
      ]}
    />
  </div>

<main class="min-h-screen bg-white">
    <!-- Blog Article Container -->
    <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      
      <!-- Article Header -->
      <header class="mb-10">
        <!-- Category Badges -->
        <div class="flex flex-wrap gap-2 mb-6">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-cyan-50 text-cyan-700">
            Basement Problems
          </span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium bg-slate-100 text-slate-700">
            Solutions Guide
          </span>
        </div>
        
        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          Why Your Basement Smells Musty After Rain (And How to Fix It)
        </h1>
        
        <!-- Meta Information -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-slate-500 pb-6 border-b border-slate-100">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <span>{author}</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <time datetime={publishDate.toISOString()}>
              {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{readingTime}</span>
          </div>
        </div>
      </header>

      <!-- Featured Image -->
      <div class="mb-10">
        <img 
          src="/images/basement-water-leak-inspection.webp" 
          alt="Basement moisture and odor problems"
          class="w-full h-[400px] object-cover rounded-xl shadow-sm"
        />
      </div>

      <!-- Table of Contents Card -->
      <nav class="mb-10 p-6 bg-slate-50 rounded-xl border border-slate-100">
        <h2 class="text-lg font-semibold text-slate-900 mb-4">In This Article</h2>
        <ul class="space-y-2">
          <li>
            <a href="#causes" class="text-cyan-600 hover:text-cyan-700 transition-colors flex items-center gap-2">
              <span class="text-slate-400">1.</span> Why Basements Smell After Rain
            </a>
          </li>
          <li>
            <a href="#health-risks" class="text-cyan-600 hover:text-cyan-700 transition-colors flex items-center gap-2">
              <span class="text-slate-400">2.</span> Health Risks and Concerns
            </a>
          </li>
          <li>
            <a href="#identification" class="text-cyan-600 hover:text-cyan-700 transition-colors flex items-center gap-2">
              <span class="text-slate-400">3.</span> Identifying the Source
            </a>
          </li>
          <li>
            <a href="#solutions" class="text-cyan-600 hover:text-cyan-700 transition-colors flex items-center gap-2">
              <span class="text-slate-400">4.</span> Professional Solutions
            </a>
          </li>
          <li>
            <a href="#prevention" class="text-cyan-600 hover:text-cyan-700 transition-colors flex items-center gap-2">
              <span class="text-slate-400">5.</span> Prevention Strategies
            </a>
          </li>
        </ul>
      </nav>

      <!-- Article Content -->
      <div class="prose prose-lg max-w-none">
        
        <!-- Introduction -->
        <div class="mb-8">
          <p class="text-xl text-slate-600 leading-relaxed">
            If you've noticed a musty smell in your basement after it rains, you're not alone. This common problem affects thousands of Toronto homeowners and can indicate serious moisture issues that need immediate attention.
          </p>
        </div>

        <!-- Key Takeaway Box -->
        <div class="bg-cyan-50 border-l-4 border-cyan-500 p-6 mb-8 rounded-r-lg">
          <h3 class="text-lg font-semibold text-cyan-800 mb-2">Key Takeaway</h3>
          <p class="text-cyan-700">
            Musty basement odors after rain typically indicate excess moisture, which can lead to mold growth, structural damage, and health issues if left untreated.
          </p>
        </div>

        <!-- Section 1: Causes -->
        <section id="causes" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Why Basements Smell After Rain</h2>
          
          <p class="text-slate-600 mb-6">
            When rain saturates the soil around your home, it creates hydrostatic pressure against your foundation walls. This pressure forces water through tiny cracks, porous concrete, or gaps in your basement's waterproofing system.
          </p>

          <div class="grid md:grid-cols-2 gap-6 mb-8">
            <!-- Primary Causes Card -->
            <div class="bg-white border border-slate-100 rounded-lg p-6 shadow-sm">
              <h3 class="text-xl font-semibold text-slate-900 mb-4">Primary Causes</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-cyan-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">Water Infiltration</strong>
                    <p class="text-sm text-slate-500 mt-1">Seepage through walls, floor, or foundation cracks</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-cyan-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">High Humidity</strong>
                    <p class="text-sm text-slate-500 mt-1">Levels above 60% create ideal conditions for mold</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-cyan-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">Poor Drainage</strong>
                    <p class="text-sm text-slate-500 mt-1">Inadequate grading or clogged gutters</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Secondary Factors Card -->
            <div class="bg-white border border-slate-100 rounded-lg p-6 shadow-sm">
              <h3 class="text-xl font-semibold text-slate-900 mb-4">Contributing Factors</h3>
              <ul class="space-y-3">
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">Organic Materials</strong>
                    <p class="text-sm text-slate-500 mt-1">Stored cardboard, paper, or fabric</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">Poor Ventilation</strong>
                    <p class="text-sm text-slate-500 mt-1">Stagnant air allows moisture to accumulate</p>
                  </div>
                </li>
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-amber-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                  </svg>
                  <div>
                    <strong class="text-slate-900">Old Waterproofing</strong>
                    <p class="text-sm text-slate-500 mt-1">Deteriorated sealants or membranes</p>
                  </div>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <!-- Section 2: Health Risks -->
        <section id="health-risks" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Health Risks and Concerns</h2>
          
          <!-- Warning Card -->
          <div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-6 h-6 text-red-500 flex-shrink-0 mt-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
              </svg>
              <div>
                <h3 class="text-lg font-semibold text-red-900 mb-2">Health Warning</h3>
                <p class="text-red-800 mb-3">
                  Prolonged exposure to mold and mildew from basement moisture can cause serious health issues, especially for vulnerable individuals.
                </p>
                <ul class="space-y-2 text-sm text-red-700">
                  <li>• Respiratory problems and asthma attacks</li>
                  <li>• Allergic reactions and skin irritation</li>
                  <li>• Headaches and fatigue</li>
                  <li>• Compromised immune system in children and elderly</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Section 3: Identification -->
        <section id="identification" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Identifying the Source</h2>
          
          <p class="text-slate-600 mb-6">
            Proper identification is crucial for effective treatment. Here's how to diagnose your basement odor problem:
          </p>

          <!-- Diagnostic Steps -->
          <div class="bg-slate-50 rounded-lg p-6 mb-8">
            <h3 class="text-xl font-semibold text-slate-900 mb-4">Diagnostic Checklist</h3>
            <div class="space-y-4">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-4 h-4 text-cyan-600 border-slate-200 rounded focus:ring-blue-500">
                <div>
                  <span class="font-medium text-slate-900">Check humidity levels</span>
                  <p class="text-sm text-slate-500">Use a hygrometer - anything above 60% is problematic</p>
                </div>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-4 h-4 text-cyan-600 border-slate-200 rounded focus:ring-blue-500">
                <div>
                  <span class="font-medium text-slate-900">Inspect for visible water</span>
                  <p class="text-sm text-slate-500">Look for puddles, water stains, or damp spots</p>
                </div>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-4 h-4 text-cyan-600 border-slate-200 rounded focus:ring-blue-500">
                <div>
                  <span class="font-medium text-slate-900">Check for efflorescence</span>
                  <p class="text-sm text-slate-500">White, chalky deposits on walls indicate water infiltration</p>
                </div>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-4 h-4 text-cyan-600 border-slate-200 rounded focus:ring-blue-500">
                <div>
                  <span class="font-medium text-slate-900">Look for mold growth</span>
                  <p class="text-sm text-slate-500">Check corners, behind furniture, and on organic materials</p>
                </div>
              </label>
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-4 h-4 text-cyan-600 border-slate-200 rounded focus:ring-blue-500">
                <div>
                  <span class="font-medium text-slate-900">Test drainage</span>
                  <p class="text-sm text-slate-500">Observe water flow around foundation during rain</p>
                </div>
              </label>
            </div>
          </div>
        </section>

        <!-- Section 4: Solutions -->
        <section id="solutions" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Professional Solutions</h2>
          
          <p class="text-slate-600 mb-8">
            Based on the severity and cause of your basement odor, different solutions may be required:
          </p>

          <!-- Solutions Grid -->
          <div class="grid gap-6 mb-8">
            <!-- Immediate Solutions -->
            <div class="bg-white border border-slate-100 rounded-lg overflow-hidden shadow-sm">
              <div class="bg-cyan-50 p-4 border-b-2 border-cyan-200">
                <h3 class="text-xl font-semibold text-slate-900">Immediate Actions</h3>
                <p class="text-cyan-700 text-sm">Can be done today - Low cost</p>
              </div>
              <div class="p-6">
                <ul class="space-y-3">
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Install dehumidifier</span>
                    <span class="text-sm font-semibold text-slate-900">$200-500</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Improve ventilation</span>
                    <span class="text-sm font-semibold text-slate-900">$100-300</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Remove organic materials</span>
                    <span class="text-sm font-semibold text-slate-900">$0-100</span>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Short-term Solutions -->
            <div class="bg-white border border-slate-100 rounded-lg overflow-hidden shadow-sm">
              <div class="bg-cyan-50 p-4 border-b-2 border-cyan-200">
                <h3 class="text-xl font-semibold text-slate-900">Short-term Repairs</h3>
                <p class="text-cyan-700 text-sm">1-2 weeks - Moderate cost</p>
              </div>
              <div class="p-6">
                <ul class="space-y-3">
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Crack injection repair</span>
                    <span class="text-sm font-semibold text-slate-900">$500-1,500</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Interior drainage system</span>
                    <span class="text-sm font-semibold text-slate-900">$3,000-5,000</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Sump pump installation</span>
                    <span class="text-sm font-semibold text-slate-900">$2,000-4,000</span>
                  </li>
                </ul>
              </div>
            </div>

            <!-- Long-term Solutions -->
            <div class="bg-white border border-slate-100 rounded-lg overflow-hidden shadow-sm">
              <div class="bg-purple-50 p-4 border-b-2 border-purple-200">
                <h3 class="text-xl font-semibold text-slate-900">Permanent Solutions</h3>
                <p class="text-purple-700 text-sm">2-4 weeks - Investment in home value</p>
              </div>
              <div class="p-6">
                <ul class="space-y-3">
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Exterior waterproofing</span>
                    <span class="text-sm font-semibold text-slate-900">$15,000-25,000</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">French drain system</span>
                    <span class="text-sm font-semibold text-slate-900">$10,000-15,000</span>
                  </li>
                  <li class="flex items-center justify-between">
                    <span class="text-slate-600">Foundation repair</span>
                    <span class="text-sm font-semibold text-slate-900">$5,000-20,000</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Section 5: Prevention -->
        <section id="prevention" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Prevention Strategies</h2>
          
          <p class="text-slate-600 mb-6">
            Preventing musty odors is easier and more cost-effective than dealing with major water damage:
          </p>

          <!-- Prevention Tips -->
          <div class="bg-cyan-50 rounded-lg p-6">
            <h3 class="text-xl font-semibold text-slate-900 mb-4">Maintenance Checklist</h3>
            <div class="grid md:grid-cols-2 gap-4">
              <div>
                <h4 class="font-medium text-slate-900 mb-2">Monthly Tasks</h4>
                <ul class="space-y-2 text-sm text-slate-600">
                  <li>• Check and empty dehumidifier</li>
                  <li>• Inspect for new cracks or leaks</li>
                  <li>• Test sump pump operation</li>
                  <li>• Monitor humidity levels</li>
                </ul>
              </div>
              <div>
                <h4 class="font-medium text-slate-900 mb-2">Seasonal Tasks</h4>
                <ul class="space-y-2 text-sm text-slate-600">
                  <li>• Clean gutters and downspouts</li>
                  <li>• Check grading around foundation</li>
                  <li>• Inspect exterior waterproofing</li>
                  <li>• Service HVAC and ventilation</li>
                </ul>
              </div>
            </div>
          </div>
        </section>

        <!-- Comprehensive Odor Assessment Section -->
        <section id="odor-assessment" class="mb-12">
          <h2 class="text-3xl font-bold text-slate-900 mb-6">Odor Intensity Assessment Guide</h2>
          
          <p class="text-slate-600 mb-8">
            Different odor intensities indicate different problems and require different solutions. Use this comprehensive guide to assess your situation:
          </p>

          <div class="grid md:grid-cols-4 gap-4 mb-8">
            <!-- Level 1 - Mild -->
            <div class="bg-cyan-50 border-2 border-cyan-200 rounded-lg p-4">
              <div class="w-12 h-12 bg-cyan-500 rounded-full mx-auto mb-3 flex items-center justify-center">
                <span class="text-xl font-bold text-white">1</span>
              </div>
              <h3 class="text-lg font-bold text-cyan-700 mb-2 text-center">MILD</h3>
              <p class="text-sm text-slate-600 mb-3">Barely noticeable, only when actively looking for odor</p>
              <div class="border-t border-cyan-200 pt-3">
                <p class="text-xs font-semibold text-slate-900 mb-2">LIKELY CAUSES:</p>
                <ul class="text-xs text-slate-600 space-y-1 mb-3">
                  <li>• High humidity (60-70%)</li>
                  <li>• Minor condensation</li>
                  <li>• Poor ventilation</li>
                  <li>• Surface moisture</li>
                </ul>
                <p class="text-xs font-semibold text-slate-900 mb-2">SOLUTIONS:</p>
                <ul class="text-xs text-slate-600 space-y-1">
                  <li>• Install dehumidifier</li>
                  <li>• Improve ventilation</li>
                  <li>• Check gutters</li>
                </ul>
                <div class="mt-3 pt-3 border-t border-cyan-200">
                  <span class="text-xs font-bold text-cyan-700">Cost: $500-$2,000</span>
                </div>
              </div>
            </div>

            <!-- Level 2 - Moderate -->
            <div class="bg-amber-50 border-2 border-yellow-200 rounded-lg p-4">
              <div class="w-12 h-12 bg-amber-500 rounded-full mx-auto mb-3 flex items-center justify-center">
                <span class="text-xl font-bold text-white">2</span>
              </div>
              <h3 class="text-lg font-bold text-amber-600 mb-2 text-center">MODERATE</h3>
              <p class="text-sm text-slate-600 mb-3">Noticeable when entering basement</p>
              <div class="border-t border-yellow-200 pt-3">
                <p class="text-xs font-semibold text-slate-900 mb-2">LIKELY CAUSES:</p>
                <ul class="text-xs text-slate-600 space-y-1 mb-3">
                  <li>• Water seepage</li>
                  <li>• Early mold growth</li>
                  <li>• Foundation cracks</li>
                  <li>• Drainage issues</li>
                </ul>
                <p class="text-xs font-semibold text-slate-900 mb-2">SOLUTIONS:</p>
                <ul class="text-xs text-slate-600 space-y-1">
                  <li>• Crack injection</li>
                  <li>• Interior drainage</li>
                  <li>• Mold remediation</li>
                </ul>
                <div class="mt-3 pt-3 border-t border-yellow-200">
                  <span class="text-xs font-bold text-amber-600">Cost: $2,000-$8,000</span>
                </div>
              </div>
            </div>

            <!-- Level 3 - Strong -->
            <div class="bg-orange-50 border-2 border-orange-200 rounded-lg p-4">
              <div class="w-12 h-12 bg-orange-500 rounded-full mx-auto mb-3 flex items-center justify-center">
                <span class="text-xl font-bold text-white">3</span>
              </div>
              <h3 class="text-lg font-bold text-orange-700 mb-2 text-center">STRONG</h3>
