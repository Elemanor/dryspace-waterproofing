  <!-- JavaScript for Calculators -->
  <script>
    function calculateConcrete() {
      const perimeter = parseFloat(document.getElementById('perimeter').value);
      const depth = parseFloat(document.getElementById('depth').value);
      const concretePrice = parseFloat(document.getElementById('concrete-type').value);
      
      // Convert feet to meters (1 foot = 0.3048 meters)
      const perimeterMeters = perimeter * 0.3048;
      const depthMeters = depth * 0.3048;
      
      // Footing calculations (16" wide x 16" thick x full depth)
      const footingWidth = 16 * 0.0254; // 16 inches width to meters
      const footingThickness = 16 * 0.0254; // 16 inches thickness to meters
      const footingVolume = perimeterMeters * footingWidth * footingThickness;
      
      // Wall calculations (10" thick x full depth minus footing thickness)
      const wallThickness = 10 * 0.0254; // inches to meters
      const wallHeight = depthMeters - footingThickness; // Wall sits on top of footing
      const wallVolume = perimeterMeters * wallThickness * wallHeight;
      
      // Total volume and cost
      const totalVolume = footingVolume + wallVolume;
      const totalCost = totalVolume * concretePrice;
      
      // Display results
      document.getElementById('footing-volume').textContent = footingVolume.toFixed(2);
      document.getElementById('wall-volume').textContent = wallVolume.toFixed(2);
      document.getElementById('total-volume').textContent = totalVolume.toFixed(2);
      document.getElementById('concrete-cost').textContent = '$' + totalCost.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      
      document.getElementById('concrete-results').classList.remove('hidden');
    }
    
    function calculateSoil() {
      const perimeter = parseFloat(document.getElementById('soil-perimeter').value);
      const width = parseFloat(document.getElementById('excavation-width').value);
      const depth = parseFloat(document.getElementById('depth').value) || 4; // Use depth from concrete calc or default
      
      // Calculate volume in cubic feet
      const volumeCubicFeet = perimeter * width * depth;
      
      // Convert to cubic yards (27 cubic feet = 1 cubic yard)
      const volumeCubicYards = volumeCubicFeet / 27;
      
      // Calculate number of bins (3 cubic yards per bin)
      const binsRequired = Math.ceil(volumeCubicYards / 3);
      
      // Calculate cost ($375 per 3 cubic yards)
      const disposalCost = binsRequired * 350;
      
      // Display results
      document.getElementById('soil-cubic-feet').textContent = volumeCubicFeet.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      document.getElementById('soil-cubic-yards').textContent = volumeCubicYards.toFixed(1);
      document.getElementById('bins-required').textContent = binsRequired;
      document.getElementById('soil-cost').textContent = '$' + disposalCost.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      
      document.getElementById('soil-results').classList.remove('hidden');
    }
  </script>
