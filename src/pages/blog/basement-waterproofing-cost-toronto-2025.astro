<script>
  document.addEventListener('DOMContentLoaded', function() {
    // FAQ toggle functionality
    const faqButtons = document.querySelectorAll('[data-faq-toggle]');
    faqButtons.forEach(button => {
      button.addEventListener('click', function() {
        const content = button.nextElementSibling;
        const arrow = button.querySelector('svg');
        
        if (content.classList.contains('hidden')) {
          content.classList.remove('hidden');
          arrow.classList.add('rotate-180');
        } else {
          content.classList.add('hidden');
          arrow.classList.remove('rotate-180');
        }
      });
    });

    // Cost Calculator
    const calculateBtn = document.getElementById('calculateCostBtn');
    if (calculateBtn) {
      calculateBtn.addEventListener('click', function() {
    const basementSize = parseFloat(document.getElementById('basementSize').value);
    const waterproofingType = document.getElementById('waterproofingType').value;
    const problemSeverity = document.getElementById('problemSeverity').value;
    const sumpPump = document.getElementById('sumpPump').checked;
    const frenchDrain = document.getElementById('frenchDrain').checked;
    const dehumidifier = document.getElementById('dehumidifier').checked;
    
    if (!basementSize) {
      alert('Please enter basement size to calculate costs.');
      return;
    }
    
    // Base cost per square foot by type
    const baseCosts = {
      'interior': { min: 12, max: 18, name: 'Interior Drainage System' },
      'exterior': { min: 25, max: 40, name: 'Exterior Waterproofing' },
      'both': { min: 35, max: 55, name: 'Comprehensive System' },
      'crack-repair': { min: 3, max: 8, name: 'Crack Repair Only' }
    };
    
    // Severity multipliers
    const severityMultipliers = {
      'minor': 0.8,
      'moderate': 1.0,
      'severe': 1.3
    };
    
    const baseType = baseCosts[waterproofingType];
    const severityMultiplier = severityMultipliers[problemSeverity];
    
    // Calculate base cost
    let minCost = basementSize * baseType.min * severityMultiplier;
    let maxCost = basementSize * baseType.max * severityMultiplier;
    
    // Add feature costs
    if (sumpPump) {
      minCost += 2000;
      maxCost += 4000;
    }
    if (frenchDrain) {
      minCost += 3000;
      maxCost += 6000;
    }
    if (dehumidifier) {
      minCost += 1500;
      maxCost += 3000;
    }
    
    // Calculate ROI
    const homeValueIncrease = (minCost + maxCost) / 2 * 0.65;
    const preventedDamage = Math.min((minCost + maxCost) / 2 * 3, 50000);
    
    // Display results
    const resultsDiv = document.getElementById('calculatorResults');
    resultsDiv.innerHTML = `
      <div class="bg-slate-50  p-6 text-center mb-4">
        <h4 class="font-semibold text-slate-900 mb-2">${baseType.name}</h4>
        <p class="text-3xl font-bold text-slate-900">$${Math.round(minCost).toLocaleString()} - $${Math.round(maxCost).toLocaleString()}</p>
        <p class="text-sm text-slate-500 mt-2">For ${basementSize.toLocaleString()} sq ft basement</p>
      </div>
      
      <div class="grid grid-cols-2 gap-3 mb-4">
        <div class="bg-slate-50  p-3 text-center">
          <h5 class="font-semibold text-cyan-600 text-sm mb-1">Monthly Payment</h5>
          <p class="text-lg text-slate-900">$${Math.round((minCost + maxCost) / 2 / 36).toLocaleString()}</p>
          <p class="text-xs text-slate-500">36-month financing</p>
        </div>
        <div class="bg-slate-50  p-3 text-center">
          <h5 class="font-semibold text-cyan-400 text-sm mb-1">Cost per Sq Ft</h5>
          <p class="text-lg text-slate-900">$${Math.round((minCost + maxCost) / 2 / basementSize)}</p>
          <p class="text-xs text-slate-500">Total project cost</p>
        </div>
      </div>
    `;
    
    // Show financing and ROI info
    document.getElementById('financingInfo').classList.remove('hidden');
    document.getElementById('roiInfo').classList.remove('hidden');
    
    // Update ROI details
    document.getElementById('roiDetails').innerHTML = `
      <ul class="space-y-1">
        <li>• Home value increase: $${Math.round(homeValueIncrease).toLocaleString()}</li>
        <li>• Potential damage prevented: $${Math.round(preventedDamage).toLocaleString()}</li>
        <li>• Break-even timeline: 3-5 years</li>
        <li>• 10-year ROI: 180-250%</li>
      </ul>
    `;
      });
    }

    // Smooth scrolling for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth'
        });
      }
    });
  });
  });
</script>