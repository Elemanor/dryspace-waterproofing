              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>15 meters of Lake Ontario shoreline high-water mark</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>30 meters of top-of-bank of any watercourse or valley</span>
              </li>
            </ul>
            <ul class="space-y-2 text-slate-700">
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>Areas with slopes greater than 15% grade</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>Designated valley or stream corridor areas</span>
              </li>
              <li class="flex items-start">
                <span class="mr-2">•</span>
                <span>Wetlands and associated buffer zones</span>
              </li>
            </ul>
