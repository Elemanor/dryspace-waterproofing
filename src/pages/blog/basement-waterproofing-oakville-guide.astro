                <td class="px-6 py-4 text-sm text-slate-700">Old Oakville, River Oaks, Glen Abbey</td>
                <td class="px-6 py-4 text-sm text-slate-700">High</td>
                <td class="px-6 py-4 text-sm text-slate-700">Conservation Halton + Town</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="px-6 py-4 text-sm text-slate-900 font-medium">Morrison Creek</td>
