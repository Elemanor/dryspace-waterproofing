  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Calculator functionality
      const calculateBtn = document.getElementById('calculateRiskBtn');
      if (calculateBtn) {
        calculateBtn.addEventListener('click', function() {
          const experience = parseInt(document.querySelector('input[name="experience"]:checked')?.value || 0);
          const severity = parseInt(document.querySelector('input[name="severity"]:checked')?.value || 0);
          const budget = parseInt(document.querySelector('input[name="budget"]:checked')?.value || 0);
          const time = parseInt(document.querySelector('input[name="time"]:checked')?.value || 0);
          
          const totalScore = experience + severity + budget + time;
          const resultDiv = document.getElementById('riskResults');
          const recommendationDiv = document.getElementById('recommendationText');
          const scoreDiv = document.getElementById('riskScore');
          
          let recommendation, risk, color;
          
          if (totalScore >= 18) {
            recommendation = " <strong>DIY Recommended</strong><br>You have the right combination of experience, budget constraints, and suitable problem severity for a successful DIY project. Consider starting with interior solutions and upgrading if needed.";
            risk = "Low Risk";
            color = "border-cyan-500";
          } else if (totalScore >= 12) {
            recommendation = " <strong>Professional Consultation Recommended</strong><br>While DIY is possible, consider getting a professional assessment first. You might benefit from a hybrid approach: professional diagnosis with some DIY execution.";
            risk = "Medium Risk";
            color = "border-cyan-500";
          } else {
            recommendation = " <strong>Professional Service Recommended</strong><br>Based on your situation, professional waterproofing offers the best value and success probability. The risks and potential costs of DIY failure outweigh the initial savings.";
            risk = "High Risk";
            color = "border-red-500";
          }
          
          recommendationDiv.innerHTML = recommendation;
          scoreDiv.textContent = `Risk Assessment: ${risk} (Score: ${totalScore}/24)`;
          resultDiv.className = `mt-8 p-6 bg-white  border-2 ${color}`;
          resultDiv.classList.remove('hidden');
        });
      }

      // FAQ toggle functionality
      const faqButtons = document.querySelectorAll('[data-faq-toggle]');
      faqButtons.forEach(button => {
        button.addEventListener('click', function() {
          const content = button.nextElementSibling;
          const arrow = button.querySelector('svg');
          
          if (content.classList.contains('hidden')) {
            content.classList.remove('hidden');
            arrow.style.transform = 'rotate(180deg)';
          } else {
            content.classList.add('hidden');
            arrow.style.transform = 'rotate(0deg)';
          }
        });
      });
    });
  </script>
