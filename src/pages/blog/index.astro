// Sort by date (newest first)
const sortedPosts = posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Featured post is the newest
const featuredPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);

// Categories for filtering
const categories = ['All', 'Permits', 'Seasonal', 'Emergency', 'Waterproofing', 'Foundation Repair', 'Underpinning', 'Drainage Systems', 'Sump Pumps', 'Costs & Pricing', 'Rebates & Financing', 'Materials', 'Education', 'Guides'];
---

<PageLayout
  title="Waterproofing Blog | Expert Guides & Tips | Dryspace"
  description="Expert waterproofing guides, tips, and industry insights. Learn about basement waterproofing, foundation repair, drainage systems, and more from Toronto's trusted experts."
>
  <!-- Blog Hero -->
  <section class="relative bg-gradient-hero py-20 lg:py-28 overflow-hidden">
    <div class="relative z-10 container mx-auto px-4">
      <div class="text-center max-w-3xl mx-auto">
        <p class="section-label-pill border-cyan-400/20 bg-cyan-400/10 text-cyan-400 mb-6">Expert Knowledge</p>
        <h1 class="text-display text-white mb-6">Waterproofing Knowledge Center</h1>
        <p class="text-xl text-slate-300 leading-relaxed">
          Expert insights, guides, and tips from Toronto's leading waterproofing professionals.
          Stay informed about the latest techniques, costs, and solutions.
        </p>
      </div>
    </div>
  </section>

  <!-- Featured Post -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <a href={`/blog/${featuredPost.slug}`} class="group block max-w-5xl mx-auto">
        <div class="rounded-2xl border border-slate-200/60 bg-white shadow-card overflow-hidden transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1">
          <div class="grid lg:grid-cols-2 gap-0">
            <div class="relative bg-gradient-to-br from-navy-900 to-cyan-900 p-10 lg:p-12 flex flex-col justify-center">
              <span class="inline-flex items-center self-start rounded-full bg-cyan-400/20 px-3 py-1 text-xs font-medium text-cyan-400 mb-4">
                Featured Article
              </span>
              <h2 class="text-2xl lg:text-3xl font-bold text-white mb-4 group-hover:text-cyan-400 transition-colors">
                {featuredPost.title}
              </h2>
              <p class="text-slate-300 leading-relaxed mb-6">{featuredPost.excerpt}</p>
              <div class="flex items-center gap-4 text-sm text-slate-400">
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                  {new Date(featuredPost.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  {featuredPost.readTime}
                </span>
              </div>
            </div>
            <div class="p-10 lg:p-12 flex flex-col justify-center bg-slate-50">
              <span class="inline-flex items-center self-start rounded-full bg-cyan-50 px-3 py-1 text-xs font-medium text-cyan-700 mb-4">
                {featuredPost.category}
              </span>
              <div class="space-y-4">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-cyan-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <span class="text-sm text-slate-600">Expert-reviewed content</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-cyan-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  </div>
                  <span class="text-sm text-slate-600">Includes cost estimates</span>
                </div>
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-cyan-50 flex items-center justify-center">
                    <svg class="w-4 h-4 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  </div>
                  <span class="text-sm text-slate-600">Toronto-specific guidance</span>
                </div>
              </div>
              <span class="mt-8 inline-flex items-center gap-2 text-sm font-medium text-cyan-600 group-hover:gap-3 transition-all">
                Read full article
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </span>
            </div>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-6 bg-white border-b border-slate-200/60">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap justify-center gap-2">
        {categories.map((category, i) => (
          <button
            class:list={[
              'filter-btn rounded-full px-5 py-2 text-sm font-medium transition-all',
              i === 0 ? 'bg-cyan-500 text-white shadow-sm' : 'bg-white text-slate-600 border border-slate-200 hover:border-cyan-200 hover:text-cyan-600'
            ]}
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {remainingPosts.map(post => (
          <article class="blog-card group" data-category={post.category}>
            <a href={`/blog/${post.slug}`} class="block h-full">
              <div class="h-full rounded-xl border border-slate-200/60 bg-white shadow-card overflow-hidden transition-all duration-300 hover:shadow-card-hover hover:-translate-y-1">
                <!-- Post Header -->
                <div class="p-6">
                  <div class="flex justify-between items-start mb-4">
                    <span class="inline-flex items-center rounded-full bg-cyan-50 px-2.5 py-0.5 text-xs font-medium text-cyan-700">
                      {post.category}
                    </span>
                    <span class="flex items-center gap-1 text-xs text-slate-400">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                      {post.readTime}
                    </span>
                  </div>
                  <h2 class="text-lg font-semibold text-slate-900 mb-3 group-hover:text-cyan-600 transition-colors leading-snug">
                    {post.title}
                  </h2>
                  <p class="text-sm text-slate-600 leading-relaxed mb-4">
                    {post.excerpt}
                  </p>
                  <div class="text-xs text-slate-400">
                    {new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
                  </div>
                </div>

                <!-- Read More -->
                <div class="px-6 py-4 border-t border-slate-100 bg-slate-50/50">
                  <span class="flex items-center gap-2 text-sm font-medium text-slate-500 group-hover:text-cyan-600 transition-colors">
                    Read article
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                  </span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Signup -->
  <section class="section-padding bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <p class="section-label-pill border-cyan-400/20 bg-cyan-400/10 text-cyan-400 mb-6">Stay Updated</p>
        <h2 class="text-headline text-white mb-4">Get Expert Tips Delivered</h2>
        <p class="text-lg text-slate-300 mb-8">
          Waterproofing tips, seasonal maintenance reminders, and exclusive offers delivered to your inbox.
        </p>
        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto">
          <input
            type="email"
            placeholder="Enter your email"
            class="flex-1 px-5 py-3 rounded-lg border border-white/10 bg-white/5 text-white placeholder-slate-400 focus:outline-none focus:border-cyan-400 focus:ring-1 focus:ring-cyan-400 transition-colors"
            required
          />
          <button
            type="submit"
            class="btn-primary whitespace-nowrap"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Popular Topics -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <p class="section-label-pill mb-4">Browse By Topic</p>
        <h2 class="text-headline text-slate-900">Popular Topics</h2>
      </div>

      <div class="grid md:grid-cols-4 gap-5 max-w-5xl mx-auto">
        <div class="rounded-xl border border-slate-200/60 bg-white shadow-card p-6 hover:shadow-card-hover transition-shadow">
          <div class="w-10 h-10 rounded-lg bg-cyan-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
          </div>
          <h3 class="text-base font-semibold text-slate-900 mb-3">Basement Waterproofing</h3>
          <ul class="space-y-2">
            <li><a href="/blog/interior-vs-exterior-waterproofing" class="text-sm text-slate-600 hover:text-cyan-600 transition-colors">Interior vs Exterior</a></li>
            <li><a href="/blog/basement-waterproofing-cost-toronto-2026" class="text-sm text-slate-600 hover:text-cyan-600 transition-colors">2026 Costs Guide</a></li>
            <li><a href="/blog/diy-vs-professional-waterproofing" class="text-sm text-slate-600 hover:text-cyan-600 transition-colors">DIY vs Professional</a></li>
          </ul>
