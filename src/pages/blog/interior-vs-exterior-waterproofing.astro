<script>
  document.addEventListener('DOMContentLoaded', function() {
    // FAQ toggle functionality
    const faqButtons = document.querySelectorAll('[data-faq-toggle]');
    faqButtons.forEach(button => {
      button.addEventListener('click', function() {
        const content = button.nextElementSibling;
        const arrow = button.querySelector('svg');
        
        if (content.classList.contains('hidden')) {
          content.classList.remove('hidden');
          arrow.classList.add('rotate-180');
        } else {
          content.classList.add('hidden');
          arrow.classList.remove('rotate-180');
        }
      });
    });

    // Recommendation Generator
    const recommendBtn = document.getElementById('generateRecommendationBtn');
    if (recommendBtn) {
      recommendBtn.addEventListener('click', function() {
    const concern = document.querySelector('input[name="concern"]:checked')?.value;
    const budget = document.getElementById('budget').value;
    const urgency = document.getElementById('urgency').value;
    const landscaping = document.getElementById('landscaping').checked;
    const utilities = document.getElementById('utilities').checked;
    const basementFinished = document.getElementById('basement-finished').checked;
    
    if (!concern) {
      alert('Please select your primary concern to get a recommendation.');
      return;
    }
    
    let recommendation = '';
    let system = '';
    let reasoning = [];
    let considerations = [];
    
    // Decision logic
    if (concern === 'active-flooding' || urgency === 'emergency') {
      system = 'Interior Drainage System';
      recommendation = 'interior';
      reasoning = [
        'Immediate solution for active water problems',
        'Works year-round regardless of weather',
        'Most effective for stopping flooding quickly',
        'Lower cost allows for immediate action'
      ];
      if (basementFinished) considerations.push('Will require some restoration work');
    } else if (concern === 'prevention' && budget === 'over-30k' && !landscaping) {
      system = 'Exterior Waterproofing';
      recommendation = 'exterior';
      reasoning = [
        'Best prevention strategy available',
        'Maximum long-term protection',
        'No ongoing maintenance requirements',
        'Budget supports comprehensive approach'
      ];
      if (urgency !== 'planning') considerations.push('Weather-dependent installation timing');
    } else if (budget === 'over-30k' && (concern === 'cracks' || urgency === 'renovation')) {
      system = 'Combined Interior + Exterior';
      recommendation = 'combined';
      reasoning = [
        'Maximum protection for high-value investment',
        'Addresses both current and future concerns',
        'Redundant systems provide ultimate security',
        'Budget supports comprehensive solution'
      ];
    } else {
      system = 'Interior Drainage System';
      recommendation = 'interior';
      reasoning = [
        'Most cost-effective solution for your situation',
        'Proven effectiveness in Toronto conditions',
        'Quick installation with minimal disruption',
        'Works well with existing constraints'
      ];
      if (landscaping) reasoning.push('Preserves your recent landscaping investment');
      if (utilities) reasoning.push('Avoids complex utility relocations');
    }
    
    // Add specific considerations
    if (landscaping && recommendation === 'exterior') {
      considerations.push('Recent landscaping will be disrupted');
    }
    if (utilities && recommendation === 'exterior') {
      considerations.push('Utility lines may complicate installation');
    }
    
    // Display results
    const resultsDiv = document.getElementById('recommendationResults');
    const systemColor = recommendation === 'interior' ? 'construction-blue' : 
                       recommendation === 'exterior' ? 'construction-orange' : 'construction-purple';
    
    resultsDiv.innerHTML = `
      <div class="bg-${systemColor}/10 border-2 border-${systemColor}/30  p-6">
        <h4 class="text-xl font-bold text-${systemColor} mb-3">Recommended: ${system}</h4>
        
        <div class="mb-4">
          <h5 class="font-semibold text-white mb-2">Why This System Is Right for You:</h5>
          <ul class="space-y-1 text-slate-600 text-sm">
            ${reasoning.map(reason => `
              <li class="flex items-start space-x-2">
                <svg class="w-4 h-4 text-${systemColor} mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path>
                </svg>
                <span>${reason}</span>
              </li>
            `).join('')}
          </ul>
        </div>
        
        ${considerations.length > 0 ? `
          <div class="mb-4">
            <h5 class="font-semibold text-cyan-400 mb-2">Additional Considerations:</h5>
            <ul class="space-y-1 text-slate-600 text-sm">
              ${considerations.map(consideration => `
                <li class="flex items-start space-x-2">
                  <div class="w-2 h-2 bg-construction-yellow  mt-2"></div>
                  <span>${consideration}</span>
                </li>
              `).join('')}
            </ul>
          </div>
        ` : ''}
        
        <div class="bg-${systemColor}/20  p-3">
          <p class="text-${systemColor} text-sm font-medium">
            <strong>Next Step:</strong> Schedule a free assessment to confirm this recommendation and get detailed pricing.
          </p>
        </div>
      </div>
    `;
      });
    }

    // Smooth scrolling for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth'
        });
      }
    });
  });
  });
</script>