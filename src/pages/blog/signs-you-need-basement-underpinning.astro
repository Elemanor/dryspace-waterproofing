  <!-- Interactive Scoring Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const checkboxes = document.querySelectorAll('input[type="checkbox"][data-points]');
      const totalScoreDisplay = document.getElementById('total-score');

      function updateScore() {
        let total = 0;
        checkboxes.forEach(checkbox => {
          if (checkbox.checked) {
            total += parseInt(checkbox.dataset.points);
          }
        });
        totalScoreDisplay.textContent = total;
      }

      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updateScore);
      });
    });
  </script>

