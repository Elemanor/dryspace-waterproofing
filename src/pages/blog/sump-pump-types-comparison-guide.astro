  <script>
    function recommendPump() {
      const water = document.querySelector('input[name="water"]:checked')?.value;
      const depth = document.querySelector('input[name="depth"]:checked')?.value;
      const power = document.querySelector('input[name="power"]:checked')?.value;
      const budget = document.querySelector('input[name="budget"]:checked')?.value;
      
      if (!water || !depth || !power || !budget) {
        alert('Please answer all questions to get a recommendation.');
        return;
      }
      
      const resultDiv = document.getElementById('pumpResults');
      const recommendationDiv = document.getElementById('recommendationText');
      const modelDiv = document.getElementById('specificModel');
      
      let recommendation, model;
      
      // Decision logic based on inputs
      if (power === 'frequent' && (water === 'moderate' || water === 'heavy' || water === 'extreme')) {
        if (budget === 'premium' || budget === 'luxury') {
          recommendation = " <strong>Battery Backup System Recommended</strong><br>Your frequent power outages and significant water issues make backup power essential for protection.";
          model = "<strong>Recommended:</strong> Basement Watchdog BW4000 - $650-800<br>Provides 8-53 hours of backup power and works with your existing primary pump.";
        } else {
          recommendation = " <strong>Consider Upgrading Budget for Battery Backup</strong><br>Your situation really benefits from backup power, but budget constraints limit options.";
          model = "<strong>Alternative:</strong> Wayne ESP25 - $480-580<br>More affordable backup option with good performance.";
        }
      } else if (depth === 'shallow' || depth === 'none') {
        if (budget === 'basic') {
          recommendation = " <strong>Pedestal Pump Recommended</strong><br>Perfect for shallow pits and budget-conscious installations.";
          model = "<strong>Recommended:</strong> Superior Pump 91250 - $120-160<br>Budget-friendly pedestal pump ideal for light water issues.";
        } else {
          recommendation = " <strong>Quality Pedestal Pump Recommended</strong><br>Better build quality for longer service life in shallow pit applications.";
          model = "<strong>Recommended:</strong> Little Giant 6-CIM-R - $185-225<br>Higher quality pedestal pump with better durability.";
        }
      } else if (water === 'heavy' || water === 'extreme') {
        if (budget === 'luxury' || budget === 'premium') {
          recommendation = " <strong>High-Capacity Submersible Recommended</strong><br>Heavy water situations require maximum pumping power and reliability.";
          model = "<strong>Recommended:</strong> Wayne CDU1000 - $450-520<br>1 HP pump with 5,100 GPH capacity for heavy-duty applications.";
        } else {
          recommendation = " <strong>Standard Submersible Recommended</strong><br>Good balance of performance and cost for your water situation.";
          model = "<strong>Recommended:</strong> Zoeller M53 Mighty-Mate - $280-320<br>Reliable cast iron construction with proven track record.";
        }
      } else {
        // Light to moderate water, standard depth
        if (budget === 'basic') {
          recommendation = " <strong>Standard Submersible Recommended</strong><br>Good protection for typical basement water issues at budget-friendly price.";
          model = "<strong>Recommended:</strong> Entry-level submersible pump - $200-300<br>Adequate protection for light to moderate water infiltration.";
        } else {
          recommendation = " <strong>Quality Submersible Recommended</strong><br>Excellent reliability and performance for standard residential applications.";
          model = "<strong>Recommended:</strong> Zoeller M53 Mighty-Mate - $280-320<br>Top-rated pump with cast iron construction and 3-year warranty.";
        }
      }
      
      recommendationDiv.innerHTML = recommendation;
      modelDiv.innerHTML = model;
      resultDiv.classList.remove('hidden');
    }

    function toggleFaq(button) {
      const content = button.nextElementSibling;
      const arrow = button.querySelector('svg');
      
      if (content.classList.contains('hidden')) {
        content.classList.remove('hidden');
        arrow.style.transform = 'rotate(180deg)';
      } else {
        content.classList.add('hidden');
        arrow.style.transform = 'rotate(0deg)';
      }
    }
  </script>
</PageLayout>