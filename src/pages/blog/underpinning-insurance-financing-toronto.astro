---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroSection from '../../components/widgets/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const meta = {
  title: "Underpinning Insurance & Financing Toronto 2026 | HELOC, Loans & Coverage Guide",
  description: "How to finance basement underpinning in Toronto. HELOC, construction mortgage, personal loans, 0% contractor financing, and government rebates ($3,400). Insurance coverage explained.",
  keywords: "underpinning financing, basement lowering loan, HELOC underpinning, underpinning insurance coverage, government rebate underpinning, basement renovation financing Toronto",
  canonical: "https://dryspacewaterproofing.ca/blog/underpinning-insurance-financing-toronto"
};
---

<PageLayout {...meta}>

  <!-- Article JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "Underpinning Insurance & Financing Toronto 2026 | HELOC, Loans & Coverage Guide",
    "author": { "@type": "Organization", "name": "DrySpace Waterproofing", "url": "https://dryspacewaterproofing.ca" },
    "publisher": { "@type": "Organization", "name": "DrySpace Waterproofing", "url": "https://dryspacewaterproofing.ca" },
    "datePublished": "2026-03-23",
    "dateModified": "2026-03-23",
    "image": "https://dryspacewaterproofing.ca/images/underpinning-financing.webp",
    "mainEntityOfPage": "https://dryspacewaterproofing.ca/blog/underpinning-insurance-financing-toronto"
  })} />

  <!-- FAQPage JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does home insurance cover basement underpinning?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Standard home insurance does NOT cover elective underpinning (lowering your basement for more space). However, if underpinning is needed due to sudden structural failure — like a foundation crack from a burst water main — your insurance may cover the structural repair portion. Always check your policy and notify your insurer before starting work."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best way to finance basement underpinning?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most cost-effective option for most Toronto homeowners is a HELOC (Home Equity Line of Credit). HELOCs offer the lowest interest rates (prime + 0.5-1.5%), flexible draw schedules that match construction milestones, and interest-only payments during the draw period. For homeowners with less equity, a construction mortgage refinance or personal loan are alternatives."
        }
      },
      {
        "@type": "Question",
        "name": "Are there government rebates for basement underpinning in Toronto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. The City of Toronto Basement Flooding Protection Subsidy provides up to $3,400 for eligible waterproofing work done during underpinning (backwater valve, sump pump, weeping tile). The Canada Greener Homes Grant may also apply if the project includes insulation upgrades. Some utility companies offer additional incentives."
        }
      },
      {
        "@type": "Question",
        "name": "How much does basement underpinning cost in Toronto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basement underpinning in Toronto costs $300-$500 per linear foot, with total projects typically ranging from $35,000 to $75,000 for an average 800 sq ft basement. Bench footing is less expensive at $200-$350 per linear foot. Add $2,100-$3,000 for permits and engineering."
        }
      },
      {
        "@type": "Question",
        "name": "Does underpinning increase property value?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. In the GTA, underpinning typically adds $50,000-$120,000 in property value by creating legal basement living space with proper ceiling height. If converted to a rental apartment, the added income of $1,500-$2,500/month further increases the property's value using income-based appraisal methods."
        }
      },
      {
        "@type": "Question",
        "name": "Can I get 0% financing for underpinning?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Some underpinning contractors, including DrySpace, offer 0% financing for 12-24 months on qualified projects. This spreads the cost without interest charges. The key requirement is typically a minimum project size ($30,000+) and approved credit. Ask your contractor about available financing promotions."
        }
      },
      {
        "@type": "Question",
        "name": "Will underpinning increase my home insurance premium?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Properly permitted underpinning should not increase premiums and may actually lower them — a stronger foundation with modern waterproofing reduces your risk of water damage claims. However, you MUST notify your insurer before work begins. Unpermitted work or failure to disclose structural modifications can void your coverage entirely."
        }
      },
      {
        "@type": "Question",
        "name": "Is the interest on a HELOC for underpinning tax-deductible?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If the underpinned basement is used as a rental property, the interest on the portion of the HELOC used for the rental unit may be tax-deductible as a business expense. For personal-use renovations, HELOC interest is not deductible. Consult a Canadian tax professional for your specific situation."
        }
      }
    ]
  })} />

  <!-- BreadcrumbList JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://dryspacewaterproofing.ca" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://dryspacewaterproofing.ca/blog" },
      { "@type": "ListItem", "position": 3, "name": "Underpinning Insurance & Financing Toronto" }
    ]
  })} />

  <Breadcrumbs
    items={[
      { label: 'Home', href: '/' },
      { label: 'Blog', href: '/blog' },
      { label: 'Underpinning Insurance & Financing' }
    ]}
  />

  <section class="py-12 md:py-16">
    <div class="container mx-auto px-4 max-w-4xl">

      <!-- Hero -->
      <header class="mb-12">
        <div class="flex items-center gap-2 text-sm text-cyan-600 font-semibold mb-4">
          <span>💰</span>
          <span>FINANCING & INSURANCE</span>
        </div>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          Underpinning Insurance & Financing Toronto 2026
        </h1>
        <p class="text-lg text-slate-600 mb-6 leading-relaxed">
          Basement underpinning is a $35,000–$75,000 investment. The good news: multiple financing options exist, government rebates can cover up to $3,400 of the waterproofing components, and the ROI is strong. Here's how to pay for it smartly.
        </p>
        <div class="flex flex-wrap gap-4 text-sm text-slate-500">
          <span>Published: March 23, 2026</span>
          <span>•</span>
          <span>14 min read</span>
          <span>•</span>
          <span>By DrySpace Waterproofing</span>
        </div>
      </header>

      <!-- Key Takeaways -->
      <div class="bg-cyan-50 border border-cyan-200 rounded-xl p-6 mb-12">
        <h2 class="text-lg font-bold text-cyan-800 mb-3">Key Takeaways</h2>
        <ul class="space-y-2 text-cyan-700">
          <li class="flex items-start gap-2"><span class="text-cyan-500 mt-1">✓</span> Standard home insurance does NOT cover elective underpinning</li>
          <li class="flex items-start gap-2"><span class="text-cyan-500 mt-1">✓</span> HELOC is the most cost-effective financing option (lowest rates)</li>
          <li class="flex items-start gap-2"><span class="text-cyan-500 mt-1">✓</span> Toronto rebates: up to $3,400 for waterproofing components</li>
          <li class="flex items-start gap-2"><span class="text-cyan-500 mt-1">✓</span> 0% contractor financing available for 12–24 months</li>
          <li class="flex items-start gap-2"><span class="text-cyan-500 mt-1">✓</span> ROI: 130–200% through increased property value + rental income</li>
        </ul>
      </div>

      <!-- Insurance Coverage -->
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Does Home Insurance Cover Underpinning?</h2>
      <p class="text-slate-600 mb-4 leading-relaxed">
        Short answer: <strong>usually no</strong>. Standard home insurance policies cover sudden and accidental damage, not planned renovations. Here's the breakdown:
      </p>

      <div class="grid md:grid-cols-2 gap-6 mb-8">
        <div class="bg-red-50 border border-red-200 rounded-lg p-5">
          <h3 class="font-bold text-red-800 mb-3">Not Covered</h3>
          <ul class="space-y-2 text-red-700 text-sm">
            <li class="flex items-start gap-2"><span class="text-red-400 mt-1">✗</span> Elective basement lowering for more space</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-1">✗</span> Underpinning for a basement apartment conversion</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-1">✗</span> Foundation reinforcement for an addition</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-1">✗</span> Gradual settling or normal wear</li>
            <li class="flex items-start gap-2"><span class="text-red-400 mt-1">✗</span> Cracks from normal concrete shrinkage</li>
          </ul>
        </div>
        <div class="bg-green-50 border border-green-200 rounded-lg p-5">
          <h3 class="font-bold text-green-800 mb-3">May Be Covered</h3>
          <ul class="space-y-2 text-green-700 text-sm">
            <li class="flex items-start gap-2"><span class="text-green-400 mt-1">✓</span> Structural damage from a burst water main</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-1">✓</span> Foundation failure from a sewer backup (with endorsement)</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-1">✓</span> Damage from a falling tree hitting the foundation</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-1">✓</span> Fire damage requiring foundation reconstruction</li>
            <li class="flex items-start gap-2"><span class="text-green-400 mt-1">✓</span> Vehicle impact damaging foundation wall</li>
          </ul>
        </div>
      </div>

      <div class="bg-amber-50 border-l-4 border-amber-400 p-5 mb-10 rounded-r-lg">
        <p class="text-amber-800 font-semibold mb-1">Important: Notify Your Insurer</p>
        <p class="text-amber-700 text-sm">You <strong>must</strong> notify your home insurance company before underpinning begins. Failure to disclose structural modifications can void your entire policy — not just for the underpinning, but for all claims. Most insurers appreciate the notification and may even lower your premium after the project (since a stronger foundation = lower risk).</p>
      </div>

      <!-- Impact on Premiums -->
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Will Underpinning Affect My Insurance Premium?</h2>
      <p class="text-slate-600 mb-4 leading-relaxed">
        Properly permitted underpinning typically has a <strong>neutral or positive impact</strong> on your premiums:
      </p>
      <ul class="space-y-2 text-slate-600 mb-8 ml-4">
        <li class="flex items-start gap-2"><span class="text-cyan-500">•</span> <strong>Positive:</strong> Stronger foundation, new waterproofing, modern drainage = lower risk of claims</li>
        <li class="flex items-start gap-2"><span class="text-cyan-500">•</span> <strong>Neutral:</strong> No premium change if properly disclosed and permitted</li>
        <li class="flex items-start gap-2"><span class="text-cyan-500">•</span> <strong>Negative:</strong> Premium increase only if you add a rental unit (higher liability) — offset by rental income</li>
        <li class="flex items-start gap-2"><span class="text-cyan-500">•</span> <strong>Dangerous:</strong> Unpermitted work can void your entire policy if discovered during a claim</li>
      </ul>

      <!-- Financing Options -->
      <h2 class="text-2xl font-bold text-slate-900 mb-6">5 Ways to Finance Basement Underpinning</h2>

      <!-- Option 1: HELOC -->
      <div class="bg-white border-2 border-cyan-200 rounded-xl p-6 mb-6">
        <div class="flex items-center gap-3 mb-4">
          <span class="bg-cyan-100 text-cyan-700 text-sm font-bold px-3 py-1 rounded-full">BEST OPTION</span>
          <h3 class="text-xl font-bold text-slate-900">1. HELOC (Home Equity Line of Credit)</h3>
        </div>
        <p class="text-slate-600 mb-4 leading-relaxed">
          A HELOC lets you borrow against your home equity at the lowest available interest rates. It's the preferred financing method for most underpinning projects because you only pay interest on what you draw, and you can draw in stages matching your construction milestones.
        </p>
        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Interest Rate</p>
            <p class="text-cyan-700 font-bold text-lg">Prime + 0.5–1.5%</p>
            <p class="text-slate-500 text-xs">Currently ~6.7–7.7% (March 2026)</p>
          </div>
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Typical Borrowing Limit</p>
            <p class="text-cyan-700 font-bold text-lg">Up to 65% of home value</p>
            <p class="text-slate-500 text-xs">Minus existing mortgage balance</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Lowest rate</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Flexible draws</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Interest-only option</span>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Requires equity</span>
        </div>
      </div>

      <!-- Option 2: Construction Mortgage -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 mb-6">
        <h3 class="text-xl font-bold text-slate-900 mb-3">2. Construction Mortgage / Refinance</h3>
        <p class="text-slate-600 mb-4 leading-relaxed">
          If you're doing a major renovation (underpinning + finishing + apartment conversion), a construction mortgage refinance rolls the entire project cost into your mortgage. This spreads the payment over 25–30 years at mortgage rates.
        </p>
        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Interest Rate</p>
            <p class="text-slate-700 font-bold text-lg">4.5–6.5% fixed</p>
          </div>
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Best For</p>
            <p class="text-slate-700 font-bold text-lg">Projects $75K+</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Lowest monthly payment</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Fixed rate option</span>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Appraisal required</span>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Longer process</span>
        </div>
      </div>

      <!-- Option 3: Personal Loan -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 mb-6">
        <h3 class="text-xl font-bold text-slate-900 mb-3">3. Personal Loan / Home Improvement Loan</h3>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Unsecured personal loans don't require home equity but come with higher interest rates. Best for smaller projects (bench footing at $15,000–$30,000) or as a bridge until your HELOC is approved.
        </p>
        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Interest Rate</p>
            <p class="text-slate-700 font-bold text-lg">7.5–12.5%</p>
          </div>
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Typical Term</p>
            <p class="text-slate-700 font-bold text-lg">3–7 years</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">No equity required</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Fast approval</span>
          <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">Higher rate</span>
          <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">Fixed payments</span>
        </div>
      </div>

      <!-- Option 4: Contractor Financing -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 mb-6">
        <h3 class="text-xl font-bold text-slate-900 mb-3">4. Contractor Financing (0% for 12–24 Months)</h3>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Some underpinning contractors partner with financing companies to offer <strong>0% interest</strong> for 12–24 months. This is essentially a free loan if you can pay it off within the promotional period. DrySpace offers 0% financing on projects over $30,000.
        </p>
        <div class="grid md:grid-cols-2 gap-4 mb-4">
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">Interest Rate</p>
            <p class="text-green-700 font-bold text-lg">0% for 12–24 months</p>
          </div>
          <div>
            <p class="text-slate-700 font-semibold text-sm mb-1">After Promo Period</p>
            <p class="text-slate-700 font-bold text-lg">19.9–29.9%</p>
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">0% interest promo</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Easy application</span>
          <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">High rate after promo</span>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Must pay in full by deadline</span>
        </div>
      </div>

      <!-- Option 5: Cash Savings -->
      <div class="bg-white border border-slate-200 rounded-xl p-6 mb-8">
        <h3 class="text-xl font-bold text-slate-900 mb-3">5. Cash / Savings</h3>
        <p class="text-slate-600 mb-4 leading-relaxed">
          Paying cash eliminates all interest costs and gives you the strongest negotiating position with contractors. If you have the savings, this is the cheapest option. Some contractors offer a <strong>3–5% discount for full payment upfront</strong>.
        </p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">No interest</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Cash discount</span>
          <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded-full">Strongest negotiating position</span>
          <span class="text-xs bg-amber-100 text-amber-700 px-2 py-1 rounded-full">Depletes savings</span>
        </div>
      </div>

      <!-- Financing Comparison Table -->
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Financing Comparison at a Glance</h2>
      <div class="overflow-x-auto mb-12">
        <table class="w-full border-collapse bg-white rounded-lg shadow-sm text-sm">
          <thead>
            <tr class="bg-slate-50">
              <th class="text-left p-3 font-semibold text-slate-700 border-b">Option</th>
              <th class="text-left p-3 font-semibold text-slate-700 border-b">Rate</th>
              <th class="text-left p-3 font-semibold text-slate-700 border-b">Monthly (on $50K)</th>
              <th class="text-left p-3 font-semibold text-slate-700 border-b">Total Interest (5yr)</th>
              <th class="text-left p-3 font-semibold text-slate-700 border-b">Best For</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b bg-cyan-50/50">
              <td class="p-3 text-slate-700 font-semibold">HELOC</td>
              <td class="p-3 text-slate-600">~7%</td>
              <td class="p-3 text-slate-600">$292 (interest only)</td>
              <td class="p-3 text-slate-600">$9,500</td>
              <td class="p-3 text-slate-500">Homeowners with equity</td>
            </tr>
            <tr class="border-b">
              <td class="p-3 text-slate-700 font-semibold">Construction Mortgage</td>
              <td class="p-3 text-slate-600">~5.5%</td>
              <td class="p-3 text-slate-600">$306 (25yr amort)</td>
              <td class="p-3 text-slate-600">$6,800</td>
              <td class="p-3 text-slate-500">Large projects $75K+</td>
            </tr>
            <tr class="border-b">
              <td class="p-3 text-slate-700 font-semibold">Personal Loan</td>
              <td class="p-3 text-slate-600">~10%</td>
              <td class="p-3 text-slate-600">$1,062 (5yr term)</td>
              <td class="p-3 text-slate-600">$13,700</td>
              <td class="p-3 text-slate-500">No equity / fast approval</td>
            </tr>
            <tr class="border-b">
              <td class="p-3 text-slate-700 font-semibold">0% Contractor</td>
              <td class="p-3 text-slate-600">0% (promo)</td>
              <td class="p-3 text-slate-600">$2,083 (24mo)</td>
              <td class="p-3 text-slate-600">$0</td>
              <td class="p-3 text-slate-500">Can pay off in 24mo</td>
            </tr>
            <tr>
              <td class="p-3 text-slate-700 font-semibold">Cash</td>
              <td class="p-3 text-slate-600">0%</td>
              <td class="p-3 text-slate-600">$0</td>
              <td class="p-3 text-slate-600">$0</td>
              <td class="p-3 text-slate-500">Have savings available</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Government Rebates -->
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Government Rebates & Incentives</h2>
      <p class="text-slate-600 mb-6 leading-relaxed">
        Several government programs can offset a portion of your underpinning costs, particularly the waterproofing and energy-efficiency components:
      </p>

      <div class="space-y-6 mb-12">
        <div class="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-green-100 text-green-700 text-sm font-bold px-3 py-1 rounded-full">UP TO $3,400</span>
            <h3 class="font-bold text-slate-900">Toronto Basement Flooding Protection Subsidy</h3>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed mb-3">
            The City of Toronto provides rebates for flood-prevention installations done during underpinning:
          </p>
          <ul class="space-y-1 text-sm text-slate-600 ml-4">
            <li class="flex items-start gap-2"><span class="text-green-500">•</span> Backwater valve installation: up to $1,250</li>
            <li class="flex items-start gap-2"><span class="text-green-500">•</span> Sump pump installation: up to $1,750</li>
            <li class="flex items-start gap-2"><span class="text-green-500">•</span> Disconnecting downspouts: up to $400</li>
          </ul>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-green-100 text-green-700 text-sm font-bold px-3 py-1 rounded-full">UP TO $5,000</span>
            <h3 class="font-bold text-slate-900">Canada Greener Homes Grant</h3>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            If your underpinning project includes basement insulation upgrades (highly recommended), you may qualify for up to $5,000 in federal rebates. Requires a pre-retrofit EnerGuide evaluation. Applies to wall insulation, rim joist insulation, and air sealing work done during the underpinning project.
          </p>
        </div>

        <div class="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
          <div class="flex items-center gap-3 mb-3">
            <span class="bg-green-100 text-green-700 text-sm font-bold px-3 py-1 rounded-full">VARIES</span>
            <h3 class="font-bold text-slate-900">Local Utility Incentives</h3>
          </div>
          <p class="text-slate-600 text-sm leading-relaxed">
            Enbridge Gas and local electric utilities offer rebates for insulation improvements. If your underpinning project includes spray foam insulation in the new foundation walls, check with your utility for available incentives.
          </p>
        </div>
      </div>

      <!-- ROI Analysis -->
      <h2 class="text-2xl font-bold text-slate-900 mb-4">ROI Analysis: 3 Scenarios</h2>
      <p class="text-slate-600 mb-6 leading-relaxed">
        Underpinning is one of the highest-ROI renovations in the GTA because it creates <strong>new living space that didn't exist before</strong>. Here are three common scenarios:
      </p>

      <div class="overflow-x-auto mb-10">
        <table class="w-full border-collapse bg-white rounded-lg shadow-sm">
          <thead>
            <tr class="bg-slate-50">
              <th class="text-left p-4 font-semibold text-slate-700 border-b">Scenario</th>
              <th class="text-left p-4 font-semibold text-slate-700 border-b">Cost</th>
              <th class="text-left p-4 font-semibold text-slate-700 border-b">Value Added</th>
              <th class="text-left p-4 font-semibold text-slate-700 border-b">ROI</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b">
              <td class="p-4 text-slate-600">
                <strong class="block text-slate-700">Unfinished — Height Only</strong>
                <span class="text-sm">Underpin + leave unfinished for storage/laundry</span>
              </td>
              <td class="p-4 text-slate-700 font-semibold">$40,000–$55,000</td>
              <td class="p-4 text-slate-700 font-semibold">$50,000–$70,000</td>
              <td class="p-4 text-green-700 font-bold">125–130%</td>
            </tr>
            <tr class="border-b">
              <td class="p-4 text-slate-600">
                <strong class="block text-slate-700">Finished Rec Room / Family Room</strong>
                <span class="text-sm">Underpin + full finishing (drywall, flooring, bathroom)</span>
              </td>
              <td class="p-4 text-slate-700 font-semibold">$75,000–$110,000</td>
              <td class="p-4 text-slate-700 font-semibold">$100,000–$150,000</td>
              <td class="p-4 text-green-700 font-bold">130–140%</td>
            </tr>
            <tr>
