<script>
  // FAQ toggle functionality
  function toggleFAQ(button) {
    const content = button.nextElementSibling;
    const arrow = button.querySelector('svg');
    
    if (content.classList.contains('hidden')) {
      content.classList.remove('hidden');
      arrow.classList.add('rotate-180');
    } else {
      content.classList.add('hidden');
      arrow.classList.remove('rotate-180');
    }
  }

  // Hydrostatic Pressure Calculator
  function calculatePressure() {
    const waterDepth = parseFloat(document.getElementById('waterDepth').value);
    const floorDepth = parseFloat(document.getElementById('floorDepth').value);
    const soilType = document.getElementById('soilType').value;
    
    if (!waterDepth || !floorDepth) {
      alert('Please enter both water depth and floor depth measurements.');
      return;
    }
    
    // Soil multipliers for pressure calculation
    const soilMultipliers = {
      'clay': 1.2,    // Clay holds more water
      'sand': 0.8,    // Sand drains better
      'loam': 1.0,    // Average conditions
      'gravel': 0.6   // Excellent drainage
    };
    
    // Calculate pressure (water density is 62.4 lbs/ft³)
    const basePressure = waterDepth * 62.4;
    const adjustedPressure = basePressure * soilMultipliers[soilType];
    
    // Assume 1000 sq ft basement for force calculation
    const basementArea = 1000;
    const totalForce = adjustedPressure * basementArea;
    const forceInTons = totalForce / 2000;
    
    // Risk assessment
    let riskLevel, riskColor, riskDescription, actions;
    
    if (adjustedPressure < 100) {
      riskLevel = 'Low';
      riskColor = 'construction-green';
      riskDescription = 'Low hydrostatic pressure. Monitor for changes and maintain proper drainage.';
      actions = [
        'Regular basement inspections',
        'Maintain exterior drainage',
        'Monitor during heavy rain periods',
        'Install humidity monitoring'
      ];
    } else if (adjustedPressure < 250) {
      riskLevel = 'Moderate';
      riskColor = 'construction-yellow';
      riskDescription = 'Moderate pressure that may cause problems during peak water periods. Consider preventive measures.';
      actions = [
        'Professional assessment recommended',
        'Consider sump pump installation',
        'Improve exterior drainage systems',
        'Monitor for floor/wall cracks'
      ];
    } else if (adjustedPressure < 400) {
      riskLevel = 'High';
      riskColor = 'construction-orange';
      riskDescription = 'High pressure likely to cause water intrusion and structural stress. Professional intervention recommended.';
      actions = [
        'Professional drainage system needed',
        'Sump pump with backup required',
        'Foundation crack monitoring essential',
        'Consider interior drainage installation'
      ];
    } else {
      riskLevel = 'Critical';
      riskColor = 'construction-red';
      riskDescription = 'Critical pressure levels that can cause severe structural damage. Immediate professional intervention required.';
      actions = [
        'Emergency professional assessment needed',
        'Interior drainage system essential',
        'Structural engineer consultation',
        'Immediate water removal planning'
      ];
    }
    
    // Display results
    const resultsDiv = document.getElementById('calculatorResults');
    resultsDiv.innerHTML = `
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div class="bg-slate-50  p-4 text-center">
          <h4 class="font-semibold text-slate-900 mb-2">Water Pressure</h4>
          <p class="text-2xl font-bold text-slate-900">${adjustedPressure.toFixed(1)}</p>
          <p class="text-xs text-slate-500">lbs per sq ft</p>
        </div>
        <div class="bg-slate-50  p-4 text-center">
          <h4 class="font-semibold text-cyan-400 mb-2">Total Upward Force</h4>
          <p class="text-2xl font-bold text-slate-900">${forceInTons.toFixed(1)}</p>
          <p class="text-xs text-slate-500">tons</p>
        </div>
      </div>
      <div class="bg-slate-50  p-4 text-center">
        <h4 class="font-semibold text-slate-900 mb-2">Equivalent Weight</h4>
        <p class="text-lg text-slate-900">${Math.round(forceInTons / 1.4)} mid-size cars pressing upward</p>
      </div>
    `;
    
    // Display risk assessment
    const riskDiv = document.getElementById('riskAssessment');
    riskDiv.className = `mt-6 p-4  bg-${riskColor}/10 border-2 border-${riskColor}/30`;
    riskDiv.classList.remove('hidden');
    
    document.getElementById('riskDescription').innerHTML = `
      <span class="text-${riskColor} font-semibold">${riskLevel} Risk:</span> ${riskDescription}
    `;
    
    // Display recommended actions
    const actionsDiv = document.getElementById('recommendedActions');
    actionsDiv.classList.remove('hidden');
    
    const actionsList = document.getElementById('actionsList');
    actionsList.innerHTML = actions.map(action => 
      `<li class="flex items-start space-x-2">
        <svg class="w-4 h-4 text-cyan-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path>
        </svg>
        <span>${action}</span>
      </li>`
    ).join('');
  }

  // Smooth scrolling for anchor links
  document.querySelectorAll('a[href^="#"]').forEach(anchor => {
    anchor.addEventListener('click', function (e) {
      e.preventDefault();
      const target = document.querySelector(this.getAttribute('href'));
      if (target) {
        target.scrollIntoView({
          behavior: 'smooth'
        });
      }
    });
  });
</script>