<script>
  // Diagnostic tool functionality
  let currentQuestion = 1;
  const maxQuestions = 3;
  let answers = {};

  // Diagnostic logic
  const diagnosticOptions = document.querySelectorAll('.diagnostic-option');
  diagnosticOptions.forEach(option => {
    option.addEventListener('click', function() {
      const questionCard = this.closest('.question-card');
      const questionNum = questionCard.dataset.question;
      const value = this.dataset.value;
      
      // Remove selection from other options in this question
      questionCard.querySelectorAll('.diagnostic-option').forEach(opt => {
        opt.classList.remove('bg-amber-500', 'border-cyan-500');
        opt.classList.add('bg-slate-50', 'border-slate-300');
      });
      
      // Mark this option as selected
      this.classList.remove('bg-slate-50', 'border-slate-300');
      this.classList.add('bg-amber-500', 'border-cyan-500');
      
      // Store answer
      answers[`question${questionNum}`] = value;
      
      // Show next question or results
      setTimeout(() => {
        if (currentQuestion < maxQuestions) {
          questionCard.classList.add('hidden');
          const nextQuestion = document.querySelector(`[data-question="${currentQuestion + 1}"]`);
          nextQuestion.classList.remove('hidden');
          currentQuestion++;
        } else {
          // Show results
          showDiagnosticResults();
        }
      }, 500);
    });
  });

  function showDiagnosticResults() {
    const resultsSection = document.getElementById('diagnostic-results');
    const resultsContent = document.getElementById('results-content');
    
    // Hide all question cards
    document.querySelectorAll('.question-card').forEach(card => {
      card.classList.add('hidden');
    });
    
    // Generate results based on answers
    const diagnosis = generateDiagnosis(answers);
    
    resultsContent.innerHTML = `
      <div class="flex items-start space-x-4 mb-6">
        <div class="flex-shrink-0 w-12 h-12 bg-slate-50  flex items-center justify-center">
          <svg class="w-6 h-6 text-slate-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <div>
          <h4 class="text-xl font-bold text-slate-900 mb-2">Most Likely Cause: ${diagnosis.cause}</h4>
          <p class="text-slate-600 mb-4">${diagnosis.description}</p>
        </div>
      </div>
      
      <div class="bg-slate-50  p-4 mb-4">
        <h5 class="font-semibold text-cyan-400 mb-2">Recommended Actions:</h5>
        <ul class="space-y-2 text-slate-600">
          ${diagnosis.recommendations.map(rec => `<li class="flex items-start space-x-2">
            <svg class="w-4 h-4 text-cyan-400 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z"></path>
            </svg>
            <span>${rec}</span>
          </li>`).join('')}
        </ul>
      </div>
      
      <div class="bg-${diagnosis.urgency === 'high' ? 'construction-red' : diagnosis.urgency === 'medium' ? 'construction-yellow' : 'construction-blue'}/10 border-2 border-${diagnosis.urgency === 'high' ? 'construction-red' : diagnosis.urgency === 'medium' ? 'construction-yellow' : 'construction-blue'}/30  p-4">
        <h5 class="font-semibold text-${diagnosis.urgency === 'high' ? 'construction-red' : diagnosis.urgency === 'medium' ? 'construction-yellow' : 'construction-blue'} mb-2">Urgency Level: ${diagnosis.urgency.charAt(0).toUpperCase() + diagnosis.urgency.slice(1)}</h5>
        <p class="text-slate-600">${diagnosis.urgencyNote}</p>
      </div>
    `;
    
    resultsSection.classList.remove('hidden');
  }

  function generateDiagnosis(answers) {
    const timing = answers.question1;
    const location = answers.question2;
    const amount = answers.question3;
    
    // Diagnostic logic
    if (timing === 'during-rain' && location === 'floor-wall-joint') {
      return {
        cause: 'Hydrostatic Pressure',
        description: 'Water pressure from saturated soil is forcing water through the foundation where the floor meets the wall.',
        recommendations: [
          'Install interior drainage system with sump pump',
          'Consider exterior waterproofing if problem persists',
          'Improve exterior drainage around foundation',
          'Seal cove joint as temporary measure'
        ],
        urgency: amount === 'pooling' ? 'high' : 'medium',
        urgencyNote: amount === 'pooling' ? 'Immediate action required to prevent structural damage and mold growth.' : 'Should be addressed within 1-2 weeks to prevent worsening.'
      };
    }
    
    if (location === 'wall-cracks' && timing !== 'constant') {
      return {
        cause: 'Foundation Wall Cracks',
        description: 'Water is entering through cracks in your foundation walls, likely caused by settlement or freeze-thaw cycles.',
        recommendations: [
          'Professional crack injection and sealing',
          'Monitor for crack growth',
          'Improve exterior drainage',
          'Consider structural assessment for large cracks'
        ],
        urgency: amount === 'pooling' ? 'high' : 'medium',
        urgencyNote: 'Foundation cracks can worsen quickly, especially during freeze-thaw cycles.'
      };
    }
    
    if (timing === 'constant') {
      return {
        cause: 'Plumbing Leak or High Water Table',
        description: 'Constant water presence suggests either a plumbing leak or groundwater issues not related to weather.',
        recommendations: [
          'Check for plumbing leaks immediately',
          'Test water meter for continuous running',
          'Professional inspection of water supply lines',
          'Assess groundwater levels if plumbing is clear'
        ],
        urgency: 'high',
        urgencyNote: 'Constant water can cause rapid damage and indicates an ongoing problem requiring immediate attention.'
      };
    }
    
    if (location === 'windows') {
      return {
        cause: 'Window Well Drainage Problems',
        description: 'Poor drainage around basement windows is allowing water to pool and seep through window seals.',
        recommendations: [
          'Clear window well drains',
          'Install or repair window well covers',
          'Improve grading around windows',
          'Seal window frames properly'
        ],
        urgency: 'medium',
        urgencyNote: 'Window well issues are often simpler to fix but can cause significant damage if ignored.'
      };
    }
    
    // Default diagnosis
    return {
      cause: 'Multiple Potential Issues',
      description: 'Your symptoms suggest several possible causes. A professional assessment is needed to determine the exact source.',
      recommendations: [
        'Professional basement inspection',
        'Moisture testing and source identification',
        'Review of drainage systems',
        'Comprehensive waterproofing plan'
      ],
      urgency: 'medium',
      urgencyNote: 'Professional diagnosis will save time and money by identifying the correct solution.'
    };
  }

  // FAQ toggle functionality
  function toggleFAQ(button) {
    const content = button.nextElementSibling;
    const arrow = button.querySelector('svg');
    
    if (content.classList.contains('hidden')) {
      content.classList.remove('hidden');
      arrow.classList.add('rotate-180');
    } else {
      content.classList.add('hidden');
      arrow.classList.remove('rotate-180');
    }
  }

  // Reset diagnostic tool function
  function resetDiagnostic() {
    currentQuestion = 1;
    answers = {};
    
    // Reset all questions
    document.querySelectorAll('.question-card').forEach((card, index) => {
      if (index === 0) {
        card.classList.remove('hidden');
      } else {
        card.classList.add('hidden');
      }
    });
    
    // Reset all options
    document.querySelectorAll('.diagnostic-option').forEach(option => {
      option.classList.remove('bg-amber-500', 'border-cyan-500');
      option.classList.add('bg-slate-50', 'border-slate-300');
    });
    
    // Hide results
    document.getElementById('diagnostic-results').classList.add('hidden');
  }
</script>