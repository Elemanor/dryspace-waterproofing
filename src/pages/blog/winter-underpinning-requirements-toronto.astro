  <!-- JavaScript for Calculators -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Heating Requirements Calculator
      const calculateBtn = document.getElementById('calculateHeating');
      const resultsDiv = document.getElementById('heatingResults');
      
      if (calculateBtn) {
        calculateBtn.addEventListener('click', function() {
          const area = parseFloat(document.getElementById('basementArea').value) || 800;
          const outsideTemp = parseFloat(document.getElementById('outsideTemp').value) || -10;
          
          // Calculate heat loss and requirements
          const tempDiff = 20 - outsideTemp; // Target 20°C inside
          const btuPerSqFt = tempDiff * 1.5; // Simplified calculation
          const totalBtu = Math.round(area * btuPerSqFt);
          
          // Calculate heater requirements
          const heaterSize = 50000; // 50,000 BTU heater
          const heatersNeeded = Math.ceil(totalBtu / heaterSize);
          
          // Calculate propane usage (1 lb propane = 21,600 BTU)
          const dailyBtu = totalBtu * 24;
          const propaneDaily = Math.round(dailyBtu / 21600);
          
          // Calculate cost (propane ~$1.20/lb)
          const weeklyCost = Math.round(propaneDaily * 7 * 1.20);
          
          // Display results
          document.getElementById('btuRequired').textContent = totalBtu.toLocaleString();
          document.getElementById('heaterCount').textContent = `${heatersNeeded} x 50,000 BTU heaters`;
          document.getElementById('propaneDaily').textContent = propaneDaily;
          document.getElementById('heatingCost').textContent = `$${weeklyCost}`;
          
          resultsDiv.classList.remove('hidden');
        });
      }
    });
  </script>
