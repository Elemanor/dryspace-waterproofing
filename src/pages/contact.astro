---
import PageLayout from '../layouts/PageLayout.astro';
import CTABand from '../components/sections/CTABand.astro';

const serviceTypes = [
  'Interior Waterproofing',
  'Exterior Waterproofing',
  'Foundation Crack Repair',
  'Sump Pump Installation',
  'French Drain System',
  'Basement Lowering',
  'Emergency Water Removal',
  'Not Sure - Need Assessment'
];
---

<PageLayout
  title="Contact Us - Free Waterproofing Estimate Toronto | 24/7 Emergency | Dryspace"
  description="Get your free waterproofing estimate. 24/7 emergency service, same-day response, lifetime warranty. Call 437-545-0067 or request your inspection online."
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-hero overflow-hidden section-padding">
    <div class="absolute inset-0 bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900 opacity-95"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-cyan-500/20 via-transparent to-transparent"></div>

    <div class="relative z-10 container mx-auto px-4 max-w-4xl text-center reveal">
      <div class="inline-block mb-6">
        <span class="section-label-pill">24/7 Emergency Service Available</span>
      </div>

      <h1 class="text-headline mb-6">
        Get in Touch
      </h1>

      <p class="text-xl md:text-2xl text-slate-200 mb-8 max-w-2xl mx-auto">
        Free inspections, honest quotes, and rapid response when you need it most.
        Our team is ready to protect your home.
      </p>

      <div class="flex flex-wrap justify-center gap-6 text-sm text-slate-300">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>Free Inspections</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>Same-Day Response</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
          </svg>
          <span>Lifetime Warranty</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Contact Section -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="grid lg:grid-cols-3 gap-8">

        <!-- Contact Form (Left - 2 columns) -->
        <div class="lg:col-span-2">
          <div class="card-base reveal">
            <div class="border-b border-slate-200 pb-6 mb-8">
              <h2 class="text-3xl font-bold text-navy-900 mb-2">Request Your Free Inspection</h2>
              <p class="text-slate-600">Fill out the form below and we'll respond within 2 hours</p>
            </div>

            <form action="/api/contact" method="POST" class="space-y-6">
              <!-- Name -->
              <div>
                <label for="name" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                  Full Name *
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20"
                  placeholder="John Smith"
                />
              </div>

              <!-- Email & Phone Row -->
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label for="email" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                    Email *
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20"
                    placeholder="john@example.com"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                    Phone *
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20"
                    placeholder="437-545-0067"
                  />
                </div>
              </div>

              <!-- Service Type -->
              <div>
                <label for="service" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                  Service Type *
                </label>
                <select
                  id="service"
                  name="service"
                  required
                  class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20"
                >
                  <option value="">Select a service</option>
                  {serviceTypes.map(service => (
                    <option value={service}>{service}</option>
                  ))}
                </select>
              </div>

              <!-- Urgency -->
              <div>
                <label for="urgency" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                  Urgency Level *
                </label>
                <select
                  id="urgency"
                  name="urgency"
                  required
                  class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20"
                >
                  <option value="">Select urgency</option>
                  <option value="emergency">Emergency - Water in Basement Now</option>
                  <option value="urgent">Urgent - Within 24-48 Hours</option>
                  <option value="within-week">Within a Week</option>
                  <option value="routine">Routine - Just Getting Quotes</option>
                </select>
              </div>

              <!-- Message -->
              <div>
                <label for="message" class="block text-sm font-semibold text-navy-900 mb-2 uppercase tracking-wide">
                  Message
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  class="w-full rounded-lg border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 placeholder:text-slate-400 focus:border-cyan-500 focus:outline-none focus:ring-2 focus:ring-cyan-500/20 resize-none"
                  placeholder="Tell us about your waterproofing needs..."
                ></textarea>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn-primary w-full text-lg">
                Send Message
              </button>

              <p class="text-xs text-center text-slate-500">
                We respect your privacy. Your information will never be shared.
              </p>
            </form>
          </div>
        </div>

        <!-- Contact Info (Right - 1 column) -->
        <div class="lg:col-span-1 space-y-6">

          <!-- Quick Contact Card -->
          <div class="card-base bg-gradient-to-br from-navy-900 to-navy-800 text-white reveal">
            <h3 class="text-xl font-bold mb-4 uppercase tracking-wide">Need Immediate Help?</h3>

            <a
              href="tel:437-545-0067"
              class="flex items-center justify-center gap-3 bg-amber-500 hover:bg-amber-400 text-navy-900 font-bold py-4 px-6 rounded-lg transition-all duration-300 mb-6 group"
            >
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
              </svg>
              <span class="text-xl">437-545-0067</span>
            </a>

            <div class="space-y-3 text-sm">
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                </svg>
                <a href="mailto:p.vysotckii@gmail.com" class="hover:text-cyan-500 transition-colors">
                  p.vysotckii@gmail.com
                </a>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Mon-Fri: 7AM-8PM</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <div>
                  <span class="block">260 Wellesley Street East</span>
                  <span class="block">Toronto, ON M4X 1G6</span>
                  <span class="block text-slate-500 text-xs mt-1">Serving the Greater Toronto Area</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Google Maps Placeholder -->
          <div class="card-base p-0 overflow-hidden reveal">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2886.6!2d-79.3700!3d43.6680!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89d4cb3b2bfcb14f%3A0x0!2s260+Wellesley+St+E%2C+Toronto%2C+ON+M4X+1G6!5e0!3m2!1sen!2sca!4v1679512345678!5m2!1sen!2sca"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="DrySpace Waterproofing - 260 Wellesley Street East, Toronto"
            ></iframe>
          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <CTABand />

</PageLayout>

<script>
  // Form submission handler
  const form = document.querySelector('form[action="/api/contact"]');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form as HTMLFormElement);
      const urgency = formData.get('urgency');

      // Show appropriate message based on urgency
      if (urgency === 'emergency') {
        alert('Emergency request received! A technician will contact you within 60 minutes. If you need immediate assistance, please call 437-545-0067.');
      } else if (urgency === 'urgent') {
        alert('Urgent request received! We will contact you within 2 hours during business hours.');
      } else {
        alert('Thank you for your message! We will respond within 24 hours with your free estimate.');
      }

      // Reset form
      (form as HTMLFormElement).reset();
    });
  }
</script>
