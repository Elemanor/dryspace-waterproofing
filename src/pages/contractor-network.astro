                  <h3 class="text-2xl font-bold text-slate-900 mb-2">Dryspace Waterproofing</h3>
                  <div class="flex items-center mb-2">
                    <div class="flex text-amber-400">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
