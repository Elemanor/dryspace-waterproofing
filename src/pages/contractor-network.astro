---
import Layout from '../layouts/Layout.astro';
import TrustBadges from '../components/TrustBadges.astro';

const title = "Verified Waterproofing Contractor Network | Toronto & GTA | Dryspace";
const description = "Browse our network of licensed, insured, and certified waterproofing contractors. View specialties, response times, and completed jobs for the Greater Toronto Area.";
---

<Layout title={title} description={description}>
  <!-- Hero Section -->
  <section class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <h1 class="text-5xl font-bold mb-6">Verified Contractor Network</h1>
        <p class="text-xl mb-8 max-w-3xl mx-auto">
          Connect with licensed, insured, and certified waterproofing professionals across the Greater Toronto Area.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#find-contractor" class="bg-white text-cyan-600 px-8 py-4 rounded-lg font-bold text-lg hover:bg-slate-50 transition-colors">
            Find Contractor
          </a>
          <a href="/emergency-marketplace" class="bg-red-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-red-700 transition-colors">
            Emergency Service
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Network Stats -->
  <section class="py-16 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-4xl font-bold text-cyan-600 mb-2">15+</div>
          <div class="text-lg font-semibold text-slate-900">Verified Contractors</div>
          <div class="text-sm text-slate-500">All licensed & insured</div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-4xl font-bold text-cyan-600 mb-2">4.8</div>
          <div class="text-lg font-semibold text-slate-900">Average Rating</div>
          <div class="text-sm text-slate-500">Based on 1,200+ reviews</div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-4xl font-bold text-orange-600 mb-2">&lt;4hr</div>
          <div class="text-lg font-semibold text-slate-900">Response Time</div>
          <div class="text-sm text-slate-500">Average network response</div>
        </div>
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="text-4xl font-bold text-purple-600 mb-2">2,500+</div>
          <div class="text-lg font-semibold text-slate-900">Jobs Completed</div>
          <div class="text-sm text-slate-500">This year alone</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Filter Options -->
  <section id="find-contractor" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-slate-900 mb-4">Find the Right Contractor</h2>
        <p class="text-xl text-slate-500">Filter by specialty, location, and availability</p>
      </div>
      
      <!-- Filter Controls -->
      <div class="bg-slate-50 rounded-lg p-6 mb-8">
        <div class="grid md:grid-cols-4 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Specialty</label>
            <select class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500" id="specialty-filter">
              <option value="">All Specialties</option>
              <option value="exterior">Exterior Waterproofing</option>
              <option value="interior">Interior Waterproofing</option>
              <option value="foundation">Foundation Repair</option>
              <option value="emergency">Emergency Response</option>
              <option value="drainage">Drainage Systems</option>
              <option value="sump">Sump Pump Services</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Location</label>
            <select class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500" id="location-filter">
              <option value="">All GTA</option>
              <option value="toronto">Toronto</option>
              <option value="mississauga">Mississauga</option>
              <option value="brampton">Brampton</option>
              <option value="vaughan">Vaughan</option>
              <option value="markham">Markham</option>
              <option value="richmond-hill">Richmond Hill</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Availability</label>
            <select class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500" id="availability-filter">
              <option value="">Any Time</option>
              <option value="immediate">Immediate (Emergency)</option>
              <option value="same-day">Same Day</option>
              <option value="within-week">Within Week</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-600 mb-2">Rating</label>
            <select class="w-full px-3 py-2 border border-slate-200 rounded-lg focus:ring-2 focus:ring-blue-500" id="rating-filter">
              <option value="">Any Rating</option>
              <option value="4.5">4.5+ Stars</option>
              <option value="4.0">4.0+ Stars</option>
              <option value="3.5">3.5+ Stars</option>
            </select>
          </div>
        </div>
        <div class="mt-4 text-center">
          <button class="bg-cyan-600 text-white px-6 py-2 rounded-lg hover:bg-cyan-700 transition-colors" onclick="applyFilters()">
            Apply Filters
          </button>
          <button class="bg-slate-500 text-white px-6 py-2 rounded-lg hover:bg-slate-600 transition-colors ml-2" onclick="clearFilters()">
            Clear All
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Contractor Profiles -->
  <section class="pb-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div id="contractors-grid" class="space-y-8">
        <!-- Dryspace Waterproofing (Featured) -->
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg shadow-lg p-8 border-2 border-cyan-200 contractor-card" 
             data-specialty="exterior interior foundation emergency drainage sump" 
             data-location="toronto mississauga brampton vaughan markham richmond-hill"
             data-availability="immediate"
             data-rating="4.9">
          <div class="flex flex-col lg:flex-row">
            <div class="lg:w-1/4 mb-6 lg:mb-0">
              <div class="w-24 h-24 bg-cyan-600 rounded-full flex items-center justify-center mx-auto lg:mx-0">
                <span class="text-white text-2xl font-bold">S</span>
              </div>
              <div class="text-center lg:text-left mt-4">
                <div class="bg-cyan-600 text-white px-3 py-1 rounded-full text-sm font-semibold inline-block">
