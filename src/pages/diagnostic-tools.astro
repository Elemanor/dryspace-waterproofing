<!-- Assessment Calculator Script -->
<script>
const riskLevels = [
  {
    range: [80, 100],
    level: "CRITICAL RISK",
    color: "red",
    action: "Emergency professional service needed immediately",
    timeline: "Call now - same day service required"
  },
  {
    range: [60, 79], 
    level: "HIGH RISK",
    color: "orange",
    action: "Professional assessment needed within 1 week",
    timeline: "Schedule professional inspection immediately"
  },
  {
    range: [40, 59],
    level: "MODERATE RISK", 
    color: "yellow",
    action: "Professional consultation recommended within 1 month",
    timeline: "Monitor closely and schedule non-emergency assessment"
  },
  {
    range: [20, 39],
    level: "LOW RISK",
    color: "green", 
    action: "Continue monitoring, consider preventive maintenance",
    timeline: "Annual professional inspection recommended"
  },
  {
    range: [0, 19],
    level: "MINIMAL RISK",
    color: "blue",
    action: "Good foundation health, maintain current care", 
    timeline: "Routine maintenance and seasonal checks"
  }
];

function calculateRisk() {
  let totalScore = 0;
  let answeredQuestions = 0;
  const formElements = document.querySelectorAll('input[type="radio"]:checked');
  
  if (formElements.length === 0) {
    alert('Please answer at least one question to get an assessment.');
    return;
  }
  
  formElements.forEach(element => {
    totalScore += parseInt(element.value);
    answeredQuestions++;
  });
  
  // Calculate percentage score
  const maxPossibleScore = answeredQuestions * 10;
  const riskScore = Math.round((totalScore / maxPossibleScore) * 100);
  
  // Find appropriate risk level
  const riskLevel = riskLevels.find(level => 
    riskScore >= level.range[0] && riskScore <= level.range[1]
  );
  
  // Display results
  const resultsDiv = document.getElementById('assessment-results');
  const scoreElement = document.getElementById('risk-score');
  const levelElement = document.getElementById('risk-level'); 
  const descriptionElement = document.getElementById('risk-description');
  const actionElement = document.getElementById('risk-action');
  const timelineElement = document.getElementById('action-timeline');
  
  scoreElement.textContent = riskScore + '%';
  levelElement.textContent = riskLevel.level;
  levelElement.className = `text-2xl font-bold mb-4 uppercase text-${riskLevel.color}-600`;
  descriptionElement.textContent = riskLevel.action;
  actionElement.textContent = riskLevel.timeline;
  timelineElement.textContent = riskLevel.timeline;
  
  resultsDiv.classList.remove('hidden');
  resultsDiv.scrollIntoView({ behavior: 'smooth' });
}
</script>