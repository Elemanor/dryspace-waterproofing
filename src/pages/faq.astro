---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import CTABand from '../components/sections/CTABand.astro';

const metadata = {
  title: 'Frequently Asked Questions | Dryspace Waterproofing Toronto',
  description: 'Get answers to common questions about basement waterproofing, foundation repair, costs, warranties, and our services in Toronto and the GTA.',
  canonical: 'https://dryspacewaterproofing.ca/faq'
};

const faqs = [
  {
    category: "General",
    id: "general",
    questions: [
      {
        question: "How long does basement waterproofing take?",
        answer: "Most residential basement waterproofing projects are completed within 2-3 days. Interior systems typically take 1-2 days, while exterior waterproofing may require 3-5 days. We'll provide a detailed timeline during your free inspection."
      },
      {
        question: "Is basement waterproofing worth the investment?",
        answer: "Absolutely. Waterproofing protects your home's foundation, prevents costly water damage ($10,000+ average repair cost), eliminates mold growth health risks, and can increase your property value by up to 30%. Most homeowners see ROI within 3-5 years."
      },
      {
        question: "Do you work year-round in Toronto?",
        answer: "Yes, we operate 365 days a year. Our techniques are designed for Canadian weather conditions. Interior waterproofing can be done any time, and we use special materials for exterior work in cold weather."
      },
      {
        question: "How do I know if I need waterproofing?",
        answer: "Warning signs include: water stains or puddles in basement, musty odors or visible mold, white powder on walls (efflorescence), cracks in walls or floors, humidity over 60%, peeling paint, windows fogging up, or doors sticking. Any of these indicate moisture problems."
      },
      {
        question: "What causes basement water problems?",
        answer: "Common causes include: poor drainage around foundation, clogged or damaged weeping tiles, hydrostatic pressure from groundwater, foundation cracks, inadequate grading, clogged gutters, window well issues, and Toronto's clay soil expansion."
      },
      {
        question: "Can I waterproof my basement myself?",
        answer: "While minor repairs like small crack sealing can be DIY, professional waterproofing is recommended because it requires specialized equipment, proper drainage design, warranty protection, and building code compliance. DIY attempts often fail and can void insurance."
      },
      {
        question: "What's the best time of year to waterproof?",
        answer: "Spring and summer are ideal for exterior work, but we waterproof year-round. Interior systems can be installed any time. Don't wait if you have active water problems - emergency services are available 24/7."
      },
      {
        question: "How long have you been in business?",
        answer: "Dryspace has been protecting Toronto homes since 1999. With over 25 years of experience and 10,000+ completed projects, we're one of the GTA's most trusted waterproofing contractors."
      }
    ]
  },
  {
    category: "Waterproofing",
    id: "waterproofing",
    questions: [
      {
        question: "Interior vs. Exterior waterproofing - which is better?",
        answer: "Both have advantages. Interior systems manage water efficiently and are less invasive/expensive. Exterior waterproofing provides the ultimate protection by stopping water before it reaches walls. We often recommend a combination approach for complete protection."
      },
      {
        question: "Can you waterproof a finished basement?",
        answer: "Yes! We specialize in waterproofing finished basements with minimal disruption. Our interior drainage systems can be installed along the perimeter without removing all finishes. We protect your belongings and clean up completely."
      },
      {
        question: "What is a French drain system?",
        answer: "A French drain is a perforated pipe installed around your foundation's perimeter to collect and redirect water. It's surrounded by gravel, connects to a sump pump, and effectively manages groundwater. Essential for Toronto's high water table areas."
      },
      {
        question: "What's the difference between weeping tile and French drain?",
        answer: "Weeping tile is the older term for foundation drainage (originally clay tiles). French drains are the modern version using perforated PVC pipe. Both serve the same purpose - managing water around your foundation. We install modern French drain systems."
      },
      {
        question: "Do I need a sump pump?",
        answer: "Sump pumps are essential if you have: high water table, history of flooding, below-grade living space, or interior drainage system. We recommend battery backup systems for power outages - crucial during storms when you need them most."
      },
      {
        question: "What is efflorescence?",
        answer: "Efflorescence is the white, powdery substance on basement walls. It's mineral deposits left when water evaporates, indicating moisture penetration. While not harmful itself, it signals water problems that need addressing."
      }
    ]
  },
  {
    category: "Foundation",
    id: "foundation",
    questions: [
      {
        question: "What is foundation underpinning?",
        answer: "Underpinning strengthens and stabilizes foundations by extending them deeper. It's needed for basement lowering, foundation settlement repair, or adding basement apartments. We're certified for all underpinning methods."
      },
      {
        question: "Can you fix foundation cracks?",
        answer: "Yes, we repair all types of foundation cracks using epoxy injection, polyurethane injection, or exterior excavation depending on crack type and severity. We identify the cause to prevent recurrence."
      }
    ]
  },
  {
    category: "Costs",
    id: "costs",
    questions: [
      {
        question: "How much does waterproofing cost?",
        answer: "Costs vary based on your specific needs: Interior waterproofing ($3,500-$8,000), Exterior waterproofing ($8,000-$15,000), Crack repairs ($500-$1,500), Sump pump installation ($1,200-$2,500). We provide free detailed quotes with no hidden fees."
      },
      {
        question: "Do you offer financing options?",
        answer: "Yes! We offer flexible financing with: 0% interest for 12 months OAC, Plans starting at $99/month, Instant approval process, No prepayment penalties. We work with multiple lenders to get you the best rates."
      },
      {
        question: "Does insurance cover waterproofing?",
        answer: "While preventive waterproofing typically isn't covered, water damage repairs often are. We work directly with insurance companies, provide detailed documentation for claims, and can help you understand your coverage options."
      },
      {
        question: "Are there government rebates available?",
        answer: "Yes! Toronto offers up to $3,400 through the Basement Flooding Protection Subsidy Program. We help you apply for all available rebates including City of Toronto subsidies, backwater valve rebates, and sump pump rebates."
      },
      {
        question: "Do you require a deposit?",
        answer: "We require a small 10% deposit to schedule your project, with the balance due upon completion. For emergency services, no deposit is required. We accept cash, cheque, credit cards, and e-transfer."
      },
      {
        question: "Can I get a quote over the phone?",
        answer: "We can provide rough estimates by phone, but accurate quotes require an on-site inspection. Every home is unique, and we need to assess the specific conditions, measure the area, and identify the best solution."
      },
      {
        question: "Why are quotes so different between companies?",
        answer: "Price variations often reflect differences in: scope of work, quality of materials, warranty terms, company reputation, and insurance/licensing. Be wary of extremely low quotes - they often lead to additional charges or substandard work."
      },
      {
        question: "Is waterproofing tax deductible?",
        answer: "Waterproofing may qualify for tax benefits if it's medical-related (mold remediation), part of rental property maintenance, or home office improvements. Consult your tax advisor. We provide detailed invoices for tax purposes."
      }
    ]
  },
  {
    category: "Warranty",
    id: "warranty",
    questions: [
      {
        question: "What's included in your 25-year warranty?",
        answer: "Our comprehensive 25-year warranty covers all materials and workmanship, is fully transferable to new homeowners (adds resale value), includes annual inspections, and provides 24/7 emergency support. No hidden fees or deductibles."
      },
      {
        question: "Are you licensed and insured?",
        answer: "Yes, we're fully licensed by the City of Toronto (License #BW-2019-3847), carry $5 million liability insurance, are WSIB compliant, and all our technicians are certified waterproofing specialists with 5+ years minimum experience."
      },
      {
        question: "What areas do you service?",
        answer: "We service all of Greater Toronto Area including Toronto, North York, Scarborough, Etobicoke, Mississauga, Brampton, Vaughan, Richmond Hill, Markham, and Oakville. Same-day service available for emergencies."
      },
      {
        question: "Do you offer free inspections?",
        answer: "Yes, we provide completely free, no-obligation inspections. Our certified inspector will assess your property, identify issues, explain solutions, and provide a detailed written quote. The inspection typically takes 45-60 minutes."
      },
      {
        question: "What if the problem returns after repair?",
        answer: "Our warranty covers this. If any issue we've addressed returns, we fix it free of charge. We also provide annual inspections to catch potential problems early. Our goal is permanent solutions, not repeat visits."
      },
      {
        question: "Do you clean up after the work?",
        answer: "Absolutely. Our service includes complete cleanup. We protect your property during work, remove all debris, restore landscaping where applicable, and leave your home cleaner than we found it. No mess left behind."
      },
      {
        question: "Can you work with my contractor/renovation?",
        answer: "Yes, we regularly coordinate with general contractors, renovation teams, and other trades. We can schedule our work to fit your renovation timeline and ensure proper integration with other improvements."
      }
    ]
  },
  {
    category: "Emergency",
    id: "emergency",
    questions: [
      {
        question: "Do you offer 24/7 emergency service?",
        answer: "Yes, we provide 24/7 emergency response for flooding, major leaks, and foundation emergencies. Our emergency team can arrive within 2 hours anywhere in the GTA. Call 437-545-0067 anytime."
      },
      {
        question: "My basement is flooding right now - what should I do?",
        answer: "1) Turn off electricity to the basement, 2) Stop water source if possible, 3) Move valuables to safety, 4) Document damage for insurance, 5) Call us immediately at 437-545-0067. Don't enter deep water - wait for professionals."
      },
      {
        question: "How quickly can you respond to emergencies?",
        answer: "Our emergency response time is typically under 2 hours in the GTA. We have crews on-call 24/7 with fully equipped trucks. Priority goes to active flooding situations."
      },
      {
        question: "What's included in emergency service?",
        answer: "Emergency service includes: immediate water extraction, temporary water diversion, emergency repairs to stop active leaks, setting up drying equipment, and planning permanent solutions. We bill insurance directly when applicable."
      },
      {
        question: "Is emergency service more expensive?",
        answer: "Emergency rates apply outside business hours, but we focus on stopping damage quickly to minimize overall costs. Many insurance policies cover emergency water damage response. We provide detailed documentation for claims."
      },
      {
        question: "What happens during the free inspection?",
        answer: "Our certified inspector will: examine interior and exterior foundation, test humidity levels, check grading and drainage, identify water entry points, explain findings in detail, provide written quote, and answer all questions. Takes about 45-60 minutes."
      },
      {
        question: "How do I prepare for waterproofing work?",
        answer: "Clear 3-4 feet from basement walls, move stored items to center, remove wall hangings, and ensure access to electrical panel. For exterior work, we'll need 10-12 feet clearance around foundation. We'll help with heavy items."
      },
      {
        question: "Will you need permits?",
        answer: "We handle all necessary permits. Most waterproofing doesn't require permits, but underpinning, structural work, and some exterior excavations do. Permit costs are included in our quotes when required."
      },
      {
        question: "How disruptive is the work?",
        answer: "Interior waterproofing is minimally disruptive - you can stay home. Exterior work is noisier but outside. We maintain clean, safe work areas, protect your property, and clean up daily. Most projects complete in 2-3 days."
      },
      {
        question: "Can I stay in my home during work?",
        answer: "Yes, you can stay home during waterproofing. We section off work areas, control dust, maintain safe pathways, and ensure utilities remain functional. Many clients go about normal routines during our work."
      },
      {
        question: "What if you find additional problems?",
        answer: "We'll stop work, explain findings, provide options and costs, and proceed only with your approval. No surprise charges. Our detailed inspections minimize unexpected issues, but we're transparent if anything arises."
      }
    ]
  }
];
---

<PageLayout metadata={metadata}>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-navy-900 via-slate-800 to-navy-900 section-padding overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(6, 182, 212, 0.15) 1px, transparent 0); background-size: 32px 32px;"></div>
    </div>
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center reveal">
        <div class="inline-flex items-center gap-2 section-label-pill mb-6">
          <span class="w-2 h-2 bg-cyan-500 rounded-full"></span>
          <span>Knowledge Base</span>
        </div>
        <h1 class="text-headline mb-6">
          Frequently Asked Questions
        </h1>
        <p class="text-xl md:text-2xl text-slate-300 mb-12 leading-relaxed">
          Everything you need to know about basement waterproofing, foundation repair, and protecting your Toronto home
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="btn-primary">
            Get Free Inspection
          </a>
          <a href="tel:437-545-0067" class="btn-secondary">
            <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Category Filter Pills -->
  <section class="bg-slate-50 py-6 border-b border-slate-200 sticky top-0 z-40 backdrop-blur-sm bg-opacity-95">
    <div class="container mx-auto px-4">
      <div class="flex gap-3 overflow-x-auto pb-2 -mb-2" style="scrollbar-width: thin; scrollbar-color: #06b6d4 #e2e8f0;">
        {faqs.map((category) => (
          <a
            href={`#${category.id}`}
            class="category-pill rounded-full border border-slate-200 px-4 py-2 text-sm font-medium whitespace-nowrap transition-all hover:border-cyan-500 hover:text-cyan-600 scroll-smooth"
            data-category={category.id}
          >
            {category.category}
            <span class="ml-2 inline-flex items-center justify-center w-6 h-6 text-xs font-bold rounded-full bg-slate-200 text-slate-700">
              {category.questions.length}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Sections -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto space-y-16">
        {faqs.map((category) => (
          <div id={category.id} class="scroll-mt-24">
            <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-8 flex items-center gap-3">
              <span class="w-2 h-8 bg-cyan-500 rounded-full"></span>
              {category.category}
            </h2>
            {category.id === 'general' && (
              <p class="speakable mb-8 text-lg leading-relaxed"><strong>The most common basement waterproofing questions in Toronto: exterior systems cost $150–$300/ft, interior drainage costs $80–$200/ft, most projects take 3–5 days, and up to $3,400 in city rebates are available.</strong></p>
            )}
            <div class="space-y-4">
              {category.questions.map((faq) => (
                <details class="group border border-slate-200 rounded-lg overflow-hidden transition-all hover:border-cyan-500 hover:shadow-md">
                  <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer select-none bg-white transition-colors group-hover:bg-slate-50">
                    <h3 class="text-lg font-semibold text-navy-900 flex-1">{faq.question}</h3>
                    <div class="flex-shrink-0 w-8 h-8 rounded-full bg-slate-100 flex items-center justify-center transition-all group-open:bg-cyan-500 group-open:rotate-180">
                      <svg class="w-5 h-5 text-slate-600 group-open:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                      </svg>
                    </div>
                  </summary>
                  <div class="px-6 pb-6 pt-2">
                    <div class="border-t border-slate-200 pt-4">
                      <p class="text-slate-600 leading-relaxed">{faq.answer}</p>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Still Have Questions Section -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Need Help?"
        title="Still have questions?"
        description="Our waterproofing experts are standing by to answer any questions about your specific situation"
        centered={true}
      />

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto mt-12">
        <!-- Contact Card -->
        <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 rounded-full bg-cyan-500/10 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy-900 mb-4">Can't find your answer?</h3>
          <p class="text-slate-600 mb-6 leading-relaxed">
            Get personalized advice for your home. Our experts are ready to answer any questions about your specific situation.
          </p>
          <a href="/contact" class="btn-primary inline-flex items-center">
            Contact Our Experts
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
        </div>

        <!-- Emergency Card -->
        <div class="bg-gradient-to-br from-red-500 to-red-600 rounded-xl p-8 shadow-md hover:shadow-lg transition-shadow text-white">
          <div class="w-12 h-12 rounded-full bg-white/20 flex items-center justify-center mb-6">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold mb-4">Emergency Water Problem?</h3>
          <p class="text-red-50 mb-6 leading-relaxed">
            Don't wait! We offer 24/7 emergency services for flooding, major leaks, and foundation emergencies.
          </p>
          <a href="tel:437-545-0067" class="inline-flex items-center gap-2 bg-white text-red-600 px-6 py-3 rounded-lg font-bold hover:bg-red-50 transition-colors shadow-lg">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call Emergency Line
          </a>
        </div>
      </div>

      <!-- Service Areas -->
      <div class="mt-16 max-w-5xl mx-auto">
        <h3 class="text-2xl md:text-3xl font-bold text-navy-900 mb-8 text-center">We Serve All of Greater Toronto</h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
          {['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'Oakville', 'Burlington', 'Hamilton', 'Scarborough', 'North York', 'Etobicoke'].map((city) => (
            <a
              href={`/locations/${city.toLowerCase().replace(' ', '-')}`}
              class="text-center p-4 bg-white rounded-lg border border-slate-200 hover:border-cyan-500 hover:shadow-md transition-all group"
            >
              <span class="text-slate-700 font-medium group-hover:text-cyan-600 transition-colors">{city}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <CTABand />

  <!-- Schema Markup for FAQ Page -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How much does basement waterproofing cost in Toronto?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Basement waterproofing in Toronto typically costs between $3,500 to $8,000 for interior solutions and $8,000 to $15,000 for exterior waterproofing. The exact cost depends on the size of your basement, severity of water issues, and chosen waterproofing method."
        }
      },
      {
        "@type": "Question",
        "name": "What is your warranty coverage?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We offer a 25-year transferable warranty on all exterior waterproofing work. This comprehensive warranty covers materials and workmanship, can be transferred to new homeowners, and includes free inspections."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer emergency services?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we provide 24/7 emergency waterproofing services throughout the Greater Toronto Area. Our emergency team can respond within 2 hours for urgent flooding, major leaks, and foundation emergencies."
        }
      },
      {
        "@type": "Question",
        "name": "How long does waterproofing take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Interior waterproofing typically takes 2-3 days, while exterior waterproofing can take 5-7 days depending on the size of your home and extent of work required. We minimize disruption and keep you informed throughout the process."
        }
      },
      {
        "@type": "Question",
        "name": "Are there government rebates available?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Toronto offers rebates up to $3,400 for basement flooding protection through the Basement Flooding Protection Subsidy Program. We help our clients apply for all available rebates and subsidies."
        }
      }
    ]
  })}></script>
</PageLayout>

<script>
  // Category pill active state on scroll
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          document.querySelectorAll('.category-pill').forEach((pill) => {
            pill.classList.remove('bg-cyan-500', 'text-white', 'border-cyan-500');
            pill.classList.add('border-slate-200');
          });
          const activePill = document.querySelector(`.category-pill[data-category="${id}"]`);
          if (activePill) {
            activePill.classList.add('bg-cyan-500', 'text-white', 'border-cyan-500');
            activePill.classList.remove('border-slate-200');
          }
        }
      });
    },
    {
      rootMargin: '-20% 0px -70% 0px',
      threshold: 0
    }
  );

  document.querySelectorAll('[id]').forEach((section) => {
    if (section.hasAttribute('id') && faqs.some(cat => cat.id === section.id)) {
      observer.observe(section);
    }
  });

  // Smooth scroll for category pills
  document.querySelectorAll('.category-pill').forEach((pill) => {
    pill.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = pill.getAttribute('data-category');
      const target = document.getElementById(targetId);
      if (target) {
        const offset = 100;
        const targetPosition = target.offsetTop - offset;
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
      }
    });
  });

  // FAQ data for intersection observer
  const faqs = [
    { id: "general" },
    { id: "waterproofing" },
    { id: "foundation" },
    { id: "costs" },
    { id: "warranty" },
    { id: "emergency" }
  ];
</script>
