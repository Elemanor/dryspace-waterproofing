  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Calculator elements
      const projectCostSlider = document.getElementById('projectCostSlider');
      const projectCostInput = document.getElementById('projectCost');
      const downPaymentSlider = document.getElementById('downPaymentSlider');
      const downPaymentInput = document.getElementById('downPayment');
      const termRadios = document.querySelectorAll('input[name="term"]');
      const paymentOptions = document.querySelectorAll('.payment-option');
      
      // Display elements
      const displayProjectCost = document.getElementById('displayProjectCost');
      const displayDownPayment = document.getElementById('displayDownPayment');
      const displayFinanceAmount = document.getElementById('displayFinanceAmount');
      
      // Payment display elements
      const payment12 = document.getElementById('payment12');
      const payment24 = document.getElementById('payment24');
      const payment36 = document.getElementById('payment36');
      const payment60 = document.getElementById('payment60');
      const payment120 = document.getElementById('payment120');
      
      const interest12 = document.getElementById('interest12');
      const interest24 = document.getElementById('interest24');
      const interest36 = document.getElementById('interest36');
      const interest60 = document.getElementById('interest60');
      const interest120 = document.getElementById('interest120');
      
      const total12 = document.getElementById('total12');
      const total24 = document.getElementById('total24');
      const total36 = document.getElementById('total36');
      const total60 = document.getElementById('total60');
      const total120 = document.getElementById('total120');
      
      // Interest rates
      const rates = {
        12: 0.00,   // 0%
        24: 0.039,  // 3.9%
        36: 0.049,  // 4.9%
        60: 0.069,  // 6.9%
        120: 0.089  // 8.9%
      };
      
      // Sync sliders with inputs
      projectCostSlider.addEventListener('input', function() {
        projectCostInput.value = this.value;
        updateCalculator();
      });
      
      projectCostInput.addEventListener('input', function() {
        projectCostSlider.value = this.value;
        updateCalculator();
      });
      
      downPaymentSlider.addEventListener('input', function() {
        downPaymentInput.value = this.value;
        updateDownPaymentMax();
        updateCalculator();
      });
      
      downPaymentInput.addEventListener('input', function() {
        downPaymentSlider.value = this.value;
        updateCalculator();
      });
      
      // Update down payment maximum based on project cost
      function updateDownPaymentMax() {
        const projectCost = parseInt(projectCostInput.value);
        const maxDownPayment = Math.floor(projectCost * 0.5); // Max 50% down
        downPaymentSlider.max = maxDownPayment;
        downPaymentInput.max = maxDownPayment;
        
        if (parseInt(downPaymentInput.value) > maxDownPayment) {
          downPaymentSlider.value = maxDownPayment;
          downPaymentInput.value = maxDownPayment;
        }
      }
      
      // Cost preset buttons
      const costPresets = document.querySelectorAll('.cost-preset');
      costPresets.forEach(preset => {
        preset.addEventListener('click', function() {
          const cost = this.dataset.cost;
          projectCostSlider.value = cost;
          projectCostInput.value = cost;
          updateDownPaymentMax();
          updateCalculator();
        });
      });
      
      // Term selection
      termRadios.forEach(radio => {
        radio.addEventListener('change', function() {
          updatePaymentOptionsSelection();
          updateCalculator();
        });
      });
      
      // Payment option selection
      paymentOptions.forEach(option => {
        option.addEventListener('click', function() {
          const term = this.dataset.term;
          paymentOptions.forEach(opt => opt.classList.remove('selected'));
          this.classList.add('selected');
          
          // Update radio button
          const radio = document.querySelector(`input[name="term"][value="${term}"]`);
          if (radio) radio.checked = true;
        });
      });
      
      function updatePaymentOptionsSelection() {
        const selectedTerm = document.querySelector('input[name="term"]:checked').value;
        paymentOptions.forEach(option => {
          if (option.dataset.term === selectedTerm) {
            option.classList.add('selected');
          } else {
            option.classList.remove('selected');
          }
        });
      }
      
      function calculatePayment(principal, rate, months) {
        if (rate === 0) {
          return principal / months;
        }
        const monthlyRate = rate / 12;
        return principal * (monthlyRate * Math.pow(1 + monthlyRate, months)) / (Math.pow(1 + monthlyRate, months) - 1);
      }
      
      function updateCalculator() {
        const projectCost = parseInt(projectCostInput.value) || 0;
        const downPayment = parseInt(downPaymentInput.value) || 0;
        const financeAmount = projectCost - downPayment;
        
        // Update display
        displayProjectCost.textContent = '$' + projectCost.toLocaleString();
        displayDownPayment.textContent = '$' + downPayment.toLocaleString();
        displayFinanceAmount.textContent = '$' + financeAmount.toLocaleString();
        
        // Calculate payments for each term
        Object.keys(rates).forEach(months => {
          months = parseInt(months);
          const rate = rates[months];
          const monthlyPayment = calculatePayment(financeAmount, rate, months);
          const totalPayments = monthlyPayment * months;
          const totalInterest = totalPayments - financeAmount;
          
          // Update display elements
          const paymentEl = document.getElementById(`payment${months}`);
          const interestEl = document.getElementById(`interest${months}`);
          const totalEl = document.getElementById(`total${months}`);
          
          if (paymentEl) paymentEl.textContent = '$' + Math.round(monthlyPayment).toLocaleString();
          if (interestEl) interestEl.textContent = '$' + Math.round(totalInterest).toLocaleString();
          if (totalEl) totalEl.textContent = '$' + Math.round(totalPayments).toLocaleString();
        });
      }
      
      // Form submission
      const financingForm = document.getElementById('financingApplication');
      if (financingForm) {
        financingForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          // Basic validation
          const requiredFields = this.querySelectorAll('[required]');
          let isValid = true;
          
          requiredFields.forEach(field => {
            if (!field.value.trim()) {
              field.style.borderColor = 'var(--color-danger)';
              isValid = false;
            } else {
              field.style.borderColor = 'rgba(255, 255, 255, 0.1)';
            }
          });
          
          if (!isValid) {
            alert('Please fill in all required fields.');
            return;
          }
          
          // Simulate form submission
          const submitBtn = this.querySelector('.btn-submit');
          const originalText = submitBtn.innerHTML;
          
          submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing Application...';
          submitBtn.disabled = true;
          
          setTimeout(() => {
            alert('Application submitted successfully! You will receive a decision within minutes.');
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            
            // Simulate redirect to approval page
            // window.location.href = '/financing-approval';
          }, 3000);
        });
      }
      
      // Compare options button
      const compareBtn = document.getElementById('compareOptions');
      if (compareBtn) {
        compareBtn.addEventListener('click', function() {
          // Show all payment options (remove selection highlighting temporarily)
          paymentOptions.forEach(option => {
            option.style.opacity = '1';
            option.style.transform = 'scale(1)';
          });
          
          // Highlight all options briefly
          setTimeout(() => {
            paymentOptions.forEach((option, index) => {
              setTimeout(() => {
                option.style.transform = 'scale(1.02)';
                setTimeout(() => {
                  option.style.transform = 'scale(1)';
                }, 200);
              }, index * 100);
            });
          }, 100);
        });
      }
      
      // Initialize calculator
      updateDownPaymentMax();
      updateCalculator();
      updatePaymentOptionsSelection();
      
      // Animate stats on scroll
      const observerOptions = {
        threshold: 0.5,
        rootMargin: '0px 0px -100px 0px'
      };
      
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const statValues = entry.target.querySelectorAll('.stat-value');
            statValues.forEach((stat, index) => {
              const finalValue = stat.textContent;
              
              if (finalValue.includes('%')) {
                const numValue = parseInt(finalValue);
                animateValue(stat, 0, numValue, 1000, '', '%');
              } else if (finalValue.includes('$')) {
                stat.textContent = '$0';
                animateValue(stat, 0, 0, 1000, '$');
              } else {
                const numValue = parseInt(finalValue);
                animateValue(stat, 0, numValue, 1000);
              }
            });
          }
        });
      }, observerOptions);
      
      const heroStats = document.querySelector('.hero-stats');
      if (heroStats) {
        statsObserver.observe(heroStats);
      }
      
      function animateValue(element, start, end, duration, prefix = '', suffix = '') {
        const startTime = performance.now();
        const update = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const current = Math.round(start + (end - start) * progress);
          element.textContent = prefix + current.toLocaleString() + suffix;
          
          if (progress < 1) {
            requestAnimationFrame(update);
          }
        };
        requestAnimationFrame(update);
      }
    });
  </script>
</PageLayout>