---
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import PageLayout from '../layouts/PageLayout.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<PageLayout 
  title="Waterproofing Financing Options | 0% Interest Available | Dryspace" 
  description="Flexible financing options for your waterproofing project. 0% interest for 12 months, extended payment plans, and instant approvals. Make your basement waterproofing affordable with our financing solutions."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-badge">
            <i class="fa-solid fa-credit-card border-2 border-slate-200"></i>
            Flexible Financing • 0% Interest Available
          </div>
          <h1 class="text-5xl font-bold text-slate-900 uppercase">FLEXIBLE WATERPROOFING FINANCING OPTIONS</h1>
          <p class="hero-description">Don't let budget concerns delay your basement protection. We offer flexible financing solutions including 0% interest options, extended payment plans, and instant approvals to make waterproofing affordable for every homeowner.</p>
          <div class="hero-features">
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>0% Interest for 12 Months</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Instant Online Approval</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>No Prepayment Penalties</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Payment Plans Up to 10 Years</span>
            </div>
          </div>
          <div class="hero-stats">
            <div class="stat-item">
              <div class="stat-value">0%</div>
              <div class="stat-label">Interest Rate</div>
              <div class="stat-note">12 months</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">$0</div>
              <div class="stat-label">Down Payment</div>
              <div class="stat-note">Required</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">2</div>
              <div class="stat-label">Minute</div>
              <div class="stat-note">Approval</div>
            </div>
          </div>
          <div class="hero-cta">
            <a href="#apply-now" class="btn-primary">
              <i class="fa-solid fa-play"></i>
              Apply for Financing
            </a>
            <a href="tel:437-545-0067" class="btn-secondary">
              <i class="fa-solid fa-phone"></i>
              Call: 437-545-0067
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="financing-showcase">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">POPULAR FINANCING OPTIONS</h3>
            <div class="showcase-options">
              <div class="showcase-option featured">
                <div class="option-header">
                  <span class="rate">0%</span>
                  <span class="badge">Most Popular</span>
                </div>
                <div class="option-details">
                  <div class="term">12 Months</div>
                  <div class="payment">$1,000/month</div>
                  <div class="total">$12,000 project</div>
                </div>
                <div class="option-benefits">
                  <span> No interest charges</span>
                  <span> No hidden fees</span>
                </div>
              </div>
              <div class="showcase-option">
                <div class="option-header">
                  <span class="rate">4.9%</span>
                </div>
                <div class="option-details">
                  <div class="term">60 Months</div>
                  <div class="payment">$226/month</div>
                  <div class="total">$12,000 project</div>
                </div>
                <div class="option-benefits">
                  <span> Low monthly payment</span>
                  <span> Extended term</span>
                </div>
              </div>
              <div class="showcase-option">
                <div class="option-header">
                  <span class="rate">7.9%</span>
                </div>
                <div class="option-details">
                  <div class="term">120 Months</div>
                  <div class="payment">$146/month</div>
                  <div class="total">$12,000 project</div>
                </div>
                <div class="option-benefits">
                  <span> Lowest payment</span>
                  <span> Maximum flexibility</span>
                </div>
              </div>
            </div>
            <div class="showcase-note">
              <i class="fa-solid fa-info-circle"></i>
              <span>Rates shown are for qualified applicants. Use calculator below for personalized options.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Financing Calculator -->
  <section class="financing-calculator">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">PAYMENT CALCULATOR</h2>
      <p class="section-intro">Calculate your monthly payment with our interactive financing calculator</p>
      
      <div class="calculator-layout">
        <div class="calculator-form">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">PROJECT DETAILS</h3>
          
          <div class="form-section">
            <div class="form-group">
              <label for="projectCost">Total Project Cost</label>
              <div class="input-with-slider">
                <input type="range" id="projectCostSlider" min="5000" max="50000" value="15000" step="500">
                <input type="number" id="projectCost" value="15000" min="5000" max="50000" step="500">
              </div>
              <div class="cost-examples">
                <button type="button" class="cost-preset" data-cost="8000">$8K - Interior System</button>
                <button type="button" class="cost-preset" data-cost="15000">$15K - Typical Project</button>
                <button type="button" class="cost-preset" data-cost="25000">$25K - Exterior + Interior</button>
                <button type="button" class="cost-preset" data-cost="35000">$35K - Complete Solution</button>
              </div>
            </div>

            <div class="form-group">
              <label for="downPayment">Down Payment (Optional)</label>
              <div class="input-with-slider">
                <input type="range" id="downPaymentSlider" min="0" max="10000" value="0" step="100">
                <input type="number" id="downPayment" value="0" min="0" max="10000" step="100">
              </div>
              <div class="down-payment-note">
                <i class="fa-solid fa-lightbulb"></i>
                <span>No down payment required, but any amount helps reduce monthly payments</span>
              </div>
            </div>

            <div class="form-group">
              <label>Preferred Payment Term</label>
              <div class="term-options">
                <label class="term-option">
                  <input type="radio" name="term" value="12" checked>
                  <span class="term-card border-2 border-slate-200">
                    <span class="term-months">12 Months</span>
                    <span class="term-rate">0% Interest</span>
                    <span class="term-note">No interest charges</span>
                  </span>
                </label>
                <label class="term-option">
                  <input type="radio" name="term" value="24">
                  <span class="term-card border-2 border-slate-200">
                    <span class="term-months">24 Months</span>
                    <span class="term-rate">3.9% Interest</span>
                    <span class="term-note">Low rate</span>
                  </span>
                </label>
                <label class="term-option">
                  <input type="radio" name="term" value="36">
                  <span class="term-card border-2 border-slate-200">
                    <span class="term-months">36 Months</span>
                    <span class="term-rate">4.9% Interest</span>
                    <span class="term-note">Balanced payment</span>
                  </span>
                </label>
                <label class="term-option">
                  <input type="radio" name="term" value="60">
                  <span class="term-card border-2 border-slate-200">
                    <span class="term-months">60 Months</span>
                    <span class="term-rate">6.9% Interest</span>
                    <span class="term-note">Lower payment</span>
                  </span>
                </label>
                <label class="term-option">
                  <input type="radio" name="term" value="120">
                  <span class="term-card border-2 border-slate-200">
                    <span class="term-months">120 Months</span>
                    <span class="term-rate">8.9% Interest</span>
                    <span class="term-note">Lowest payment</span>
                  </span>
                </label>
              </div>
            </div>

            <div class="form-group">
              <label>Credit Score Range (Optional)</label>
              <select id="creditScore">
                <option value="excellent">Excellent (750+)</option>
                <option value="good" selected>Good (650-749)</option>
                <option value="fair">Fair (600-649)</option>
                <option value="poor">Poor (Below 600)</option>
                <option value="unknown">Don't Know</option>
              </select>
              <div class="credit-note">
                <i class="fa-solid fa-info-circle"></i>
                <span>We offer financing options for all credit levels</span>
              </div>
            </div>
          </div>
        </div>

        <div class="calculator-results">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">YOUR PAYMENT OPTIONS</h3>
          
          <div class="results-header">
            <div class="project-summary">
              <div class="summary-item">
                <span class="label">Project Cost:</span>
                <span class="value" id="displayProjectCost">$15,000</span>
              </div>
              <div class="summary-item">
                <span class="label">Down Payment:</span>
                <span class="value" id="displayDownPayment">$0</span>
              </div>
              <div class="summary-item">
                <span class="label">Amount to Finance:</span>
                <span class="value" id="displayFinanceAmount">$15,000</span>
              </div>
            </div>
          </div>

          <div class="payment-options">
            <div class="payment-option selected" data-term="12">
              <div class="option-header">
                <div class="option-term">12 Months</div>
                <div class="option-rate">0% Interest</div>
              </div>
              <div class="option-payment">
                <span class="payment-amount" id="payment12">$1,250</span>
                <span class="payment-period">per month</span>
              </div>
              <div class="option-details">
                <div class="detail-row">
                  <span>Total Interest:</span>
                  <span id="interest12">$0</span>
                </div>
                <div class="detail-row">
                  <span>Total Amount:</span>
                  <span id="total12">$15,000</span>
                </div>
              </div>
              <div class="option-benefits">
                <span> No interest charges</span>
                <span> Pay off fastest</span>
              </div>
            </div>

            <div class="payment-option" data-term="24">
              <div class="option-header">
                <div class="option-term">24 Months</div>
                <div class="option-rate">3.9% Interest</div>
              </div>
              <div class="option-payment">
                <span class="payment-amount" id="payment24">$651</span>
                <span class="payment-period">per month</span>
              </div>
              <div class="option-details">
                <div class="detail-row">
                  <span>Total Interest:</span>
                  <span id="interest24">$624</span>
                </div>
                <div class="detail-row">
                  <span>Total Amount:</span>
                  <span id="total24">$15,624</span>
                </div>
              </div>
              <div class="option-benefits">
                <span> Moderate payment</span>
                <span> Low interest rate</span>
              </div>
            </div>

            <div class="payment-option" data-term="36">
              <div class="option-header">
                <div class="option-term">36 Months</div>
                <div class="option-rate">4.9% Interest</div>
              </div>
              <div class="option-payment">
                <span class="payment-amount" id="payment36">$447</span>
                <span class="payment-period">per month</span>
              </div>
              <div class="option-details">
                <div class="detail-row">
                  <span>Total Interest:</span>
                  <span id="interest36">$1,092</span>
                </div>
                <div class="detail-row">
                  <span>Total Amount:</span>
                  <span id="total36">$16,092</span>
                </div>
              </div>
              <div class="option-benefits">
                <span> Balanced payment</span>
                <span> Popular choice</span>
              </div>
            </div>

            <div class="payment-option" data-term="60">
              <div class="option-header">
                <div class="option-term">60 Months</div>
                <div class="option-rate">6.9% Interest</div>
              </div>
              <div class="option-payment">
                <span class="payment-amount" id="payment60">$296</span>
                <span class="payment-period">per month</span>
              </div>
              <div class="option-details">
                <div class="detail-row">
                  <span>Total Interest:</span>
                  <span id="interest60">$2,760</span>
                </div>
                <div class="detail-row">
                  <span>Total Amount:</span>
                  <span id="total60">$17,760</span>
                </div>
              </div>
              <div class="option-benefits">
                <span> Lower monthly payment</span>
                <span> Better cash flow</span>
              </div>
            </div>

            <div class="payment-option" data-term="120">
              <div class="option-header">
                <div class="option-term">120 Months</div>
                <div class="option-rate">8.9% Interest</div>
              </div>
              <div class="option-payment">
                <span class="payment-amount" id="payment120">$189</span>
                <span class="payment-period">per month</span>
              </div>
              <div class="option-details">
                <div class="detail-row">
                  <span>Total Interest:</span>
                  <span id="interest120">$7,680</span>
                </div>
                <div class="detail-row">
                  <span>Total Amount:</span>
                  <span id="total120">$22,680</span>
                </div>
              </div>
              <div class="option-benefits">
                <span> Lowest monthly payment</span>
                <span> Maximum affordability</span>
              </div>
            </div>
          </div>

          <div class="results-actions">
            <a href="#apply-now" class="btn-apply">
              <i class="fa-solid fa-credit-card border-2 border-slate-200"></i>
              Apply for This Option
            </a>
            <button type="button" class="btn-compare" id="compareOptions">
              <i class="fa-solid fa-balance-scale"></i>
              Compare All Options
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Financing Options -->
  <section class="financing-options">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">OUR FINANCING PARTNERS</h2>
      <p class="section-intro">We work with trusted lending partners to offer the best rates and terms</p>
      
      <div class="partners-grid">
        <div class="partner-card primary border-2 border-slate-200">
          <div class="partner-header">
            <div class="partner-logo">
              <i class="fa-solid fa-building-columns"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">DRYSPACE DIRECT FINANCING</h3>
            <div class="partner-badge">Recommended</div>
          </div>
          <div class="partner-details">
            <div class="key-features">
              <div class="feature-item">
                <i class="fa-solid fa-percentage"></i>
                <span>0% Interest Available</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-clock"></i>
                <span>Instant Decision</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-shield-check"></i>
                <span>No Hidden Fees</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-calendar-alt"></i>
                <span>Flexible Terms</span>
              </div>
            </div>
            <div class="partner-offers">
              <h4 class="text-xl font-bold text-slate-900 uppercase">AVAILABLE OPTIONS:</h4>
              <ul>
                <li><strong>0% APR</strong> for 12 months (OAC)</li>
                <li><strong>3.9% APR</strong> for 24 months</li>
                <li><strong>4.9% APR</strong> for 36 months</li>
                <li><strong>6.9% APR</strong> for 60 months</li>
              </ul>
            </div>
            <div class="partner-benefits">
              <h4 class="text-xl font-bold text-slate-900 uppercase">WHY CHOOSE DIRECT FINANCING:</h4>
              <ul>
                <li>Streamlined approval process</li>
                <li>Work directly with Dryspace</li>
                <li>Coordinated project scheduling</li>
                <li>Single point of contact</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="partner-card border-2 border-slate-200">
          <div class="partner-header">
            <div class="partner-logo">
              <i class="fa-solid fa-university"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">TRADITIONAL BANK FINANCING</h3>
          </div>
          <div class="partner-details">
            <div class="key-features">
              <div class="feature-item">
                <i class="fa-solid fa-chart-line"></i>
                <span>Competitive Rates</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-calendar-days"></i>
                <span>Extended Terms</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-handshake"></i>
                <span>Established Relationships</span>
              </div>
            </div>
            <div class="partner-offers">
              <h4 class="text-xl font-bold text-slate-900 uppercase">TYPICAL OPTIONS:</h4>
              <ul>
                <li><strong>Home Equity Line of Credit</strong></li>
                <li><strong>Personal Loans</strong> up to 7 years</li>
                <li><strong>Home Improvement Loans</strong></li>
                <li><strong>Secured Loans</strong> with collateral</li>
              </ul>
            </div>
            <div class="partner-benefits">
              <h4 class="text-xl font-bold text-slate-900 uppercase">ADVANTAGES:</h4>
              <ul>
                <li>Potentially lower long-term rates</li>
                <li>Higher credit limits available</li>
                <li>Tax-deductible interest (some loans)</li>
                <li>Relationship building with your bank</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="partner-card border-2 border-slate-200">
          <div class="partner-header">
            <div class="partner-logo">
              <i class="fa-solid fa-mobile-alt"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">ONLINE LENDING PLATFORMS</h3>
          </div>
          <div class="partner-details">
            <div class="key-features">
              <div class="feature-item">
                <i class="fa-solid fa-bolt"></i>
                <span>Fast Approval</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-users"></i>
                <span>Flexible Requirements</span>
              </div>
              <div class="feature-item">
                <i class="fa-solid fa-laptop"></i>
                <span>Digital Process</span>
              </div>
            </div>
            <div class="partner-offers">
              <h4 class="text-xl font-bold text-slate-900 uppercase">POPULAR OPTIONS:</h4>
              <ul>
                <li><strong>Personal Loans</strong> 2-7 years</li>
                <li><strong>Peer-to-Peer Lending</strong></li>
                <li><strong>Alternative Credit</strong> assessment</li>
                <li><strong>Same-day Funding</strong> available</li>
              </ul>
            </div>
            <div class="partner-benefits">
              <h4 class="text-xl font-bold text-slate-900 uppercase">BENEFITS:</h4>
              <ul>
                <li>Quick approval process</li>
                <li>Flexible credit requirements</li>
                <li>Competitive rates for good credit</li>
                <li>Entirely online application</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="application-process">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">SIMPLE 3-STEP APPLICATION PROCESS</h2>
      <p class="section-intro">Get approved for financing in minutes with our streamlined process</p>
      
      <div class="process-steps">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">APPLY ONLINE</h3>
            <p>Complete our secure online application in just 2-3 minutes. We only ask for essential information to get you pre-qualified.</p>
            <ul>
              <li>Basic personal information</li>
              <li>Employment details</li>
              <li>Preferred loan amount and term</li>
              <li>Secure SSL encryption</li>
            </ul>
            <div class="step-time">
              <i class="fa-solid fa-clock"></i>
              <span>2-3 minutes</span>
            </div>
          </div>
          <div class="step-visual">
            <div class="application-form-preview">
              <div class="form-header">
                <h4 class="text-xl font-bold text-slate-900 uppercase">QUICK APPLICATION</h4>
                <div class="security-badge">
                  <i class="fa-solid fa-lock"></i>
                  <span>Secure</span>
                </div>
              </div>
              <div class="form-fields">
                <div class="field-group">
                  <div class="field-placeholder"></div>
                  <div class="field-placeholder short"></div>
                </div>
                <div class="field-group">
                  <div class="field-placeholder medium"></div>
                  <div class="field-placeholder"></div>
                </div>
                <div class="field-group">
                  <div class="field-placeholder long"></div>
                </div>
              </div>
              <div class="form-button">Apply Now</div>
            </div>
          </div>
        </div>

        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">INSTANT DECISION</h3>
            <p>Receive an instant pre-approval decision with multiple financing options tailored to your situation.</p>
            <ul>
              <li>Automated credit assessment</li>
              <li>Multiple offer comparison</li>
              <li>No impact on credit score</li>
              <li>Transparent terms and rates</li>
            </ul>
            <div class="step-time">
              <i class="fa-solid fa-clock"></i>
              <span>Under 60 seconds</span>
            </div>
          </div>
          <div class="step-visual">
            <div class="approval-preview">
              <div class="approval-header">
                <i class="fa-solid fa-check-circle"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">PRE-APPROVED!</h4>
              </div>
              <div class="approval-options">
                <div class="approval-option">
                  <div class="option-rate">0%</div>
                  <div class="option-term">12 mo</div>
                </div>
                <div class="approval-option">
                  <div class="option-rate">4.9%</div>
                  <div class="option-term">36 mo</div>
                </div>
                <div class="approval-option">
                  <div class="option-rate">6.9%</div>
                  <div class="option-term">60 mo</div>
                </div>
              </div>
              <div class="approval-amount">
                Up to $25,000 approved
              </div>
            </div>
          </div>
        </div>

        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">START YOUR PROJECT</h3>
            <p>Choose your preferred option, complete final documentation, and schedule your waterproofing project.</p>
            <ul>
              <li>Select best financing option</li>
              <li>E-sign loan documents</li>
              <li>Schedule project start date</li>
              <li>Work begins immediately</li>
            </ul>
            <div class="step-time">
              <i class="fa-solid fa-clock"></i>
              <span>Same day project start</span>
            </div>
          </div>
          <div class="step-visual">
            <div class="project-preview">
              <div class="project-header">
                <h4 class="text-xl font-bold text-slate-900 uppercase">PROJECT SCHEDULED</h4>
                <div class="project-date">
                  <i class="fa-solid fa-calendar"></i>
                  <span>Tomorrow 9:00 AM</span>
                </div>
              </div>
              <div class="project-details">
                <div class="project-item">
                  <i class="fa-solid fa-tools"></i>
                  <span>Crew dispatched</span>
                </div>
                <div class="project-item">
                  <i class="fa-solid fa-truck"></i>
                  <span>Materials ready</span>
