    .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 1rem;
      position: relative;
      z-index: 1;
    }

    .hero-content {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    @media (max-width: 1024px) {
      .hero-content {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: #fbbf24;
      color: #1f2937;
      padding: 0.5rem 1rem;
      font-weight: bold;
      font-size: 0.875rem;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }

    .hero-description {
      font-size: 1.125rem;
      color: #4b5563;
      margin: 1.5rem 0;
      line-height: 1.8;
    }

    .hero-features {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin: 2rem 0;
    }

    @media (max-width: 640px) {
      .hero-features {
        grid-template-columns: 1fr;
      }
    }

    .hero-feature {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #374151;
    }

    .checkmark {
      display: inline-block;
      width: 20px;
      height: 20px;
      background: #10b981;
      border-radius: 50%;
      position: relative;
      flex-shrink: 0;
    }

    .checkmark::after {
      content: '✓';
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      color: white;
      font-size: 12px;
      font-weight: bold;
    }

    .hero-stats {
      display: flex;
      gap: 2rem;
      margin: 2rem 0;
      padding: 2rem;
      background: white;
      border: 3px solid #e5e7eb;
    }

    .stat-item {
      text-align: center;
      flex: 1;
    }

    .stat-value {
      font-size: 2.5rem;
      font-weight: bold;
      color: #fbbf24;
      display: block;
    }

    .stat-label {
      font-size: 0.875rem;
      color: #1f2937;
      font-weight: bold;
      text-transform: uppercase;
      margin-top: 0.5rem;
    }

    .stat-note {
      font-size: 0.75rem;
      color: #6b7280;
      margin-top: 0.25rem;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      margin-top: 2rem;
    }

    @media (max-width: 640px) {
      .hero-cta {
        flex-direction: column;
      }
    }

    .btn-primary,
    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 1rem 2rem;
      font-weight: bold;
      text-transform: uppercase;
      text-decoration: none;
      transition: all 0.3s;
      border: 3px solid;
    }

    .btn-primary {
      background: #fbbf24;
      color: #1f2937;
      border-color: #fbbf24;
    }

    .btn-primary:hover {
      background: transparent;
      transform: translateY(-2px);
    }

    .btn-secondary {
      background: transparent;
      color: #1f2937;
      border-color: #1f2937;
    }

    .btn-secondary:hover {
      background: #1f2937;
      color: white;
    }

    .inspection-image {
      width: 100%;
      height: auto;
      border: 4px solid #e5e7eb;
    }

    .inspection-preview {
      background: white;
      border: 3px solid #fbbf24;
      padding: 1.5rem;
      margin-top: -50px;
      position: relative;
      z-index: 2;
    }

    .inspection-categories {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
      margin: 1rem 0;
    }

    .category-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: #f9fafb;
      border: 2px solid #e5e7eb;
      transition: all 0.3s;
    }

    .category-item:hover {
      border-color: #fbbf24;
      transform: translateX(5px);
    }

    .category-icon {
      width: 40px;
      height: 40px;
      background: #fbbf24;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .category-details h4 {
      margin-bottom: 0.25rem;
    }

    .category-details p {
      font-size: 0.875rem;
      color: #6b7280;
    }

    .preview-note {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 2px solid #e5e7eb;
      color: #6b7280;
      font-size: 0.875rem;
    }

    /* Quick Booking Widget */
    .quick-booking {
      background: #1f2937;
      padding: 3rem 0;
    }

    .booking-widget {
      background: white;
      border: 4px solid #fbbf24;
      padding: 2rem;
    }

    .widget-header {
      text-align: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 3px solid #e5e7eb;
    }

    .widget-header p {
      color: #6b7280;
      margin-top: 0.5rem;
    }

    .booking-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }

    @media (max-width: 768px) {
      .booking-options {
        grid-template-columns: 1fr;
      }
    }

    .booking-option {
      border: 3px solid #e5e7eb;
      padding: 1.5rem;
      text-align: center;
      transition: all 0.3s;
    }

    .booking-option:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .booking-option.urgent {
      border-color: #dc2626;
      background: #fef2f2;
    }

    .booking-option.standard {
      border-color: #059669;
      background: #ecfdf5;
    }

    .booking-option.consultation {
      border-color: #2563eb;
      background: #eff6ff;
    }

    .option-icon {
      width: 60px;
      height: 60px;
      background: #fbbf24;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1rem;
      font-size: 24px;
    }

    .option-content h3 {
      margin-bottom: 0.5rem;
    }

    .option-content p {
      color: #6b7280;
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }

    .option-time {
      font-weight: bold;
      color: #059669;
      margin-bottom: 1rem;
    }

    .option-btn {
      display: inline-block;
      padding: 0.75rem 1.5rem;
      font-weight: bold;
      text-transform: uppercase;
      text-decoration: none;
      border: 2px solid;
      transition: all 0.3s;
    }

    .option-btn.emergency {
      background: #dc2626;
      color: white;
      border-color: #dc2626;
    }

    .option-btn.standard {
      background: #059669;
      color: white;
      border-color: #059669;
    }

    .option-btn.consultation {
      background: #2563eb;
      color: white;
      border-color: #2563eb;
    }

    .option-btn:hover {
      background: transparent;
      color: currentColor;
    }

    /* Inspection Details */
    .inspection-details {
      padding: 4rem 0;
      background: white;
    }

    .section-intro {
      text-align: center;
      color: #6b7280;
      font-size: 1.125rem;
      margin-bottom: 3rem;
    }

    .inspection-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    @media (max-width: 1024px) {
      .inspection-grid {
        grid-template-columns: 1fr;
      }
    }

    .inspection-category {
      border: 3px solid #e5e7eb;
      background: white;
      transition: all 0.3s;
    }

    .inspection-category:hover {
      border-color: #fbbf24;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    }

    .category-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.5rem;
      background: #f9fafb;
      border-bottom: 3px solid #e5e7eb;
    }

    .category-header .category-icon {
      width: 50px;
      height: 50px;
      background: #fbbf24;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
    }

    .category-header h3 {
      flex: 1;
    }

    .point-count {
      background: #1f2937;
      color: white;
      padding: 0.25rem 0.75rem;
      font-size: 0.875rem;
      font-weight: bold;
    }

    .checklist {
      padding: 1.5rem;
    }

    .checklist-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid #f3f4f6;
    }

    .checklist-item:last-child {
      border-bottom: none;
    }

    .checklist-item i {
      color: #10b981;
      margin-top: 0.25rem;
      flex-shrink: 0;
    }

    /* Process Timeline */
    .inspection-process {
      padding: 4rem 0;
      background: #f9fafb;
    }

    .process-timeline {
      max-width: 1200px;
      margin: 0 auto;
    }

    .process-step {
      display: grid;
      grid-template-columns: 80px 1fr 400px;
      gap: 2rem;
      margin-bottom: 3rem;
      position: relative;
    }

    @media (max-width: 1024px) {
      .process-step {
        grid-template-columns: 80px 1fr;
      }

      .step-visual {
        display: none;
      }
    }

    .process-step:not(:last-child)::after {
      content: '';
      position: absolute;
      left: 40px;
      top: 80px;
      bottom: -3rem;
      width: 2px;
      background: #e5e7eb;
    }

    .step-number {
      width: 80px;
      height: 80px;
      background: #fbbf24;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2rem;
      font-weight: bold;
      color: #1f2937;
    }

    .step-content h3 {
      margin-bottom: 1rem;
    }

    .step-details {
      background: white;
      border: 2px solid #e5e7eb;
      padding: 1.5rem;
    }

    .step-details p {
      color: #4b5563;
      margin-bottom: 1rem;
    }

    .step-details ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }

    .step-details li {
      padding: 0.5rem 0;
      padding-left: 1.5rem;
      position: relative;
      color: #374151;
    }

    .step-details li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: #fbbf24;
      font-weight: bold;
    }

    .step-time {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 2px solid #f3f4f6;
      color: #6b7280;
      font-size: 0.875rem;
    }

    .visual-card {
      background: white;
      overflow: hidden;
    }

    .card-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 1rem;
      background: #f9fafb;
      border-bottom: 2px solid #e5e7eb;
    }

    .card-content {
      padding: 1rem;
    }

    /* Preparation Checklist */
    .preparation-checklist {
      padding: 4rem 0;
      background: white;
    }

    .preparation-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      margin-bottom: 3rem;
    }

    @media (max-width: 768px) {
      .preparation-grid {
        grid-template-columns: 1fr;
      }
    }

    .prep-category {
      border: 3px solid #e5e7eb;
      background: white;
    }

    .prep-header {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.5rem;
      background: #f9fafb;
      border-bottom: 3px solid #e5e7eb;
    }

    .prep-header i {
      font-size: 24px;
      color: #fbbf24;
    }

    .prep-checklist {
      padding: 1.5rem;
    }

    .prep-item {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      padding: 1rem;
      margin-bottom: 1rem;
      border: 2px solid #e5e7eb;
      cursor: pointer;
      transition: all 0.3s;
    }

    .prep-item:hover {
      border-color: #fbbf24;
      background: #fef3c7;
    }

    .prep-checkbox {
      width: 20px;
      height: 20px;
      cursor: pointer;
    }

    .prep-content strong {
      display: block;
      margin-bottom: 0.25rem;
      color: #1f2937;
    }

    .prep-content p {
      font-size: 0.875rem;
      color: #6b7280;
    }

    .prep-summary {
      max-width: 600px;
      margin: 0 auto;
    }

    .summary-card {
      background: white;
      padding: 2rem;
      text-align: center;
    }

    .progress-bar {
      height: 30px;
      background: #e5e7eb;
      border-radius: 15px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #fbbf24 0%, #f59e0b 100%);
      transition: width 0.5s ease;
    }

    .summary-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-top: 1.5rem;
    }

    .btn-print,
    .btn-ready {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.75rem 1.5rem;
      font-weight: bold;
      text-transform: uppercase;
      border: 2px solid;
      cursor: pointer;
      transition: all 0.3s;
    }

    .btn-print {
      background: transparent;
      color: #6b7280;
      border-color: #6b7280;
    }

    .btn-ready {
      background: #fbbf24;
      color: #1f2937;
      border-color: #fbbf24;
      text-decoration: none;
    }

    .btn-ready:hover {
      background: transparent;
    }

    /* Booking Form */
    .booking-form-section {
      padding: 4rem 0;
      background: #f9fafb;
    }

    .booking-layout {
      display: grid;
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
    }

    @media (max-width: 1024px) {
      .booking-layout {
        grid-template-columns: 1fr;
      }
    }

    .booking-form {
      background: white;
      border: 3px solid #e5e7eb;
      padding: 2rem;
    }

    .form-section {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 2px solid #f3f4f6;
    }

    .form-section:last-child {
      border-bottom: none;
    }

    .form-section h3 {
      margin-bottom: 1.5rem;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    @media (max-width: 640px) {
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    .form-group {
      margin-bottom: 1rem;
    }

    .form-group label {
      display: block;
      font-weight: bold;
      color: #1f2937;
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      font-size: 0.875rem;
    }

    .form-group input,
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 0.75rem;
      border: 2px solid #e5e7eb;
      background: white;
      font-size: 1rem;
      transition: all 0.3s;
    }

    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #fbbf24;
      box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.1);
    }

    .urgency-options {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    @media (max-width: 768px) {
      .urgency-options {
        grid-template-columns: 1fr;
      }
    }

    .urgency-option {
      position: relative;
    }

    .urgency-option input[type="radio"] {
      position: absolute;
      opacity: 0;
    }

    .urgency-card {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 1.5rem;
      cursor: pointer;
      transition: all 0.3s;
    }

    .urgency-card.emergency {
      background: #fef2f2;
      border-color: #dc2626;
    }

    .urgency-card.urgent {
      background: #fef3c7;
      border-color: #f59e0b;
    }

    .urgency-card.standard {
      background: #f0fdf4;
      border-color: #10b981;
    }

    .urgency-option input[type="radio"]:checked + .urgency-card {
      border-width: 4px;
      transform: scale(1.05);
    }

    .urgency-title {
      font-weight: bold;
      margin: 0.5rem 0;
    }

    .urgency-desc {
      font-size: 0.875rem;
      color: #6b7280;
    }

    .urgency-time {
      font-weight: bold;
      margin-top: 0.5rem;
      color: #059669;
    }

    .concerns-grid,
    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    @media (max-width: 640px) {
      .concerns-grid,
      .services-grid {
        grid-template-columns: 1fr;
      }
    }

    .concern-item,
    .service-item {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      padding: 0.75rem;
      border: 2px solid #e5e7eb;
      cursor: pointer;
      transition: all 0.3s;
    }

    .concern-item:hover,
    .service-item:hover {
      border-color: #fbbf24;
      background: #fef3c7;
    }

    .service-details {
      flex: 1;
    }

    .service-details strong {
      display: block;
      margin-bottom: 0.25rem;
    }

    .service-details small {
      display: block;
      color: #6b7280;
      font-size: 0.75rem;
    }

    .service-price {
      display: block;
      margin-top: 0.5rem;
      font-weight: bold;
      color: #059669;
    }

    .consent-checkboxes {
      margin: 1.5rem 0;
    }

    .consent-label {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-bottom: 1rem;
      cursor: pointer;
    }

    .consent-label a {
      color: #2563eb;
      text-decoration: underline;
    }

    .btn-book {
      width: 100%;
      padding: 1.25rem;
      background: #fbbf24;
      color: #1f2937;
      font-size: 1.25rem;
      font-weight: bold;
      text-transform: uppercase;
      border: 3px solid #fbbf24;
      cursor: pointer;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }

    .btn-book:hover {
      background: transparent;
    }

    .btn-book:disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }

    /* Booking Sidebar */
    .booking-sidebar {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .inspection-summary,
    .inspector-credentials,
    .emergency-contact {
      background: white;
      border: 3px solid #e5e7eb;
      padding: 1.5rem;
    }

    .summary-header,
    .inspector-credentials h3,
    .emergency-contact h3 {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid #f3f4f6;
    }

    .summary-items {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .summary-item {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      color: #374151;
    }

    .summary-item i {
      color: #10b981;
      flex-shrink: 0;
    }

    .credentials-list {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .credential-item {
      display: flex;
      gap: 1rem;
      padding: 1rem;
      background: #f9fafb;
      border: 2px solid #e5e7eb;
    }

    .credential-item i {
      color: #fbbf24;
      font-size: 24px;
      flex-shrink: 0;
    }

    .credential-item strong {
      display: block;
      margin-bottom: 0.25rem;
    }

    .credential-item p {
      font-size: 0.875rem;
      color: #6b7280;
    }

    .emergency-contact {
      background: #fef2f2;
      border-color: #dc2626;
    }

    .emergency-contact p {
      color: #7f1d1d;
      margin-bottom: 1rem;
    }

    .emergency-btn {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
      width: 100%;
      padding: 1rem;
      background: #dc2626;
      color: white;
      font-weight: bold;
      text-decoration: none;
      transition: all 0.3s;
    }

    .emergency-btn:hover {
      background: #b91c1c;
      transform: scale(1.05);
    }

    .emergency-btn span {
      font-size: 1.25rem;
    }

    /* Equipment and Report Previews */
    .equipment-list,
    .report-preview,
    .findings-preview {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .equipment-item,
    .report-section {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem;
      background: #f9fafb;
      border: 1px solid #e5e7eb;
      font-size: 0.875rem;
    }

    .finding-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem;
      margin-bottom: 0.5rem;
      border-left: 3px solid;
    }

    .finding-item.high {
      background: #fef2f2;
      border-color: #dc2626;
    }

    .finding-item.medium {
      background: #fef3c7;
      border-color: #f59e0b;
    }

    .finding-item.low {
      background: #f0fdf4;
      border-color: #10b981;
