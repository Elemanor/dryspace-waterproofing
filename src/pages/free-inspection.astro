---
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import PageLayout from '../layouts/PageLayout.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<PageLayout 
  title="Free Basement Inspection Toronto | Professional Assessment | Dryspace" 
  description="Book your free professional basement inspection in Toronto. Expert evaluation, detailed report, and no-obligation quote. Available 7 days a week with same-day emergency service."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-badge">
            <i class="fa-solid fa-calendar-check"></i>
            Free Professional Inspection • No Obligation
          </div>
          <h1 class="text-5xl font-bold text-slate-900 uppercase">FREE BASEMENT INSPECTION & ASSESSMENT TORONTO</h1>
          <p class="hero-description">Get a comprehensive professional evaluation of your basement's condition. Our certified inspectors provide detailed assessments, identification of potential issues, and expert recommendations - all at no cost to you.</p>
          <div class="hero-features">
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Certified Professional Inspector</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Comprehensive 45-Point Check</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Detailed Written Report</span>
            </div>
            <div class="hero-feature">
              <span class="checkmark"></span>
              <span>Same-Day Emergency Available</span>
            </div>
          </div>
          <div class="hero-stats">
            <div class="stat-item">
              <div class="stat-value">45</div>
              <div class="stat-label">Point Inspection</div>
              <div class="stat-note">Comprehensive check</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">100%</div>
              <div class="stat-label">Free</div>
              <div class="stat-note">No hidden costs</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">24/7</div>
              <div class="stat-label">Emergency</div>
              <div class="stat-note">Service available</div>
            </div>
          </div>
          <div class="hero-cta">
            <a href="#book-inspection" class="btn-primary">
              <i class="fa-solid fa-calendar-plus"></i>
              Book Free Inspection
            </a>
            <a href="tel:437-545-0067" class="btn-secondary">
              <i class="fa-solid fa-phone"></i>
              Call: 437-545-0067
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <img src="/assets/waterproofing/basement-water-leak-inspection.webp" alt="Professional basement inspection in progress" loading="lazy" class="inspection-image" / width="800" height="600" decoding="async">
          <div class="inspection-preview">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">WHAT WE INSPECT</h3>
            <div class="inspection-categories">
              <div class="category-item">
                <div class="category-icon">
                  <i class="fa-solid fa-eye"></i>
                </div>
                <div class="category-details">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">VISUAL ASSESSMENT</h4>
                  <p>Foundation walls, floors, ceiling inspection</p>
                </div>
              </div>
              <div class="category-item">
                <div class="category-icon">
                  <i class="fa-solid fa-droplet"></i>
                </div>
                <div class="category-details">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">MOISTURE DETECTION</h4>
                  <p>Humidity levels, water intrusion signs</p>
                </div>
              </div>
              <div class="category-item">
                <div class="category-icon">
                  <i class="fa-solid fa-hammer"></i>
                </div>
                <div class="category-details">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">STRUCTURAL REVIEW</h4>
                  <p>Foundation integrity, settlement issues</p>
                </div>
              </div>
              <div class="category-item">
                <div class="category-icon">
                  <i class="fa-solid fa-water"></i>
                </div>
                <div class="category-details">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">DRAINAGE SYSTEMS</h4>
                  <p>Sump pumps, weeping tiles, gutters</p>
                </div>
              </div>
            </div>
            <div class="preview-note">
              <i class="fa-solid fa-clock"></i>
              <span>Typically takes 45-60 minutes • Detailed report provided</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Booking Widget -->
  <section class="quick-booking">
    <div class="container">
      <div class="booking-widget">
        <div class="widget-header">
          <h2 class="text-4xl font-bold text-slate-900 uppercase">BOOK YOUR FREE INSPECTION</h2>
          <p>Choose your preferred date and time - we'll confirm within 1 hour</p>
        </div>
        <div class="booking-options">
          <div class="booking-option urgent">
            <div class="option-icon">
              <i class="fa-solid fa-bolt"></i>
            </div>
            <div class="option-content">
              <h3 class="text-2xl font-bold text-slate-900 uppercase">EMERGENCY SERVICE</h3>
              <p>Water intrusion, active leaks, structural concerns</p>
              <div class="option-time">Available within 2 hours</div>
              <a href="tel:437-545-0067" class="option-btn emergency">Call Now: 437-545-0067</a>
            </div>
          </div>
          <div class="booking-option standard">
            <div class="option-icon">
              <i class="fa-solid fa-calendar-alt"></i>
            </div>
            <div class="option-content">
              <h3 class="text-2xl font-bold text-slate-900 uppercase">STANDARD APPOINTMENT</h3>
              <p>Routine inspection, preventive assessment</p>
              <div class="option-time">Next available: Tomorrow</div>
              <a href="#book-inspection" class="option-btn standard">Book Online</a>
            </div>
          </div>
          <div class="booking-option consultation">
            <div class="option-icon">
              <i class="fa-solid fa-comments"></i>
            </div>
            <div class="option-content">
              <h3 class="text-2xl font-bold text-slate-900 uppercase">PHONE CONSULTATION</h3>
              <p>Discuss concerns, get initial advice</p>
              <div class="option-time">Available now</div>
              <a href="tel:437-545-0067" class="option-btn consultation">Speak with Expert</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What We Inspect -->
  <section class="inspection-details">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">COMPREHENSIVE 45-POINT INSPECTION CHECKLIST</h2>
      <p class="section-intro">Our certified inspectors follow a detailed checklist to ensure nothing is missed</p>
      
      <div class="inspection-grid">
        <div class="inspection-category">
          <div class="category-header">
            <div class="category-icon">
              <i class="fa-solid fa-home"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">FOUNDATION & STRUCTURE</h3>
            <span class="point-count">12 Points</span>
          </div>
          <div class="checklist">
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Foundation wall condition and alignment</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Basement floor levelness and cracks</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Support beam and post integrity</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Floor joist condition and spacing</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Foundation settlement indicators</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Structural load distribution</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Wall bowing or leaning assessment</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Foundation anchoring and ties</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Ceiling and overhead structure</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Stairway safety and condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Window and door frame integrity</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Overall structural stability</span>
            </div>
          </div>
        </div>

        <div class="inspection-category">
          <div class="category-header">
            <div class="category-icon">
              <i class="fa-solid fa-tint"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">MOISTURE & WATER ISSUES</h3>
            <span class="point-count">15 Points</span>
          </div>
          <div class="checklist">
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Active water leaks and seepage</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Humidity levels measurement</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Condensation patterns and causes</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Water stains and discoloration</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Mold and mildew presence</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Musty odors and air quality</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Efflorescence on walls</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Wall and floor moisture content</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Ventilation adequacy</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Dehumidification systems</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Vapor barrier condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Insulation moisture damage</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Waterproofing system condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Previous water damage signs</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Moisture intrusion points</span>
            </div>
          </div>
        </div>

        <div class="inspection-category">
          <div class="category-header">
            <div class="category-icon">
              <i class="fa-solid fa-water"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">DRAINAGE SYSTEMS</h3>
            <span class="point-count">10 Points</span>
          </div>
          <div class="checklist">
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Sump pump operation and condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Sump pit and float switch</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Battery backup system</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Interior drainage tiles</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Floor drain functionality</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Backwater valve presence</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Exterior drainage around home</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Gutter and downspout condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Grading and water flow</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Window well drainage</span>
            </div>
          </div>
        </div>

        <div class="inspection-category">
          <div class="category-header">
            <div class="category-icon">
              <i class="fa-solid fa-shield-alt"></i>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">SAFETY & CODE COMPLIANCE</h3>
            <span class="point-count">8 Points</span>
          </div>
          <div class="checklist">
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Electrical system safety</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>HVAC system condition</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Fire safety and egress</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Carbon monoxide risks</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Building code compliance</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Proper ventilation systems</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Insulation and energy efficiency</span>
            </div>
            <div class="checklist-item">
              <i class="fa-solid fa-check"></i>
              <span>Overall habitability assessment</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Inspection Process -->
  <section class="inspection-process">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">WHAT TO EXPECT DURING YOUR INSPECTION</h2>
      <p class="section-intro">Our systematic approach ensures thorough evaluation and clear communication</p>
      
      <div class="process-timeline">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">PRE-INSPECTION CONSULTATION</h3>
            <div class="step-details">
              <p>Our inspector arrives on time and introduces themselves, explaining the inspection process and addressing any specific concerns you've mentioned.</p>
              <ul>
                <li>Review of your concerns and history</li>
                <li>Explanation of inspection scope</li>
                <li>Safety briefing and access requirements</li>
                <li>Timeline and process overview</li>
              </ul>
              <div class="step-time">
                <i class="fa-solid fa-clock"></i>
                <span>5-10 minutes</span>
              </div>
            </div>
          </div>
          <div class="step-visual">
            <div class="visual-card border-2 border-slate-200">
              <div class="card-header border-2 border-slate-200">
                <i class="fa-solid fa-handshake"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">PROFESSIONAL GREETING</h4>
              </div>
              <div class="card-content border-2 border-slate-200">
                <div class="inspector-info">
                  <div class="inspector-badge">
                    <i class="fa-solid fa-certificate"></i>
                    <span>Certified Inspector</span>
                  </div>
                  <div class="inspector-details">
                    <span>Licensed & Insured</span>
                    <span>25+ Years Experience</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">COMPREHENSIVE INSPECTION</h3>
            <div class="step-details">
              <p>Systematic 45-point evaluation using professional equipment and proven methodologies. We document everything with photos and measurements.</p>
              <ul>
                <li>Foundation and structural assessment</li>
                <li>Moisture and humidity testing</li>
                <li>Drainage system evaluation</li>
                <li>Safety and code compliance check</li>
              </ul>
              <div class="step-time">
                <i class="fa-solid fa-clock"></i>
                <span>30-45 minutes</span>
              </div>
            </div>
          </div>
          <div class="step-visual">
            <div class="visual-card border-2 border-slate-200">
              <div class="card-header border-2 border-slate-200">
                <i class="fa-solid fa-search"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">PROFESSIONAL EQUIPMENT</h4>
              </div>
              <div class="card-content border-2 border-slate-200">
                <div class="equipment-list">
                  <div class="equipment-item">
                    <i class="fa-solid fa-thermometer-half"></i>
                    <span>Moisture Meters</span>
                  </div>
                  <div class="equipment-item">
                    <i class="fa-solid fa-camera"></i>
                    <span>Documentation Camera</span>
                  </div>
                  <div class="equipment-item">
                    <i class="fa-solid fa-ruler"></i>
                    <span>Measuring Tools</span>
                  </div>
                  <div class="equipment-item">
                    <i class="fa-solid fa-flashlight"></i>
                    <span>Inspection Lighting</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">FINDINGS REVIEW & DISCUSSION</h3>
            <div class="step-details">
              <p>We review all findings with you on-site, explaining what we discovered and the implications for your home's safety and value.</p>
              <ul>
                <li>Walk-through of identified issues</li>
                <li>Photo documentation review</li>
                <li>Priority level assessment</li>
                <li>Q&A session with inspector</li>
              </ul>
              <div class="step-time">
                <i class="fa-solid fa-clock"></i>
                <span>10-15 minutes</span>
              </div>
            </div>
          </div>
          <div class="step-visual">
            <div class="visual-card border-2 border-slate-200">
              <div class="card-header border-2 border-slate-200">
                <i class="fa-solid fa-clipboard-list"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">DETAILED FINDINGS</h4>
              </div>
              <div class="card-content border-2 border-slate-200">
                <div class="findings-preview">
                  <div class="finding-item high">
                    <span class="priority">High</span>
                    <span>Active water infiltration</span>
                  </div>
                  <div class="finding-item medium">
                    <span class="priority">Medium</span>
                    <span>Drainage improvement needed</span>
                  </div>
                  <div class="finding-item low">
                    <span class="priority">Low</span>
                    <span>Minor foundation crack</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">DETAILED REPORT & RECOMMENDATIONS</h3>
            <div class="step-details">
              <p>Within 24 hours, you receive a comprehensive written report with prioritized recommendations and cost estimates for any needed work.</p>
              <ul>
                <li>Complete inspection findings</li>
                <li>Photo documentation</li>
                <li>Prioritized action plan</li>
                <li>Cost estimates for solutions</li>
              </ul>
              <div class="step-time">
                <i class="fa-solid fa-clock"></i>
                <span>Within 24 hours</span>
              </div>
            </div>
          </div>
          <div class="step-visual">
            <div class="visual-card border-2 border-slate-200">
              <div class="card-header border-2 border-slate-200">
                <i class="fa-solid fa-file-alt"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">PROFESSIONAL REPORT</h4>
              </div>
              <div class="card-content border-2 border-slate-200">
                <div class="report-preview">
                  <div class="report-section">
                    <i class="fa-solid fa-exclamation-triangle"></i>
                    <span>Issues Identified</span>
                  </div>
                  <div class="report-section">
                    <i class="fa-solid fa-tools"></i>
                    <span>Recommended Solutions</span>
                  </div>
                  <div class="report-section">
                    <i class="fa-solid fa-dollar-sign"></i>
                    <span>Cost Estimates</span>
                  </div>
                  <div class="report-section">
                    <i class="fa-solid fa-calendar"></i>
                    <span>Priority Timeline</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Preparation Checklist -->
  <section class="preparation-checklist">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">HOW TO PREPARE FOR YOUR INSPECTION</h2>
      <p class="section-intro">A little preparation helps ensure the most thorough and efficient inspection possible</p>
      
      <div class="preparation-grid">
        <div class="prep-category">
          <div class="prep-header">
            <i class="fa-solid fa-unlock"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">ACCESS & SAFETY</h3>
          </div>
          <div class="prep-checklist">
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
              <span class="checkmark"></span>
              <div class="prep-content">
                <strong>Clear basement access</strong>
                <p>Ensure stairway is clear and well-lit</p>
              </div>
            </label>
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
              <span class="checkmark"></span>
              <div class="prep-content">
                <strong>Move storage items</strong>
                <p>Clear areas around walls, floors, and utilities</p>
              </div>
            </label>
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
              <span class="checkmark"></span>
              <div class="prep-content">
                <strong>Turn on basement lights</strong>
                <p>Replace any burnt-out bulbs for better visibility</p>
              </div>
            </label>
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
              <span class="checkmark"></span>
              <div class="prep-content">
                <strong>Pet accommodation</strong>
                <p>Secure pets in another area during inspection</p>
              </div>
            </label>
          </div>
        </div>

        <div class="prep-category">
          <div class="prep-header">
            <i class="fa-solid fa-clipboard-list"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">DOCUMENTATION</h3>
          </div>
          <div class="prep-checklist">
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
              <span class="checkmark"></span>
              <div class="prep-content">
                <strong>Previous reports</strong>
                <p>Gather any prior inspection or repair documentation</p>
              </div>
            </label>
            <label class="prep-item">
              <input type="checkbox" class="prep-checkbox">
