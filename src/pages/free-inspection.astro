  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Preparation checklist functionality
      const prepCheckboxes = document.querySelectorAll('.prep-checkbox');
      const checkedCountEl = document.getElementById('checkedCount');
      const totalCountEl = document.getElementById('totalCount');
      const prepProgressEl = document.getElementById('prepProgress');
      
      function updatePreparationProgress() {
        const totalCount = prepCheckboxes.length;
        const checkedCount = document.querySelectorAll('.prep-checkbox:checked').length;
        
        checkedCountEl.textContent = checkedCount;
        totalCountEl.textContent = totalCount;
        
        const percentage = (checkedCount / totalCount) * 100;
        prepProgressEl.style.width = percentage + '%';
        
        // Save progress to localStorage
        const checkedItems = [];
        prepCheckboxes.forEach((checkbox, index) => {
          if (checkbox.checked) {
            checkedItems.push(index);
          }
        });
        localStorage.setItem('inspectionPrepChecklist', JSON.stringify(checkedItems));
        
        // Show completion message if all checked
        if (checkedCount === totalCount) {
          showCompletionMessage();
        }
      }
      
      function showCompletionMessage() {
        const summaryCard = document.querySelector('.summary-card');
        if (summaryCard && !document.querySelector('.completion-message')) {
          const message = document.createElement('div');
          message.className = 'completion-message';
          message.style.cssText = `
            background: #10b981;
            color: white;
            padding: 1rem;
            border-radius: 0.5rem;
            margin-top: 1rem;
            animation: slideIn 0.5s ease;
          `;
          message.innerHTML = `
            <strong> Congratulations!</strong> You're fully prepared for your inspection!
            <br>Our inspector will be impressed with your preparation.
          `;
          summaryCard.appendChild(message);
        }
      }
      
      // Load saved progress
      function loadSavedProgress() {
        const saved = localStorage.getItem('inspectionPrepChecklist');
        if (saved) {
          const checkedItems = JSON.parse(saved);
          checkedItems.forEach(index => {
            if (prepCheckboxes[index]) {
              prepCheckboxes[index].checked = true;
            }
          });
        }
      }
      
      // Clear checklist button
      function addClearButton() {
        const buttonsContainer = document.querySelector('.prep-buttons');
        if (buttonsContainer && !document.querySelector('.btn-clear')) {
          const clearBtn = document.createElement('button');
          clearBtn.className = 'btn-clear';
          clearBtn.style.cssText = `
            background: #ef4444;
            color: white;
            padding: 0.75rem 1.5rem;
            border: none;
            border-radius: 0.5rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
          `;
          clearBtn.innerHTML = '<i class="fa-solid fa-trash"></i> Clear All';
          clearBtn.onclick = () => {
            if (confirm('Clear all checked items?')) {
              prepCheckboxes.forEach(checkbox => checkbox.checked = false);
              localStorage.removeItem('inspectionPrepChecklist');
              updatePreparationProgress();
              const completionMsg = document.querySelector('.completion-message');
              if (completionMsg) completionMsg.remove();
            }
          };
          buttonsContainer.appendChild(clearBtn);
        }
      }
      
      prepCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', updatePreparationProgress);
      });
      
      // Initialize
      loadSavedProgress();
      addClearButton();
      
      // Form validation and submission
      const bookingForm = document.getElementById('inspectionBookingForm');
      
      if (bookingForm) {
        // Set minimum date to today
        const preferredDateInput = document.getElementById('preferredDate');
        const today = new Date().toISOString().split('T')[0];
        preferredDateInput.min = today;
        
        bookingForm.addEventListener('submit', function(e) {
          e.preventDefault();
          
          // Basic validation
          const requiredFields = this.querySelectorAll('[required]');
          let isValid = true;
          
          requiredFields.forEach(field => {
            if (!field.value.trim()) {
              field.style.borderColor = 'var(--color-danger)';
              isValid = false;
            } else {
              field.style.borderColor = 'rgba(255, 255, 255, 0.1)';
            }
          });
          
          if (!isValid) {
            alert('Please fill in all required fields.');
            return;
          }
          
          // Get form data
          const formData = new FormData(this);
          const urgency = formData.get('urgency');
          const concerns = formData.getAll('concerns');
          const additionalServices = formData.getAll('additionalServices');
          
          // Simulate form submission
          const submitBtn = this.querySelector('.btn-book');
          const originalText = submitBtn.innerHTML;
          
          submitBtn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Booking Inspection...';
          submitBtn.disabled = true;
          
          setTimeout(() => {
            let message = 'Inspection successfully booked! ';
            
            if (urgency === 'emergency') {
              message += 'Our emergency team will contact you within 30 minutes.';
            } else if (urgency === 'urgent') {
              message += 'We will contact you within 2 hours to confirm your appointment.';
            } else {
              message += 'We will contact you within 24 hours to confirm your appointment.';
            }
            
            alert(message);
            
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
            
            // Reset form or redirect
            // this.reset();
          }, 2000);
        });
      }
      
      // Auto-update preferred date based on urgency
      const urgencyRadios = document.querySelectorAll('input[name="urgency"]');
      urgencyRadios.forEach(radio => {
        radio.addEventListener('change', function() {
          const preferredDate = document.getElementById('preferredDate');
          const today = new Date();
          
          if (this.value === 'emergency') {
            preferredDate.value = today.toISOString().split('T')[0];
          } else if (this.value === 'urgent') {
            const tomorrow = new Date(today);
            tomorrow.setDate(tomorrow.getDate() + 1);
            preferredDate.value = tomorrow.toISOString().split('T')[0];
          } else {
            const nextWeek = new Date(today);
            nextWeek.setDate(nextWeek.getDate() + 7);
            preferredDate.value = nextWeek.toISOString().split('T')[0];
          }
        });
      });
      
      // Animate stats on scroll
      const observerOptions = {
        threshold: 0.5,
        rootMargin: '0px 0px -100px 0px'
      };
      
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const statValues = entry.target.querySelectorAll('.stat-value');
            statValues.forEach((stat, index) => {
              const finalValue = stat.textContent;
              
              if (finalValue.includes('%')) {
                const numValue = parseInt(finalValue);
                stat.textContent = '0%';
                animateValue(stat, 0, numValue, 1500, '', '%');
              } else if (finalValue.includes('/')) {
                // Handle "24/7" case
                stat.textContent = '0/0';
                setTimeout(() => {
                  stat.textContent = finalValue;
                }, index * 200);
              } else {
                const numValue = parseInt(finalValue);
                stat.textContent = '0';
                animateValue(stat, 0, numValue, 1500);
              }
            });
          }
        });
      }, observerOptions);
      
      const heroStats = document.querySelector('.hero-stats');
      if (heroStats) {
        statsObserver.observe(heroStats);
      }
      
      function animateValue(element, start, end, duration, prefix = '', suffix = '') {
        const startTime = performance.now();
        const update = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const current = Math.round(start + (end - start) * progress);
          element.textContent = prefix + current + suffix;
          
          if (progress < 1) {
            requestAnimationFrame(update);
          }
        };
        requestAnimationFrame(update);
      }
      
      // Initialize preparation progress
      updatePreparationProgress();
    });
  </script>
</PageLayout>