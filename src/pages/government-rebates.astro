---
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import PageLayout from '../layouts/PageLayout.astro';
import CostCalculator from '../components/CostCalculator.astro';
import FAQ from '../components/FAQ.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<PageLayout 
  title="Toronto Waterproofing Rebates 2025 | Government Funding Guide" 
  description="Complete guide to Toronto and Ontario waterproofing rebates. Learn about the Toronto Basement Flooding Protection Subsidy, federal tax credits, and municipal programs. Save up to $4,900 on your waterproofing project."
>
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <div class="hero-badge">
            <i class="fa-solid fa-piggy-bank"></i>
            Government Rebates Available • Save Up to $4,900
          </div>
          <h1 class="text-5xl font-bold text-slate-900 uppercase">TORONTO WATERPROOFING REBATES & GOVERNMENT FUNDING 2025</h1>
          <p class="hero-description">Don't pay full price for waterproofing! Toronto and Ontario offer substantial rebates and tax credits for basement waterproofing and flood protection measures. Our complete guide shows you how to claim up to $4,900 in available funding.</p>
          <div class="hero-stats">
            <div class="stat-item">
              <div class="stat-value">$3,400</div>
              <div class="stat-label">Toronto Basement Flooding Subsidy</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">$1,500</div>
              <div class="stat-label">Federal Tax Credit</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">$4,900</div>
              <div class="stat-label">Total Available</div>
            </div>
          </div>
          <div class="hero-cta">
            <a href="tel:437-545-0067" class="btn-primary">
              <i class="fa-solid fa-phone"></i>
              Get Rebate Help: 437-545-0067
            </a>
            <a href="#rebate-calculator" class="btn-secondary">
              <i class="fa-solid fa-calculator"></i>
              Calculate Your Savings
            </a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="rebate-breakdown">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">2025 REBATE BREAKDOWN</h3>
            <div class="rebate-items">
              <div class="rebate-item toronto">
                <div class="rebate-logo">
                  <i class="fa-solid fa-city"></i>
                </div>
                <div class="rebate-info">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">CITY OF TORONTO</h4>
                  <p>Basement Flooding Protection</p>
                  <div class="rebate-amount">Up to $3,400</div>
                </div>
              </div>
              <div class="rebate-item federal">
                <div class="rebate-logo">
                  <i class="fa-solid fa-flag"></i>
                </div>
                <div class="rebate-info">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">FEDERAL GOVERNMENT</h4>
                  <p>Home Renovation Tax Credit</p>
                  <div class="rebate-amount">Up to $1,500</div>
                </div>
              </div>
              <div class="rebate-item total">
                <div class="rebate-info">
                  <h4 class="text-xl font-bold text-slate-900 uppercase">YOUR TOTAL SAVINGS</h4>
                  <div class="rebate-amount">Up to $4,900</div>
                </div>
              </div>
            </div>
            <div class="qualification-note">
              <i class="fa-solid fa-info-circle"></i>
              <span>Dryspace helps you qualify and apply for all available rebates</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Last Updated Notice -->
  <section class="update-notice">
    <div class="container">
      <div class="update-box">
        <div class="update-icon">
          <i class="fa-solid fa-calendar-check"></i>
        </div>
        <div class="update-content">
          <strong>Last Updated: December 26, 2025</strong>
          <span class="update-separator">•</span>
          <span>All rebate information verified with government agencies</span>
          <span class="update-separator">•</span>
          <span>Next review: March 2025</span>
        </div>
        <div class="update-alert">
          <i class="fa-solid fa-bell"></i>
          <span>Subscribe for rebate updates</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Toronto Basement Flooding Protection Subsidy -->
  <section class="toronto-subsidy">
    <div class="container">
      <div class="section-header">
        <div class="city-logo">
          <i class="fa-solid fa-building-columns"></i>
        </div>
        <h2 class="text-4xl font-bold text-slate-900 uppercase">CITY OF TORONTO BASEMENT FLOODING PROTECTION SUBSIDY PROGRAM</h2>
        <p class="section-intro">The City's flagship program provides substantial financial assistance for basement waterproofing and flood protection measures.</p>
      </div>

      <div class="subsidy-details">
        <div class="subsidy-overview">
          <div class="overview-card border-2 border-slate-200">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">PROGRAM OVERVIEW</h3>
            <div class="overview-content">
              <div class="overview-item">
                <i class="fa-solid fa-dollar-sign"></i>
                <div>
                  <strong>Maximum Rebate: $3,400</strong>
                  <p>Covers up to 80% of eligible work costs</p>
                </div>
              </div>
              <div class="overview-item">
                <i class="fa-solid fa-home"></i>
                <div>
                  <strong>Eligible Properties</strong>
                  <p>Residential properties within Toronto city limits</p>
                </div>
              </div>
              <div class="overview-item">
                <i class="fa-solid fa-calendar-check"></i>
                <div>
                  <strong>Application Period</strong>
                  <p>Year-round applications accepted</p>
                </div>
              </div>
              <div class="overview-item">
                <i class="fa-solid fa-clock"></i>
                <div>
                  <strong>Processing Time</strong>
                  <p>4-6 weeks for approval</p>
                </div>
              </div>
            </div>
          </div>

          <div class="eligibility-card border-2 border-slate-200">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">ELIGIBILITY REQUIREMENTS</h3>
            <div class="eligibility-list">
              <div class="requirement met">
                <i class="fa-solid fa-check-circle"></i>
                <span>Property located within Toronto city boundaries</span>
              </div>
              <div class="requirement met">
                <i class="fa-solid fa-check-circle"></i>
                <span>Residential property (single-family, semi, townhouse)</span>
              </div>
              <div class="requirement met">
                <i class="fa-solid fa-check-circle"></i>
                <span>Property owner is applicant</span>
              </div>
              <div class="requirement met">
                <i class="fa-solid fa-check-circle"></i>
                <span>Work performed by licensed contractor</span>
              </div>
              <div class="requirement met">
                <i class="fa-solid fa-check-circle"></i>
                <span>Permits obtained where required</span>
              </div>
              <div class="requirement warning">
                <i class="fa-solid fa-exclamation-triangle"></i>
                <span>No previous flooding subsidy claimed</span>
              </div>
            </div>
          </div>
        </div>

        <div class="covered-work">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">COVERED WORK & REBATE AMOUNTS</h3>
          <div class="work-categories">
            <div class="category-card border-2 border-slate-200">
              <div class="category-header">
                <i class="fa-solid fa-house-crack"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">EXTERIOR WATERPROOFING</h4>
              </div>
              <div class="category-content">
                <div class="work-item">
                  <span>Foundation excavation & membrane</span>
                  <span class="rebate-amount">Up to $2,000</span>
                </div>
                <div class="work-item">
                  <span>Weeping tile installation</span>
                  <span class="rebate-amount">Up to $800</span>
                </div>
                <div class="work-item">
                  <span>Window well installation</span>
                  <span class="rebate-amount">Up to $400</span>
                </div>
                <div class="work-item total">
                  <span>Category Maximum</span>
                  <span class="rebate-amount">$3,200</span>
                </div>
              </div>
            </div>

            <div class="category-card border-2 border-slate-200">
              <div class="category-header">
                <i class="fa-solid fa-water"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">SUMP PUMP & DRAINAGE</h4>
              </div>
              <div class="category-content">
                <div class="work-item">
                  <span>Sump pump installation</span>
                  <span class="rebate-amount">Up to $1,250</span>
                </div>
                <div class="work-item">
                  <span>Interior drainage system</span>
                  <span class="rebate-amount">Up to $1,500</span>
                </div>
                <div class="work-item">
                  <span>Backup power system</span>
                  <span class="rebate-amount">Up to $750</span>
                </div>
                <div class="work-item total">
                  <span>Category Maximum</span>
                  <span class="rebate-amount">$3,500</span>
                </div>
              </div>
            </div>

            <div class="category-card border-2 border-slate-200">
              <div class="category-header">
                <i class="fa-solid fa-shield-alt"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">BACKWATER VALVE</h4>
              </div>
              <div class="category-content">
                <div class="work-item">
                  <span>Backwater valve installation</span>
                  <span class="rebate-amount">Up to $1,250</span>
                </div>
                <div class="work-item">
                  <span>Floor restoration</span>
                  <span class="rebate-amount">Up to $500</span>
                </div>
                <div class="work-item total">
                  <span>Category Maximum</span>
                  <span class="rebate-amount">$1,750</span>
                </div>
              </div>
            </div>

            <div class="category-card border-2 border-slate-200">
              <div class="category-header">
                <i class="fa-solid fa-arrows-alt"></i>
                <h4 class="text-xl font-bold text-slate-900 uppercase">LOT GRADING & DRAINAGE</h4>
              </div>
              <div class="category-content">
                <div class="work-item">
                  <span>Lot grading improvements</span>
                  <span class="rebate-amount">Up to $400</span>
                </div>
                <div class="work-item">
                  <span>Downspout disconnection</span>
                  <span class="rebate-amount">Up to $200</span>
                </div>
                <div class="work-item total">
                  <span>Category Maximum</span>
                  <span class="rebate-amount">$600</span>
                </div>
              </div>
            </div>
          </div>

          <div class="important-note">
            <i class="fa-solid fa-exclamation-circle"></i>
            <div>
              <strong>Important:</strong> Overall program maximum is $3,400 per property. You can combine work from multiple categories up to this limit.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Application Process -->
  <section class="application-process">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">HOW TO APPLY FOR TORONTO BASEMENT FLOODING PROTECTION SUBSIDY</h2>
      <p class="section-intro">Dryspace handles the entire application process for you, ensuring maximum rebate approval</p>
      
      <div class="process-timeline">
        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">1</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">PRE-APPLICATION ASSESSMENT</h3>
            <p><strong>What we do:</strong> Free property assessment to determine eligible work and potential rebate amount.</p>
            <ul>
              <li>Property eligibility verification</li>
              <li>Scope of work assessment</li>
              <li>Maximum rebate calculation</li>
              <li>Required permits identification</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: Same day</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">2</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">APPLICATION PREPARATION</h3>
            <p><strong>What we do:</strong> Complete all application forms and gather required documentation.</p>
            <ul>
              <li>Application form completion</li>
              <li>Technical drawings preparation</li>
              <li>Cost estimates and quotes</li>
              <li>Supporting documentation assembly</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: 1-2 business days</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">3</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">APPLICATION SUBMISSION</h3>
            <p><strong>What we do:</strong> Submit complete application package to the City of Toronto.</p>
            <ul>
              <li>Online application portal submission</li>
              <li>Document upload and verification</li>
              <li>Application tracking setup</li>
              <li>Confirmation receipt</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: Same day</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">4</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CITY REVIEW & APPROVAL</h3>
            <p><strong>What happens:</strong> City reviews application and issues conditional approval.</p>
            <ul>
              <li>Technical review by city staff</li>
              <li>Eligibility confirmation</li>
              <li>Rebate amount approval</li>
              <li>Conditional approval letter issued</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: 4-6 weeks</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">5</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">WORK COMPLETION</h3>
            <p><strong>What we do:</strong> Complete approved waterproofing work according to specifications.</p>
            <ul>
              <li>Work performed per approved plans</li>
              <li>Quality control and inspections</li>
              <li>Photo documentation</li>
              <li>Completion certificates</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: 3-10 days</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">6</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">FINAL CLAIM SUBMISSION</h3>
            <p><strong>What we do:</strong> Submit final claim with all required documentation for rebate payment.</p>
            <ul>
              <li>Final invoices and receipts</li>
              <li>Before/after photographs</li>
              <li>Permit closure documents</li>
              <li>Warranty information</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: 1 business day</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker">
            <span class="step-number">7</span>
          </div>
          <div class="timeline-content">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">REBATE PAYMENT</h3>
            <p><strong>What happens:</strong> City processes final claim and issues rebate payment.</p>
            <ul>
              <li>Final review and verification</li>
              <li>Rebate calculation confirmation</li>
              <li>Payment authorization</li>
              <li>Direct deposit or cheque issuance</li>
            </ul>
            <div class="timeline-duration">
              <i class="fa-solid fa-clock"></i>
              <span>Duration: 4-6 weeks</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Federal Programs -->
  <section class="federal-programs">
    <div class="container">
      <div class="section-header">
        <div class="federal-logo">
          <i class="fa-solid fa-flag"></i>
        </div>
        <h2 class="text-4xl font-bold text-slate-900 uppercase">FEDERAL GOVERNMENT WATERPROOFING INCENTIVES</h2>
        <p class="section-intro">Additional savings available through federal tax credits and programs</p>
      </div>

      <div class="federal-grid">
        <div class="program-card border-2 border-slate-200">
          <div class="program-header">
            <i class="fa-solid fa-receipt"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">HOME RENOVATION TAX CREDIT</h3>
            <div class="program-amount">Up to $1,500</div>
          </div>
          <div class="program-content">
            <div class="program-details">
              <h4 class="text-xl font-bold text-slate-900 uppercase">PROGRAM DETAILS</h4>
              <ul>
                <li>15% tax credit on eligible expenses</li>
                <li>Maximum $10,000 in eligible expenses</li>
                <li>Applies to waterproofing and flood prevention</li>
                <li>Available for homeowners and landlords</li>
              </ul>
            </div>
            <div class="eligibility">
              <h4 class="text-xl font-bold text-slate-900 uppercase">ELIGIBILITY</h4>
              <ul>
                <li>Work performed on principal residence</li>
                <li>Expenses over $1,000 minimum</li>
                <li>Work completed in tax year</li>
                <li>Licensed contractor required</li>
              </ul>
            </div>
            <div class="how-to-claim">
              <h4 class="text-xl font-bold text-slate-900 uppercase">HOW TO CLAIM</h4>
              <p>Include waterproofing expenses on your income tax return using Form T2042. Keep all receipts and contractor information.</p>
            </div>
          </div>
        </div>

        <div class="program-card border-2 border-slate-200">
          <div class="program-header">
            <i class="fa-solid fa-home-heart"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CANADA GREENER HOMES INITIATIVE</h3>
            <div class="program-amount">Up to $5,000</div>
          </div>
          <div class="program-content">
            <div class="program-details">
              <h4 class="text-xl font-bold text-slate-900 uppercase">PROGRAM DETAILS</h4>
              <ul>
                <li>Grants for home resilience improvements</li>
                <li>Includes flood protection measures</li>
                <li>Combined with energy efficiency upgrades</li>
                <li>Professional energy assessment required</li>
              </ul>
            </div>
            <div class="eligibility">
              <h4 class="text-xl font-bold text-slate-900 uppercase">ELIGIBILITY</h4>
              <ul>
                <li>Canadian homeowner</li>
                <li>Home built before 2022</li>
                <li>EnerGuide assessment completed</li>
                <li>Qualified contractor installation</li>
              </ul>
            </div>
            <div class="how-to-claim">
              <h4 class="text-xl font-bold text-slate-900 uppercase">HOW TO APPLY</h4>
              <p>Register online at canada.ca/greener-homes. Complete pre-retrofit assessment, then apply for grants.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Municipal Programs -->
  <section class="municipal-programs">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">OTHER GTA MUNICIPAL WATERPROOFING PROGRAMS</h2>
      <p class="section-intro">Additional rebates available in surrounding municipalities</p>
      
      <div class="municipality-grid">
        <div class="municipality-card border-2 border-slate-200">
          <div class="municipality-header">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CITY OF MISSISSAUGA</h3>
            <div class="status available">Program Available</div>
          </div>
          <div class="municipality-content">
            <div class="program-info">
              <h4 class="text-xl font-bold text-slate-900 uppercase">BASEMENT FLOODING PROTECTION SUBSIDY</h4>
              <div class="program-amount">Up to $2,500</div>
              <ul>
                <li>Sump pump installation: Up to $1,000</li>
                <li>Backwater valve: Up to $1,000</li>
                <li>Lot grading: Up to $500</li>
              </ul>
            </div>
            <div class="contact-info">
              <p><strong>Contact:</strong> 311 or mississauga.ca</p>
              <p><strong>Application:</strong> Online portal</p>
            </div>
          </div>
        </div>

        <div class="municipality-card border-2 border-slate-200">
          <div class="municipality-header">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CITY OF BRAMPTON</h3>
            <div class="status available">Program Available</div>
          </div>
          <div class="municipality-content">
            <div class="program-info">
              <h4 class="text-xl font-bold text-slate-900 uppercase">RESIDENTIAL FLOOD PROTECTION PROGRAM</h4>
              <div class="program-amount">Up to $2,000</div>
              <ul>
                <li>Sump pump & pit: Up to $750</li>
                <li>Backwater valve: Up to $750</li>
                <li>Foundation drainage: Up to $500</li>
              </ul>
            </div>
            <div class="contact-info">
              <p><strong>Contact:</strong> 311 or brampton.ca</p>
              <p><strong>Application:</strong> By appointment</p>
            </div>
          </div>
        </div>

        <div class="municipality-card border-2 border-slate-200">
          <div class="municipality-header">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">TOWN OF OAKVILLE</h3>
            <div class="status limited">Limited Program</div>
          </div>
          <div class="municipality-content">
            <div class="program-info">
              <h4 class="text-xl font-bold text-slate-900 uppercase">STORMWATER MANAGEMENT GRANTS</h4>
              <div class="program-amount">Up to $1,500</div>
              <ul>
                <li>Downspout disconnection: Up to $200</li>
                <li>Rain gardens: Up to $800</li>
                <li>Permeable surfaces: Up to $500</li>
              </ul>
            </div>
            <div class="contact-info">
              <p><strong>Contact:</strong> oakville.ca/environment</p>
              <p><strong>Application:</strong> Online form</p>
            </div>
          </div>
        </div>

        <div class="municipality-card border-2 border-slate-200">
          <div class="municipality-header">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CITY OF VAUGHAN</h3>
            <div class="status developing">Program Developing</div>
          </div>
          <div class="municipality-content">
            <div class="program-info">
              <h4 class="text-xl font-bold text-slate-900 uppercase">FUTURE FLOOD PROTECTION INITIATIVE</h4>
              <div class="program-amount">TBD</div>
              <ul>
                <li>Program under development</li>
                <li>Expected launch: 2025</li>
                <li>Focus on basement flooding prevention</li>
              </ul>
            </div>
            <div class="contact-info">
              <p><strong>Contact:</strong> 311 or vaughan.ca</p>
              <p><strong>Updates:</strong> Municipal website</p>
            </div>
          </div>
        </div>

        <div class="municipality-card border-2 border-slate-200">
          <div class="municipality-header">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">CITY OF MARKHAM</h3>
            <div class="status available">Program Available</div>
          </div>
          <div class="municipality-content">
