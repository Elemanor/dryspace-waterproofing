  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Rebate calculator elements
      const municipalitySelect = document.getElementById('municipality');
      const propertyTypeSelect = document.getElementById('propertyType');
      const incomeSelect = document.getElementById('income');
      const workCheckboxes = document.querySelectorAll('.work-item input[type="checkbox"]');
      const principalResidenceInputs = document.querySelectorAll('input[name="principalResidence"]');
      
      // Result elements
      const municipalRebateEl = document.getElementById('municipalRebate');
      const federalTaxCreditEl = document.getElementById('federalTaxCredit');
      const greenerHomesGrantEl = document.getElementById('greenerHomesGrant');
      const totalProjectCostEl = document.getElementById('totalProjectCost');
      const totalRebatesEl = document.getElementById('totalRebates');
      const netCostEl = document.getElementById('netCost');
      
      // Chart elements
      const originalCostBar = document.getElementById('originalCostBar');
      const rebateSavingsBar = document.getElementById('rebateSavingsBar');
      
      // Municipal rebate programs
      const municipalPrograms = {
        toronto: { maxRebate: 3400, name: 'Toronto Basement Flooding Protection' },
        mississauga: { maxRebate: 2500, name: 'Mississauga Basement Flooding Subsidy' },
        brampton: { maxRebate: 2000, name: 'Brampton Residential Flood Protection' },
        markham: { maxRebate: 1800, name: 'Markham Basement Flooding Reduction' },
        vaughan: { maxRebate: 0, name: 'Program Under Development' },
        oakville: { maxRebate: 1500, name: 'Stormwater Management Grants' },
        'richmond-hill': { maxRebate: 1000, name: 'Residential Subsidy Program' },
        other: { maxRebate: 0, name: 'No Program Available' }
      };
      
      // Work type rebate calculations
      const workRebates = {
        'exterior-waterproofing': { toronto: 2000, mississauga: 0, brampton: 0, markham: 0, oakville: 0, 'richmond-hill': 0 },
        'interior-drainage': { toronto: 1500, mississauga: 0, brampton: 500, markham: 0, oakville: 0, 'richmond-hill': 0 },
        'sump-pump': { toronto: 1250, mississauga: 1000, brampton: 750, markham: 800, oakville: 0, 'richmond-hill': 0 },
        'backwater-valve': { toronto: 1250, mississauga: 1000, brampton: 750, markham: 600, oakville: 0, 'richmond-hill': 1000 },
        'foundation-repair': { toronto: 0, mississauga: 0, brampton: 0, markham: 0, oakville: 0, 'richmond-hill': 0 },
        'lot-grading': { toronto: 400, mississauga: 500, brampton: 0, markham: 400, oakville: 800, 'richmond-hill': 0 }
      };
      
      function calculateRebates() {
        const municipality = municipalitySelect.value;
        const propertyType = propertyTypeSelect.value;
        const income = incomeSelect.value;
        const isPrincipalResidence = document.querySelector('input[name="principalResidence"]:checked').value === 'yes';
        
        let totalProjectCost = 0;
        let municipalRebate = 0;
        let federalTaxCredit = 0;
        let greenerHomesGrant = 0;
        
        // Calculate project cost and municipal rebates
        workCheckboxes.forEach(checkbox => {
          if (checkbox.checked) {
            const workType = checkbox.value;
            const cost = parseInt(checkbox.dataset.cost);
            totalProjectCost += cost;
            
            // Add municipal rebate for this work type
            if (workRebates[workType] && workRebates[workType][municipality]) {
              municipalRebate += workRebates[workType][municipality];
            }
          }
        });
        
        // Apply municipal program maximum
        if (municipalPrograms[municipality]) {
          municipalRebate = Math.min(municipalRebate, municipalPrograms[municipality].maxRebate);
        }
        
        // Calculate federal tax credit (15% of eligible expenses, max $1,500)
        if (isPrincipalResidence && totalProjectCost >= 1000) {
          federalTaxCredit = Math.min(totalProjectCost * 0.15, 1500);
        }
        
        // Greener Homes Grant (if applicable)
        if (isPrincipalResidence && totalProjectCost >= 5000) {
          // Simplified calculation - actual program has complex eligibility
          greenerHomesGrant = Math.min(1000, totalProjectCost * 0.05);
        }
        
        const totalRebates = municipalRebate + federalTaxCredit + greenerHomesGrant;
        const netCost = Math.max(0, totalProjectCost - totalRebates);
        
        // Update display
        municipalRebateEl.textContent = '$' + municipalRebate.toLocaleString();
        federalTaxCreditEl.textContent = '$' + Math.round(federalTaxCredit).toLocaleString();
        greenerHomesGrantEl.textContent = '$' + Math.round(greenerHomesGrant).toLocaleString();
        totalProjectCostEl.textContent = '$' + totalProjectCost.toLocaleString();
        totalRebatesEl.textContent = '$' + Math.round(totalRebates).toLocaleString();
        netCostEl.textContent = '$' + Math.round(netCost).toLocaleString();
        
        // Update chart
        if (totalProjectCost > 0) {
          const savingsPercentage = (totalRebates / totalProjectCost) * 100;
          const costPercentage = 100 - savingsPercentage;
          
          originalCostBar.style.flex = costPercentage;
          rebateSavingsBar.style.flex = savingsPercentage;
          
          originalCostBar.textContent = Math.round(costPercentage) + '%';
          rebateSavingsBar.textContent = Math.round(savingsPercentage) + '%';
        } else {
          originalCostBar.style.flex = 1;
          rebateSavingsBar.style.flex = 0;
          originalCostBar.textContent = '';
          rebateSavingsBar.textContent = '';
        }
      }
      
      // Add event listeners
      municipalitySelect.addEventListener('change', calculateRebates);
      propertyTypeSelect.addEventListener('change', calculateRebates);
      incomeSelect.addEventListener('change', calculateRebates);
      
      workCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', calculateRebates);
      });
      
      principalResidenceInputs.forEach(input => {
        input.addEventListener('change', calculateRebates);
      });
      
      // Initialize calculator
      calculateRebates();
      
      // Animate stats on scroll
      const observerOptions = {
        threshold: 0.5,
        rootMargin: '0px 0px -100px 0px'
      };
      
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const statValues = entry.target.querySelectorAll('.stat-value');
            statValues.forEach((stat, index) => {
              const finalValue = stat.textContent;
              stat.textContent = '$0';
              
              setTimeout(() => {
                animateValue(stat, 0, parseInt(finalValue.replace(/[$,]/g, '')), 1500, '$');
              }, index * 200);
            });
          }
        });
      }, observerOptions);
      
      const heroStats = document.querySelector('.hero-stats');
      if (heroStats) {
        statsObserver.observe(heroStats);
      }
      
      function animateValue(element, start, end, duration, prefix = '') {
        const startTime = performance.now();
        const update = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const current = Math.round(start + (end - start) * progress);
          element.textContent = prefix + current.toLocaleString();
          
          if (progress < 1) {
            requestAnimationFrame(update);
          }
        };
        requestAnimationFrame(update);
      }
    });
  </script>
