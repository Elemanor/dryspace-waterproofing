---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import ServiceProcess from '../components/sections/ServiceProcess.astro';
import CTABand from '../components/sections/CTABand.astro';

const pageTitle = "Basement Waterproofing Toronto | 24/7 | DrySpace";
const pageDescription = "Emergency water protection services in the GTA. Same-day response, 25-year warranty, government rebates available. 487+ 5-star reviews. Call 437-545-0067.";

const services = [
  { title: "Exterior Waterproofing", description: "Complete exterior foundation protection with membrane, drainage, and backfill.", href: "/services/exterior-waterproofing", price: "From $8,500" },
  { title: "Interior Waterproofing", description: "Interior drainage systems, weeping tile, and moisture control solutions.", href: "/services/interior-waterproofing", price: "From $4,500" },
  { title: "Foundation Repair", description: "Fix cracks, bowing walls, and structural issues with engineered solutions.", href: "/services/foundation-repair", price: "From $3,500" },
  { title: "Sump Pump Systems", description: "Professional sump pump installation with battery backup and alarm.", href: "/services/sump-pump-installation", price: "From $2,800" },
  { title: "Underpinning", description: "Foundation lowering and structural reinforcement for basement conversions.", href: "/services/underpinning", price: "From $15,000" },
  { title: "Concrete Works", description: "Slabs, walls, driveways, patios, and decorative stamped concrete.", href: "/services/concrete-works", price: "From $3,000" },
];

const reviews = [
  { name: "Sarah M.", location: "Toronto", rating: 5, text: "DrySpace waterproofed our 80-year-old home. The crew was professional, on-time, and the results exceeded expectations. No more flooding after heavy rains.", date: "2 weeks ago" },
  { name: "David K.", location: "Mississauga", rating: 5, text: "Emergency response was incredible — they arrived within an hour when our basement flooded. Excellent work on the sump pump and drainage system.", date: "1 month ago" },
  { name: "Jennifer L.", location: "Brampton", rating: 5, text: "We got multiple quotes and DrySpace offered the best value. They helped us apply for the $3,400 rebate too. Highly recommend their exterior waterproofing service.", date: "3 weeks ago" },
];

const areas = [
  { name: "Downtown Toronto", href: "/neighborhoods/downtown" },
  { name: "Scarborough", href: "/locations/scarborough" },
  { name: "North York", href: "/locations/north-york" },
  { name: "Etobicoke", href: "/locations/etobicoke" },
  { name: "Mississauga", href: "/locations/mississauga" },
  { name: "Brampton", href: "/locations/brampton" },
  { name: "Vaughan", href: "/locations/vaughan" },
  { name: "Markham", href: "/locations/markham" },
  { name: "Richmond Hill", href: "/locations/richmond-hill" },
  { name: "Oakville", href: "/locations/oakville" },
  { name: "Burlington", href: "/locations/burlington" },
  { name: "Hamilton", href: "/locations/hamilton" },
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>
  <!-- ═══════════════════════ 1. HERO ═══════════════════════ -->
  <Hero
    title="GTA's Most Trusted Water Protection Experts"
    subtitle="Protecting local homes from moisture damage since 1999. Under 60-minute emergency response, lifetime transferable warranty, and government rebates available."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Emergency: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="$3,400 REBATE AVAILABLE"
  />

  <!-- ═══════════════════════ 2. TRUST BAR ═══════════════════════ -->
  <TrustBar />

  <!-- ═══════════════════════ 3. SERVICES GRID ═══════════════════════ -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Our Services"
        title="Complete Waterproofing & Foundation Solutions"
        description="From emergency repairs to full foundation restoration — we handle every aspect of below-grade protection for GTA homes."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((svc, i) => (
          <a href={svc.href} class="group card-interactive p-6 reveal reveal-delay-{(i % 3) + 1}">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-cyan-50 text-cyan-600 mb-4 transition-colors group-hover:bg-cyan-500 group-hover:text-white">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.23 3.05A1.1 1.1 0 014.5 17.3V6.7a1.1 1.1 0 011.69-.92l5.23 3.05a1.1 1.1 0 010 1.84z" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2 group-hover:text-cyan-600 transition-colors">{svc.title}</h3>
            <p class="text-sm text-slate-600 mb-4 leading-relaxed">{svc.description}</p>
            <div class="flex items-center justify-between">
              <span class="text-sm font-semibold text-cyan-600">{svc.price}</span>
              <span class="text-xs font-medium text-slate-400 group-hover:text-cyan-500 transition-colors flex items-center gap-1">
                Learn more
                <svg class="w-3 h-3 transition-transform group-hover:translate-x-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/services" class="btn-secondary">
          View All Services
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ 4. SOCIAL PROOF ═══════════════════════ -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Reviews"
        title="What Our Clients Say"
        description="487+ verified 5-star reviews across Google, HomeStars, and BBB."
      />

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto mb-12">
        <div class="text-center reveal">
          <p class="text-4xl font-bold text-slate-900">4.9<span class="text-lg text-amber-500">/5</span></p>
          <p class="text-sm text-slate-500 mt-1">Google Rating</p>
        </div>
        <div class="text-center reveal reveal-delay-1">
          <p class="text-4xl font-bold text-slate-900">487+</p>
          <p class="text-sm text-slate-500 mt-1">5-Star Reviews</p>
        </div>
        <div class="text-center reveal reveal-delay-2">
          <p class="text-4xl font-bold text-slate-900">25+</p>
          <p class="text-sm text-slate-500 mt-1">Years in Business</p>
        </div>
        <div class="text-center reveal reveal-delay-3">
          <p class="text-4xl font-bold text-slate-900">A+</p>
          <p class="text-sm text-slate-500 mt-1">BBB Rating</p>
        </div>
      </div>

      <!-- Review cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {reviews.map((review, i) => (
          <div class="card-base p-6 reveal reveal-delay-{i + 1}">
            <div class="flex items-center gap-1 mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <p class="text-sm text-slate-600 leading-relaxed mb-4">"{review.text}"</p>
            <div class="flex items-center justify-between border-t border-slate-100 pt-3">
              <div>
                <p class="text-sm font-semibold text-slate-900">{review.name}</p>
                <p class="text-xs text-slate-400">{review.location}</p>
              </div>
              <span class="text-xs text-slate-400">{review.date}</span>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/reviews" class="btn-secondary">
          Read All Reviews
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ 5. PROCESS ═══════════════════════ -->
  <ServiceProcess />

  <!-- ═══════════════════════ 6. SERVICE AREAS ═══════════════════════ -->
  <section class="section-padding bg-navy-900">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Service Areas"
        title="Protecting Homes Across the GTA"
        description="24/7 emergency water protection service covering the Greater Toronto Area."
        dark
      />

      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 max-w-5xl mx-auto">
        {areas.map((area, i) => (
          <a
            href={area.href}
            class="group rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-center text-sm font-medium text-white/80 transition-all hover:border-cyan-500/30 hover:bg-cyan-500/10 hover:text-cyan-400 reveal"
          >
            {area.name}
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/service-areas" class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors inline-flex items-center gap-1">
          View all service areas
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ STRATEGIC INTERNAL LINKS ═══════════════════════ -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- Spring Flooding Alert -->
          <div class="card-base p-6 border-2 border-amber-500 bg-amber-50">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">!</div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Spring Flood Alert 2026</h3>
                <p class="text-sm text-slate-600 mb-4">
                  Spring thaw brings the highest flooding risk of the year. Learn how to protect your basement before melting snow overwhelms your drainage.
                </p>
                <a href="/blog/spring-basement-flooding-prevention-2026" class="text-cyan-600 hover:text-cyan-700 font-semibold text-sm inline-flex items-center gap-1">
                  Read Prevention Guide
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Government Rebates -->
          <div class="card-base p-6 border-2 border-cyan-500 bg-cyan-50">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">$</div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Save Up to $3,400</h3>
                <p class="text-sm text-slate-600 mb-4">
                  Toronto offers substantial rebates for basement waterproofing and flood protection. We handle all the paperwork for maximum savings.
                </p>
                <a href="/government-rebates" class="text-cyan-600 hover:text-cyan-700 font-semibold text-sm inline-flex items-center gap-1">
                  Explore Rebate Programs
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Emergency Service -->
          <div class="card-base p-6 border-2 border-red-600 bg-red-50">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">🚨</div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Emergency Flooding?</h3>
                <p class="text-sm text-slate-600 mb-4">
                  24/7 emergency response with 30-minute average arrival time. Professional water extraction, pumping, and damage control.
                </p>
                <a href="/emergency" class="text-red-600 hover:text-red-700 font-semibold text-sm inline-flex items-center gap-1">
                  Emergency Services
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" /></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Key Locations -->
          <div class="card-base p-6 border-2 border-slate-200">
            <div class="flex items-start gap-4 mb-4">
              <div class="text-3xl">📍</div>
              <div>
                <h3 class="text-xl font-bold text-slate-900 mb-2">Featured Service Areas</h3>
                <p class="text-sm text-slate-600 mb-4">
                  Expert waterproofing in your area. Visit our specialized pages for Oakville, Vaughan, and East York neighborhoods.
                </p>
                <div class="flex flex-wrap gap-2">
                  <a href="/locations/oakville" class="text-cyan-600 hover:text-cyan-700 font-semibold text-sm">Oakville</a>
                  <span class="text-slate-400">•</span>
                  <a href="/locations/vaughan" class="text-cyan-600 hover:text-cyan-700 font-semibold text-sm">Vaughan</a>
                  <span class="text-slate-400">•</span>
                  <a href="/neighborhoods/east-york" class="text-cyan-600 hover:text-cyan-700 font-semibold text-sm">East York</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ 7. FINAL CTA ═══════════════════════ -->
  <CTABand
    title="Ready to Protect Your Home?"
    subtitle="Book a free, no-obligation inspection. Our certified experts will assess your property and provide a detailed quote — including all available rebates."
    primaryCTA={{ text: "Book Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call 437-545-0067", href: "tel:437-545-0067" }}
  />

  <!-- Schema Markup -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "DrySpace Waterproofing",
      "description": "Professional foundation water protection services in the GTA with 24/7 emergency response",
      "url": "https://dryspacewaterproofing.ca",
      "telephone": "437-545-0067",
      "priceRange": "$$$",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Greater Toronto Area",
        "addressRegion": "ON",
        "addressCountry": "CA"
      },
      "openingHoursSpecification": {
        "@type": "OpeningHoursSpecification",
        "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
        "opens": "00:00",
        "closes": "23:59"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "487"
      }
    }
  </script>
</PageLayout>
