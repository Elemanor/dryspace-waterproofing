  <!-- Location Hero -->
  <Hero
    title="Basement Waterproofing Brampton"
    subtitle="Etobicoke Creek Flood Specialists & Heritage District Foundation Experts. Expert basement waterproofing for Brampton homes from Queen St heritage properties to modern Castlemore subdivisions."
