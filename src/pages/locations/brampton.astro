const locationFAQs = [
  {
    question: "How much does basement waterproofing cost in Brampton?",
    answer: "Basement waterproofing in Brampton typically costs $140-$260 per linear foot for exterior work, with most homes averaging $10,000-$24,000 for a complete project. Interior drainage systems range from $4,000-$8,000. Costs vary based on foundation depth, Halton Till clay conditions (which require extra excavation effort), property access in tight subdivisions, and whether you're in a newer home (simpler repairs) versus Heritage District properties (more complex restoration). We provide free on-site assessments with detailed quotes for all Brampton neighborhoods."
