const cityData = locationData['burlington'];
const pageTitle = "Basement Waterproofing Burlington | Escarpment & Lakefront Specialists";
const pageDescription = "Basement waterproofing Burlington — Niagara Escarpment drainage, lakefront protection, and mature home foundation repair. $150-$275/linear foot. 25-year warranty.";

// Local area information
const localInfo = {
  cityName: "Burlington",
  population: "186,000",
  waterTable: "Variable - escarpment vs lakefront",
  soilType: "Glacial deposits - sand over clay",
  avgHomesAge: "35-45 years",
  floodRisk: "Moderate - Lake Ontario influence",
