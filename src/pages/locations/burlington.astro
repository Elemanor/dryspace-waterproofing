const pageTitle = "Waterproofing Burlington | Lakefront & Escarpment Service";
const pageDescription = "Expert waterproofing in Burlington. Handling unique lakefront and escarpment challenges. Free consultation.";

// Local area information
const localInfo = {
  cityName: "Local Area",
  population: "186,000",
  waterTable: "Variable - escarpment vs lakefront",
  soilType: "Glacial deposits - sand over clay",
  avgHomesAge: "35-45 years",
  floodRisk: "Moderate - Lake Ontario influence",
  avgRainfall: "805mm annually",
  elevation: "75-250m above Lake Ontario",
  geology: "Niagara Escarpment limestone bedrock"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'ESCARPMENT DRAINAGE SPECIALISTS',
    description: 'Expert management of Niagara Escarpment water runoff and complex slope drainage systems.',
    highlight: true
  },
  {
    title: 'LAKEFRONT PROPERTY EXPERTS',
    description: 'Specialized solutions for Lake Ontario moisture challenges and fluctuating water table conditions.',
    highlight: true
  },
  {
    title: 'GEOLOGICAL EXPERTISE',
    description: 'Deep understanding of glacial deposit soil transitions from escarpment to lakeshore.',
    highlight: true
  },
  {
    title: 'ELEVATION-SPECIFIC SOLUTIONS',
    description: 'Tailored approaches for properties from lake level to 250m escarpment heights.'
  },
  {
    title: 'MATURE HOME RESTORATION',
    description: 'Specialized techniques for 1980s-1990s construction common in Burlington.'
  },
  {
    title: 'WATERSHED PROTECTION',
    description: 'Environmental compliance for Sixteen Mile Creek and Spencer Creek watersheds.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do you handle escarpment drainage issues unique to Burlington?",
    answer: "We specialize in Niagara Escarpment drainage challenges including steep slope runoff, limestone bedrock water channeling, and elevation changes from lake level to 250m. Our solutions include specialized french drain systems and slope stabilization techniques."
  },
  {
    question: "What makes lakefront properties in Burlington different for waterproofing?",
    answer: "Burlington's Lake Ontario properties face unique challenges: fluctuating lake levels affecting groundwater, constant moisture from lake effect weather, and sandy soils that shift with water table changes. We use marine-grade waterproofing materials and specialized drainage designed for these conditions."
  },
  {
    question: "How do soil conditions vary across Burlington's elevation changes?",
    answer: "Burlington's glacial history created distinct soil zones: sandy deposits near the lake transition to clay deposits mid-elevation, with limestone bedrock exposure on the escarpment. Each zone requires different waterproofing approaches based on drainage characteristics and foundation bearing conditions."
  },
  {
    question: "Do you work with Burlington's watershed protection requirements?",
    answer: "Yes, we're fully certified for work within Sixteen Mile Creek and Spencer Creek watershed areas. We ensure all drainage solutions comply with Conservation Halton requirements and use environmentally approved materials and methods."
  },
  {
    question: "What about Burlington's mature neighborhood foundation challenges?",
    answer: "Burlington's 1980s-1990s boom created many homes now reaching the 30-40 year mark when foundation issues typically emerge. We specialize in retrofitting these homes with modern waterproofing while preserving original architectural features and working within established neighborhoods."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "WaterproofingService"],
  "name": "Dryspace Waterproofing",
  "description": "Professional waterproofing services in Burlington. Expert basement waterproofing, foundation repair, and drainage solutions. Serving all Burlington neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Burlington Service Area",
    "addressLocality": "Burlington",
    "addressRegion": "ON",
    "postalCode": "L7L",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.3255",
    "longitude": "-79.7990"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Burlington",
      "sameAs": "https://en.wikipedia.org/wiki/Burlington,_Ontario"
    },
    {
      "@type": "Place",
      "name": "Halton Region"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates", 
      "latitude": "43.3255",
      "longitude": "-79.7990"
    },
    "geoRadius": "25000"
  },
  "openingHours": [
    "Mo-Fr 07:00-19:00",
    "Sa 08:00-17:00", 
    "Su 09:00-17:00"
  ],
  "availableLanguage": ["English"],
  "currenciesAccepted": "CAD",
  "paymentAccepted": ["Cash", "Credit Card", "Debit Card", "Bank Transfer"],
  "priceRange": "$$",
  "url": "https://dryspacewaterproofing.com/locations/burlington",
  "logo": "https://dryspacewaterproofing.com/images/dryspace-logo.webp",
  "image": "https://dryspacewaterproofing.com/images/dryspace_hero_desktop.webp",
  "sameAs": [
    "https://www.facebook.com/dryspacewaterproofing",
    "https://www.linkedin.com/company/dryspace-waterproofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Waterproofing Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Basement Waterproofing",
          "description": "Complete basement waterproofing solutions"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Foundation Repair",
          "description": "Foundation crack repair and structural solutions"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "Drainage Solutions",
          "description": "French drains, sump pumps, and drainage systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emergency Water Removal",
          "description": "24/7 emergency flooding and water damage response"
        }
      }
    ]
  },
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "4.9",
      "bestRating": "5"
    },
    "author": {
      "@type": "Organization",
      "name": "Dryspace Waterproofing Customers"
    }
  },
  "aggregateRating": {
    "@type": "AggregateRating",
