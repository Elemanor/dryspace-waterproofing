---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Etobicoke" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero 
    title="Waterproofing Etobicoke"
    subtitle="Professional basement waterproofing and foundation repair serving all Etobicoke neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Etobicoke Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Etobicoke"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="etobicoke" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Quick Facts Box -->
  <section class="py-8 border-b border-slate-200">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Basement Waterproofing in Etobicoke — Quick Facts</h2>
        <dl class="grid md:grid-cols-2 gap-x-8 gap-y-3 text-sm speakable">
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Exterior waterproofing</dt>
            <dd class="font-bold text-slate-900">$150–$300 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Interior drainage</dt>
            <dd class="font-bold text-slate-900">$80–$200 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Average project cost</dt>
            <dd class="font-bold text-slate-900">$15,000–$30,000</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Toronto rebate</dt>
            <dd class="font-bold text-slate-900">Up to $3,400</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Typical timeline</dt>
            <dd class="font-bold text-slate-900">3–5 days (exterior)</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Emergency response</dt>
            <dd class="font-bold text-slate-900">Under 2 hours</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Warranty</dt>
            <dd class="font-bold text-slate-900">25-year transferable</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Humber Valley specialists</dt>
            <dd class="font-bold text-slate-900">Flood protection</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">How Much Does Basement Waterproofing Cost in Etobicoke?</h2>

        <div class="prose prose-lg  max-w-none">
          <p class="text-lg text-slate-600 mb-6 speakable">
            <strong>Basement waterproofing in Etobicoke costs $150–$300 per linear foot for exterior systems, with most homes totaling $15,000–$30,000. Toronto homeowners can access up to $3,400 through the Basement Flooding Protection Subsidy Program.</strong>
          </p>
          <p class="text-lg text-slate-600 mb-6">
            Etobicoke homeowners face complex waterproofing challenges unique to the Humber River valley. With mature neighborhoods featuring 50-70 year old homes, extensive mature tree coverage, and variable river valley conditions, specialized expertise is essential. Our team understands the intricate relationship between mature landscaping, vintage foundations, and seasonal water patterns.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">ETOBICOKE QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600 ">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">365,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">50-70 YEARS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">850MM + RUNOFF</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.2 METERS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                <span class="text-sm font-bold text-slate-900">HIGH - HUMBER RIVER</span>
              </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WHY ETOBICOKE NEEDS WATERPROOFING</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>River valley clay creates unstable conditions</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Seasonal Humber River water table fluctuations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Mature tree canopy creates moisture retention</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Tree root systems damage aging foundations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Humber River seasonal flooding and overflow</span>
              </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Neighborhoods We Serve</h3>
          <p class="mb-4">
            Our Etobicoke waterproofing team serves all neighborhoods including:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Islington","Mimico","The Kingsway","Rexdale","Long Branch"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Construction Eras Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">Etobicoke Construction History</h2>
        <p class="text-lg text-slate-600 mb-12">
          Each building era in Etobicoke presents unique waterproofing challenges based on construction methods and materials of the time.
        </p>

        <div class="space-y-8">
          <!-- Era 1: 1920s-1950s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                1
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1920s-1950s: Old Etobicoke Core</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> Mimico, Long Branch, New Toronto
                </p>
                <p class="text-slate-600 mb-4">
                  Original Etobicoke settlements feature brick and stone foundations built before modern waterproofing. Many homes near the lakeshore have foundation movement from clay soils.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Stone, rubble stone, early concrete block</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Tar coating or none - requires full exterior membrane</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Mortar deterioration, stone settlement, no drainage tile</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Era 2: 1960s-1970s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                2
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1960s-1970s: Post-War Expansion</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> The Kingsway, Islington, Humber Valley neighborhoods
                </p>
                <p class="text-slate-600 mb-4">
                  Post-war boom brought rapid development with poured concrete foundations. Quality varied widely - some homes have minimal waterproofing and undersized drainage.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Poured concrete, concrete block with brick veneer</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Tar or asphalt damp-proofing (degraded by now)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Cracked concrete, tree root damage, inadequate drainage</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Era 3: 1980s-1990s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                3
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1980s-1990s: Suburban Infill</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> Rexdale, Richview, Humber Valley subdivisions
                </p>
                <p class="text-slate-600 mb-4">
                  Modern subdivisions with improved drainage but still pre-building code waterproofing requirements. Many developments in former Humber floodplains.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Poured concrete, some ICF systems</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Rubberized asphalt, drainage tile (may be undersized)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Drainage overwhelmed, sump pump failures, backwater valve missing</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhoods with Project Counts -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-4xl font-bold text-white mb-4 uppercase">Projects Completed by Neighborhood</h2>
        <p class="text-lg text-slate-300 mb-12">
          Our Etobicoke track record across the city's diverse communities.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { name: "Mimico", count: 42 },
            { name: "Kingsway", count: 38 },
            { name: "Long Branch", count: 35 },
            { name: "Islington-City Centre", count: 30 },
            { name: "Alderwood", count: 26 },
            { name: "Rexdale", count: 23 },
            { name: "Richview", count: 20 },
            { name: "New Toronto", count: 18 }
          ].map((neighborhood) => (
            <div class="bg-white/10 backdrop-blur-sm border-2 border-slate-700 p-6 hover:bg-white/15 transition-colors">
              <div class="text-amber-500 text-4xl font-bold mb-2">{neighborhood.count}</div>
              <div class="text-white font-bold uppercase text-sm">{neighborhood.name}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-slate-400 text-sm">
          <p>Also serving: Sunnylea, Humber Bay, Princess Gardens, Thistletown, and all Etobicoke neighborhoods.</p>
        </div>
      </div>
    </div>
  </section>

  <GeologicalProfile city="Etobicoke" data={cityData.geological} />
  <SeasonalRiskCalendar city="Etobicoke" data={cityData.seasonal} />
  <InfrastructureReport city="Etobicoke" data={cityData.infrastructure} />
  <FoundationCensus city="Etobicoke" data={cityData.foundationCensus} />
  <FloodTimeline city="Etobicoke" data={cityData.floodHistory} />

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN ETOBICOKE</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Local expertise combined with industry-leading warranties and service
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {locationFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
