import InfrastructureReport from '../../components/sections/InfrastructureReport.astro';
import FoundationCensus from '../../components/sections/FoundationCensus.astro';
import FloodTimeline from '../../components/sections/FloodTimeline.astro';
import { locationData } from '../../data/location-data';

const cityData = locationData['etobicoke'];
const pageTitle = "Basement Waterproofing Etobicoke | Foundation Repair & Drainage";
const pageDescription = "Professional basement waterproofing in Etobicoke. Foundation repair, sump pumps, crack repair. Humber Valley flood protection. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  cityName: "Etobicoke",
  population: "365,000",
  waterTable: "Variable - river valley",
  soilType: "River valley clay/silt",
  avgHomesAge: "50-70 years",
  floodRisk: "High - Humber flooding",
  avgRainfall: "850mm + runoff"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL ETOBICOKE EXPERTS',
    description: 'Serving Etobicoke for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in Etobicoke. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Islington, Mimico, The Kingsway and all Etobicoke areas.',
    highlight: true
  },
  {
    title: 'HUMBER VALLEY EXPERTS',
    description: 'Specialized in river valley drainage, mature tree root damage, flood plain protection.'
  },
  {
    title: 'VINTAGE HOME SPECIALISTS',
    description: 'Expert restoration of 50-70 year old bungalows and post-war foundation systems.'
  },
  {
    title: 'FLOOD PLAIN SOLUTIONS',
    description: 'Advanced protection for Humber River flood zones and seasonal overflow areas.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do mature trees affect Etobicoke basement waterproofing?",
    answer: "Mature trees in Etobicoke create unique challenges through root infiltration, soil moisture depletion and rehydration cycles, and foundation pressure. We specialize in root-resistant barriers and tree-friendly drainage solutions that protect both your foundation and valuable mature landscaping."
  },
  {
    question: "What makes Humber River valley waterproofing different?",
    answer: "The Humber River valley has variable soil conditions, seasonal flooding risks, and elevated groundwater. Our valley-specific solutions include enhanced drainage systems, flood barriers, and specialized sump pump configurations designed for river proximity challenges."
  },
  {
    question: "How do you waterproof older Etobicoke bungalows?",
    answer: "Etobicoke's 50-70 year old bungalows require specialized approaches including foundation underpinning compatibility, heritage-sensitive solutions, and upgrades that work with original construction methods. We maintain the character while providing modern protection."
  },
  {
    question: "What are the flood risks in different Etobicoke areas?",
    answer: "Areas near the Humber River face seasonal flooding, while neighborhoods like Mimico deal with lake effects. Islington and The Kingsway have mature tree root issues. We provide area-specific solutions based on each neighborhood's unique challenges."
  },
  {
    question: "How do you handle Humber River emergency flooding?",
    answer: "Our Etobicoke emergency response includes rapid deployment to flood-prone areas during spring melt and severe storms. We maintain specialized river flooding equipment and coordinate with municipal flood response protocols."
  },
  {
    question: "Can you work around mature landscaping in Etobicoke?",
    answer: "Yes! We specialize in preserving mature trees and established gardens while installing effective waterproofing. Our techniques include minimal excavation methods, root-safe barriers, and strategic drainage placement to protect both your home and landscaping investments."
  },
  {
    question: "How does Mimico Creek affect basement flooding?",
    answer: "Mimico Creek creates localized flooding risks during heavy rainfall, particularly in older neighborhoods near the creek. We install enhanced drainage systems, backwater valves, and sump pumps specifically designed for creek-adjacent properties with rapid water level changes."
  },
  {
    question: "What issues do combined sewers create in Etobicoke?",
    answer: "Many older Etobicoke neighborhoods have combined storm and sanitary sewers that can backup during heavy rain. We install backwater valves and independent drainage systems to protect your basement even when municipal systems are overwhelmed."
  },
  {
    question: "How do you handle foundation issues in older Etobicoke homes?",
    answer: "Homes built in the 1920s-1950s often have stone or early concrete foundations that have settled or cracked. We combine structural repair (crack injection, underpinning if needed) with comprehensive waterproofing to address both foundation integrity and water intrusion."
  },
  {
    question: "Do I need permits for waterproofing work in Toronto/Etobicoke?",
    answer: "Most waterproofing work requires a building permit from the City of Toronto. We handle all permit applications and inspections as part of our service. Permits ensure work meets code and are required for the Toronto rebate program."
  },
  {
    question: "What's the typical cost for waterproofing an Etobicoke home?",
    answer: "Average exterior waterproofing in Etobicoke costs $15,000-$30,000 depending on foundation length, soil conditions, and access. Interior drainage systems are typically $8,000-$18,000. Many homeowners receive $2,800-$3,400 back through Toronto's subsidy program."
  },
  {
    question: "How does proximity to the Humber River impact waterproofing needs?",
    answer: "Properties within the Humber River floodplain require enhanced protection including commercial-grade sump pumps, battery backup systems, and flood barriers. We design systems specifically for river valley hydrology and seasonal flood risk patterns unique to the Humber watershed."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "WaterproofingService"],
  "name": "Dryspace Waterproofing",
  "description": "Professional waterproofing services in Etobicoke. Expert basement waterproofing, foundation repair, and drainage solutions. Serving all Etobicoke neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
