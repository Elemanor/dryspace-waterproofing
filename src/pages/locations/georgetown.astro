---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import LocationImageShowcase from '../../components/LocationImageShowcase.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Basement Waterproofing Georgetown | Foundation Repair | DrySpace";
const pageDescription = "Professional basement waterproofing in Georgetown. Credit River flood protection. Foundation repair, sump pumps, heritage homes. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  cityName: "Georgetown",
  population: "42,000",
  waterTable: "River influenced",
  soilType: "Escarpment clay/limestone",
  avgHomesAge: "Mixed heritage-modern",
  floodRisk: "Credit River seasonal",
  avgRainfall: "880mm + escarpment"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL GEORGETOWN EXPERTS',
    description: 'Serving Georgetown for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in Georgetown. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Downtown, Delrex, Georgetown South and all Georgetown areas.',
    highlight: true
  },
  {
    title: 'HERITAGE PRESERVATION',
    description: 'Specialized conservation techniques for Georgetown historic buildings and modern additions.'
  },
  {
    title: 'CREDIT RIVER EXPERTS',
    description: 'Advanced solutions for river valley conditions and escarpment drainage challenges.'
  },
  {
    title: 'ESCARPMENT SOLUTIONS',
    description: 'Specialized drainage for Georgetown escarpment properties and slope stability.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do you preserve Georgetown's heritage buildings during waterproofing work?",
    answer: "Georgetown's historic downtown requires specialized heritage conservation techniques. We use period-appropriate materials, reversible methods, and work closely with heritage committees to preserve architectural integrity while providing modern waterproofing."
  },
  {
    question: "What challenges does the Credit River valley create for waterproofing?",
    answer: "The Credit River valley creates variable water table conditions, seasonal flooding risks, and unique soil compositions. Our river valley expertise includes specialized drainage systems and flood mitigation designed for Georgetown's topographic challenges."
  },
  {
    question: "How do escarpment properties in Georgetown require different waterproofing?",
    answer: "Georgetown's escarpment location creates unique drainage challenges with rapid water runoff, soil erosion, and slope stability concerns. We design specialized retention systems and grade management to handle the significant elevation changes."
  },
  {
    question: "What makes Georgetown's downtown core waterproofing unique?",
    answer: "Downtown Georgetown features a mix of heritage buildings, modern infill, and connected structures requiring coordinated waterproofing approaches. We navigate shared foundations, heritage restrictions, and municipal requirements for downtown properties."
  },
  {
    question: "How do you handle Georgetown's mixed soil conditions?",
    answer: "Georgetown sits on varied escarpment geology including clay deposits, limestone bedrock, and river gravels. Our soil analysis determines the best waterproofing approach for each property's specific geological conditions."
  },
  {
    question: "Do you work with Georgetown heritage committees?",
    answer: "Yes! We maintain relationships with local heritage committees and understand Georgetown's heritage designation requirements. Our heritage-sensitive solutions meet both waterproofing needs and preservation standards."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "FoundationService"],
  "name": "DrySpace Waterproofing",
  "description": "Professional basement waterproofing services in Georgetown. Expert foundation repair, crack repair, and drainage solutions. Serving all Georgetown neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Georgetown Service Area",
    "addressLocality": "Georgetown",
    "addressRegion": "ON",
    "postalCode": "L7G",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.6426",
    "longitude": "-79.9079"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Georgetown",
      "sameAs": "https://en.wikipedia.org/wiki/Georgetown,_Ontario"
    },
    {
      "@type": "Place",
      "name": "Halton Hills"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates", 
      "latitude": "43.6426",
      "longitude": "-79.9079"
    },
    "geoRadius": "25000"
  },
  "openingHours": [
    "Mo-Fr 07:00-19:00",
    "Sa 08:00-17:00", 
    "Su 09:00-17:00"
  ],
  "availableLanguage": ["English"],
  "currenciesAccepted": "CAD",
  "paymentAccepted": ["Cash", "Credit Card", "Debit Card", "Bank Transfer"],
  "priceRange": "$$",
  "url": "https://dryspacewaterproofing.com/locations/georgetown",
  "logo": "https://dryspacewaterproofing.com/images/dryspace-logo.webp",
  "image": "https://dryspacewaterproofing.com/images/dryspace_hero_desktop.webp",
  "sameAs": [
    "https://www.facebook.com/dryspacewaterproofing",
    "https://www.linkedin.com/company/dryspace-waterproofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Waterproofing Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Basement Waterproofing",
          "description": "Complete basement waterproofing solutions"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Foundation Repair",
          "description": "Foundation crack repair and structural solutions"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "Drainage Solutions",
          "description": "French drains, sump pumps, and drainage systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emergency Water Removal",
          "description": "24/7 emergency flooding and water damage response"
        }
      }
    ]
  }
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Georgetown" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero
    title="Basement Waterproofing Georgetown"
    subtitle="Professional basement waterproofing and foundation repair serving all Georgetown neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Georgetown Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Georgetown"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="georgetown" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Quick Facts Box -->
  <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6 my-8" style="margin-left: auto; margin-right: auto;">
    <h2 class="text-lg font-bold text-slate-900 mb-4">Basement Waterproofing in Georgetown — Quick Facts</h2>
    <dl class="grid md:grid-cols-2 gap-x-8 gap-y-3 text-sm speakable">
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Exterior waterproofing</dt>
        <dd class="font-bold text-slate-900">$140–$275 / linear ft</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Interior drainage</dt>
        <dd class="font-bold text-slate-900">$80–$200 / linear ft</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Average project cost</dt>
        <dd class="font-bold text-slate-900">$12,000–$27,000</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Municipal rebate</dt>
        <dd class="font-bold text-slate-900">Halton Region</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Typical timeline</dt>
        <dd class="font-bold text-slate-900">3–5 days (exterior)</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Warranty</dt>
        <dd class="font-bold text-slate-900">25-year transferable</dd>
      </div>
    </dl>
  </div>

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">How Much Does Basement Waterproofing Cost in Georgetown?</h2>

        <div class="bg-cyan-50 border-l-4 border-cyan-500 p-6 mb-8 speakable">
          <p class="text-slate-700 leading-relaxed">
            Basement waterproofing in Georgetown costs $140–$275 per linear foot for exterior systems, with most homes totaling $12,000–$27,000. Georgetown homeowners can access Halton Hills municipal programs for flooding protection.
          </p>
        </div>

        <div class="prose prose-lg  max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Georgetown presents unique waterproofing challenges combining heritage preservation with modern protection needs. Situated in the Credit River valley with significant escarpment topography, Georgetown requires specialized expertise for both historic downtown buildings and modern residential developments.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">GEORGETOWN QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600 ">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">42,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">MIXED HERITAGE-MODERN</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">880MM + ESCARPMENT</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.2 METERS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                <span class="text-sm font-bold text-slate-900">CREDIT RIVER SEASONAL</span>
              </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WHY GEORGETOWN NEEDS WATERPROOFING</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Escarpment clay over limestone creates pressure</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Credit River influences groundwater levels</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Escarpment position increases precipitation</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Freeze-thaw cycles damage foundations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Credit River valley seasonal flooding</span>
              </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Neighborhoods We Serve</h3>
          <p class="mb-4">
            Our Georgetown waterproofing team serves all neighborhoods including:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Historic Downtown","Delrex","Silver Creek","Limehouse","Glen Williams","Georgetown South"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN GEORGETOWN</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Local expertise combined with industry-leading warranties and service
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {locationFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {locationFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />


  <!-- Location Image Showcase -->
  <LocationImageShowcase city="Georgetown" />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">GEORGETOWN WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Georgetown homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {locationFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PRESERVE GEORGETOWN'S HERITAGE PROPERTIES</h2>
        <p class="text-lg text-slate-300 mb-8">
          Heritage-sensitive waterproofing solutions for Credit River valley properties
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Get Heritage Property Assessment
          </a>
          <a 
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">24/7 Emergency Service Available</span>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": locationFAQs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Locations', url: '/locations'}, {name: 'Georgetown'}]} />
