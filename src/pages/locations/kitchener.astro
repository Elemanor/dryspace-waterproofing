---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import LocationImageShowcase from '../../components/LocationImageShowcase.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Basement Waterproofing Kitchener | Foundation Repair | DrySpace";
const pageDescription = "Professional basement waterproofing in Kitchener. Grand River flood protection. Foundation repair, sump pumps, heritage homes. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  cityName: "Kitchener",
  population: "256,000",
  waterTable: "Grand River influenced",
  soilType: "River valley clay/sand",
  avgHomesAge: "Mixed heritage-tech era",
  floodRisk: "Grand River seasonal",
  avgRainfall: "916mm + urban runoff"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL KITCHENER EXPERTS',
    description: 'Serving Kitchener for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in Kitchener. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Downtown, Doon, Forest Heights and all Kitchener areas.',
    highlight: true
  },
  {
    title: 'TECH CORRIDOR SPECIALISTS',
    description: 'Modern waterproofing for Kitchener innovation district and rapid development areas.'
  },
  {
    title: 'GERMAN HERITAGE EXPERTS',
    description: 'Preservation techniques for historic German settlement buildings and modern tech facilities.'
  },
  {
    title: 'GRAND RIVER SOLUTIONS',
    description: 'Advanced flood protection for Grand River watershed properties and seasonal variations.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do you waterproof Kitchener's tech district buildings?",
    answer: "Kitchener's innovation district requires specialized waterproofing for modern commercial and mixed-use buildings. We provide advanced systems compatible with smart building technologies, underground parking, and high-density development requirements typical of the tech corridor."
  },
  {
    question: "What challenges does the Grand River create for Kitchener waterproofing?",
    answer: "The Grand River significantly influences Kitchener's water table and creates seasonal flooding risks. Our Grand River expertise includes specialized drainage systems, flood barriers, and watershed-aware solutions designed for river proximity challenges."
  },
  {
    question: "How do you preserve German heritage buildings during waterproofing?",
    answer: "Kitchener's German heritage buildings require specialized preservation techniques including period-appropriate materials, traditional masonry compatibility, and heritage committee compliance. We maintain historical integrity while providing modern waterproofing protection."
  },
  {
    question: "What makes Kitchener's rapid development areas different?",
    answer: "Areas experiencing rapid tech sector growth face unique challenges including new construction settling, inadequate initial drainage, and high-density development impacts. We specialize in post-construction waterproofing for emerging neighborhoods and commercial districts."
  },
  {
    question: "How do you handle seasonal Grand River flooding?",
    answer: "Our Kitchener team monitors Grand River levels and provides specialized flood response during spring melt and severe weather. We maintain equipment specifically for river flooding scenarios and coordinate with municipal flood management protocols."
  },
  {
    question: "Do you work with tech companies for commercial waterproofing?",
    answer: "Yes! We provide commercial waterproofing services for Kitchener's growing tech sector including data centers, research facilities, and innovation hubs. Our solutions accommodate sensitive equipment protection and continuous operation requirements."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "WaterproofingService"],
  "name": "Dryspace Waterproofing",
  "description": "Professional waterproofing services in Kitchener. Expert basement waterproofing, foundation repair, and drainage solutions. Serving all Kitchener neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Kitchener Service Area",
    "addressLocality": "Kitchener",
    "addressRegion": "ON",
    "postalCode": "N2H",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.4516",
    "longitude": "-80.4925"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Kitchener",
      "sameAs": "https://en.wikipedia.org/wiki/Kitchener,_Ontario"
    },
    {
      "@type": "Place",
      "name": "Waterloo Region"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates", 
      "latitude": "43.4516",
      "longitude": "-80.4925"
    },
    "geoRadius": "25000"
  },
  "openingHours": [
    "Mo-Fr 07:00-19:00",
    "Sa 08:00-17:00", 
    "Su 09:00-17:00"
  ],
  "availableLanguage": ["English"],
  "currenciesAccepted": "CAD",
  "paymentAccepted": ["Cash", "Credit Card", "Debit Card", "Bank Transfer"],
  "priceRange": "$$",
  "url": "https://dryspacewaterproofing.com/locations/kitchener",
  "logo": "https://dryspacewaterproofing.com/images/dryspace-logo.webp",
  "image": "https://dryspacewaterproofing.com/images/dryspace_hero_desktop.webp",
  "sameAs": [
    "https://www.facebook.com/dryspacewaterproofing",
    "https://www.linkedin.com/company/dryspace-waterproofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Waterproofing Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Basement Waterproofing",
          "description": "Complete basement waterproofing solutions"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Foundation Repair",
          "description": "Foundation crack repair and structural solutions"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "Drainage Solutions",
          "description": "French drains, sump pumps, and drainage systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emergency Water Removal",
          "description": "24/7 emergency flooding and water damage response"
        }
      }
    ]
  }
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Kitchener" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero 
    title="Waterproofing Kitchener"
    subtitle="Professional basement waterproofing and foundation repair serving all Kitchener neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Kitchener Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Kitchener"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="kitchener" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Quick Facts Box -->
  <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6 my-8" style="margin-left: auto; margin-right: auto;">
    <h2 class="text-lg font-bold text-slate-900 mb-4">Basement Waterproofing in Kitchener — Quick Facts</h2>
    <dl class="grid md:grid-cols-2 gap-x-8 gap-y-3 text-sm speakable">
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Exterior waterproofing</dt>
        <dd class="font-bold text-slate-900">$130–$260 / linear ft</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Interior drainage</dt>
        <dd class="font-bold text-slate-900">$80–$200 / linear ft</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Average project cost</dt>
        <dd class="font-bold text-slate-900">$11,000–$25,000</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Municipal rebate</dt>
        <dd class="font-bold text-slate-900">Region of Waterloo</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Typical timeline</dt>
        <dd class="font-bold text-slate-900">3–5 days (exterior)</dd>
      </div>
      <div class="flex justify-between border-b border-slate-100 pb-2">
        <dt class="font-medium text-slate-600">Warranty</dt>
        <dd class="font-bold text-slate-900">25-year transferable</dd>
      </div>
    </dl>
  </div>

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">How Much Does Basement Waterproofing Cost in Kitchener?</h2>

        <div class="bg-cyan-50 border-l-4 border-cyan-500 p-6 mb-8 speakable">
          <p class="text-slate-700 leading-relaxed">
            Basement waterproofing in Kitchener costs $130–$260 per linear foot for exterior systems, with most homes totaling $11,000–$25,000. Kitchener offers the Stormwater Utility Credit Program and basement flooding protection rebates.
          </p>
        </div>

        <div class="prose prose-lg  max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Kitchener presents unique waterproofing challenges as a rapidly evolving tech hub with significant heritage preservation needs. The Grand River influences local groundwater conditions, while the innovation district brings modern development challenges alongside historic German settlement buildings requiring specialized preservation techniques.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">KITCHENER QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600 ">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">256,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">MIXED HERITAGE-TECH ERA</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">916MM + URBAN RUNOFF</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.2 METERS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                <span class="text-sm font-bold text-slate-900">GRAND RIVER SEASONAL</span>
              </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WHY KITCHENER NEEDS WATERPROOFING</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Grand River valley clay creates foundation pressure</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Grand River influences seasonal groundwater</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Tech district development increases runoff</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Freeze-thaw cycles damage foundations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Grand River seasonal flooding zones</span>
              </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Neighborhoods We Serve</h3>
          <p class="mb-4">
            Our Kitchener waterproofing team serves all neighborhoods including:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Innovation District","Downtown Core","Doon","Forest Heights","Stanley Park","Bridgeport"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN KITCHENER</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Local expertise combined with industry-leading warranties and service
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {locationFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {locationFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />


  <!-- Location Image Showcase -->
  <LocationImageShowcase city="Kitchener" />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">KITCHENER WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Kitchener homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {locationFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">MODERN SOLUTIONS FOR HISTORIC KITCHENER</h2>
        <p class="text-lg text-slate-300 mb-8">
          Advanced waterproofing for tech corridor properties and heritage building preservation
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Get Tech District Assessment
          </a>
          <a 
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">24/7 Emergency Service Available</span>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": locationFAQs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
})} />
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Locations', url: '/locations'}, {name: 'Kitchener'}]} />
