const pageTitle = "Moisture Protection Markham | Reliable Lower Level Solutions";
const pageDescription = "Lower level protection locally. Modern techniques, experienced team, guaranteed results. Free estimates.";

// Local area information
const localInfo = {
  cityName: "Local Area",
  population: "338,000",
  waterTable: "Consistently high - Rouge River watershed",
  soilType: "Dense clay with seasonal saturation",
  avgHomesAge: "25-35 years (rapid development era)",
  floodRisk: "Moderate with seasonal Rouge River flooding",
  avgRainfall: "815mm annually",
  developmentPattern: "Planned communities over former farmland",
  culturalHeritage: "Significant Chinese-Canadian historic sites"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'NEW DEVELOPMENT SPECIALISTS',
    description: 'Expert solutions for rapidly developed subdivisions built over former farmland with challenging drainage.',
    highlight: true
  },
  {
    title: 'HIGH WATER TABLE MANAGEMENT',
    description: 'Specialized systems for Rouge River watershed\'s consistently elevated groundwater conditions.',
    highlight: true
  },
  {
    title: 'HERITAGE BUILDING PRESERVATION',
    description: 'Culturally sensitive moisture protection for the area\'s significant Chinese-Canadian historic properties.',
    highlight: true
  },
  {
    title: 'CLAY SOIL EXPERTISE',
    description: 'Advanced techniques for the region\'s dense clay soils that retain water and create hydrostatic pressure.'
  },
  {
    title: 'SUBDIVISION DRAINAGE',
    description: 'Comprehensive solutions for planned community drainage systems and lot-to-lot water management.'
  },
  {
    title: 'RAPID RESPONSE NETWORK',
    description: 'Strategically positioned for York Region\'s largest municipality with multiple service zones.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "Why do Markham's newer homes have water problems despite modern construction?",
    answer: "Markham's rapid development (1990s-2010s) often placed subdivisions on former farmland with naturally high water tables and clay soils. Many builders didn't anticipate the long-term drainage challenges of converting agricultural fields to residential areas. The Rouge River watershed also creates consistently elevated groundwater levels."
  },
  {
    question: "How do you handle Markham's dense clay soil conditions?",
    answer: "Markham's clay soils retain water and create significant hydrostatic pressure against foundations. We use specialized drainage systems including aggressive gravel drainage layers, high-capacity pumping systems, and clay-specific waterproofing membranes designed for these challenging soil conditions."
  },
  {
    question: "Can you work with Markham's cultural heritage buildings and sites?",
    answer: "Yes, we specialize in culturally sensitive restoration for Markham's significant Chinese-Canadian heritage properties, including historic temples, community buildings, and traditional architecture. We work with heritage consultants to ensure appropriate materials and methods are used while meeting modern waterproofing standards."
  },
  {
    question: "What about seasonal flooding from the Rouge River system?",
    answer: "The Rouge River watershed creates seasonal flooding challenges throughout Markham. We install comprehensive flood protection including backwater valves, emergency pumping systems, and specialized drainage designed for the area's seasonal water level fluctuations and storm water management requirements."
  },
  {
    question: "How do you address drainage issues in Markham's planned subdivisions?",
    answer: "Markham's subdivisions often have complex drainage interdependencies between properties. We assess whole-neighbourhood drainage patterns, coordinate with municipal storm systems, and install solutions that work within the planned community infrastructure while protecting individual properties."
  }
];

// Schema markup for local business
