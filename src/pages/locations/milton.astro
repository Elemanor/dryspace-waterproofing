const pageTitle = "Moisture Protection Milton | Fast-Growing Community Experts";
const pageDescription = "Local rapid expansion moisture protection. New subdivision specialists, escarpment drainage, post-construction solutions.";

// Local area information
const localInfo = {
  cityName: "Milton",
  population: "125,000",
  waterTable: "Escarpment influenced",
  soilType: "Escarpment clay/bedrock",
  avgHomesAge: "10-20 years new builds",
  floodRisk: "Escarpment runoff",
  avgRainfall: "880mm + elevation"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL MILTON EXPERTS',
    description: 'Serving Milton for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in Milton. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Dempsey, Clarke, Willmont and all Milton areas.',
    highlight: true
  },
  {
    title: 'NEW DEVELOPMENT EXPERTS',
    description: 'Specialized in rapid subdivision development, post-construction waterproofing upgrades.'
  },
  {
    title: 'ESCARPMENT SPECIALISTS',
    description: 'Advanced solutions for escarpment drainage, elevation changes, and slope management.'
  },
  {
    title: 'RAPID GROWTH SOLUTIONS',
    description: 'Addressing infrastructure challenges from Milton fastest growth in GTA region.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "What waterproofing issues affect Milton's new subdivisions?",
    answer: "Milton's rapid expansion creates unique challenges including inadequate initial drainage, construction settling, and overwhelmed municipal systems. We specialize in post-construction waterproofing upgrades for homes in newer subdivisions that weren't properly protected initially."
  },
  {
    question: "How does the Niagara Escarpment affect Milton waterproofing?",
    answer: "The escarpment creates dramatic elevation changes, rapid water runoff, and unique soil conditions mixing clay and limestone bedrock. Our escarpment expertise includes specialized retention systems, slope stabilization, and drainage management for elevation challenges."
  },
  {
    question: "Why do newer Milton homes need waterproofing so soon?",
    answer: "Rapid development often prioritizes speed over long-term protection. New Milton homes frequently experience foundation settling, inadequate grading, and builder-grade waterproofing failures. We provide comprehensive upgrades that exceed original specifications."
  },
  {
    question: "How do you handle Milton's infrastructure growing pains?",
    answer: "Milton's rapid growth has strained municipal drainage systems. We design private waterproofing solutions that don't rely solely on overwhelmed storm systems, including enhanced sump capacity and independent drainage networks."
  },
  {
    question: "What makes Milton's soil conditions challenging?",
    answer: "Milton sits where escarpment clay meets limestone bedrock, creating variable drainage and foundation challenges. Water can pool in clay layers or disappear into limestone, requiring specialized solutions for each property's unique geological profile."
  },
  {
    question: "Do you work with new home warranties in Milton?",
    answer: "Yes! We work within warranty requirements to provide enhanced waterproofing that doesn't void builder warranties. Many Milton homeowners upgrade their waterproofing while maintaining their new home coverage."
  }
];

// Schema markup for local business
const localBusinessSchema = {
