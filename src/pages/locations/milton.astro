const locationFAQs = [
  {
    question: "What waterproofing issues affect Milton's new subdivisions?",
    answer: "Milton's rapid expansion creates unique challenges including inadequate initial drainage, construction settling, and overwhelmed municipal systems. We specialize in post-construction waterproofing upgrades for homes in newer subdivisions that weren't properly protected initially."
  },
  {
    question: "How does the Niagara Escarpment affect Milton waterproofing?",
    answer: "The escarpment creates dramatic elevation changes, rapid water runoff, and unique soil conditions mixing clay and limestone bedrock. Our escarpment expertise includes specialized retention systems, slope stabilization, and drainage management for elevation challenges."
  },
