---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Milton" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero 
    title="Waterproofing Milton"
    subtitle="Professional basement waterproofing and foundation repair serving all Milton neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Milton Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Milton"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="milton" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Quick Facts Box -->
  <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6 my-8" style="margin-left: auto; margin-right: auto;">
