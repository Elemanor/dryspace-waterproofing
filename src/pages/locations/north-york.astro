    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.7615",
    "longitude": "-79.4111"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "North York",
      "sameAs": "https://en.wikipedia.org/wiki/North_York"
    },
    {
      "@type": "Place",
      "name": "City of Toronto"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates", 
      "latitude": "43.7615",
