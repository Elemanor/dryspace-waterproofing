---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import LocationImageShowcase from '../../components/LocationImageShowcase.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';
import GeologicalProfile from '../../components/sections/GeologicalProfile.astro';
import SeasonalRiskCalendar from '../../components/sections/SeasonalRiskCalendar.astro';
import InfrastructureReport from '../../components/sections/InfrastructureReport.astro';
import FoundationCensus from '../../components/sections/FoundationCensus.astro';
import FloodTimeline from '../../components/sections/FloodTimeline.astro';
import { locationData } from '../../data/location-data';

const cityData = locationData['north-york'];
const pageTitle = "Basement Waterproofing North York | Foundation Repair | A+ BBB";
const pageDescription = "Professional basement waterproofing in North York. Foundation repair, sump pumps, crack repair. Don River watershed experts. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  cityName: "North York",
  population: "670,000",
  waterTable: "Don River influenced",
  soilType: "Glacial till/clay",
  avgHomesAge: "40-60 years mixed",
  floodRisk: "Don watershed variable",
  avgRainfall: "850mm + urban effect"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL EXPERTS',
    description: 'Serving the area for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in the area. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Willowdale, York Mills, Don Mills and all local areas.',
    highlight: true
  },
  {
    title: 'HIGH-RISE SPECIALISTS',
    description: 'Specialized waterproofing for local condominium towers and underground parking.',
  },
  {
    title: 'AGING INFRASTRUCTURE',
    description: 'Expert solutions for local aging municipal systems and infrastructure challenges.',
  },
  {
    title: 'DON WATERSHED EXPERTS',
    description: 'Advanced protection for Don River watershed properties and ravine system drainage.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do you protect local high-rise buildings?",
    answer: "Local numerous condominium towers require specialized waterproofing for underground parking, mechanical rooms, and below-grade amenities. Our high-rise expertise includes structural protection, parking garage solutions, and coordination with condominium boards and property management."
  },
  {
    question: "What challenges does the Don River watershed create?",
    answer: "The Don River watershed significantly influences local drainage patterns, creating variable water table conditions and seasonal flooding risks in ravine areas. Our watershed expertise includes specialized drainage systems and flood mitigation for properties near the extensive ravine system."
  },
  {
    question: "How do you handle local aging infrastructure problems?",
    answer: "Local older municipal infrastructure often can't handle modern drainage demands, leading to basement flooding during heavy rainfall. We design private protection solutions that don't rely on aging storm systems, including enhanced sump capacity and independent drainage networks."
  },
  {
    question: "What makes waterproofing different for local mixed housing?",
    answer: "The area features everything from 1960s split-levels to modern condominiums, each requiring different approaches. We adapt our techniques for post-war bungalows, 1970s-80s high-rises, and contemporary developments, ensuring appropriate solutions for each building type."
  },
  {
    question: "How do you work with local condominium corporations?",
    answer: "We maintain relationships with numerous local condominium corporations and understand the complex approval processes, reserve fund considerations, and coordination required for multi-unit protection projects."
  },
  {
    question: "What are the unique Don Mills area waterproofing challenges?",
    answer: "Don Mills, as a planned community from the 1950s, has unique drainage patterns and aging infrastructure. The area's proximity to the Don River creates specific challenges including ravine drainage, mature tree root systems, and original construction methods requiring specialized approaches."
  },
  {
    question: "How does Don River flooding affect North York basements?",
    answer: "The Don River and its tributaries (including Taylor-Massey Creek and German Mills Creek) can cause localized flooding during heavy rainfall. We install enhanced sump systems, backwater valves, and independent drainage designed specifically for ravine-adjacent properties with rapid water table changes."
  },
  {
    question: "What issues do Black Creek properties face?",
    answer: "Black Creek runs through western North York (Downsview, Jane-Finch areas) and creates flooding risks during storms. We design protection systems with commercial-grade pumps and emergency backup for properties in the Black Creek watershed."
  },
  {
    question: "Why do combined sewers cause problems in older North York neighborhoods?",
    answer: "Neighborhoods like Downsview and Lawrence Manor have combined storm/sanitary sewers that backup during heavy rain. We install backwater valves and create independent drainage so your basement stays dry even when municipal systems are overwhelmed."
  },
  {
    question: "What foundation issues are common in North York block foundations?",
    answer: "Many 1950s-1960s homes have concrete block foundations that allow water penetration through the blocks and mortar joints. We seal the exterior with modern membranes and install comprehensive drainage systems to prevent water infiltration."
  },
  {
    question: "Do I need permits for waterproofing work in North York/Toronto?",
    answer: "Yes, most waterproofing work requires a building permit from the City of Toronto. We handle all permit applications, inspections, and close-out as part of our service. Permits are mandatory for the Toronto rebate program and ensure code compliance."
  },
  {
    question: "What's the typical cost for waterproofing a North York home?",
    answer: "Average exterior waterproofing costs $15,000-$30,000 depending on foundation length, access, and soil conditions. Interior drainage systems typically run $8,000-$18,000. Most homeowners receive $2,800-$3,400 back through Toronto's subsidy program, reducing net costs significantly."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "ProtectionService"],
  "name": "Dryspace Protection",
  "description": "Professional basement protection services in North York. Expert foundation repair, and drainage solutions. Serving all local neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Service Area",
    "addressLocality": "North York",
    "addressRegion": "ON",
