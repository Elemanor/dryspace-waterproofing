};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "North York" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero
    title="Basement Waterproofing North York"
    subtitle="Professional basement protection and foundation repair serving all local neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving the Area"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="north-york" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Quick Facts Box -->
  <section class="py-8 border-b border-slate-200">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-white border-2 border-cyan-100 rounded-xl p-6">
        <h2 class="text-lg font-bold text-slate-900 mb-4">Basement Waterproofing in North York — Quick Facts</h2>
        <dl class="grid md:grid-cols-2 gap-x-8 gap-y-3 text-sm speakable">
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Exterior waterproofing</dt>
            <dd class="font-bold text-slate-900">$150–$300 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Interior drainage</dt>
            <dd class="font-bold text-slate-900">$80–$200 / linear ft</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Average project cost</dt>
            <dd class="font-bold text-slate-900">$15,000–$30,000</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Toronto rebate</dt>
            <dd class="font-bold text-slate-900">Up to $3,400</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Typical timeline</dt>
            <dd class="font-bold text-slate-900">3–5 days (exterior)</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Emergency response</dt>
            <dd class="font-bold text-slate-900">Under 2 hours</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">Warranty</dt>
            <dd class="font-bold text-slate-900">25-year transferable</dd>
          </div>
          <div class="flex justify-between border-b border-slate-100 pb-2">
            <dt class="font-medium text-slate-600">High-rise specialists</dt>
            <dd class="font-bold text-slate-900">Condo experience</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">How Much Does Basement Waterproofing Cost in North York?</h2>

        <div class="prose prose-lg  max-w-none">
          <p class="text-lg text-slate-600 mb-6 speakable">
            <strong>Basement waterproofing in North York costs $150–$300 per linear foot for exterior systems, with most homes totaling $15,000–$30,000. Toronto homeowners can access up to $3,400 through the Basement Flooding Protection Subsidy Program.</strong>
          </p>
          <p class="text-lg text-slate-600 mb-6">
            The area presents complex moisture challenges as Toronto's most densely populated area with diverse housing types from 1950s planned communities to modern high-rises. The Don River watershed influences local drainage while aging municipal infrastructure struggles with modern demands, requiring specialized expertise for both residential and condominium protection.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">LOCAL QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600 ">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">670,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">40-60 YEARS MIXED</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">850MM + URBAN EFFECT</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.2 METERS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                <span class="text-sm font-bold text-slate-900">DON WATERSHED VARIABLE</span>
              </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WHY NORTH YORK NEEDS WATERPROOFING</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Glacial till creates complex drainage patterns</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Don River watershed influences groundwater</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Urban heat island increases precipitation</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Freeze-thaw cycles damage foundations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Don River ravine system flooding</span>
              </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Neighborhoods We Serve</h3>
          <p class="mb-4">
            Our local waterproofing team serves all neighborhoods including:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Willowdale","York Mills","Don Mills","Bayview Village","Lawrence Park","Lansing","Newtonbrook"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Construction Eras Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">North York Construction History</h2>
        <p class="text-lg text-slate-600 mb-12">
          From post-war planned communities to modern high-rises, each era brings distinct waterproofing requirements.
        </p>

        <div class="space-y-8">
          <!-- Era 1: 1940s-1960s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                1
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1940s-1960s: Post-War North York</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> Downsview, Lawrence Manor, early Willowdale
                </p>
                <p class="text-slate-600 mb-4">
                  Post-war housing boom created affordable single-family homes with basic concrete or concrete block foundations. Minimal waterproofing was standard - many homes have only tar coating.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Poured concrete, concrete block (often hollow)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Tar or minimal asphalt coating (degraded by now)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Block foundation water infiltration, no drainage tile, cracked floors</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Era 2: 1960s-1970s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                2
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1960s-1970s: Suburban Boom Era</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> Don Mills planned community, Bathurst Manor, Lansing
                </p>
                <p class="text-slate-600 mb-4">
                  Peak suburban expansion with Don Mills as Canada's first planned suburb. Split-level homes and early high-rises. Variable quality - some excellent, some rushed construction.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Poured concrete, some pre-cast panels (high-rises)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Asphalt damp-proofing, clay tile drainage (often failed)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Failed clay tile, condo parking garage leaks, split-level drainage</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Era 3: 1980s-1990s -->
          <div class="bg-slate-50 border-2 border-slate-200 p-8 border-l-4 border-l-cyan-500">
            <div class="flex items-start gap-6">
              <div class="bg-cyan-500 text-white text-2xl font-bold w-16 h-16 rounded-full flex items-center justify-center flex-shrink-0">
                3
              </div>
              <div class="flex-1">
                <h3 class="text-2xl font-bold text-slate-900 mb-3 uppercase">1980s-1990s: Infill & Condo Boom</h3>
                <p class="text-slate-600 mb-4">
                  <strong>Areas:</strong> Yonge corridor high-rises, Sheppard subway area, Jane-Finch redevelopment
                </p>
                <p class="text-slate-600 mb-4">
                  Intensification brought high-rise condos and infill housing. Better drainage systems but still pre-modern waterproofing code. Many condo underground parking issues.
                </p>
                <ul class="space-y-2 text-slate-600">
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Foundation Type:</strong> Poured concrete, shotcrete (high-rises)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Waterproofing:</strong> Rubberized asphalt, membrane systems (aging now)</span>
                  </li>
                  <li class="flex items-start">
                    <span class="text-cyan-600 mr-2">•</span>
                    <span><strong>Common Issues:</strong> Membrane failure, sump pump inadequate, condo parking leaks</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Neighborhoods with Project Counts -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-4xl font-bold text-white mb-4 uppercase">Projects Completed by Neighborhood</h2>
        <p class="text-lg text-slate-300 mb-12">
          Our North York track record across Toronto's most populous district.
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {[
            { name: "Downsview", count: 40 },
            { name: "Lawrence Manor", count: 35 },
            { name: "Don Mills", count: 32 },
            { name: "Willowdale", count: 28 },
            { name: "Bathurst Manor", count: 25 },
            { name: "Lansing", count: 22 },
            { name: "Bayview Village", count: 19 },
            { name: "Jane-Finch", count: 16 }
          ].map((neighborhood) => (
            <div class="bg-white/10 backdrop-blur-sm border-2 border-slate-700 p-6 hover:bg-white/15 transition-colors">
              <div class="text-amber-500 text-4xl font-bold mb-2">{neighborhood.count}</div>
              <div class="text-white font-bold uppercase text-sm">{neighborhood.name}</div>
            </div>
          ))}
        </div>

        <div class="mt-8 text-slate-400 text-sm">
          <p>Also serving: Yorkdale, Newtonbrook, Armour Heights, York Mills, and all North York neighborhoods.</p>
        </div>
      </div>
    </div>
  </section>

  <GeologicalProfile city="North York" data={cityData.geological} />
  <SeasonalRiskCalendar city="North York" data={cityData.seasonal} />
  <InfrastructureReport city="North York" data={cityData.infrastructure} />
  <FoundationCensus city="North York" data={cityData.foundationCensus} />
  <FloodTimeline city="North York" data={cityData.floodHistory} />

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE LOCALLY</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Local expertise combined with industry-leading warranties and service
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {locationFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {locationFeatures.filter(f => !f.highlight).map((feature) => (
