---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Oakville" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero 
    title="Moisture Control Oakville"
    subtitle="Professional lower level moisture control and foundation repair serving all Oakville neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Oakville Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Oakville"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="oakville" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WATERPROOFING SERVICES IN Oakville</h2>
        
        <div class="prose prose-lg  max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Oakville homeowners face unique waterproofing challenges. With a population of 211,000 and homes averaging 30-40 years old, 
            foundation issues are common. Our local team understands Oakville's Sand and clay soil conditions and High near lake water table.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">the region QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600 ">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">211,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">30-40 YEARS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">799MM ANNUALLY</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.0 METERS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                <span class="text-sm font-bold text-slate-900">MODERATE - LAKEFRONT AREAS</span>
              </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200  p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">Why Oakville Needs Waterproofing</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Sand and clay soil expands when wet</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>High near lake water table issues</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>799mm annually of annual rainfall</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Freeze-thaw cycles damage foundations</span>
              </li>
                <li class="text-sm text-slate-300 flex items-start">
                <span class="mr-2 text-cyan-400">•</span>
                <span>Moderate - lakefront areas flood risk areas</span>
              </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4">Neighborhoods We Serve</h3>
          <p class="mb-4">
            Our Oakville waterproofing team serves all neighborhoods including:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Old Oakville (Heritage homes)","Glen Abbey (Golf course properties)","Bronte Village (Lakefront estates)","Morrison (Luxury custom homes)","River Oaks (Family neighborhoods)","Clearview (Mature tree areas)","West Oak Trails (New developments)","Uptown Core (Mixed residential)"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">Why Choose Dryspace In Oakville</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Local expertise combined with industry-leading warranties and service
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {locationFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {locationFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />


  <!-- Location Image Showcase -->
  <LocationImageShowcase city="Oakville" />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">the region WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Oakville homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {locationFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">OAKVILLE FOUNDATION PROTECTION STARTS HERE</h2>
        <p class="text-lg text-slate-300 mb-8">
          Join 2,000+ Oakville families who trust their homes to our certified waterproofing team
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Book Oakville Assessment
          </a>
          <a 
            href="/financing"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            View Financing Options
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">Licensed in Halton Region • Heritage Property Certified</span>
        </div>
      </div>
    </div>
  </section>
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}>
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Locations', url: '/locations'}, {name: 'Oakville'}]} />
