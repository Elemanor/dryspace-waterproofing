const pageTitle = "Moisture Protection Pickering | Reliable Basement Solutions";
const pageDescription = "Pickering Rouge Park moisture protection. Mixed rural-urban specialists, nuclear safety proximity, conservation area solutions.";

// Local area information
const localInfo = {
  cityName: "Pickering",
  population: "101,000",
  waterTable: "Rouge River influenced",
  soilType: "Glacial/conservation area",
  avgHomesAge: "20-40 years mixed",
  floodRisk: "Rouge River seasonal",
  avgRainfall: "840mm + conservation"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL EXPERTS',
    description: 'Serving the area for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in the area. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Bay Ridges, Rouge Park, Liverpool and all local areas.',
    highlight: true
  },
  {
    title: 'CONSERVATION AREA EXPERTS',
    description: 'Specialized in Rouge Park proximity, conservation restrictions, environmental compliance.'
  },
  {
    title: 'MIXED DEVELOPMENT SPECIALISTS',
    description: 'Expert solutions for rural estates, urban subdivisions, and conservation area properties.'
  },
  {
    title: 'ROUGE RIVER SOLUTIONS',
    description: 'Advanced protection for Rouge River watershed and seasonal conservation flooding.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How does Rouge Park proximity affect local moisture protection?",
    answer: "Properties near Rouge Park face unique challenges including conservation area restrictions, protected wetland influences, and environmental compliance requirements. Our conservation-aware solutions work within TRCA guidelines while providing effective basement protection."
  },
  {
    question: "What challenges exist for rural properties in the area?",
    answer: "Local rural areas feature larger lots, private wells, septic systems, and different drainage patterns than urban subdivisions. We specialize in rural moisture control that works with existing septic systems and protects well water quality."
  },
  {
    question: "How do you handle the area's mixed urban-rural development?",
    answer: "This location uniquely combines urban subdivisions with rural estates and conservation areas. Each area requires different approaches - from subdivision drainage issues to rural property management and conservation area compliance."
  },
  {
    question: "What makes the Rouge River watershed different for moisture protection?",
    answer: "The Rouge River creates complex drainage patterns, seasonal flooding, and strict environmental protections. Our watershed expertise includes specialized drainage systems that protect both your property and the sensitive river ecosystem."
  },
  {
    question: "Do you work near the nuclear facility with special safety considerations?",
    answer: "Yes, we're familiar with the enhanced safety protocols for properties near the Nuclear Generating Station. Our work meets all safety requirements and regulatory standards for the area while providing effective basement protection."
  },
  {
    question: "How do conservation area restrictions affect basement protection options?",
    answer: "TRCA conservation areas have specific restrictions on excavation and drainage modifications. We work within these guidelines, often using specialized techniques that minimize environmental impact while maximizing protection."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "ProtectionService"],
  "name": "Dryspace Protection",
