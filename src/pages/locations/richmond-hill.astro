---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import LocationImageShowcase from '../../components/LocationImageShowcase.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Moisture Protection Richmond Hill | Professional Basement Solutions";
const pageDescription = "Richmond Hill Oak Ridges Moraine moisture protection. Kettle lake specialists, affluent estate solutions, moraine geology experts.";

// Local area information
const localInfo = {
  cityName: "Richmond Hill",
  population: "202,000",
  waterTable: "Moraine influenced",
  soilType: "Glacial moraine complex",
  avgHomesAge: "20-30 years affluent",
  floodRisk: "Kettle lake seasonal",
  avgRainfall: "850mm + elevation"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL EXPERTS',
    description: 'Serving the area for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in the area. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Oak Ridges, Langstaff, Jefferson and all local areas.',
    highlight: true
  },
  {
    title: 'MORAINE GEOLOGY EXPERTS',
    description: 'Specialized in Oak Ridges Moraine unique geology, kettle lakes, and complex drainage.'
  },
  {
    title: 'LUXURY ESTATE SPECIALISTS',
    description: 'Premium moisture protection solutions for local affluent properties and custom homes.',
  },
  {
    title: 'KETTLE LAKE SOLUTIONS',
    description: 'Advanced management of kettle lake drainage and seasonal water level variations.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How does the Oak Ridges Moraine affect local moisture protection?",
    answer: "The Oak Ridges Moraine creates unique geological conditions with complex glacial deposits, kettle lakes, and variable drainage patterns. Our moraine expertise includes specialized solutions for the challenging soil conditions and natural water retention areas characteristic of this sensitive geological formation."
  },
  {
    question: "What are kettle lakes and how do they affect foundations?",
    answer: "Kettle lakes are natural depressions formed by glacial activity, common in Richmond Hill. They create localized high water tables, seasonal flooding, and unique drainage challenges. Our kettle lake solutions include specialized drainage systems and water level management for properties near these natural features."
  },
  {
    question: "How do you protect luxury estates in the area?",
    answer: "Local affluent properties require premium moisture protection solutions including sophisticated drainage systems, high-end finishes, and minimal disruption to extensive landscaping. We provide white-glove service that meets the expectations of luxury homeowners while delivering superior protection."
  },
  {
    question: "What makes Oak Ridges area soil conditions unique?",
    answer: "Oak Ridges sits on complex glacial moraine deposits mixing clay, sand, gravel, and till in unpredictable patterns. This creates challenging drainage conditions requiring detailed soil analysis and customized waterproofing approaches for each property's unique geological profile."
  },
  {
    question: "Do you work with environmental restrictions in the moraine?",
    answer: "Yes! The Oak Ridges Moraine is environmentally protected, requiring compliance with strict conservation guidelines. Our moraine-compliant solutions work within environmental restrictions while providing effective waterproofing protection for this sensitive ecological area."
  },
  {
    question: "How do you handle newer development challenges?",
    answer: "Local rapid upscale development often features inadequate initial drainage, construction settling, and overwhelmed systems. We specialize in post-construction protection upgrades that exceed original builder specifications while maintaining property values."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "ProtectionService"],
  "name": "Dryspace Protection",
  "description": "Professional basement protection services in Richmond Hill. Expert foundation repair, and drainage solutions. Serving all local neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Service Area",
    "addressLocality": "Richmond Hill",
    "addressRegion": "ON",
    "postalCode": "L4C",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.8828",
    "longitude": "-79.4403"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Richmond Hill",
      "sameAs": "https://en.wikipedia.org/wiki/Richmond_Hill,_Ontario"
    },
    {
      "@type": "Place",
      "name": "York Region"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates", 
      "latitude": "43.8828",
      "longitude": "-79.4403"
    },
    "geoRadius": "25000"
  },
  "openingHours": [
    "Mo-Fr 07:00-19:00",
    "Sa 08:00-17:00", 
    "Su 09:00-17:00"
  ],
  "availableLanguage": ["English"],
  "currenciesAccepted": "CAD",
  "paymentAccepted": ["Cash", "Credit Card", "Debit Card", "Bank Transfer"],
  "priceRange": "$$",
  "url": "https://dryspacewaterproofing.com/locations/richmond-hill",
  "logo": "https://dryspacewaterproofing.com/images/dryspace-logo.webp",
  "image": "https://dryspacewaterproofing.com/images/dryspace_hero_desktop.webp",
  "sameAs": [
    "https://www.facebook.com/dryspacewaterproofing",
    "https://www.linkedin.com/company/dryspace-waterproofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Protection Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Basement Waterproofing",
          "description": "Complete basement protection solutions"
        }
      },
      {
        "@type": "Offer", 
        "itemOffered": {
          "@type": "Service",
          "name": "Foundation Repair",
          "description": "Foundation crack repair and structural solutions"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service", 
          "name": "Drainage Solutions",
          "description": "French drains, sump pumps, and drainage systems"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emergency Water Removal",
          "description": "24/7 emergency flooding and moisture damage response"
        }
      }
    ]
  },
  "review": {
