        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Richmond Hill" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero
    title="Basement Waterproofing Richmond Hill"
    subtitle="Professional basement protection and foundation repair serving all local neighborhoods. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving the Area"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="richmond-hill" />
    </div>
  </section>

