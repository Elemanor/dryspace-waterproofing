          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">AGINCOURT — 85 projects completed</h4>
              <p class="text-sm text-slate-500">1960s-70s housing, clay soil, Finch Ave E, Sheppard Ave E, Birchmount Rd, McCowan Rd corridors</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">MALVERN — 62 projects completed</h4>
              <p class="text-sm text-slate-500">1970s-80s subdivisions, Neilson Rd, Morningside Ave, Finch Ave E, Sheppard Ave E areas</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">GUILDWOOD — 48 projects completed</h4>
              <p class="text-sm text-slate-500">Bluffs proximity, ravine erosion, Kingston Rd, Guildwood Pkwy, Living Arts Dr corridors</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">BIRCH CLIFF — 41 projects completed</h4>
              <p class="text-sm text-slate-500">Bluffs-edge properties, steep grades, Kingston Rd, Birchmount Rd, Victoria Park Ave</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">ROUGE — 55 projects completed</h4>
              <p class="text-sm text-slate-500">Rouge River flooding, newer subdivisions, Sheppard Ave E, Meadowvale Rd, Rouge Hills Dr</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">WEST HILL — 47 projects completed</h4>
              <p class="text-sm text-slate-500">Highland Creek valley, older housing stock, Kingston Rd, Lawrence Ave E, Morningside Ave</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">CLIFFSIDE — 38 projects completed</h4>
              <p class="text-sm text-slate-500">Lake-effect moisture, Bluffs terrain, Kingston Rd, Cliffside Dr, Midland Ave corridors</p>
            </div>
            <div class="bg-white p-4 border border-slate-100 rounded">
              <h4 class="font-bold text-slate-900 mb-1">HIGHLAND CREEK — 52 projects completed</h4>
              <p class="text-sm text-slate-500">Creek flooding risk, ravine proximity, Ellesmere Rd, Military Trail, Old Kingston Rd</p>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            {["Agincourt","Malvern","Guildwood","Rouge","Birch Cliff","West Hill","Cliffside","Highland Creek","Morningside","Centennial","Dorset Park","Woburn"].map((neighborhood) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm">
                {neighborhood}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Construction Era Analysis -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">SCARBOROUGH HOMES BY CONSTRUCTION ERA</h2>
        <p class="text-lg text-slate-600 mb-8">
          Understanding when your Scarborough home was built is critical for choosing the right basement waterproofing approach. Each construction era used different foundation types, drainage methods, and materials — and each has predictable failure patterns.
        </p>

        {constructionEras.map((era) => (
          <div class="mb-8 border-2 border-slate-200 p-6">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between mb-4">
              <h3 class="text-xl font-bold text-slate-900 uppercase">{era.period}</h3>
              <span class="text-sm font-semibold text-cyan-600 mt-1 md:mt-0">{era.areas}</span>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <h4 class="text-sm font-bold text-slate-700 uppercase mb-2">Foundation Type</h4>
                <p class="text-sm text-slate-600">{era.foundation}</p>
              </div>
              <div>
                <h4 class="text-sm font-bold text-red-700 uppercase mb-2">Common Problems</h4>
                <p class="text-sm text-slate-600">{era.problems}</p>
              </div>
              <div>
                <h4 class="text-sm font-bold text-cyan-700 uppercase mb-2">Recommended Solution</h4>
                <p class="text-sm text-slate-600">{era.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Location Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE FOR BASEMENT WATERPROOFING IN SCARBOROUGH</h2>
