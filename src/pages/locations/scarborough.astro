const pageTitle = "Moisture Protection Scarborough | Eastern Toronto Specialists";
const pageDescription = "Scarborough Bluffs erosion protection. Ravine system specialists, diverse housing stock, lakefront cliff solutions.";

// Local area information
const localInfo = {
  cityName: "Scarborough",
  population: "632,000",
  waterTable: "Bluffs/ravine variable",
  soilType: "Glacial bluff clay",
  avgHomesAge: "35-60 years diverse",
  floodRisk: "Ravine + bluff erosion",
  avgRainfall: "860mm + lake effect"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'LOCAL EXPERTS',
    description: 'Serving the area for over 25 years with deep knowledge of local conditions.',
    highlight: true
  },
  {
    title: 'FAST RESPONSE TIME',
    description: '2-hour emergency response anywhere in the area. Available 24/7.',
    highlight: true
  },
  {
    title: 'ALL NEIGHBORHOODS',
    description: 'Serving Agincourt, Malvern, Guildwood and all local areas.',
    highlight: true
  },
  {
    title: 'BLUFFS EROSION EXPERTS',
    description: 'Specialized in local Bluffs cliff erosion, slope stability, and lakefront challenges.',
  },
  {
    title: 'DIVERSE HOUSING SPECIALISTS',
    description: 'Expert solutions for varied local housing from post-war bungalows to modern condos.',
  },
  {
    title: 'RAVINE SYSTEM SOLUTIONS',
    description: 'Advanced protection for extensive ravine network and seasonal creek flooding.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How do local Bluffs erosion affect moisture protection?",
    answer: "The local Bluffs face ongoing erosion from Lake Ontario wave action and groundwater seepage. Properties near the bluffs require specialized protection systems that account for slope instability, cliff erosion, and elevated groundwater from lake proximity."
  },
  {
    question: "What challenges do the area's ravine systems create?",
    answer: "The area has one of Toronto's most extensive ravine networks, creating complex drainage patterns and seasonal flooding risks. Our ravine expertise includes specialized retention systems, creek overflow management, and slope stabilization for properties in these sensitive areas."
  },
  {
    question: "How do you protect the area's diverse housing types?",
    answer: "The area features everything from 1950s bungalows to modern high-rises and townhomes. Each housing type requires different approaches - from post-war foundation upgrades to contemporary condominium protection and multi-unit drainage coordination."
  },
  {
    question: "What makes lakefront properties in the area unique?",
    answer: "Local lakefront properties face combined challenges of lake proximity, bluff erosion, and elevated groundwater. Our lakefront solutions include erosion protection, enhanced drainage systems, and specialized foundation stabilization for cliff-edge properties."
  },
  {
    question: "How do you handle flooding in local creek systems?",
    answer: "Local numerous creeks including Highland Creek and Rouge River create seasonal flooding challenges. We provide specialized flood protection including creek overflow barriers, enhanced sump systems, and coordination with municipal flood management."
  },
  {
    question: "Do you work with TRCA restrictions near ravines?",
    answer: "Yes! Many local properties are subject to Toronto and Region Conservation Authority regulations due to ravine proximity. Our TRCA-compliant solutions work within environmental restrictions while providing effective basement protection."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "ProtectionService"],
  "name": "Dryspace Protection",
  "description": "Professional basement protection services in Scarborough. Expert foundation repair, and drainage solutions. Serving all local neighborhoods with 25-year warranty protection.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Service Area",
    "addressLocality": "Scarborough",
    "addressRegion": "ON",
    "postalCode": "M1P",
    "addressCountry": "CA"
  },
  "geo": {
