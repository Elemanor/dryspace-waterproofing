    "latitude": "43.7731",
    "longitude": "-79.2578"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Scarborough",
      "sameAs": "https://en.wikipedia.org/wiki/Scarborough,_Toronto"
    },
    {
