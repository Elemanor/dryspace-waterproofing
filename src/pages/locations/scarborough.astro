        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Emergency Water Removal",
          "description": "24/7 emergency flooding and water damage response"
        }
      }
    ]
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": locationFAQs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
>

  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs
      items={[
        { name: "Home", url: "/" },
        { name: "Service Areas", url: "/service-areas" },
        { name: "Scarborough" }
      ]}
    />
  </div>

<!-- Location Hero -->
  <Hero
    title="Basement Waterproofing Scarborough"
    subtitle="Professional basement waterproofing and foundation repair for Scarborough's Bluffs, ravines, and diverse housing stock. 25-year warranty, free inspection."
    primaryCTA={{ text: "Get Free Scarborough Quote", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Scarborough"
  />

  <!-- Internal Links -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4">
      <InternalLinks category="location" currentPage="scarborough" />
    </div>
  </section>

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">BASEMENT WATERPROOFING SERVICES IN SCARBOROUGH</h2>

        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Basement waterproofing in Scarborough requires specialized expertise due to the dramatic Scarborough Bluffs, one of Toronto's most extensive ravine networks, and a diverse housing stock spanning seven decades. From glacial clay soils that shift with seasonal moisture to Highland Creek flooding and Lake Ontario groundwater influence, Scarborough presents some of the GTA's most complex waterproofing challenges. Our Scarborough team has completed over 850 basement waterproofing projects across every neighborhood — from post-war bungalows in Agincourt to modern townhomes in Rouge.
          </p>

          <div class="bg-cyan-50 border-l-4 border-cyan-500 p-6 mb-8">
            <h3 class="text-lg font-bold text-cyan-900 mb-2">Scarborough Waterproofing Costs at a Glance</h3>
            <p class="text-cyan-700 text-sm">
              Interior basement waterproofing in Scarborough: <strong>$150-$275 per linear foot</strong> ($12,000-$25,000 average project). Exterior waterproofing: <strong>$200-$350 per linear foot</strong>. Bluffs-area properties typically run 15-20% higher. Toronto residents may qualify for up to <strong>$3,400</strong> through the Basement Flooding Protection Subsidy.
            </p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">SCARBOROUGH QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Population</span>
                <span class="text-sm font-bold text-slate-900">632,000</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                <span class="text-sm font-bold text-slate-900">35-60 YEARS</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Annual Rainfall</span>
                <span class="text-sm font-bold text-slate-900">860MM + LAKE EFFECT</span>
              </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                <span class="text-sm font-semibold text-slate-600 uppercase">Frost Line</span>
                <span class="text-sm font-bold text-slate-900">1.2 METERS</span>
