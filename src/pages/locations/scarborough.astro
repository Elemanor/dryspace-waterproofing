---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import LocationImageShowcase from '../../components/LocationImageShowcase.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Basement Waterproofing Scarborough | Bluffs & Ravine Specialists";
const pageDescription = "Basement waterproofing Scarborough — Bluffs erosion protection, ravine drainage, and foundation repair. $150-$275/linear foot. 25-year warranty, free inspection. Serving Agincourt, Malvern, Guildwood & all Scarborough neighborhoods.";

// Local area information
const localInfo = {
  cityName: "Scarborough",
  population: "632,000",
  waterTable: "Bluffs/ravine variable",
  soilType: "Glacial bluff clay",
  avgHomesAge: "35-60 years diverse",
  floodRisk: "Ravine + bluff erosion",
  avgRainfall: "860mm + lake effect"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'BLUFFS EROSION EXPERTS',
    description: 'Specialized basement waterproofing for Scarborough Bluffs properties facing cliff erosion, slope instability, and Lake Ontario groundwater pressure.',
    highlight: true
  },
  {
    title: '90-MINUTE EMERGENCY RESPONSE',
    description: 'Our Scarborough crew responds to basement flooding emergencies within 90 minutes — covering Agincourt to Guildwood. Available 24/7, 365 days.',
    highlight: true
  },
  {
    title: 'ALL SCARBOROUGH NEIGHBORHOODS',
    description: 'Serving Agincourt, Malvern, Guildwood, Rouge, Birch Cliff, West Hill, Cliffside, Highland Creek, and Morningside with 850+ completed projects.',
    highlight: true
  },
  {
    title: 'RAVINE SYSTEM SOLUTIONS',
    description: 'Advanced basement waterproofing for Scarborough\'s extensive ravine network — Highland Creek, Rouge River overflow protection, and seasonal creek flood management.'
  },
  {
    title: 'DIVERSE HOUSING SPECIALISTS',
    description: 'Expert waterproofing for Scarborough\'s varied housing from 1950s-60s post-war bungalows to 1970s-80s split-levels and modern townhome complexes.'
  },
  {
    title: 'TRCA-COMPLIANT INSTALLATIONS',
    description: 'Fully licensed for Toronto and Region Conservation Authority regulated zones — permits handled, environmental compliance guaranteed.'
  }
];

// Location-specific testimonials
const localTestimonials = [
  {
    name: "David Chen",
    neighborhood: "Agincourt",
    text: "After 3 spring floods in a row, DrySpace installed an interior drainage system and backwater valve. We haven't had a drop of water in 2 years. Their Scarborough team knew exactly what our 1970s split-level needed.",
    rating: 5,
    project: "Interior waterproofing + sump pump"
  },
  {
    name: "Patricia Morrison",
    neighborhood: "Birch Cliff",
    text: "Living near the Bluffs, we were told by two other companies our situation was too complex. DrySpace designed a custom drainage solution that accounts for the slope and clay movement. Outstanding work.",
    rating: 5,
    project: "Exterior waterproofing + slope stabilization"
  }
];

// Construction era analysis
const constructionEras = [
  {
    period: "1950s-1960s Post-War Bungalows",
    areas: "Agincourt, West Hill, Cliffside",
    foundation: "Poured concrete or cinder block, shallow footings",
    problems: "Original weeping tiles collapsed or clogged with clay. Concrete block foundations develop horizontal cracks from decades of frost heave. Many lack any waterproofing membrane.",
    solution: "Full interior drainage system with new weeping tile, sump pump installation, and crack injection. Exterior membrane recommended for block foundations."
  },
  {
    period: "1970s-1980s Split-Levels & Raised Ranches",
    areas: "Malvern, Rouge, Highland Creek",
    foundation: "Poured concrete walls, deeper footings",
    problems: "Parging failure exposes concrete to moisture. Window wells flood during storms. Slab-on-grade sections develop cove joint leaks where floor meets wall.",
    solution: "Targeted interior drainage at cove joint, window well drainage systems, and exterior parging repair with waterproof membrane."
  },
  {
    period: "1990s-2000s Subdivisions & Townhomes",
    areas: "Rouge, Malvern North, Centennial",
    foundation: "Poured concrete, builder-grade waterproofing",
    problems: "Builder-applied damp proofing (not true waterproofing) failing after 20-25 years. Lot grading settles, directing water toward foundations. Shared drainage systems between townhomes create liability gaps.",
    solution: "Exterior waterproofing membrane replacement, re-grading, and individual sump pump systems for townhome units."
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "How much does basement waterproofing cost in Scarborough?",
    answer: "Basement waterproofing in Scarborough typically costs $150-$275 per linear foot for interior systems, with average projects ranging from $12,000-$25,000 depending on basement size and severity. Exterior waterproofing runs $200-$350 per linear foot. Bluffs-area properties may cost 15-20% more due to soil complexity and slope stabilization requirements. We provide free on-site estimates with transparent pricing."
  },
  {
    question: "How do Scarborough Bluffs erosion affect basement waterproofing?",
    answer: "The Scarborough Bluffs face ongoing erosion from Lake Ontario wave action and groundwater seepage through glacial clay layers. Properties within 500 meters of the bluff edge experience elevated groundwater pressure, unstable soil conditions, and seasonal clay movement that cracks foundations. Our Bluffs-specific waterproofing includes reinforced drainage systems, slope monitoring, and membranes designed for shifting clay soils."
  },
  {
    question: "Do I need a TRCA permit for waterproofing near Scarborough ravines?",
    answer: "Yes — properties within the Toronto and Region Conservation Authority regulated area (typically within 30 meters of a ravine crest or floodplain) require TRCA approval for exterior excavation work. Interior waterproofing usually doesn't require a TRCA permit. DrySpace handles all permit applications and ensures full environmental compliance. Permit processing takes 4-8 weeks, so we recommend planning ahead."
  },
  {
    question: "What challenges do Scarborough's ravine systems create for basements?",
    answer: "Scarborough has one of Toronto's most extensive ravine networks — Highland Creek, Rouge River, and dozens of tributaries create complex drainage patterns. Properties near ravines face seasonal flooding during spring thaw, elevated groundwater from creek systems, and soil erosion that undermines foundations. Our ravine-specific solutions include backwater valves, high-capacity sump systems, and French drains designed for high water table conditions."
  },
  {
    question: "How do you protect Scarborough's diverse housing types from water damage?",
    answer: "Scarborough features everything from 1950s bungalows with cinder block foundations to modern townhome complexes. Each era requires different waterproofing approaches — post-war homes often need full drainage replacement, while 1970s-80s split-levels typically need cove joint sealing and window well drainage. We assess the specific foundation type and construction era before recommending solutions."
  },
  {
    question: "Is basement waterproofing in Scarborough covered by insurance?",
    answer: "Standard home insurance typically covers sudden water damage (burst pipe, sewer backup with endorsement) but not gradual seepage or foundation leaks. However, waterproofing your Scarborough basement can lower your insurance premiums and prevent costly claims. Some insurers offer discounts for homes with backwater valves and sump pumps. We provide documentation for insurance claims when water damage leads to waterproofing work."
  },
  {
    question: "How does Highland Creek flooding affect Scarborough basements?",
    answer: "Highland Creek and its tributaries flood during heavy rainfall events and spring snowmelt, particularly affecting homes in Morningside, West Hill, and the Highland Creek valley. The 2013 Toronto flood caused significant basement damage along this corridor. Our flood protection includes high-capacity sump pumps with battery backup, backwater valves on floor drains, and exterior grading improvements to direct surface water away from foundations."
  },
  {
    question: "What is the best season for basement waterproofing in Scarborough?",
    answer: "Late spring through early fall (May-October) is ideal for exterior waterproofing in Scarborough because the ground is workable and concrete cures properly. Interior waterproofing can be done year-round. However, booking in late fall or winter often means shorter wait times and potential seasonal discounts of 5-10%. The worst time to discover you need waterproofing is during a spring flood — proactive assessment in fall saves emergency costs."
  },
  {
    question: "Do you offer financing for basement waterproofing in Scarborough?",
    answer: "Yes — we offer 0% interest financing for 12 months, extended payment plans up to 60 months, and same-day approval. For a typical Scarborough interior waterproofing project of $15,000, monthly payments start at around $250/month over 60 months. We also help homeowners access the City of Toronto Basement Flooding Protection Subsidy for eligible properties."
  },
  {
    question: "What warranty do you provide on Scarborough waterproofing work?",
    answer: "Every DrySpace basement waterproofing project in Scarborough comes with a transferable 25-year warranty covering materials and workmanship. This warranty transfers to new owners if you sell your home, adding resale value. Our warranty covers the complete drainage system, sump pump, waterproofing membranes, and crack repairs. We also include annual maintenance checks for the first 5 years."
  },
  {
    question: "How long does basement waterproofing take in a Scarborough home?",
    answer: "Interior waterproofing in a typical Scarborough home takes 2-4 days depending on basement size and scope. Exterior waterproofing requires 5-10 days including excavation, membrane application, and backfill. Bluffs-area projects with slope stabilization may take 7-14 days. We provide a detailed timeline during your free assessment and work to minimize disruption — you can stay in your home during interior work."
  },
  {
    question: "Can I get the $3,400 Toronto Basement Flooding Protection Subsidy in Scarborough?",
    answer: "Yes — Scarborough residents qualify for the City of Toronto Basement Flooding Protection Subsidy, which provides up to $3,400 for flood-prevention measures including backwater valve installation ($1,250), sump pump installation ($1,750), and pipe severance/capping ($400). DrySpace handles the application process and ensures your installation meets all program requirements for reimbursement."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "HomeAndConstructionBusiness", "WaterproofingService"],
  "name": "DrySpace Waterproofing",
  "description": "Professional basement waterproofing services in Scarborough. Expert foundation repair, drainage solutions, and Bluffs erosion protection. Serving all Scarborough neighborhoods with 25-year warranty.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Scarborough Service Area",
    "addressLocality": "Scarborough",
    "addressRegion": "ON",
    "postalCode": "M1P",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "43.7731",
    "longitude": "-79.2578"
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Scarborough",
      "sameAs": "https://en.wikipedia.org/wiki/Scarborough,_Toronto"
    },
    {
      "@type": "Place",
      "name": "Toronto"
    }
  ],
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": "43.7731",
      "longitude": "-79.2578"
    },
    "geoRadius": "25000"
  },
  "openingHours": [
    "Mo-Fr 07:00-19:00",
    "Sa 08:00-17:00",
    "Su 09:00-17:00"
  ],
  "availableLanguage": ["English"],
  "currenciesAccepted": "CAD",
  "paymentAccepted": ["Cash", "Credit Card", "Debit Card", "Bank Transfer"],
  "priceRange": "$$",
  "url": "https://dryspacewaterproofing.com/locations/scarborough",
  "logo": "https://dryspacewaterproofing.com/images/dryspace-logo.webp",
  "image": "https://dryspacewaterproofing.com/images/dryspace_hero_desktop.webp",
  "sameAs": [
    "https://www.facebook.com/dryspacewaterproofing",
    "https://www.linkedin.com/company/dryspace-waterproofing"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Waterproofing Services",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Basement Waterproofing",
          "description": "Complete basement waterproofing solutions for Scarborough homes"
        }
      },
      {
        "@type": "Offer",
