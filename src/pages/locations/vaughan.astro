const pageTitle = "Moisture Control Vaughan | Premium Foundation Protection";
const pageDescription = "Professional moisture control in Vaughan. Luxury home specialists, complete solutions, warranty protection.";

// Local area information
const localInfo = {
  cityName: "Vaughan",
  population: "323,000",
  waterTable: "Variable across rapid development zones",
  soilType: "Mixed glacial till and clay - highly variable",
  avgHomesAge: "20-30 years (boom development era)",
  floodRisk: "Variable by development - poor initial drainage planning",
  avgRainfall: "810mm annually",
  developmentChallenge: "Fastest growing GTA municipality",
  mixedUse: "Commercial, industrial, and luxury residential integration"
};

// Location-specific features
const locationFeatures = [
  {
    title: 'RAPID DEVELOPMENT SPECIALISTS',
    description: 'Expert solutions for Vaughan\'s unprecedented growth challenges and varying soil conditions across development phases.',
    highlight: true
  },
  {
    title: 'LUXURY HOME PROTECTION',
    description: 'Premium waterproofing solutions for Vaughan\'s high-value properties with finished basements and luxury features.',
    highlight: true
  },
  {
    title: 'COMMERCIAL-RESIDENTIAL EXPERTISE',
    description: 'Specialized approaches for mixed-use developments and properties adjacent to commercial/industrial zones.',
    highlight: true
  },
  {
    title: 'VARIABLE SOIL MANAGEMENT',
    description: 'Advanced techniques for Vaughan\'s highly variable glacial till and clay soil conditions.'
  },
  {
    title: 'BOOM-ERA CONSTRUCTION',
    description: 'Targeted solutions for 2000s-2010s construction methods and their emerging long-term issues.'
  },
  {
    title: 'MULTI-ZONE COVERAGE',
    description: 'Comprehensive service across Vaughan\'s diverse communities from rural Kleinburg to urban Thornhill.'
  }
];

// Location-specific FAQs
const locationFAQs = [
  {
    question: "Why do Vaughan's newer luxury homes have waterproofing issues?",
    answer: "Vaughan's rapid development (2000s-2010s) often prioritized speed over optimal foundation engineering. Large homes with finished basements were built quickly across varying soil conditions, and many builders underestimated the long-term drainage challenges. High property values make proper waterproofing critical for investment protection."
  },
  {
    question: "How do you handle Vaughan's highly variable soil conditions?",
    answer: "Vaughan's glacial history created a patchwork of clay, till, and mixed soils that can vary dramatically even within a single property. We perform detailed soil analysis and customize drainage solutions for each specific soil type, often using hybrid systems that adapt to changing ground conditions."
  },
  {
    question: "What about waterproofing in Vaughan's mixed commercial-residential areas?",
    answer: "Vaughan's unique development pattern places residential properties adjacent to commercial and industrial zones, creating complex drainage interdependencies. We assess broader area drainage impacts and install systems that account for altered runoff patterns from nearby commercial developments and parking areas."
  },
  {
    question: "Can you protect luxury finished basements and high-end features?",
    answer: "Absolutely. Vaughan's luxury homes often feature expensive finished basements, wine cellars, and entertainment areas that require premium protection. We use high-grade waterproofing systems with redundant protection layers and climate control considerations to safeguard these valuable spaces."
  },
  {
    question: "How do you work with Vaughan's rapid development and construction activity?",
    answer: "Ongoing construction in Vaughan can affect neighboring properties' drainage patterns. We coordinate with developers, monitor construction impacts on existing homes, and install adaptable systems that can accommodate changing neighbourhood drainage conditions as development continues."
  }
];

// Schema markup for local business
