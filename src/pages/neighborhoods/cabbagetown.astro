---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Cabbagetown Waterproofing | Basement & Foundation Solutions";
const pageDescription = "Professional basement waterproofing in Cabbagetown Toronto. Victorian home specialists. Foundation repair, sump pumps, crack repair. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  neighborhoodName: "Cabbagetown",
  cityName: "Toronto",
  avgHomeAge: "100-150 years",
  foundationType: "Stone & Brick",
  soilType: "Clay mix",
  waterTable: "Variable",
  floodRisk: "Moderate",
  avgProjectCost: "$8,000-$15,000",
  responseTime: "15-20 minutes"
};

// Neighborhood-specific features
const neighborhoodFeatures = [
  {
    title: 'VICTORIAN HOME EXPERTS',
    description: 'Specialized in 100+ year old Victorian homes common in Cabbagetown.',
    highlight: true
  },
  {
    title: 'HERITAGE PRESERVATION',
    description: 'Careful waterproofing that maintains historical integrity.',
    highlight: true
  },
  {
    title: 'STONE FOUNDATION REPAIR',
    description: 'Expert repair of original stone and brick foundations.',
    highlight: true
  },
  {
    title: 'RAPID RESPONSE',
    description: 'Under 20 minutes emergency response in this area.',
  },
  {
    title: 'LOWER LEVEL EXPANSION',
    description: 'Convert low Victorian below-grade areas into livable space.',
  },
  {
    title: 'ROOT DAMAGE REPAIR',
    description: 'Fix foundation damage from mature tree roots.',
  }
];

// Local challenges specific to neighborhood
const localChallenges = [
  {
    problem: "AGING STONE STRUCTURES",
    description: "Victorian-era stone building bases deteriorate and allow water infiltration",
    solution: "Stone structure repointing and waterproof membrane application"
  },
  {
    problem: "MATURE TREE ROOTS",
    description: "Large trees along streets damage building bases and drainage systems",
    solution: "Root barrier installation and structure reinforcement"
  },
  {
    problem: "COMBINED SEWER SYSTEM",
    description: "Old combined sewers can back up during heavy rainfall",
    solution: "Backwater valve installation and sump pump systems"
  }
];

// Neighborhood-specific FAQs
const neighborhoodFAQs = [
  {
    question: "Do you work on heritage homes in this area?",
    answer: "Yes! We specialize in waterproofing for Victorian and heritage homes while preserving their historical character. Our team is experienced with stone building bases and period-appropriate repair methods."
  },
  {
    question: "What are common water issues in this neighborhood?",
    answer: "This area's 100+ year old homes often face stone structure deterioration, root damage from mature trees, and lower level moisture from aging drainage systems. The combined sewer system can also cause backup issues."
  },
  {
    question: "How quickly can you respond to emergencies locally?",
    answer: "We guarantee 15-20 minute emergency response anywhere in this neighborhood. Our team knows every street from Parliament to the Don Valley."
  },
  {
    question: "Can you lower Victorian below-grade areas locally?",
    answer: "Yes, lower level expansion is one of our specialties for Victorian homes. We can convert your 5-6 foot below-grade area into proper living space while ensuring proper water protection."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dryspace Water Protection Cabbagetown",
  "description": "Expert basement waterproofing services in this historic Toronto area. Victorian home specialists, structure repair, sump pumps.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Cabbagetown",
    "addressRegion": "Toronto",
    "addressCountry": "CA"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Cabbagetown, Toronto"
  }
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Toronto", url: "/locations/toronto" },
        { name: "Neighborhoods", url: "/locations/toronto#neighborhoods" },
        { name: "Cabbagetown" }
      ]}
    />
  </div>

<!-- Neighborhood Hero -->
  <Hero 
    title="Water Protection in Cabbagetown"
    subtitle="Victorian home specialists protecting Toronto's historic community. Stone structure experts, heritage preservation, 24/7 emergency service."
    primaryCTA={{ text: "Get Free Local Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving This Area"
  />

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WATER PROTECTION SERVICES LOCALLY</h2>

        <p class="speakable"><strong>Basement waterproofing in Cabbagetown, Toronto costs $155–$310 per linear foot for North America's largest collection of preserved Victorian homes, many with original stone foundations dating to the 1870s–1890s that require heritage-sensitive techniques.</strong></p>

        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            This area's Victorian homes, built between 1870-1910, require specialized waterproofing expertise. With {localInfo.avgHomeAge} old homes 
            featuring {localInfo.foundationType} building bases, our team understands the unique challenges of preserving these historic properties 
            while ensuring modern protective services.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">LOCAL QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgHomeAge.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Foundation Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.foundationType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Soil Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.soilType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Response Time</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.responseTime.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Cost</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgProjectCost}</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">NEIGHBORHOOD CHALLENGES</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Stone building bases deteriorating after 100+ years</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Tree root damage from mature street trees</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Combined sewer backup during storms</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Low below-grade height in Victorian homes</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Heritage preservation requirements</span>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4 uppercase">STREETS WE SERVE LOCALLY</h3>
          <p class="mb-4">
            Our team provides rapid response throughout this community:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Parliament Street", "Carlton Street", "Winchester Street", "Spruce Street", "Metcalfe Street", "Sackville Street", "Sumach Street", "Amelia Street"].map((street) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm uppercase">
                {street}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Neighborhood Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE LOCALLY</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Specialized expertise for Victorian homes and heritage properties
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {neighborhoodFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {neighborhoodFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Challenges Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-12 text-center uppercase">LOCAL WATER CHALLENGES</h2>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {localChallenges.map((challenge) => (
          <div class="bg-white border-2 border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{challenge.problem}</h3>
            <p class="text-sm text-slate-600 mb-4">{challenge.description}</p>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-sm font-semibold text-slate-900 uppercase mb-1">OUR SOLUTION:</p>
              <p class="text-sm text-slate-600">{challenge.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">LOCAL WATER PROTECTION FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from local homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {neighborhoodFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PROTECT YOUR HOME TODAY</h2>
        <p class="text-lg text-slate-300 mb-8">
          Expert water protection for Victorian homes and heritage properties
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Schedule Local Inspection
          </a>
          <a 
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">24/7 Emergency Service Available</span>
        </div>
      </div>
    </div>
  </section>
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Neighborhoods'}, {name: 'Cabbagetown'}]} />
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>