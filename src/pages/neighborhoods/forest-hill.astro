---
import Testimonials from '../../components/sections/Testimonials.astro';
import Process from '../../components/sections/Process.astro';
import Services from '../../components/sections/Services.astro';
import Stats from '../../components/sections/Stats.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import StickyBooking from '../../components/StickyBooking.astro';
import ValuePropositions from '../../components/ValuePropositions.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const neighborhoodData = {
  name: 'Forest Hill',
  avgHomeAge: '60-90 years',
  commonFoundation: 'Poured Concrete & Brick',
  floodRisk: 'Medium (Ravine proximity)',
  avgProjectCost: '$15,000-$35,000',
  responseTime: '15-20 minutes'
};
---

<PageLayout 
  title="Waterproofing Forest Hill Toronto | Luxury Estate Protection Experts" 
  description="Premium waterproofing for Forest Hill estates. Ravine property specialists, pool house protection, wine cellar experts. White-glove service. (437) 545-0067."
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Toronto", url: "/locations/toronto" },
        { name: "Neighborhoods", url: "/locations/toronto#neighborhoods" },
        { name: "Forest Hill" }
      ]}
    />
  </div>

<section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold text-white mb-6 uppercase">ESTATE WATERPROOFING IN FOREST HILL</h1>
        <p class="text-xl text-slate-300 mb-8">Protecting Toronto's Most Distinguished Properties with White-Glove Service</p>
        
        <div class="grid grid-cols-3 gap-4 mb-8">
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">$10M+</span>
            <span class="text-sm text-slate-600 uppercase">Average Property Value</span>
          </div>
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">200+</span>
            <span class="text-sm text-slate-600 uppercase">Estates Protected</span>
          </div>
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">100%</span>
            <span class="text-sm text-slate-600 uppercase">Privacy Guaranteed</span>
          </div>
        </div>
        
        <div class="flex gap-4 justify-center">
          <a href="/free-inspection" class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase">Schedule Private Consultation</a>
          <a href="tel:4375450067" class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase">
            Direct Line: (437) 545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">FOREST HILL'S UNIQUE ESTATE CHALLENGES</h2>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="challenge-card estate">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">RAVINE PROPERTIES & SLOPE MANAGEMENT</h3>
          <p class="text-slate-600">Many Forest Hill estates back onto ravines, creating complex drainage challenges with significant elevation changes and natural spring water.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Engineered slope stabilization with French drain networks designed to manage both surface and subsurface water flow.
          </div>
        </div>
        
        <div class="challenge-card estate">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">POOL HOUSES & SPA FACILITIES</h3>
          <p class="text-slate-600">Indoor pools, spas, and pool houses require specialized vapor barriers and dehumidification to prevent moisture migration to main residence.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Commercial-grade vapor barriers with integrated climate control systems protecting both structures and finishes.
          </div>
        </div>
        
        <div class="challenge-card estate">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">WINE CELLARS & ART GALLERIES</h3>
          <p class="text-slate-600">Forest Hill's extensive wine collections and private galleries demand perfect humidity control and absolute moisture protection.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Museum-quality environmental controls with redundant waterproofing systems and 24/7 monitoring available.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">FOREST HILL DRAINAGE & RAVINE IMPACT</h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">RAVINE WATER FLOW</h3>
          <div class="inline-block px-3 py-1 bg-cyan-500 text-slate-900 font-bold uppercase text-xs mb-2">HIGH IMPACT</div>
          <p class="text-slate-600">Belt Line and Cedarvale ravines channel massive water volumes during storms, affecting adjacent properties</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">NATURAL SPRINGS</h3>
          <div class="inline-block px-3 py-1 bg-amber-500 text-black font-bold uppercase text-xs mb-2">YEAR-ROUND</div>
          <p class="text-slate-600">Underground springs throughout Forest Hill create constant hydrostatic pressure on foundations</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">MATURE TREE IMPACT</h3>
          <div class="inline-block px-3 py-1 bg-amber-500 text-black font-bold uppercase text-xs mb-2">SEASONAL</div>
          <p class="text-slate-600">Century-old trees affect drainage patterns and can damage waterproofing with root systems</p>
        </div>
      </div>
      
      <div class="mt-8 bg-navy-900 border-2 border-slate-200 p-6">
        <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">RECENT WATER EVENTS IN FOREST HILL</h3>
        <ul class="space-y-2">
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">September 2024:</span> Ravine overflow affected 12 estates along Forest Hill Road</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">July 2024:</span> Pool house flooding on Old Forest Hill Road during 85mm storm</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">May 2024:</span> Spring water table rise impacted wine cellars on Dunvegan Road</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">March 2024:</span> Rapid snowmelt caused slope erosion near Spadina bridge</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">RECENT FOREST HILL ESTATE PROJECTS</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">DUNVEGAN ROAD MANOR</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Complete Estate Protection</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">12,000 sq ft foundation</li>
              <li class="text-slate-600 mb-2">Wine cellar climate control</li>
              <li class="text-slate-600 mb-2">Pool house integration</li>
              <li class="text-slate-600 mb-2">Ravine water management</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $68,000</div>
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">OLD FOREST HILL ROAD ESTATE</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Wine Cellar Preservation</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">3,000 bottle capacity room</li>
              <li class="text-slate-600 mb-2">Humidity control system</li>
              <li class="text-slate-600 mb-2">Redundant waterproofing</li>
              <li class="text-slate-600 mb-2">Smart monitoring system</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $42,000</div>
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">RUSSELL HILL ROAD PROPERTY</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Pool Complex Waterproofing</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">Indoor/outdoor pool connection</li>
              <li class="text-slate-600 mb-2">Spa facility protection</li>
              <li class="text-slate-600 mb-2">Underground passage sealed</li>
              <li class="text-slate-600 mb-2">Landscape restoration</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $55,000</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">TRUSTED BY FOREST HILL'S ELITE FAMILIES</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="testimonial elite">
          <div class="stars"></div>
          <p class="text-slate-600">"They handled our estate with the utmost professionalism and discretion. The team worked around our schedule and left the property immaculate. Our wine collection and art gallery are now perfectly protected."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Private Family Office</strong>
            <span>Dunvegan Road</span>
          </div>
        </div>
        
        <div class="testimonial elite">
          <div class="stars"></div>
          <p class="text-slate-600">"Managing water from the ravine seemed impossible until Dryspace engineered a solution. Five years later, not a drop of water. They saved our foundation and our sanity."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Estate Owner</strong>
            <span>Forest Hill Road</span>
          </div>
        </div>
        
        <div class="testimonial elite">
          <div class="stars"></div>
          <p class="text-slate-600">"When our pool house started showing moisture, they responded immediately. Fixed the issue without disrupting our pool season. Exceptional service worthy of Forest Hill standards."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Homeowner</strong>
            <span>Old Forest Hill Road</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">SERVICING FOREST HILL'S PREMIER LOCATIONS</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">UPPER CANADA COLLEGE AREA</h3>
          <p class="text-slate-600">Estates near UCC require discrete service during school hours. We coordinate with property managers to minimize disruption.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">BISHOP STRACHAN SCHOOL VICINITY</h3>
          <p class="text-slate-600">Historic properties near BSS often feature complex foundations requiring specialized preservation techniques.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">CEDARVALE RAVINE PROPERTIES</h3>
          <p class="text-slate-600">Homes backing onto Cedarvale face unique challenges. We've developed specific solutions for ravine-adjacent estates.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">SPADINA MUSEUM GROUNDS AREA</h3>
          <p class="text-slate-600">Properties near the historic museum require heritage-sensitive approaches maintaining architectural integrity.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="estate-services">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHITE-GLOVE ESTATE SERVICES</h2>
      
      <div class="services-grid">
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">PRIVATE CONSULTATIONS</h3>
          <p class="text-slate-600">Discrete assessments scheduled at your convenience with senior technicians only</p>
        </div>
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">PROPERTY MANAGEMENT COORDINATION</h3>
          <p class="text-slate-600">Direct communication with your property management team for seamless service</p>
        </div>
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">LANDSCAPE RESTORATION</h3>
          <p class="text-slate-600">Complete landscape restoration to pre-work conditions with premium materials</p>
        </div>
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">ANNUAL MAINTENANCE PROGRAMS</h3>
          <p class="text-slate-600">Scheduled inspections and preventive maintenance to protect your investment</p>
        </div>
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">EMERGENCY PRIORITY RESPONSE</h3>
          <p class="text-slate-600">Guaranteed 15-minute response for Forest Hill estates with priority status</p>
        </div>
        <div class="estate-service">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">INSURANCE LIAISON SERVICE</h3>
          <p class="text-slate-600">Direct billing and complete documentation for high-value insurance claims</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">FOREST HILL SERVICE TERRITORY</h2>
      
      <div class="bg-slate-50 border-2 border-slate-200 p-8">
        <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">ESTATE SERVICE ZONE:</h3>
        <ul class="space-y-2">
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">North:</span> Eglinton Avenue West</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">South:</span> St. Clair Avenue West</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">East:</span> Avenue Road</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">West:</span> Bathurst Street</li>
        </ul>
        
        <div class="mt-8">
          <h4 class="text-lg font-bold text-slate-900 mb-2 uppercase">PREMIER STREETS SERVED:</h4>
          <div class="grid grid-cols-3 md:grid-cols-4 gap-2 mt-4">
            <span>Old Forest Hill Road</span>
            <span>Forest Hill Road</span>
            <span>Dunvegan Road</span>
            <span>Russell Hill Road</span>
            <span>Chadwick Avenue</span>
            <span>Elderwood Drive</span>
            <span>Kilbarry Road</span>
            <span>Strathearn Road</span>
            <span>Burton Road</span>
            <span>Vesta Drive</span>
            <span>Woodlawn Avenue</span>
            <span>Oriole Parkway</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ValuePropositions />
