---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Parkdale Water Protection | Basement & Foundation Solutions";
const pageDescription = "Expert moisture control services in Parkdale Toronto. brick & stone structure specialists, 24/7 emergency response.";

// Local area information
const localInfo = {
  neighborhoodName: "Parkdale",
  cityName: "Toronto",
  avgHomeAge: "90-120 years",
  foundationType: "Brick & Stone",
  soilType: "Sandy",
  waterTable: "High",
  floodRisk: "Moderate",
  avgProjectCost: "$7,000-$14,000",
  responseTime: "20-25 minutes"
};

// Neighborhood-specific features
const neighborhoodFeatures = [
  {
    title: "VICTORIAN SPECIALISTS",
    description: "Expert with grand old local homes.",
    highlight: true
  },
  {
    title: "LAKE PROXIMITY PROS",
    description: "Handle high water table near lake.",
    highlight: true
  },
  {
    title: "MULTI-UNIT EXPERTS",
    description: "Converted mansions and apartments.",
    highlight: true
  },
  {
    title: "AFFORDABLE OPTIONS",
    description: "Solutions for every budget."
  },
  {
    title: "RAPID RESPONSE",
    description: "Quick access from Gardiner."
  },
  {
    title: "COMMUNITY MINDED",
    description: "Support local initiatives."
  }
];

// Local challenges specific to neighborhood
const localChallenges = [
  {
    problem: "LAKE PROXIMITY",
    description: "High water table from Lake Ontario",
    solution: "Heavy-duty sump pumps and drainage"
  },
  {
    problem: "CONVERTED BUILDINGS",
    description: "Multi-unit conversions have complex needs",
    solution: "Comprehensive building-wide solutions"
  },
  {
    problem: "AGING INFRASTRUCTURE",
    description: "Century-old sewers and water mains",
    solution: "Backflow prevention and modern drainage"
  }
];

// Neighborhood-specific FAQs
const neighborhoodFAQs = [
  {
    question: "Do you service all of Parkdale?",
    answer: "Yes! We provide comprehensive moisture control services throughout this community, with 20-25 minutes emergency response times. Our team knows every street and the unique challenges of local homes."
  },
  {
    question: "What are common water issues in Parkdale?",
    answer: "local homes, typically 90-120 years old with brick & stone foundations, face challenges from sandy soil and high water table levels. The area has a moderate flood risk."
  },
  {
    question: "How much does waterproofing cost in Parkdale?",
    answer: "Typical waterproofing projects in Parkdale range from $7,000-$14,000, depending on the extent of work needed. We provide free inspections and detailed quotes."
  },
  {
    question: "How quickly can you respond to emergencies in Parkdale?",
    answer: "We guarantee 20-25 minutes emergency response anywhere in Parkdale. Our team is available 24/7 for flooding emergencies."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dryspace Waterproofing Parkdale",
  "description": "Expert moisture control services in Parkdale Toronto. Brick & Stone structure specialists.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Parkdale",
    "addressRegion": "Toronto",
    "addressCountry": "CA"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Parkdale, Toronto"
  }
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Toronto", url: "/locations/toronto" },
        { name: "Neighborhoods", url: "/locations/toronto#neighborhoods" },
        { name: "Parkdale" }
      ]}
    />
  </div>

<!-- Neighborhood Hero -->
  <Hero 
    title="Waterproofing Parkdale"
    subtitle="Expert lower level moisture control and structure repair for local homes. 90-120 years home specialists, 24/7 emergency service."
    primaryCTA={{ text: "Get Free Local Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving This Area"
  />

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WATERPROOFING SERVICES IN PARKDALE</h2>
        
        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Parkdale's homes, typically {localInfo.avgHomeAge} old with {localInfo.foundationType} foundations, 
            require specialized waterproofing expertise. Our team understands the unique challenges of {localInfo.soilType} soil 
            and {localInfo.waterTable} water table conditions in this West Toronto neighborhood.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">PARKDALE QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgHomeAge.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Foundation Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.foundationType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Soil Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.soilType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Response Time</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.responseTime.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Cost</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgProjectCost}</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">PARKDALE CHALLENGES</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>High water table from Lake Ontario</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Multi-unit conversions have complex needs</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Century-old sewers and water mains</span>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4 uppercase">STREETS WE SERVE IN PARKDALE</h3>
          <p class="mb-4">
            Our team provides rapid response throughout this community:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Queen Street West","King Street West","Jameson Avenue","Dowling Avenue","Dufferin Street","Lansdowne Avenue","Close Avenue"].map((street) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm uppercase">
                {street}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Neighborhood Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN PARKDALE</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Specialized expertise for local homes and properties
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {neighborhoodFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {neighborhoodFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Challenges Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-12 text-center uppercase">PARKDALE WATER CHALLENGES</h2>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {localChallenges.map((challenge) => (
          <div class="bg-white border-2 border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{challenge.problem}</h3>
            <p class="text-sm text-slate-600 mb-4">{challenge.description}</p>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-sm font-semibold text-slate-900 uppercase mb-1">OUR SOLUTION:</p>
              <p class="text-sm text-slate-600">{challenge.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PARKDALE WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Parkdale homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {neighborhoodFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PROTECT YOUR PARKDALE HOME TODAY</h2>
        <p class="text-lg text-slate-300 mb-8">
          Expert waterproofing for 90-120 years homes in Parkdale
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Schedule Local Inspection
          </a>
          <a 
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">24/7 Emergency Service Available</span>
        </div>
      </div>
    </div>
  </section>
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Neighborhoods'}, {name: 'Parkdale'}]} />
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>