---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Basement Waterproofing Streetsville | Heritage Home Specialists | DrySpace";
const pageDescription = "Professional basement waterproofing in Streetsville, Mississauga. Heritage home specialists. Interior & exterior systems from $150/ft. $3,400 rebate. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  neighborhoodName: "Streetsville",
  cityName: "Mississauga",
  avgHomeAge: "40-120 years",
  foundationType: "Mixed — Stone, Block & Poured Concrete",
  soilType: "Credit Valley Clay",
  waterTable: "High (Credit River)",
  floodRisk: "High",
  avgProjectCost: "$12,000-$25,000",
  responseTime: "30-45 minutes"
};

// Neighborhood-specific features
const neighborhoodFeatures = [
  {
    title: 'HERITAGE HOME EXPERTS',
    description: 'Specialized in Streetsville\'s historic village homes dating back to the 1850s.',
    highlight: true
  },
  {
    title: 'CREDIT RIVER PROTECTION',
    description: 'Advanced waterproofing for homes in the Credit River flood plain.',
    highlight: true
  },
  {
    title: 'CLAY SOIL SPECIALISTS',
    description: 'Expert solutions for Credit Valley clay that expands up to 70% when wet.',
    highlight: true
  },
  {
    title: 'RAPID RESPONSE',
    description: 'Under 45 minutes emergency response to all Streetsville streets.',
  },
  {
    title: '$3,400 REBATE ASSISTANCE',
    description: 'We handle all paperwork for Mississauga\'s Basement Flooding Protection Subsidy.',
  },
  {
    title: 'HERITAGE PERMIT EXPERTISE',
    description: 'Navigate Streetsville Heritage Conservation District requirements.',
  }
];

// Local challenges specific to Streetsville
const localChallenges = [
  {
    problem: "CREDIT RIVER FLOODING",
    description: "Proximity to the Credit River creates high water table conditions and flood risk, especially during spring thaw and heavy rainstorms",
    solution: "Multi-layer exterior waterproofing with sump pump backup systems and backwater valve installation"
  },
  {
    problem: "HERITAGE FOUNDATION AGING",
    description: "Streetsville's historic village core has homes with 100+ year old stone and rubble foundations that crack and deteriorate",
    solution: "Heritage-sensitive foundation repair, stone repointing, and waterproof membrane systems"
  },
  {
    problem: "CREDIT VALLEY CLAY SOIL",
    description: "Expansive clay soil (30-70% clay content) shifts seasonally, putting pressure on foundations and cracking basement walls",
    solution: "Exterior waterproofing with proper drainage to manage hydrostatic pressure from clay expansion"
  }
];

// Neighborhood-specific FAQs
const neighborhoodFAQs = [
  {
    question: "How much does basement waterproofing cost in Streetsville?",
    answer: "Basement waterproofing in Streetsville costs $150-$200 per linear foot for interior systems and $200-$280 per linear foot for exterior waterproofing. A typical Streetsville home (100-120 linear feet) costs $12,000-$25,000 total. Heritage homes in the village core may cost 15-20% more due to specialized techniques and heritage permit requirements. Mississauga residents can access up to $3,400 through the Basement Flooding Protection Subsidy Program."
  },
  {
    question: "Is my Streetsville home at risk for Credit River flooding?",
    answer: "Properties within 500 meters of the Credit River corridor, especially south of Queen Street South, face elevated flood risk. The Credit River has flooded 7 times in the past 20 years, with major events in 2013, 2017, and 2024. Even homes several blocks from the river can experience high water table conditions during spring thaw (March-April) when the water table rises 2-4 feet. Properties near Queen Street, Main Street, and Church Street are at highest risk. A professional assessment can determine your specific risk level and recommend appropriate protection."
  },
  {
    question: "Do I need special permits for waterproofing a heritage home in Streetsville?",
    answer: "Yes, homes in the Streetsville Heritage Conservation District may require heritage permits for exterior work. DrySpace handles all permit applications with the City of Mississauga, including heritage permits, building permits for excavation, and Region of Peel plumbing permits."
  },
  {
    question: "How quickly can you respond to flooding emergencies in Streetsville?",
    answer: "We guarantee response times under 45 minutes to all Streetsville addresses. Our teams are stationed across Mississauga with 24/7 availability. For Credit River flood events, we deploy specialized pumping equipment for rapid water removal."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "DrySpace Waterproofing Streetsville",
  "description": "Expert basement waterproofing in Streetsville, Mississauga. Heritage home specialists, Credit River flood protection, foundation repair.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "260 Wellesley Street East",
    "addressLocality": "Toronto",
    "addressRegion": "ON",
    "postalCode": "M4X 1G6",
    "addressCountry": "CA"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Streetsville, Mississauga"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 43.5818,
    "longitude": -79.7143
  }
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Basement Waterproofing Streetsville | Heritage Home Specialists",
  "description": pageDescription,
  "url": "https://dryspacewaterproofing.ca/neighborhoods/streetsville",
  "publisher": {
    "@type": "Organization",
    "name": "DrySpace Waterproofing"
  }
};

const speakableSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Basement Waterproofing Streetsville",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "h2", ".speakable"]
  },
  "mainEntity": {
    "@type": "LocalBusiness",
    "name": "DrySpace Waterproofing",
    "telephone": "437-545-0067",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "260 Wellesley Street East",
      "addressLocality": "Toronto",
      "addressRegion": "ON",
      "postalCode": "M4X 1G6",
      "addressCountry": "CA"
    },
    "areaServed": {
      "@type": "City",
      "name": "Streetsville",
      "containedInPlace": {
        "@type": "City",
        "name": "Mississauga"
      }
    }
  }
};
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
>

  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs
      items={[
        { name: "Home", url: "/" },
        { name: "Mississauga", url: "/basement-waterproofing-mississauga" },
        { name: "Streetsville" }
      ]}
    />
  </div>

  <!-- Neighborhood Hero -->
  <Hero
    title="BASEMENT WATERPROOFING STREETSVILLE"
    subtitle="Heritage home specialists protecting Streetsville from Credit River flooding and clay soil damage. 92+ projects completed. 24/7 emergency response."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="$3,400 REBATE AVAILABLE"
  />

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase speakable">BASEMENT WATERPROOFING IN STREETSVILLE</h2>

        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-slate-600 mb-6 speakable">
            Streetsville, Mississauga is one of the GTA's oldest neighborhoods, with homes dating back to the 1850s village era.
            These heritage properties in Streetsville face unique basement waterproofing challenges — from aging stone foundations in the
            historic core to Credit Valley clay soil that causes foundation movement throughout Streetsville.
            DrySpace has completed 92+ waterproofing projects in Streetsville, Mississauga, making us the area's most experienced
            basement waterproofing contractor.
          </p>

          <div class="bg-cyan-50 border-l-4 border-cyan-600 p-6 mb-6">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">Streetsville Basement Waterproofing Costs (2026)</h3>
            <ul class="space-y-2 text-slate-700">
              <li class="speakable"><strong>Interior Waterproofing:</strong> $150-$200 per linear foot (installed)</li>
              <li class="speakable"><strong>Exterior Waterproofing:</strong> $200-$280 per linear foot (excavation + membrane + drainage)</li>
              <li class="speakable"><strong>Foundation Crack Repair:</strong> $800-$1,500 per crack (epoxy or polyurethane injection)</li>
              <li class="speakable"><strong>Sump Pump Installation:</strong> $1,800-$2,500 (includes pit, pump, and discharge)</li>
              <li class="speakable"><strong>Battery Backup System:</strong> $800-$1,200 (for power outage protection)</li>
              <li class="speakable"><strong>Average Total Project:</strong> $12,000-$25,000 (typical Streetsville home, 100-120 linear feet)</li>
            </ul>
            <p class="text-sm text-slate-600 mt-4 italic">Prices reflect Streetsville's heritage home requirements and Credit Valley clay soil conditions. Mississauga residents eligible for up to $3,400 Basement Flooding Protection Subsidy.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">STREETSVILLE QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgHomeAge.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Foundation Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.foundationType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Soil Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.soilType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Flood Risk</span>
                  <span class="text-sm font-bold text-red-600">{localInfo.floodRisk.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Response Time</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.responseTime.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Cost</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgProjectCost}</span>
                </li>
              </ul>
            </div>

            <div class="bg-navy-900 border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase speakable">STREETSVILLE WATERPROOFING CHALLENGES</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start speakable">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Credit River flood plain proximity (homes within 500m face elevated risk)</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start speakable">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Heritage conservation district restrictions (special permits required for exterior work)</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start speakable">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Credit Valley clay soil (30-70% clay content, expands up to 70% when saturated)</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start speakable">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Aging stone foundations in village core (homes built 1850-1920)</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start speakable">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>High water table from Credit River aquifer (seasonal fluctuations 2-4 feet)</span>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4 uppercase">STREETS WE SERVE IN STREETSVILLE, MISSISSAUGA</h3>
          <p class="mb-4">
            Our team provides rapid response throughout the entire Streetsville, Mississauga community:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Queen Street South", "Main Street", "Church Street", "Thomas Street", "Tannery Street", "Falconer Drive", "Joymar Drive", "Creditview Road", "Barbertown Road", "Bristol Road"].map((street) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm uppercase">
                {street}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Neighborhood Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN STREETSVILLE</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Heritage home expertise and Credit River flood protection specialists
        </p>
      </div>

      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {neighborhoodFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>

      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {neighborhoodFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Challenges Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-12 text-center uppercase">STREETSVILLE WATERPROOFING CHALLENGES</h2>

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {localChallenges.map((challenge) => (
          <div class="bg-white border-2 border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{challenge.problem}</h3>
            <p class="text-sm text-slate-600 mb-4">{challenge.description}</p>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-sm font-semibold text-slate-900 uppercase mb-1">OUR SOLUTION:</p>
              <p class="text-sm text-slate-600">{challenge.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />

  <!-- Trust Signals -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-8 text-center uppercase">STREETSVILLE BASEMENT WATERPROOFING EXPERTS</h2>
      <div class="max-w-4xl mx-auto grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 rounded-lg shadow border-2 border-slate-200">
          <div class="text-4xl font-bold text-cyan-600 mb-2">92+</div>
          <p class="text-sm font-bold text-slate-900 uppercase mb-1">Streetsville Projects</p>
          <p class="text-sm text-slate-600">Completed basement waterproofing installations in Streetsville, Mississauga since 2019</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow border-2 border-slate-200">
          <div class="text-4xl font-bold text-cyan-600 mb-2">25-Year</div>
          <p class="text-sm font-bold text-slate-900 uppercase mb-1">Warranty Coverage</p>
          <p class="text-sm text-slate-600">Transferable warranty on all exterior waterproofing systems installed in Streetsville</p>
        </div>
        <div class="bg-white p-6 rounded-lg shadow border-2 border-slate-200">
          <div class="text-4xl font-bold text-cyan-600 mb-2">&lt;45min</div>
          <p class="text-sm font-bold text-slate-900 uppercase mb-1">Emergency Response</p>
          <p class="text-sm text-slate-600">24/7 flood response to all Streetsville addresses, including Credit River emergencies</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">STREETSVILLE WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Streetsville homeowners</p>
      </div>

      <div class="max-w-4xl mx-auto">
        {neighborhoodFAQs.map((faq) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Related Resources -->
  <section class="py-12 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="uppercase text-2xl font-bold mb-6 text-slate-900">Streetsville Waterproofing Resources</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="p-6 bg-cyan-50 border-2 border-cyan-200">
          <h3 class="font-bold mb-3 text-slate-900 uppercase">Waterproofing Services</h3>
          <ul class="space-y-2">
            <li><a href="/services/exterior-waterproofing" class="text-cyan-600 hover:underline">Exterior Waterproofing Streetsville</a></li>
            <li><a href="/services/interior-waterproofing" class="text-cyan-600 hover:underline">Interior Waterproofing Systems</a></li>
            <li><a href="/services/foundation-repair" class="text-cyan-600 hover:underline">Foundation Repair & Crack Sealing</a></li>
            <li><a href="/services/sump-pump-installation" class="text-cyan-600 hover:underline">Sump Pump Installation & Backup</a></li>
          </ul>
        </div>
        <div class="p-6 bg-orange-50 border-2 border-orange-200">
          <h3 class="font-bold mb-3 text-slate-900 uppercase">Mississauga Resources</h3>
          <ul class="space-y-2">
            <li><a href="/basement-waterproofing-mississauga" class="text-orange-600 hover:underline">Basement Waterproofing Mississauga</a></li>
            <li><a href="/government-rebates" class="text-orange-600 hover:underline">$3,400 Mississauga Rebate Program</a></li>
            <li><a href="/free-inspection" class="text-orange-600 hover:underline">Free Streetsville Inspection</a></li>
            <li><a href="/service-areas" class="text-orange-600 hover:underline">All GTA Service Areas</a></li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PROTECT YOUR STREETSVILLE HOME</h2>
        <p class="text-lg text-slate-300 mb-8">
          Expert basement waterproofing for Streetsville heritage homes and Credit River properties. $3,400 rebate available.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Schedule Streetsville Inspection
          </a>
          <a
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>

        <div class="mt-8 text-slate-300 border-t border-slate-700 pt-6">
          <p class="text-sm font-semibold uppercase mb-2">DrySpace Waterproofing</p>
          <p class="text-sm">260 Wellesley Street East, Toronto, ON M4X 1G6</p>
          <p class="text-sm mt-1">Serving Streetsville & All of Mississauga</p>
          <p class="text-cyan-400 font-bold text-sm mt-3">24/7 Emergency Service — Under 45 Minutes to Streetsville</p>
        </div>
      </div>
    </div>
  </section>

  <BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Mississauga', url: '/basement-waterproofing-mississauga'}, {name: 'Streetsville'}]} />
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)}></script>
<script type="application/ld+json" set:html={JSON.stringify(speakableSchema)}></script>
