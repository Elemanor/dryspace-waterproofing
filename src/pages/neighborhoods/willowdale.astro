---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Services from '../../components/sections/Services.astro';
import Process from '../../components/sections/Process.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import Stats from '../../components/sections/Stats.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const pageTitle = "Willowdale Water Protection | Lower-Level & Structure Solutions";
const pageDescription = "Professional basement waterproofing in Willowdale Toronto. Foundation repair, sump pumps, crack repair. Poured concrete specialists. 25-year warranty. Free inspection. Call 437-545-0067.";

// Local area information
const localInfo = {
  neighborhoodName: "Willowdale",
  cityName: "Toronto",
  avgHomeAge: "30-60 years",
  foundationType: "Poured Concrete",
  soilType: "Clay",
  waterTable: "Moderate",
  floodRisk: "Low",
  avgProjectCost: "$8,000-$15,000",
  responseTime: "25-30 minutes"
};

// Neighborhood-specific features
const neighborhoodFeatures = [
  {
    title: "MODERN HOME EXPERTS",
    description: "Specialized in newer construction methods.",
    highlight: true
  },
  {
    title: "CONDO TOWNHOUSE PRO",
    description: "Experience with strata properties.",
    highlight: true
  },
  {
    title: "TECH-SAVVY SERVICE",
    description: "Digital quotes and progress tracking.",
    highlight: true
  },
  {
    title: "LARGE PROPERTIES",
    description: "Equipment for bigger homes."
  },
  {
    title: "POOL INTEGRATION",
    description: "Coordinate with pool systems."
  },
  {
    title: "SMART HOME READY",
    description: "IoT water detection systems."
  }
];

// Local challenges specific to neighborhood
const localChallenges = [
  {
    problem: "HIGH DENSITY DEVELOPMENT",
    description: "New condos affecting drainage patterns",
    solution: "Comprehensive water management systems"
  },
  {
    problem: "DEEP BASEMENTS",
    description: "Modern homes with deep foundations",
    solution: "Multi-level drainage and waterproofing"
  },
  {
    problem: "POOL COMPLICATIONS",
    description: "Swimming pools affecting water table",
    solution: "Integrated pool and foundation drainage"
  }
];

// Neighborhood-specific FAQs
const neighborhoodFAQs = [
  {
    question: "Do you service all of this area?",
    answer: "Yes! We provide comprehensive waterproofing services throughout this community, with 25-30 minutes emergency response times. Our team knows every street and the unique challenges of local homes."
  },
  {
    question: "What are common water issues in Willowdale?",
    answer: "Willowdale homes, typically 30-60 years old with poured concrete foundations, face challenges from clay soil and moderate water table levels. The area has a low flood risk."
  },
  {
    question: "How much does water protection cost locally?",
    answer: "Typical waterproofing projects in this area range from $8,000-$15,000, depending on the extent of work needed. We provide free inspections and detailed quotes."
  },
  {
    question: "How quickly can you respond to emergencies in this neighborhood?",
    answer: "We guarantee 25-30 minutes emergency response anywhere in Willowdale. Our team is available 24/7 for flooding emergencies."
  }
];

// Schema markup for local business
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Dryspace Waterproofing Willowdale",
  "description": "Expert basement waterproofing services in this community Toronto. Poured Concrete structure specialists.",
  "telephone": "437-545-0067",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Willowdale",
    "addressRegion": "Toronto",
    "addressCountry": "CA"
  },
  "areaServed": {
    "@type": "Place",
    "name": "Willowdale, Toronto"
  }
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Toronto", url: "/locations/toronto" },
        { name: "Neighborhoods", url: "/locations/toronto#neighborhoods" },
        { name: "Willowdale" }
      ]}
    />
  </div>

<!-- Neighborhood Hero -->
  <Hero 
    title="Waterproofing Willowdale"
    subtitle="Expert basement waterproofing and foundation repair for Willowdale homes. 30-60 years home specialists, 24/7 emergency service."
    primaryCTA={{ text: "Get Free Willowdale Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/dryspace_hero_desktop.webp"
    badge="Serving Willowdale"
  />

  <!-- Stats -->
  <Stats />

  <!-- Local Information Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WATERPROOFING SERVICES IN WILLOWDALE</h2>

        <p class="speakable"><strong>Basement waterproofing in Willowdale, North York costs $145–$285 per linear foot for the area's 1950s–1970s bungalows and split-levels, many with deteriorating parging and failed perimeter drainage that allows spring meltwater infiltration.</strong></p>

        <div class="prose prose-lg max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            Willowdale's homes, typically {localInfo.avgHomeAge} old with {localInfo.foundationType} foundations, 
            require specialized waterproofing expertise. Our team understands the unique challenges of {localInfo.soilType} soil 
            and {localInfo.waterTable} water table conditions in this North Toronto neighborhood.
          </p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 my-8">
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WILLOWDALE QUICK FACTS</h3>
              <ul class="space-y-2 text-slate-600">
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Home Age</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgHomeAge.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Foundation Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.foundationType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Soil Type</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.soilType.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Response Time</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.responseTime.toUpperCase()}</span>
                </li>
                <li class="flex justify-between items-center pb-2 border-b border-slate-100">
                  <span class="text-sm font-semibold text-slate-600 uppercase">Average Cost</span>
                  <span class="text-sm font-bold text-slate-900">{localInfo.avgProjectCost}</span>
                </li>
              </ul>
            </div>
            
            <div class="bg-navy-900 border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-6 uppercase">WILLOWDALE CHALLENGES</h3>
              <ul class="space-y-2 text-slate-300">
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>New condos affecting drainage patterns</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Modern homes with deep foundations</span>
                </li>
                <li class="text-sm text-slate-300 flex items-start">
                  <span class="mr-2 text-cyan-400">•</span>
                  <span>Swimming pools affecting water table</span>
                </li>
              </ul>
            </div>
          </div>

          <h3 class="text-2xl font-bold mt-8 mb-4 uppercase">STREETS WE SERVE IN WILLOWDALE</h3>
          <p class="mb-4">
            Our team provides rapid response throughout this community:
          </p>
          <div class="flex flex-wrap gap-2">
            {["Yonge Street","Bayview Avenue","Sheppard Avenue","Finch Avenue","Empress Avenue","Doris Avenue","Beecroft Road"].map((street) => (
              <span class="border-2 border-slate-200 px-4 py-2 text-sm uppercase">
                {street}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <Services />

  <!-- Neighborhood Features -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WHY CHOOSE DRYSPACE IN WILLOWDALE</h2>
        <p class="text-lg text-slate-600 max-w-3xl mx-auto">
          Specialized expertise for Willowdale homes and properties
        </p>
      </div>
      
      <!-- Highlighted Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">
        {neighborhoodFeatures.filter(f => f.highlight).map((feature) => (
          <div class="bg-amber-500 border-2 border-slate-700 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-900">{feature.description}</p>
          </div>
        ))}
      </div>
      
      <!-- Regular Features -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {neighborhoodFeatures.filter(f => !f.highlight).map((feature) => (
          <div class="bg-white border-2 border-slate-200 p-6 hover:border-slate-300 transition-colors">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{feature.title}</h3>
            <p class="text-sm text-slate-600">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Local Challenges Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-12 text-center uppercase">WILLOWDALE WATER CHALLENGES</h2>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {localChallenges.map((challenge) => (
          <div class="bg-white border-2 border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">{challenge.problem}</h3>
            <p class="text-sm text-slate-600 mb-4">{challenge.description}</p>
            <div class="pt-4 border-t border-slate-100">
              <p class="text-sm font-semibold text-slate-900 uppercase mb-1">OUR SOLUTION:</p>
              <p class="text-sm text-slate-600">{challenge.solution}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">WILLOWDALE WATERPROOFING FAQS</h2>
        <p class="text-lg text-slate-600">Common questions from Willowdale homeowners</p>
      </div>
      
      <div class="max-w-4xl mx-auto">
        {neighborhoodFAQs.map((faq, index) => (
          <details class="mb-4 border-2 border-slate-200 bg-white">
            <summary class="cursor-pointer p-6 hover:bg-slate-50 transition-colors">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-slate-900 uppercase pr-4">{faq.question}</h3>
                <span class="text-slate-400 flex-shrink-0 text-2xl">+</span>
              </div>
            </summary>
            <div class="px-6 pb-6 pt-0">
              <p class="text-slate-600">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">PROTECT YOUR WILLOWDALE HOME TODAY</h2>
        <p class="text-lg text-slate-300 mb-8">
          Expert waterproofing for 30-60 years homes in Willowdale
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="/free-inspection"
            class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase"
          >
            Schedule Willowdale Inspection
          </a>
          <a 
            href="tel:437-545-0067"
            class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase"
          >
            Call: 437-545-0067
          </a>
        </div>
        
        <div class="mt-8 inline-flex items-center text-cyan-400">
          <span class="text-sm font-bold uppercase">24/7 Emergency Service Available</span>
        </div>
      </div>
    </div>
  </section>
<BreadcrumbSchema items={[{name: 'Home', url: '/'}, {name: 'Neighborhoods'}, {name: 'Willowdale'}]} />
</PageLayout>

<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)}></script>