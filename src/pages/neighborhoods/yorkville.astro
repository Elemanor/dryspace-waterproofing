      <div class="bg-slate-50 border-2 border-slate-200 p-8">
        <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">PRIORITY SERVICE ZONE:</h3>
        <ul class="space-y-2">
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">North:</span> Davenport Road</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">South:</span> Charles Street</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">East:</span> Yonge Street</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">West:</span> Avenue Road</li>
        </ul>
        
        <div class="mt-8">
          <h4 class="text-lg font-bold text-slate-900 mb-2 uppercase">PREMIUM SERVICE STREETS:</h4>
          <div class="grid grid-cols-3 md:grid-cols-4 gap-2 mt-4">
            <span>Yorkville Avenue</span>
            <span>Cumberland Street</span>
            <span>Hazelton Avenue</span>
            <span>Scollard Street</span>
            <span>Bellair Street</span>
            <span>Bay Street</span>
