---
import Testimonials from '../../components/sections/Testimonials.astro';
import Process from '../../components/sections/Process.astro';
import Services from '../../components/sections/Services.astro';
import Stats from '../../components/sections/Stats.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import TrustBadges from '../../components/TrustBadges.astro';
import StickyBooking from '../../components/StickyBooking.astro';
import ValuePropositions from '../../components/ValuePropositions.astro';
import LastUpdated from '../../components/LastUpdated.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const neighborhoodData = {
  name: 'Yorkville',
  avgHomeAge: '40-150 years (mix)',
  commonFoundation: 'Poured Concrete & Luxury High-Rise',
  floodRisk: 'Medium',
  avgProjectCost: '$12,000-$25,000',
  responseTime: '10-15 minutes'
};
---

<PageLayout 
  title="Waterproofing in Yorkville Toronto | Luxury Home & Condo Specialists" 
  description="Premium waterproofing services for Yorkville's luxury homes and condos. Discrete service, high-end solutions. 10-minute response. Call (437) 545-0067."
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Toronto", url: "/locations/toronto" },
        { name: "Neighborhoods", url: "/locations/toronto#neighborhoods" },
        { name: "Yorkville" }
      ]}
    />
  </div>

<section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="container mx-auto px-4 text-center">
        <h1 class="text-5xl font-bold text-white mb-6 uppercase">PREMIUM WATERPROOFING SERVICES IN YORKVILLE</h1>
        <p class="text-xl text-slate-300 mb-8">Protecting Toronto's Most Prestigious Properties Since 1999</p>
        
        <div class="grid grid-cols-3 gap-4 mb-8">
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">$5M+</span>
            <span class="text-sm text-slate-600 uppercase">Property Values Protected</span>
          </div>
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">10 min</span>
            <span class="text-sm text-slate-600 uppercase">Average Response Time</span>
          </div>
          <div class="bg-white border-2 border-slate-200 p-4">
            <span class="text-2xl font-bold text-slate-900">100%</span>
            <span class="text-sm text-slate-600 uppercase">Discrete Service Guarantee</span>
          </div>
        </div>
        
        <div class="flex gap-4 justify-center">
          <a href="/free-inspection" class="bg-amber-500 text-black px-8 py-4 text-lg font-bold hover:bg-amber-400 transition-colors uppercase">Schedule Confidential Assessment</a>
          <a href="tel:4375450067" class="border-2 border-white text-slate-900 px-8 py-4 text-lg font-bold hover:bg-white hover:text-black transition-colors uppercase">
            Priority Line: (437) 545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">YORKVILLE'S UNIQUE WATERPROOFING REQUIREMENTS</h2>
      
      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="challenge-card luxury">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">HIGH-RISE & UNDERGROUND PARKING</h3>
          <p class="text-slate-600">Multi-level underground parking garages require specialized membrane systems and drainage solutions to protect luxury vehicles and storage areas.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Commercial-grade crystalline waterproofing and epoxy injection systems with minimal disruption to residents.
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">HERITAGE MANSIONS & MODERN RENOVATIONS</h3>
          <p class="text-slate-600">Yorkville's mix of Victorian estates and ultra-modern homes requires versatile expertise in both traditional and cutting-edge techniques.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Custom solutions that preserve architectural integrity while implementing modern waterproofing technology.
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <div class="hidden"</div>
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">WINE CELLARS & ART STORAGE</h3>
          <p class="text-slate-600">Many Yorkville properties feature climate-controlled wine cellars and art storage requiring precise humidity control and zero moisture tolerance.</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Our Solution:</strong> Museum-quality vapor barriers and dehumidification systems protecting collections worth millions.
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">YORKVILLE FLOODING RISK ANALYSIS</h2>
      
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">URBAN HEAT ISLAND EFFECT</h3>
          <div class="inline-block px-3 py-1 bg-amber-500 text-black font-bold uppercase text-xs mb-2">MEDIUM</div>
          <p class="text-slate-600">Dense development creates rapid runoff during storms, overwhelming century-old storm sewers</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">HIGH WATER TABLE</h3>
          <div class="inline-block px-3 py-1 bg-cyan-500 text-slate-900 font-bold uppercase text-xs mb-2">HIGH</div>
          <p class="text-slate-600">Proximity to former Taddle Creek means elevated groundwater levels, especially near Bloor & Avenue Road</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">CONSTRUCTION IMPACT</h3>
          <div class="inline-block px-3 py-1 bg-amber-500 text-black font-bold uppercase text-xs mb-2">VARIABLE</div>
          <p class="text-slate-600">Ongoing development can redirect underground water flow, affecting neighboring properties</p>
        </div>
      </div>
      
      <div class="mt-8 bg-navy-900 border-2 border-slate-200 p-6">
        <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">RECENT WATER EVENTS IN YORKVILLE</h3>
        <ul class="space-y-2">
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">August 2024:</span> Burst water main on Cumberland flooded 3 underground parking garages</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">July 2024:</span> Flash flooding affected luxury retailers along Bloor Street</li>
          <li class="text-slate-600 mb-2" class="text-slate-600"><span class="font-bold text-slate-900">May 2024:</span> Spring melt caused seepage in multiple heritage properties</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">RECENT YORKVILLE PROJECTS</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">THE HAZELTON PRIVATE RESIDENCES</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Parking Garage Membrane System</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">3-level underground parking</li>
              <li class="text-slate-600 mb-2">Zero-disruption installation</li>
              <li class="text-slate-600 mb-2">Completed over weekend</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $45,000</div>
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">HERITAGE HOME - HAZELTON AVENUE</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Wine Cellar Waterproofing</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">Climate control preservation</li>
              <li class="text-slate-600 mb-2">Vapor barrier installation</li>
              <li class="text-slate-600 mb-2">$2M wine collection protected</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $28,500</div>
          </div>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          
          <div class="">
            <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">LUXURY TOWNHOUSE - SCOLLARD STREET</h3>
            <p class="text-sm font-semibold text-slate-600 uppercase mb-2">Complete Foundation System</p>
            <ul class="space-y-2">
              <li class="text-slate-600 mb-2">Exterior waterproofing</li>
              <li class="text-slate-600 mb-2">French drain system</li>
              <li class="text-slate-600 mb-2">Landscape restoration included</li>
            </ul>
            <div class="mt-4 pt-4 border-t border-slate-100 font-bold text-slate-900">Investment: $35,000</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">TRUSTED BY YORKVILLE'S ELITE</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <div class="testimonial vip">
          <div class="stars"></div>
          <p class="text-slate-600">"Discrete, professional, and incredibly thorough. They waterproofed our wine cellar without any disruption to our collection. Exceptional white-glove service."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Private Client</strong>
            <span>Hazelton Avenue</span>
          </div>
        </div>
        
        <div class="testimonial vip">
          <div class="stars"></div>
          <p class="text-slate-600">"When water threatened our underground gallery, Dryspace responded within 10 minutes. They saved artwork worth more than my home. Forever grateful."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Gallery Owner</strong>
            <span>Cumberland Street</span>
          </div>
        </div>
        
        <div class="testimonial vip">
          <div class="stars"></div>
          <p class="text-slate-600">"They worked around our schedule, completed everything over a weekend, and left the property immaculate. This is how contractors should operate."</p>
          <div class="mt-4 pt-4 border-t border-slate-100">
            <strong>Condo Board President</strong>
            <span>Yorkville Avenue</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">SERVICING YORKVILLE'S PREMIER ADDRESSES</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">FOUR SEASONS PRIVATE RESIDENCES</h3>
          <p class="text-slate-600">Specialized in high-rise waterproofing solutions for luxury condominiums with underground amenities and parking.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">ROM & BLOOR STREET CORRIDOR</h3>
          <p class="text-slate-600">Protecting properties near major cultural institutions requires understanding of unique drainage patterns and foot traffic impact.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">YORKVILLE VILLAGE & HAZELTON LANES</h3>
          <p class="text-slate-600">Commercial and mixed-use properties need rapid response to protect retail spaces and maintain business continuity.</p>
        </div>
        
        <div class="bg-white border-2 border-slate-200 p-6">
          <h3 class="text-xl font-bold text-slate-900 mb-3 uppercase">QUEEN'S PARK ADJACENT PROPERTIES</h3>
          <p class="text-slate-600">Historic homes near the park face unique challenges from tree roots and elevation changes requiring specialized approaches.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
