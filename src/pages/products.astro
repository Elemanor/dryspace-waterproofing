---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Footer from "../components/Footer.astro";
import CTASection from "../components/sections/CTA.astro";
---

<Layout
  title="Products & Solutions | DrySpace Waterproofing"
  description="Professional waterproofing products, drainage systems, and glass safety solutions. NBC compliant materials for foundation protection and building safety."
>
  <Navbar />
  <Hero
    title="Professional Products & Solutions"
    subtitle="Industry-Leading Materials for Waterproofing, Drainage & Safety Glass"
    backgroundImage="/images/dryspace_hero_desktop.webp"
  />

  <main class="container mx-auto px-6 py-12">
    <!-- Product Categories -->
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      <div class="bg-cyan-50 rounded-lg p-6 text-center">
        <div class="text-4xl mb-4">💧</div>
        <h3 class="font-bold text-xl mb-2">Waterproofing</h3>
        <p class="text-slate-500">Membranes & Coatings</p>
      </div>
      <div class="bg-cyan-50 rounded-lg p-6 text-center">
        <div class="text-4xl mb-4">🚿</div>
        <h3 class="font-bold text-xl mb-2">Drainage Systems</h3>
        <p class="text-slate-500">Pumps & Drains</p>
      </div>
      <div class="bg-orange-50 rounded-lg p-6 text-center">
        <div class="text-4xl mb-4">🪟</div>
        <h3 class="font-bold text-xl mb-2">Safety Glass</h3>
        <p class="text-slate-500">Guards & Partitions</p>
      </div>
    </div>

    <!-- Waterproofing Products -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Waterproofing Solutions</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Delta-MS Dimpled Membrane -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden relative">
          <div class="absolute top-2 right-2 bg-orange-500 text-white px-3 py-1 rounded-full text-xs font-bold">FEATURED</div>
          <img src="/images/dimpled membrane on base of footing.webp" alt="Delta-MS Dimpled Membrane" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Delta-MS Dimpled Membrane</h3>
            <p class="text-slate-500 mb-4">High-density polyethylene (HDPE) dimpled drainage membrane providing air gap technology for foundation walls. Creates effective moisture barrier and drainage plane.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ Air gap eliminates hydrostatic pressure</li>
              <li>✓ Compressive strength: 5,200 psf</li>
              <li>✓ 65-year life expectancy</li>
            </ul>
            <div class="mt-4 text-orange-600 font-semibold">$3.50-4.50/sq ft installed</div>
            <a href="/products/delta-ms-membrane" class="mt-4 block bg-cyan-600 text-white text-center py-2 rounded hover:bg-cyan-700 transition">
              View Full Specifications →
            </a>
          </div>
        </div>

        <!-- Aqua-Bloc 770-06 Membrane -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="/images/waterproofing membrane dumpproofing aqua block.webp" alt="Aqua-Bloc 770-06 Waterproofing" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Aqua-Bloc 770-06 Elastomeric</h3>
            <p class="text-slate-500 mb-4">One-component seamless rubberized asphalt membrane. Cold applied elastomeric compound replaces hot mop systems.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ 90 mils (2.25mm) thickness</li>
              <li>✓ 1500% elongation capacity</li>
              <li>✓ CAN/CGSB-37.58 compliant</li>
              <li>✓ -40°C to 85°C service range</li>
            </ul>
            <div class="mt-4 text-orange-600 font-semibold">$3.50-5.00/sq ft installed</div>
          </div>
        </div>

        <!-- Styrofoam Insulation -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="/images/waterproofing + insuulation of foundation walls styrofoam.webp" alt="Insulated Waterproofing System" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Insulated Foundation System</h3>
            <p class="text-slate-500 mb-4">Rigid foam insulation panels with integrated drainage channels. Provides R-10 insulation value while managing moisture.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ 2" extruded polystyrene</li>
              <li>✓ R-10 insulation value</li>
              <li>✓ Protects waterproofing membrane</li>
            </ul>
            <div class="mt-4 text-orange-600 font-semibold">$5.00-7.00/sq ft installed</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Product Specification -->
    <section class="mb-16 bg-gradient-to-br from-gray-50 to-gray-100 rounded-lg p-8">
      <h2 class="text-3xl font-bold mb-8 text-center">Featured: Aqua-Bloc 770-06 Technical Specifications</h2>
      
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Product Features -->
        <div class="bg-white rounded-lg p-6">
          <h3 class="font-bold text-xl mb-4 text-cyan-600">Key Features & Benefits</h3>
          <ul class="space-y-3">
            <li class="flex items-start">
              <span class="text-cyan-600 mr-2">✓</span>
              <div>
                <strong>Seamless Application:</strong> Single-coat rubberized membrane eliminates joints and seams
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-600 mr-2">✓</span>
              <div>
                <strong>Superior Adhesion:</strong> Bonds to concrete, stone, wood, cement, and metal surfaces
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-600 mr-2">✓</span>
              <div>
                <strong>Flexible Performance:</strong> Retains flexibility from -40°C to 85°C service temperature
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-600 mr-2">✓</span>
              <div>
                <strong>Cold Applied:</strong> No kettles or special equipment required
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-cyan-600 mr-2">✓</span>
              <div>
                <strong>Chemical Resistant:</strong> Withstands mild acids, alkalis, salt, and calcium chloride
              </div>
            </li>
          </ul>
        </div>

        <!-- Physical Properties -->
        <div class="bg-white rounded-lg p-6">
          <h3 class="font-bold text-xl mb-4 text-orange-600">Physical Properties (CAN/CGSB-37.58)</h3>
          <table class="w-full text-sm">
            <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="py-2 font-medium">Color:</td>
                <td class="py-2">Black</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Solids by Weight:</td>
                <td class="py-2">65% (approx.)</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Density:</td>
                <td class="py-2">0.94 kg/L (7.7 lbs/gal)</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Coverage:</td>
                <td class="py-2">2.5 L/m² @ 90 mils wet</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Initial Set:</td>
                <td class="py-2">8 hours @ 25°C, 45% RH</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Full Cure:</td>
                <td class="py-2">24 hours</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Elongation (ASTM D412):</td>
                <td class="py-2">1500%</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Recovery:</td>
                <td class="py-2">85%</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Shore A Hardness:</td>
                <td class="py-2">35</td>
              </tr>
              <tr>
                <td class="py-2 font-medium">Water Vapour Permeance:</td>
                <td class="py-2">0.05 perms (ASTM E96)</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Applications -->
      <div class="mt-8 bg-cyan-50 rounded-lg p-6">
        <h3 class="font-bold text-xl mb-4">Ideal Applications</h3>
        <div class="grid md:grid-cols-3 gap-4">
          <div>
            <h4 class="font-semibold mb-2">Above Grade</h4>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>• Parking decks</li>
              <li>• Mechanical rooms</li>
              <li>• Planters</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-2">On Grade</h4>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>• Tunnels</li>
              <li>• Reflective pools</li>
              <li>• Plaza decks</li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-2">Below Grade</h4>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>• Foundation walls</li>
              <li>• Elevator pits</li>
              <li>• Retaining walls</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Application Notes -->
      <div class="mt-6 bg-amber-50 border border-yellow-200 rounded-lg p-4">
        <p class="text-sm"><strong>Important:</strong> Must be protected from damage during construction. Not for permanently exposed surfaces. Allow membrane to cure before installing polystyrene insulation. Minimum application temperature: -12°C.</p>
      </div>
    </section>

    <!-- Drainage Products -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Drainage Systems</h2>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Liberty Sump Pump System -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="/images/sump pump with back up.webp" alt="Liberty Sump Pump System" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Liberty 230-Series Sump Pump</h3>
            <p class="text-slate-500 mb-4">Professional-grade 1/3 HP submersible pump with automatic operation. Model 2312 delivers reliable basement protection.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ 37 GPM at 10' head / 21' max head</li>
              <li>✓ Vortex impeller handles 3/8" solids</li>
              <li>✓ Thermal protection & 3-year warranty</li>
              <li>✓ CSA & SSPMA certified</li>
            </ul>
            <div class="mt-4">
              <div class="text-slate-400 text-sm">Pump only: $710</div>
              <div class="text-orange-600 font-semibold">Complete install with backup: $2,200-3,000</div>
            </div>
            <a href="/products/liberty-sump-pump" class="mt-4 block bg-cyan-600 text-white text-center py-2 rounded hover:bg-cyan-700 transition">
              View Full Specifications →
            </a>
          </div>
        </div>

        <!-- Perforated Drain Tile -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="/images/perforated drain.webp" alt="Perforated Drain Tile" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Big-O Perforated Drain Tile</h3>
            <p class="text-slate-500 mb-4">4" corrugated HDPE drainage pipe with filter sock. Meets NBC 9.14.3 requirements for foundation drainage.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ 3/8" perforations</li>
              <li>✓ Geotextile filter sock</li>
              <li>✓ 100-year service life</li>
            </ul>
            <div class="mt-4 text-orange-600 font-semibold">$15-25/linear foot installed</div>
          </div>
        </div>

        <!-- Foundation Crack Repair -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <img src="/images/crack on foundation wall due winter freeze .webp" alt="Foundation Crack" class="w-full h-48 object-cover" width="400" height="192" loading="lazy" decoding="async">
          <div class="p-6">
            <h3 class="font-bold text-xl mb-2">Crack Injection System</h3>
            <p class="text-slate-500 mb-4">Polyurethane injection for structural crack repair. Expands to seal cracks from 1/64" to 1/4" wide.</p>
            <ul class="text-sm text-slate-500 space-y-1">
              <li>✓ Flexible polyurethane resin</li>
              <li>✓ 600% expansion rate</li>
              <li>✓ Permanent waterproof seal</li>
            </ul>
            <div class="mt-4 text-orange-600 font-semibold">$300-500 per crack</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Glass Safety Products -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Safety Glass Solutions</h2>
      
      <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-8 mb-8">
        <h3 class="text-2xl font-bold mb-4">NBC Compliant Glass Guards & Partitions</h3>
        <p class="text-slate-600 mb-6">All glass products meet NBC Section 2.1.1 and DIN EN 14179-1 standards for safety glass in buildings.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Tempered Glass Guards -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="font-bold text-xl mb-4">Tempered Glass Guards</h3>
          <p class="text-slate-500 mb-4">Heat soaked tempered safety glass for railings and guards, tested to DIN EN 14179-1 standards.</p>
          
          <div class="bg-slate-50 rounded p-4 mb-4">
            <h4 class="font-semibold mb-2">NBC Table 2.1.1.1 Requirements:</h4>
            <ul class="text-sm space-y-2">
              <li><span class="font-medium">Within 50mm of floor:</span> Heat strengthened laminated</li>
              <li><span class="font-medium">50-150mm from floor:</span> Heat soaked tempered</li>
              <li><span class="font-medium">>150mm from floor:</span> Heat soaked tempered</li>
              <li><span class="font-medium">Minimum thickness:</span> 6mm tempered glass</li>
            </ul>
          </div>
          
          <div class="text-orange-600 font-semibold">$150-300/sq ft installed</div>
        </div>

        <!-- Laminated Safety Glass -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="font-bold text-xl mb-4">Laminated Safety Glass</h3>
          <p class="text-slate-500 mb-4">Designed to remain in frame if broken, preventing dislodgement per NBC 2.1.1.2 requirements.</p>
          
          <div class="bg-slate-50 rounded p-4 mb-4">
            <h4 class="font-semibold mb-2">Structural Design Features:</h4>
            <ul class="text-sm space-y-2">
              <li>✓ PVB interlayer thickness: 0.76mm minimum</li>
              <li>✓ Deflection limits per NBC Part 4</li>
              <li>✓ Live load: 0.5 kN or 1.0 kN/m</li>
              <li>✓ Temperature allowances included</li>
            </ul>
          </div>
          
          <div class="text-orange-600 font-semibold">$100-200/sq ft installed</div>
        </div>
      </div>

      <!-- Glass Specifications Table -->
      <div class="mt-8 overflow-x-auto">
        <table class="min-w-full bg-white rounded-lg overflow-hidden shadow-lg">
          <thead class="bg-cyan-600 text-white">
            <tr>
              <th class="px-6 py-3 text-left">Application</th>
              <th class="px-6 py-3 text-left">Glass Type Required</th>
              <th class="px-6 py-3 text-left">Thickness</th>
              <th class="px-6 py-3 text-left">Standard</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-6 py-4">Guards - Floor Edge</td>
              <td class="px-6 py-4">Heat Strengthened Laminated</td>
              <td class="px-6 py-4">10mm+</td>
              <td class="px-6 py-4">NBC 2.1.1.1</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-6 py-4">Guards - Inward</td>
              <td class="px-6 py-4">Heat Soaked Tempered</td>
              <td class="px-6 py-4">6mm+</td>
              <td class="px-6 py-4">DIN EN 14179-1</td>
            </tr>
            <tr>
              <td class="px-6 py-4">Office Partitions</td>
              <td class="px-6 py-4">Tempered or Laminated</td>
              <td class="px-6 py-4">10-12mm</td>
              <td class="px-6 py-4">NBC Part 4</td>
            </tr>
            <tr class="bg-slate-50">
              <td class="px-6 py-4">Shower Enclosures</td>
              <td class="px-6 py-4">Tempered Safety Glass</td>
              <td class="px-6 py-4">8-10mm</td>
              <td class="px-6 py-4">ANSI Z97.1</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Product Warranty Section -->
    <section class="bg-gradient-to-r from-orange-500 to-orange-600 text-white rounded-lg p-8 mb-12">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">Industry-Leading Warranties</h2>
        <div class="grid md:grid-cols-3 gap-6 mt-8">
          <div>
            <div class="text-4xl font-bold">25</div>
            <div>Years on Membranes</div>
          </div>
          <div>
            <div class="text-4xl font-bold">10</div>
            <div>Years on Glass</div>
          </div>
          <div>
            <div class="text-4xl font-bold">5</div>
            <div>Years on Pumps</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Installation Process -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-8 text-center">Professional Installation Process</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="bg-cyan-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan-600">1</span>
          </div>
          <h3 class="font-semibold mb-2">Site Assessment</h3>
          <p class="text-sm text-slate-500">Free inspection and detailed quote</p>
        </div>
        <div class="text-center">
          <div class="bg-cyan-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan-600">2</span>
          </div>
          <h3 class="font-semibold mb-2">Product Selection</h3>
          <p class="text-sm text-slate-500">NBC compliant materials chosen</p>
        </div>
        <div class="text-center">
          <div class="bg-cyan-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan-600">3</span>
          </div>
          <h3 class="font-semibold mb-2">Professional Install</h3>
          <p class="text-sm text-slate-500">Certified technicians, quality assured</p>
        </div>
        <div class="text-center">
          <div class="bg-cyan-50 rounded-full w-16 h-16 flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-cyan-600">4</span>
          </div>
          <h3 class="font-semibold mb-2">Warranty & Support</h3>
          <p class="text-sm text-slate-500">Long-term protection guaranteed</p>
        </div>
      </div>
    </section>
  </main>

  <CTASection />
  <Footer />
</Layout>