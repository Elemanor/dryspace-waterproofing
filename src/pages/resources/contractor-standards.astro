---
import PageLayout from '../../layouts/PageLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ResourceImageGallery from '../../components/ResourceImageGallery.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const professionalStandards = [
  {
    category: 'Permits & Compliance',
    items: [
      'All necessary building permits obtained before work begins',
      'Full compliance with Ontario Building Code',
      'Electrical and plumbing permits as required',
      'Municipal inspections coordinated',
      'Heritage property considerations when applicable'
    ]
  },
  {
    category: 'Insurance & Protection',
    items: [
      'Comprehensive general liability insurance (minimum $2 million)',
      'WSIB coverage for all workers',
      'Property damage protection',
      'Errors and omissions insurance',
      'Proof of coverage provided before work begins'
    ]
  },
  {
    category: 'Professional Associations',
    items: [
      'Canadian Home Builders Association member',
      'Better Business Bureau accredited',
      'Ontario Building Officials Association compliance',
      'Tarion Warranty Corporation registered',
      'Local trade associations participation'
    ]
  },
  {
    category: 'Contract & Documentation',
    items: [
      'Detailed written contracts with clear scope',
      'Transparent pricing with itemized quotes',
      'Change order procedures documented',
      'Payment schedules clearly defined',
      'All warranties in writing'
    ]
  }
];

const contractElements = [
  { element: 'Contractor Information', details: 'Company name, address, phone, email, GST number' },
  { element: 'Client Information', details: 'Property address, contact information' },
  { element: 'Scope of Work', details: 'Detailed description of all work to be performed' },
  { element: 'Materials & Specifications', details: 'Complete list with brands, models, grades' },
  { element: 'Timeline', details: 'Start date, completion date, milestone schedule' },
  { element: 'Payment Terms', details: 'Total cost, payment schedule, acceptable payment methods' },
  { element: 'Warranties', details: 'Workmanship warranty, manufacturer warranties' },
  { element: 'Change Orders', details: 'Process for modifications and additional work' },
  { element: 'Permits', details: 'List of required permits and who obtains them' },
  { element: 'Insurance', details: 'Proof of liability and WSIB coverage' }
];
---

<PageLayout 
  title="Professional Contractor Standards | Dryspace Waterproofing Guidelines" 
  description="Learn about our professional standards, insurance coverage, warranties, and commitment to following all building codes and regulations in Toronto."
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Resources", url: "/resources" },
        { name: "Contractor Standards" }
      ]}
    />
  </div>

<!-- Hero Section -->
  <section class="hero-section">
    <div class="hero-container">
      <div class="badge-container">
        <span class="badge certified">Fully Licensed</span>
        <span class="badge insured">Fully Insured</span>
        <span class="badge wsib">WSIB Covered</span>
      </div>
      
      <h1 class="hero-title">
        Professional Standards & Guidelines
        <span class="subtitle">Your Protection is Our Priority</span>
      </h1>
      
      <p class="hero-description">
        At Dryspace Waterproofing, we maintain the highest professional standards in the industry. 
        From comprehensive insurance coverage to detailed contracts and proper permits, 
        we ensure your project is protected at every level.
      </p>

      <div class="trust-indicators">
        <div class="indicator">
          <i class="fa-solid fa-shield-halved"></i>
          <span>$2M Liability Insurance</span>
        </div>
        <div class="indicator">
          <i class="fa-solid fa-certificate"></i>
          <span>Licensed & Bonded</span>
        </div>
        <div class="indicator">
          <i class="fa-solid fa-hard-hat"></i>
          <span>WSIB Coverage</span>
        </div>
        <div class="indicator">
          <i class="fa-solid fa-award"></i>
          <span>BBB Accredited</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Professional Standards Grid -->
  <section class="standards-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">OUR PROFESSIONAL STANDARDS</h2>
      <p class="section-intro">Every aspect of your project is backed by professional certifications and comprehensive protection</p>
      
      <div class="standards-grid">
        {professionalStandards.map(standard => (
          <div class="standard-card border-2 border-slate-200">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">{standard.category}</h3>
            <ul class="standard-list">
              {standard.items.map(item => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Insurance & Liability Section -->
  <section class="insurance-section">
    <div class="container">
      <div class="insurance-content">
        <div class="insurance-text">
          <h2 class="text-4xl font-bold text-slate-900 uppercase">COMPREHENSIVE INSURANCE COVERAGE</h2>
          <p class="lead">Your property and investment are fully protected</p>
          
          <div class="coverage-details">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">WHAT OUR INSURANCE COVERS:</h3>
            <ul>
              <li><strong>Property Damage:</strong> Protection against accidental damage during work</li>
              <li><strong>General Liability:</strong> $2 million coverage for your peace of mind</li>
              <li><strong>Workers' Compensation:</strong> Full WSIB coverage for all employees</li>
              <li><strong>Professional Liability:</strong> Errors and omissions protection</li>
              <li><strong>Completed Operations:</strong> Coverage continues after project completion</li>
            </ul>

            <div class="insurance-note">
              <i class="fa-solid fa-info-circle"></i>
              <p>We provide proof of insurance before any work begins. Our coverage exceeds industry standards and municipal requirements.</p>
            </div>
          </div>
        </div>
        
        <div class="insurance-images">
          <img src="/waterproofing manual/content/photo_2025-08-25_20-49-25.jpg" 
               alt="Insurance and workers compensation documentation" 
               class="insurance-img" / width="800" height="600" loading="lazy" decoding="async">
          <div class="certification-badges">
            <div class="cert-badge">
              <i class="fa-solid fa-check-circle"></i>
              <span>WSIB Certificate</span>
            </div>
            <div class="cert-badge">
              <i class="fa-solid fa-check-circle"></i>
              <span>Liability Insurance</span>
            </div>
            <div class="cert-badge">
              <i class="fa-solid fa-check-circle"></i>
              <span>Bonded Contractor</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contract Elements Section -->
  <section class="contract-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">TRANSPARENT CONTRACT PROCESS</h2>
      <p class="section-intro">Every project begins with a detailed, written contract that protects both parties</p>
      
      <div class="contract-grid">
        <div class="contract-elements">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">WHAT'S INCLUDED IN EVERY CONTRACT:</h3>
          <div class="elements-list">
            {contractElements.map(item => (
              <div class="contract-item">
                <div class="item-header">
                  <i class="fa-solid fa-check"></i>
                  <strong>{item.element}</strong>
                </div>
                <p>{item.details}</p>
              </div>
            ))}
          </div>
        </div>
        
        <div class="contract-image">
          <img src="/waterproofing manual/content/photo_2025-08-25_20-49-30.jpg" 
               alt="Professional contract documentation" / width="800" height="600" loading="lazy" decoding="async">
          <div class="quote-process">
            <h3 class="text-2xl font-bold text-slate-900 uppercase">OUR QUOTE PROCESS:</h3>
            <ol>
              <li>Free on-site inspection</li>
              <li>Detailed written quote with itemized costs</li>
              <li>Clear scope of work description</li>
              <li>No hidden fees or surprise charges</li>
              <li>Valid for 30 days</li>
            </ol>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Warranty Section -->
  <section class="warranty-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">INDUSTRY-LEADING WARRANTIES</h2>
      
      <div class="warranty-grid">
        <div class="warranty-card featured border-2 border-slate-200">
          <div class="warranty-header">
            <i class="fa-solid fa-shield-halved"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">LIFETIME WARRANTY</h3>
          </div>
          <p>Our comprehensive lifetime warranty covers all major waterproofing work</p>
          <ul>
            <li>Transferable to new homeowners</li>
            <li>Covers materials and workmanship</li>
            <li>No deductibles or hidden fees</li>
            <li>24/7 emergency response</li>
          </ul>
        </div>

        <div class="warranty-card border-2 border-slate-200">
          <div class="warranty-header">
            <i class="fa-solid fa-tools"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">WORKMANSHIP GUARANTEE</h3>
          </div>
          <p>25-year warranty on all installation work</p>
          <ul>
            <li>Certified technician installation</li>
            <li>Quality control inspections</li>
            <li>Follow-up service included</li>
          </ul>
        </div>

        <div class="warranty-card border-2 border-slate-200">
          <div class="warranty-header">
            <i class="fa-solid fa-cube"></i>
            <h3 class="text-2xl font-bold text-slate-900 uppercase">MANUFACTURER'S WARRANTY</h3>
          </div>
          <p>Full manufacturer warranties on all materials</p>
          <ul>
            <li>Premium grade materials only</li>
            <li>Direct manufacturer support</li>
            <li>Extended coverage available</li>
          </ul>
        </div>
      </div>

      <div class="warranty-image">
        <img src="/waterproofing manual/content/photo_2025-08-25_20-49-26.jpg" 
             alt="Warranty coverage documentation" / width="800" height="600" loading="lazy" decoding="async">
      </div>
    </div>
  </section>

  <!-- Permits & Compliance -->
  <section class="permits-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">PERMITS & BUILDING CODE COMPLIANCE</h2>
      <p class="section-intro">We handle all permit requirements and ensure full code compliance</p>
      
      <div class="permits-content">
        <div class="permits-info">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">OUR PERMIT PROCESS:</h3>
          <div class="process-steps">
            <div class="step">
              <span class="step-number">1</span>
              <div class="step-content">
                <h4 class="text-xl font-bold text-slate-900 uppercase">ASSESSMENT</h4>
                <p>We determine which permits are required for your project</p>
              </div>
            </div>
            <div class="step">
              <span class="step-number">2</span>
              <div class="step-content">
                <h4 class="text-xl font-bold text-slate-900 uppercase">APPLICATION</h4>
                <p>We prepare and submit all permit applications</p>
              </div>
            </div>
            <div class="step">
              <span class="step-number">3</span>
              <div class="step-content">
                <h4 class="text-xl font-bold text-slate-900 uppercase">COORDINATION</h4>
                <p>We schedule and coordinate all required inspections</p>
              </div>
            </div>
            <div class="step">
              <span class="step-number">4</span>
              <div class="step-content">
                <h4 class="text-xl font-bold text-slate-900 uppercase">COMPLIANCE</h4>
                <p>We ensure all work meets or exceeds building codes</p>
              </div>
            </div>
          </div>
        </div>

        <div class="compliance-card border-2 border-slate-200">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">BUILDING CODE COMPLIANCE</h3>
          <img src="/waterproofing manual/content/photo_2025-08-25_20-49-24.jpg" 
               alt="Building permits and compliance" / width="800" height="600" loading="lazy" decoding="async">
          <ul class="compliance-list">
            <li>Ontario Building Code (OBC) compliant</li>
            <li>Municipal bylaw adherence</li>
            <li>Electrical Safety Authority (ESA) approved</li>
            <li>Technical Standards & Safety Authority (TSSA)</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Professional Associations -->
  <section class="associations-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">PROFESSIONAL MEMBERSHIPS</h2>
      <p class="section-intro">Active participation in industry associations ensures we stay current with best practices</p>
      
      <div class="associations-grid">
        <div class="association-card border-2 border-slate-200">
          <i class="fa-solid fa-building"></i>
          <h3 class="text-2xl font-bold text-slate-900 uppercase">CHBA</h3>
          <p>Canadian Home Builders' Association</p>
        </div>
        <div class="association-card border-2 border-slate-200">
          <i class="fa-solid fa-award"></i>
          <h3 class="text-2xl font-bold text-slate-900 uppercase">BBB</h3>
          <p>Better Business Bureau Accredited</p>
        </div>
        <div class="association-card border-2 border-slate-200">
          <i class="fa-solid fa-shield-halved"></i>
          <h3 class="text-2xl font-bold text-slate-900 uppercase">TARION</h3>
          <p>Registered with Tarion Warranty</p>
        </div>
        <div class="association-card border-2 border-slate-200">
          <i class="fa-solid fa-certificate"></i>
          <h3 class="text-2xl font-bold text-slate-900 uppercase">WSIB</h3>
          <p>Workers Safety Insurance Board</p>
        </div>
      </div>

      <div class="association-benefits">
        <img src="/waterproofing manual/content/photo_2025-08-25_20-49-23.jpg" 
             alt="Professional associations benefits" / width="800" height="600" loading="lazy" decoding="async">
        <div class="benefits-content">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">BENEFITS OF WORKING WITH ASSOCIATION MEMBERS:</h3>
          <ul>
            <li>Access to latest industry standards and techniques</li>
            <li>Ongoing professional development and training</li>
            <li>Dispute resolution services if needed</li>
            <li>Adherence to professional codes of conduct</li>
            <li>Network of qualified trade partners</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Change Orders & Project Management -->
  <section class="project-section">
    <div class="container">
      <h2 class="text-4xl font-bold text-slate-900 uppercase">PROJECT MANAGEMENT EXCELLENCE</h2>
      
      <div class="project-grid">
        <div class="project-card border-2 border-slate-200">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">CHANGE ORDER PROCESS</h3>
          <img src="/waterproofing manual/content/photo_2025-08-25_20-49-28.jpg" 
               alt="Change order documentation" / width="800" height="600" loading="lazy" decoding="async">
          <p>All changes to the original scope are documented in writing:</p>
          <ul>
            <li>Detailed description of changes</li>
            <li>Cost implications clearly stated</li>
            <li>Timeline adjustments documented</li>
            <li>Written approval before proceeding</li>
          </ul>
        </div>

        <div class="project-card border-2 border-slate-200">
          <h3 class="text-2xl font-bold text-slate-900 uppercase">COST ESTIMATION STANDARDS</h3>
          <img src="/waterproofing manual/content/photo_2025-08-25_20-49-31.jpg" 
               alt="Project cost estimation" / width="800" height="600" loading="lazy" decoding="async">
          <p>Industry-accepted standards for accurate estimates:</p>
          <ul>
            <li>Detailed material quantities</li>
            <li>Labour hours breakdown</li>
            <li>Equipment and overhead costs</li>
            <li>10-15% contingency included</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  
  <!-- Resource Images and Diagrams -->
  <ResourceImageGallery resource="technical-specs" />

<!-- CTA Section -->
  <section class="cta-section">
    <div class="container">
      <div class="cta-content">
        <h2 class="text-4xl font-bold text-slate-900 uppercase">EXPERIENCE THE DRYSPACE DIFFERENCE</h2>
        <p>Work with fully licensed, insured, and certified waterproofing professionals</p>
        
        <div class="cta-features">
          <div class="cta-feature">
            <i class="fa-solid fa-clipboard-check"></i>
            <span>Detailed Contracts</span>
          </div>
          <div class="cta-feature">
            <i class="fa-solid fa-shield-halved"></i>
            <span>Full Insurance</span>
          </div>
          <div class="cta-feature">
            <i class="fa-solid fa-certificate"></i>
            <span>All Permits Included</span>
          </div>
          <div class="cta-feature">
            <i class="fa-solid fa-award"></i>
            <span>Lifetime Warranty</span>
          </div>
        </div>
        
        <div class="cta-actions">
          <a href="/contact" class="btn-primary">Get Your Free Quote</a>
          <a href="tel:437-545-0067" class="btn-secondary">
            <i class="fa-solid fa-phone"></i>
            Call: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
  <Footer />
</PageLayout>

