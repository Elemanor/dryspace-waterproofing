---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import CTABand from '../components/sections/CTABand.astro';

const reviews = [
  {
    rating: 5,
    text: "Dryspace completed our exterior waterproofing last month and we couldn't be happier. The crew was professional, the site was kept clean, and most importantly - our basement is bone dry! They explained every step of the process and the 25-year warranty gives us tremendous peace of mind.",
    name: "Sarah & Michael Chen",
    location: "Forest Hill, Toronto",
    date: "March 2026",
    service: "Exterior Waterproofing"
  },
  {
    rating: 5,
    text: "We had a sump pump failure during a heavy rain and water was coming in fast. Called Dryspace at 11pm and they had a crew here within 2 hours. They stopped the flooding, installed a backup battery system, and saved our basement. Truly 24/7 emergency service!",
    name: "James Patterson",
    location: "North York",
    date: "February 2026",
    service: "Emergency Sump Pump"
  },
  {
    rating: 5,
    text: "Foundation crack repair was done professionally and efficiently. Alex walked me through the entire process, showed me photos at each stage, and the repair is completely invisible now. Price was fair and warranty is excellent. Highly recommend!",
    name: "Maria Rodriguez",
    location: "Mississauga",
    date: "March 2026",
    service: "Foundation Crack Repair"
  },
  {
    rating: 5,
    text: "After getting 4 quotes for our basement waterproofing, Dryspace wasn't the cheapest but they were by far the most thorough. The inspection report was detailed, they answered all our questions, and the work quality is outstanding. You get what you pay for - worth every penny.",
    name: "David & Lisa Thompson",
    location: "Etobicoke",
    date: "January 2026",
    service: "Interior Waterproofing"
  },
  {
    rating: 5,
    text: "Our 1920s home needed underpinning and we were nervous about the process. Dryspace made it stress-free. Daily updates, clean worksite, respectful crew. The engineer's reports gave us confidence and now we have 8 feet of ceiling height in our basement. Amazing transformation!",
    name: "Jennifer Wu",
    location: "The Beaches, Toronto",
    date: "December 2025",
    service: "Basement Underpinning"
  },
  {
    rating: 5,
    text: "French drain installation was completed ahead of schedule and under budget. The crew worked through some challenging clay soil conditions without any complaints. Our yard drainage problems are completely solved. Professional from start to finish.",
    name: "Robert MacKenzie",
    location: "Brampton",
    date: "February 2026",
    service: "French Drain System"
  },
  {
    rating: 5,
    text: "Had severe water intrusion through our foundation walls. Dryspace diagnosed it as hydrostatic pressure and recommended exterior waterproofing. Two years later and still 100% dry. Their warranty actually means something. Best investment we've made in our home.",
    name: "Priya Sharma",
    location: "Scarborough",
    date: "March 2024",
    service: "Exterior Waterproofing"
  },
  {
    rating: 5,
    text: "Needed a sump pump installed before selling our home. Dryspace completed it in one day, provided all documentation for the buyer, and the inspection passed without issues. Made the sale process smooth. Very responsive and reliable company.",
    name: "Tom Anderson",
    location: "Richmond Hill",
    date: "January 2026",
    service: "Sump Pump Installation"
  },
  {
    rating: 5,
    text: "Our foundation had multiple cracks that were leaking during spring thaw. Dryspace used polyurethane injection and guaranteed the repair for 25 years. It's been 3 years now through several wet seasons and not a single drop. Excellent work and warranty stands behind it.",
    name: "Elena Popescu",
    location: "Downtown Toronto",
    date: "April 2023",
    service: "Crack Injection"
  },
  {
    rating: 5,
    text: "Window well waterproofing and drainage installation was exactly what our basement needed. No more water pooling around the windows. The crew was punctual, polite, and left everything cleaner than they found it. Will definitely use them again for future projects.",
    name: "Kevin O'Brien",
    location: "Oakville",
    date: "March 2026",
    service: "Window Well Drainage"
  },
  {
    rating: 5,
    text: "Exterior waterproofing of our semi-detached home was completed with minimal disruption. They coordinated with our neighbor perfectly, protected our landscaping, and restored everything beautifully. The wall membrane and weeping tile system are top quality. Very impressed.",
    name: "Amir & Fatima Khan",
    location: "Mississauga",
    date: "November 2025",
    service: "Exterior Waterproofing"
  },
  {
    rating: 5,
    text: "Emergency response when our sump pump died during a storm. Arrived within 90 minutes at 2am, pumped out water, and installed a new system by morning. Above and beyond service. This is a company that truly cares about protecting your home.",
    name: "Catherine Dubois",
    location: "Vaughan",
    date: "February 2026",
    service: "Emergency Service"
  }
];

const stats = [
  { value: "5-Star", label: "Service", icon: "⭐" },
  { value: "25+", label: "Years of Service", icon: "💬" },
  { value: "98%", label: "Would Recommend", icon: "👍" },
  { value: "25+", label: "Years in Business", icon: "🏆" }
];

const platforms = [
  {
    name: "Google Reviews",
    rating: "5-Star",
    count: "Verified Business",
    icon: "⭐",
    color: "cyan"
  },
  {
    name: "HomeStars",
    rating: "9.8/10",
    count: "Best of 2024",
    icon: "🏆",
    color: "amber"
  },
  {
    name: "BBB Rating",
    rating: "A+",
    count: "Accredited",
    icon: "✓",
    color: "cyan"
  }
];

const trustFeatures = [
  {
    title: "25-Year Warranty",
    description: "Fully transferable warranty that protects your investment for decades. Written guarantee on all waterproofing and foundation work.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
    </svg>`
  },
  {
    title: "Licensed & Insured",
    description: "Fully licensed, WSIB covered, and $5M liability insurance. All work meets or exceeds Ontario Building Code standards.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`
  },
  {
    title: "24/7 Emergency Service",
    description: "Real emergency response when you need it most. Not an answering service - actual crew dispatch within hours, any time of day or night.",
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`
  }
];
---

<PageLayout
  title="Customer Reviews & Testimonials | Dryspace Waterproofing Toronto"
  description="Read real reviews from Toronto homeowners. See why we're Toronto's most trusted waterproofing company since 1999."
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-br from-navy-900 via-slate-900 to-navy-900 section-padding overflow-hidden">
    <!-- Ambient background effects -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-1/3 right-1/4 w-96 h-96 bg-amber-500 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative container mx-auto px-4 text-center">
      <p class="section-label-pill border-cyan-400/20 bg-cyan-400/10 text-cyan-400 mb-6">
        Customer Reviews
      </p>
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6">
        What Toronto Homeowners<br />Say About Us
      </h1>
      <p class="text-xl text-slate-300 max-w-3xl mx-auto mb-12">
        See why GTA homeowners trust Dryspace with their waterproofing and foundation needs
      </p>

      <!-- Stats Bar -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {stats.map(stat => (
          <div class="card-base bg-white/5 backdrop-blur border-white/10 text-center py-6">
            <div class="text-3xl mb-2">{stat.icon}</div>
            <div class="text-3xl font-bold text-white mb-1">{stat.value}</div>
            <div class="text-sm text-slate-400">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review Platforms -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Where to Find Us"
        title="Verified Reviews Across Platforms"
        description="Check our ratings on the platforms that matter most to homeowners"
      />

      <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {platforms.map(platform => (
          <div class="card-base reveal text-center group hover:border-cyan-500/30 transition-all">
            <div class="text-5xl mb-4">{platform.icon}</div>
            <h3 class="text-xl font-bold text-slate-900 mb-3">{platform.name}</h3>
            <div class:list={[
              "text-4xl font-bold mb-2",
              platform.color === "cyan" ? "text-cyan-500" : "text-amber-500"
            ]}>
              {platform.rating}
            </div>
            <p class="text-slate-600">{platform.count}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Review Grid -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Real Feedback"
        title="What Our Customers Say"
        description="Authentic reviews from homeowners across the Greater Toronto Area"
      />

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-7xl mx-auto">
        {reviews.map((review, idx) => (
          <div class="card-base reveal group hover:shadow-float-hover transition-all" style={`animation-delay: ${idx * 100}ms`}>
            <!-- Star Rating -->
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Review Text -->
            <p class="text-slate-700 mb-6 leading-relaxed">"{review.text}"</p>

            <!-- Reviewer Info -->
            <div class="border-t border-slate-200 pt-4 mt-auto">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-bold text-slate-900">{review.name}</p>
                  <p class="text-sm text-slate-600">{review.location}</p>
                  <p class="text-xs text-slate-500 mt-1">{review.service}</p>
                </div>
                <div class="flex flex-col items-end">
                  <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-cyan-100 text-cyan-700 border border-cyan-200">
                    ✓ Verified
                  </span>
                  <p class="text-xs text-slate-500 mt-2">{review.date}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Load More Reviews CTA -->
      <div class="text-center mt-12">
        <p class="text-slate-600 mb-6">
          Showing 12 of our reviews
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="https://g.page/dryspace-waterproofing/review" target="_blank" rel="noopener noreferrer" class="btn-secondary">
            Read All Google Reviews →
          </a>
          <a href="/free-inspection" class="btn-primary">
            Get Your Free Inspection
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Homeowners Trust Us -->
  <section class="section-padding bg-gradient-to-br from-navy-900 via-slate-900 to-navy-900 relative overflow-hidden">
    <!-- Ambient effects -->
    <div class="absolute inset-0 opacity-10">
      <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-cyan-500 rounded-full mix-blend-multiply filter blur-3xl"></div>
    </div>

    <div class="relative container mx-auto px-4">
      <SectionHeader
        label="Our Commitment"
        title="Why Homeowners Trust Dryspace"
        description="Protecting Toronto homes since 1999 with professional service and guaranteed results"
        dark
      />

      <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        {trustFeatures.map(feature => (
          <div class="card-base bg-white/5 backdrop-blur border-white/10 reveal group hover:bg-white/10 transition-all">
            <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-cyan-500 to-cyan-600 flex items-center justify-center text-white mb-6 group-hover:scale-110 transition-transform">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-xl font-bold text-white mb-4">{feature.title}</h3>
            <p class="text-slate-300 leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <CTABand
    title="Join Our Happy Homeowners"
    subtitle="Get your free inspection and see why Toronto trusts Dryspace for waterproofing and foundation repair."
  />
</PageLayout>
