---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
---

<BaseLayout 
  title="Safety & Compliance | WSIB Cleared | Dryspace Waterproofing Toronto" 
  description="WSIB cleared, fully insured waterproofing contractor in Toronto. Complete safety protocols, property protection, and Ontario Building Code 2024 compliance."
>
  <Hero
    title="Safety & Compliance Standards"
    subtitle="WSIB cleared, fully insured, and committed to protecting your property"
    backgroundImage="/images/safety-hero.webp"
    ctaText="Get Safe Service"
    ctaLink="/contact"
    secondaryCtaText="Call: 437-545-0067"
    secondaryCtaLink="tel:437-545-0067"
  />

  <!-- Safety Compliance Component -->
  <div id="safety-compliance-root"></div>

  <!-- Additional Safety Information -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center">Our Safety Commitment</h2>
        
        <div class="prose max-w-none">
          <p class="text-lg text-slate-600 mb-6">
            At Dryspace Waterproofing, safety isn't just a priority—it's embedded in everything we do. 
            From protecting your family and property to ensuring our workers go home safely every day, 
            we maintain the highest safety standards in the industry.
          </p>
          
          <h3 class="text-2xl font-semibold mb-4">Worker Safety</h3>
          <p class="text-slate-600 mb-6">
            All our workers are fully trained in safety protocols specific to waterproofing and excavation work. 
            We maintain active WSIB coverage and require ongoing safety training for all team members. 
            Our crews are equipped with proper PPE including hard hats, safety boots, fall protection, 
            and respirators for confined space work.
          </p>
          
          <h3 class="text-2xl font-semibold mb-4">Property Protection</h3>
          <p class="text-slate-600 mb-6">
            We understand your home is your most valuable asset. That's why we take extensive measures to 
            protect your property during waterproofing work. This includes laying protective coverings on 
            floors, setting up dust barriers, carefully preserving landscaping, and maintaining clean work 
            areas throughout the project.
          </p>
          
          <h3 class="text-2xl font-semibold mb-4">Environmental Responsibility</h3>
          <p class="text-slate-600 mb-6">
            Waterproofing work must be done responsibly to protect our environment. We ensure proper water 
            drainage during excavation, safe disposal of all materials, and use eco-friendly waterproofing 
            products whenever possible. All waste is disposed of according to Ontario environmental regulations.
          </p>
          
          <h3 class="text-2xl font-semibold mb-4">Insurance & Liability</h3>
          <p class="text-slate-600 mb-6">
            We carry $5 million in liability insurance to protect you and your property. Our comprehensive 
            coverage includes general liability, property damage, and completed operations coverage. We're 
            also bonded and maintain all required business licenses and certifications.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Safety Statistics -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">Safety by the Numbers</h2>
      
      <div class="grid md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="text-4xl font-bold text-cyan-600 mb-2">0</div>
          <p class="text-slate-500">Lost time injuries in 2024</p>
        </div>
        
        <div class="text-center">
          <div class="text-4xl font-bold text-cyan-600 mb-2">100%</div>
          <p class="text-slate-500">Workers safety certified</p>
        </div>
        
        <div class="text-center">
          <div class="text-4xl font-bold text-purple-600 mb-2">$5M</div>
          <p class="text-slate-500">Liability insurance coverage</p>
        </div>
        
        <div class="text-center">
          <div class="text-4xl font-bold text-orange-600 mb-2">25+</div>
          <p class="text-slate-500">Years without major incidents</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Compliance Certifications -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-8 text-center">Certifications & Compliance</h2>
        
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-slate-50 rounded-lg p-6">
            <h3 class="text-xl font-semibold mb-4">Industry Certifications</h3>
            <ul class="space-y-3">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                WSIB Clearance Certificate
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                BBB A+ Accreditation
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Licensed & Bonded Contractor
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Ontario Building Code 2024 Certified
              </li>
            </ul>
          </div>
          
          <div class="bg-slate-50 rounded-lg p-6">
            <h3 class="text-xl font-semibold mb-4">Safety Training</h3>
            <ul class="space-y-3">
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Working at Heights Certification
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Confined Space Entry Training
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                First Aid & CPR Certified
              </li>
              <li class="flex items-center gap-2">
                <svg class="w-5 h-5 text-cyan-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                WHMIS 2015 Certification
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 bg-gradient-to-r from-blue-600 to-blue-700">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">
          Experience Safe, Professional Waterproofing
        </h2>
        <p class="text-xl text-cyan-100 mb-8">
          Trust Toronto's safety-focused waterproofing experts for your home
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contact" class="inline-block bg-white text-cyan-600 px-8 py-4 rounded-lg font-bold hover:bg-slate-50 transition-colors shadow-lg">
            Schedule Safe Service
          </a>
          <a href="tel:437-545-0067" class="inline-block bg-cyan-800 text-white px-8 py-4 rounded-lg font-bold hover:bg-navy-900 transition-colors shadow-lg">
            <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path>
            </svg>
            Call: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { createRoot } from 'react-dom/client';
    import React from 'react';
    import SafetyCompliance from '../components/react/SafetyCompliance.tsx';
    
    const container = document.getElementById('safety-compliance-root');
    const root = createRoot(container);
    root.render(React.createElement(SafetyCompliance));
  </script>
</BaseLayout>