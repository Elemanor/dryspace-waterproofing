---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import ContactForm from '../components/ContactForm.astro';

const pageTitle = "Seasonal Waterproofing Maintenance Guide | Toronto Climate | Year-Round Protection";
const pageDescription = "Complete seasonal maintenance guide for waterproofing systems in Toronto. Spring flooding prep, summer drainage checks, fall protection, winter freeze prevention. Expert tips and schedules.";

// Seasonal maintenance by system type
const seasonalMaintenance = {
  spring: {
    season: "SPRING",
    icon: "🌱",
    subtitle: "Post-Winter Recovery & Flood Preparation",
    description: "Spring is critical for waterproofing in Toronto. Snow melt and spring rains test all systems after winter freeze damage.",
    tasks: [
      {
        system: "EXTERIOR WATERPROOFING",
        priority: "HIGH",
        tasks: [
          "Inspect foundation walls for winter freeze damage",
          "Check for membrane lifting or separation",
          "Clear debris from drainage areas around foundation", 
          "Verify proper grading directs water away from home",
          "Inspect and clear window wells of debris",
          "Test all drainage outlets for blockages"
        ],
        timeline: "Early March - April",
        frequency: "Annual",
        diyLevel: "Homeowner can inspect, professional repairs needed"
      },
      {
        system: "SUMP PUMP SYSTEMS",
        priority: "CRITICAL",
        tasks: [
          "Test sump pump operation with water",
          "Check and clean sump basin of debris",
          "Verify float switch operates smoothly",
          "Test battery backup system (if installed)",
          "Inspect discharge line for freeze damage",
          "Clear ice from discharge point"
        ],
        timeline: "Before first major rain (March)",
        frequency: "Annual + before major storms",
        diyLevel: "Homeowner can perform basic tests"
      },
      {
        system: "FRENCH DRAIN SYSTEMS", 
        priority: "HIGH",
        tasks: [
          "Flush drain lines with water to check flow",
          "Clear outlet points of debris and vegetation",
          "Check for settling that affects drainage slope",
          "Inspect catch basins and clean if accessible",
          "Verify surface drains are clear of winter debris",
          "Test overall system during first heavy rain"
        ],
        timeline: "March - Early April",
        frequency: "Annual",
        diyLevel: "Homeowner inspection, professional cleaning"
      },
      {
        system: "BACKWATER VALVES",
        priority: "HIGH", 
        tasks: [
          "Remove valve cover and inspect for damage",
          "Clean debris from valve chamber",
          "Test gate operation - should open and close freely",
          "Check rubber seals for wear or damage",
          "Verify manual override function works",
          "Document condition with photos"
        ],
        timeline: "Before storm season (April)",
        frequency: "Annual minimum, bi-annual recommended",
        diyLevel: "Homeowner maintenance required"
      }
    ]
  },
  summer: {
    season: "SUMMER", 
    icon: "☀️",
    subtitle: "Storm Preparation & System Optimization",
    description: "Summer storms bring intense rainfall to Toronto. Ensuring all drainage systems operate at peak efficiency is critical.",
    tasks: [
      {
        system: "DRAINAGE SYSTEMS",
        priority: "HIGH",
        tasks: [
          "Clean eavestroughs and downspouts monthly",
          "Extend downspouts minimum 6 feet from foundation",
          "Check that soil grades away from house (6\" drop in 6 feet)",
          "Trim vegetation away from foundation (3 feet minimum)",
          "Inspect and repair any cracks in foundation walls",
          "Monitor basement for any moisture signs"
        ],
        timeline: "June - August",
        frequency: "Monthly during storm season",
        diyLevel: "Most tasks homeowner friendly"
      },
      {
        system: "SUMP PUMP SYSTEMS",
        priority: "CRITICAL",
        tasks: [
          "Test system before each major storm warning",
          "Keep spare pump parts (check valve, switch)",
          "Ensure backup power source is functional", 
          "Clear discharge area of landscaping obstacles",
          "Monitor pump cycles during heavy rains",
          "Keep emergency contact info for repair service"
        ],
        timeline: "Before each storm season",
        frequency: "Before major storms",
        diyLevel: "Basic monitoring, professional repairs"
      },
      {
        system: "WATERPROOFING MEMBRANES",
        priority: "MEDIUM",
        tasks: [
          "Inspect exposed membranes for UV damage",
          "Check protective boards for shifting or damage",
          "Monitor for any pooling water against foundation",
          "Verify landscaping doesn't redirect water to foundation",
          "Check basement walls for any new moisture signs",
          "Document any changes with photos"
        ],
        timeline: "Mid-summer inspection",
        frequency: "Annual visual inspection",
        diyLevel: "Homeowner inspection only"
      }
    ]
  },
  fall: {
    season: "FALL",
    icon: "🍂", 
    subtitle: "Winter Preparation & System Securing",
    description: "Fall preparation prevents winter freeze damage and ensures systems survive Toronto's harsh winter conditions.",
    tasks: [
      {
        system: "ALL DRAINAGE SYSTEMS",
        priority: "CRITICAL",
        tasks: [
          "Final eavestrough and downspout cleaning",
          "Disconnect and store garden hoses",
          "Shut off and drain exterior water lines", 
          "Clear all drains of leaves and debris",
          "Extend discharge lines away from house",
          "Seal any small foundation cracks before freezing"
        ],
        timeline: "October - November",
        frequency: "Annual",
        diyLevel: "Homeowner tasks with professional crack sealing"
      },
      {
        system: "SUMP PUMP WINTERIZATION",
        priority: "HIGH",
        tasks: [
          "Remove and store discharge hose if removable",
          "Install discharge line winter protection",
          "Test battery backup before winter",
          "Check sump cover fits tightly",
          "Verify pump is properly positioned in basin",
          "Schedule professional inspection if system is >5 years old"
        ],
        timeline: "Before first freeze (November)",
        frequency: "Annual",
        diyLevel: "Homeowner with professional backup"
      },
      {
        system: "FOUNDATION PROTECTION",
        priority: "HIGH",
        tasks: [
          "Apply foundation crack sealant where needed",
          "Clear vegetation from foundation walls",
          "Ensure soil is properly graded for spring runoff",
          "Cover window wells with protective covers",
          "Inspect foundation drainage outlets",
          "Document baseline condition before winter"
        ],
        timeline: "Late October - Early November", 
        frequency: "Annual",
        diyLevel: "Inspection homeowner, repairs professional"
      }
    ]
  },
  winter: {
    season: "WINTER",
    icon: "❄️",
    subtitle: "Freeze Protection & Emergency Preparedness", 
    description: "Winter maintenance focuses on preventing freeze damage and preparing for spring melt emergencies.",
    tasks: [
      {
        system: "FREEZE PREVENTION",
        priority: "CRITICAL",
        tasks: [
          "Keep basement temperature above 10°C (50°F)",
          "Monitor sump pump discharge for ice buildup",
          "Clear ice dams from eavestroughs promptly",
          "Remove snow buildup against foundation walls",
          "Check that heating is working in areas near plumbing",
          "Keep emergency pump and supplies accessible"
        ],
        timeline: "December - February",
        frequency: "Weekly monitoring during cold snaps",
        diyLevel: "Homeowner monitoring and basic maintenance"
      },
      {
        system: "ICE DAM PREVENTION",
        priority: "HIGH", 
        tasks: [
          "Maintain consistent attic temperature",
          "Remove snow from roof edges when possible",
          "Keep eavestroughs clear of ice",
          "Check for icicles forming over foundation areas",
          "Monitor interior walls for frost or ice",
          "Ensure adequate insulation in problem areas"
        ],
        timeline: "Throughout winter",
        frequency: "After each snowfall >10cm",
        diyLevel: "Homeowner where safely accessible"
      },
      {
        system: "SPRING MELT PREPARATION",
        priority: "HIGH",
        tasks: [
          "Test sump pump monthly during winter",
          "Keep backup power source ready",
          "Monitor weather forecasts for rapid melt conditions",
          "Ensure basement access is clear for emergency service",
          "Keep emergency contact numbers accessible",
          "Prepare for early spring system testing"
        ],
        timeline: "January - March",
        frequency: "Monthly testing",
        diyLevel: "Homeowner preparation"
      }
    ]
  }
};

// Monthly maintenance calendar
const monthlyCalendar = [
  {
    month: "JANUARY",
    priority: "Monitor & Maintain",
    keyTasks: ["Test sump pump monthly", "Clear ice from discharge areas", "Monitor basement temperature"],
    weather: "Coldest month - freeze protection critical"
  },
  {
    month: "FEBRUARY", 
    priority: "Prepare for Melt",
    keyTasks: ["Continue freeze protection", "Plan spring maintenance", "Check backup systems"],
    weather: "Late winter storms possible - maintain readiness"
  },
  {
    month: "MARCH",
    priority: "Critical Preparation",
    keyTasks: ["Spring melt preparation", "Test all systems", "Clear winter debris"],
    weather: "Spring melt begins - highest flood risk period"
  },
  {
    month: "APRIL",
    priority: "Full System Check",
    keyTasks: ["Complete spring inspection", "Professional service calls", "Address winter damage"],
    weather: "Spring rains + melt - maximum water flow"
  },
  {
    month: "MAY",
    priority: "Storm Preparation", 
    keyTasks: ["Final spring setup", "Landscaping adjustments", "System optimization"],
    weather: "Spring storms increase - verify all systems"
  },
  {
    month: "JUNE",
    priority: "Summer Preparation",
    keyTasks: ["Storm season prep", "Clean eavestroughs", "Extend downspouts"],
    weather: "Storm season begins - prepare for heavy rain"
  },
  {
    month: "JULY",
    priority: "Active Monitoring",
    keyTasks: ["Monitor during storms", "Maintain vegetation", "Check drainage"],
    weather: "Peak storm season - active system monitoring"
  },
  {
    month: "AUGUST",
    priority: "Continued Vigilance",
    keyTasks: ["Mid-summer inspection", "Storm preparation", "System testing"],
    weather: "Continued storm risk - maintain readiness"
  },
  {
    month: "SEPTEMBER",
    priority: "Fall Preparation",
    keyTasks: ["Begin fall prep", "Clear early leaves", "Plan winter prep"],
    weather: "Transition season - prepare for fall rains"
  },
  {
    month: "OCTOBER",
    priority: "Winter Preparation",
    keyTasks: ["Winterize systems", "Final cleaning", "Professional inspections"],
    weather: "Last chance for outdoor work before freeze"
  },
  {
    month: "NOVEMBER",
    priority: "Final Winterization",
    keyTasks: ["Complete winterization", "Final drainage clearing", "Secure systems"],
    weather: "First freeze likely - final preparations"
  },
  {
    month: "DECEMBER", 
    priority: "Winter Monitoring",
    keyTasks: ["Begin winter monitoring", "Freeze prevention", "Emergency preparedness"],
    weather: "Winter begins - switch to monitoring mode"
  }
];

// Emergency preparedness checklist
const emergencyPrep = [
  {
    emergency: "SPRING FLOODING",
    likelihood: "High in Toronto",
    preparation: [
      "Keep portable sump pump as backup",
      "Stock sandbags or flood barriers", 
      "Know location of main water shutoff",
      "Have emergency power source ready",
      "Keep important documents elevated",
      "Maintain emergency contact list"
    ],
    response: [
      "Contact emergency service immediately",
      "Document damage with photos",
      "Remove standing water quickly",
      "Call insurance company within 24 hours",
      "Begin dehumidification immediately",
      "Avoid electrical hazards in flooded areas"
    ]
  },
  {
    emergency: "SUMP PUMP FAILURE",
    likelihood: "Moderate during storms",
    preparation: [
      "Test pump monthly year-round",
      "Keep backup pump available",
      "Maintain battery backup system",
      "Know pump specifications for replacement",
      "Keep emergency service contact ready",
      "Understand manual water removal methods"
    ],
    response: [
      "Check power supply and circuit breaker",
      "Clear debris from pump intake",
      "Test float switch operation",
      "Use backup pump if available",
      "Begin manual water removal if needed",
      "Call professional service immediately"
    ]
  },
  {
    emergency: "FROZEN DISCHARGE LINES",
    likelihood: "High in Toronto winters",
    preparation: [
      "Insulate discharge lines where possible",
      "Install freeze-resistant discharge points",
      "Keep ice removal tools ready",
      "Monitor discharge areas weekly in winter",
      "Know signs of discharge backup",
      "Plan alternative discharge routes"
    ],
    response: [
      "Safely remove ice from discharge point",
      "Use warm water to thaw blockages",
      "Check for backup into basement",
      "Clear alternative drainage paths",
      "Monitor pump operation closely",
      "Call for service if backup occurs"
    ]
  }
];

// Professional service schedule
const professionalServices = [
  {
    service: "ANNUAL SYSTEM INSPECTION",
    frequency: "Yearly",
    timing: "Spring (April-May)",
    includes: ["Complete system evaluation", "Performance testing", "Minor adjustments", "Maintenance recommendations"],
    cost: "$200-400",
    necessity: "Recommended for warranty compliance"
  },
  {
    service: "SUMP PUMP SERVICE",
    frequency: "Every 2-3 years",
    timing: "Spring before storm season",
    includes: ["Pump inspection and cleaning", "Float switch testing", "Discharge line check", "Battery backup service"],
    cost: "$150-300", 
    necessity: "Essential for reliability"
  },
  {
    service: "DRAINAGE SYSTEM CLEANING",
    frequency: "Every 3-5 years",
    timing: "As needed based on performance",
    includes: ["French drain flushing", "Catch basin cleaning", "Line inspection", "Flow testing"],
    cost: "$300-600",
    necessity: "Required when flow decreases"
  },
  {
    service: "WATERPROOFING INSPECTION",
    frequency: "Every 5 years",
    timing: "Any season, dry conditions",
    includes: ["Membrane condition assessment", "Joint and seal inspection", "Crack evaluation", "System integrity check"],
    cost: "$300-500",
    necessity: "Recommended for early problem detection"
  }
];

// Schema markup for maintenance guides
const maintenanceSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Seasonal Waterproofing Maintenance Guide",
  "description": pageDescription,
  "totalTime": "P1Y",
  "supply": ["Basic tools", "Cleaning supplies", "Safety equipment"],
  "tool": ["Flashlight", "Garden hose", "Ladder"],
  "step": Object.values(seasonalMaintenance).map(season => ({
    "@type": "HowToStep",
    "name": `${season.season} Maintenance`,
    "text": season.description
  }))
};
---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>
  <!-- Hero Section -->
  <Hero 
    title="SEASONAL WATERPROOFING MAINTENANCE"
    subtitle="Complete year-round maintenance guide for Toronto's extreme climate. Prevent costly failures with proper seasonal care. Spring flood prep, summer storm readiness, fall winterization, winter monitoring."
    primaryCTA={{ text: "Download Maintenance Schedule", href: "/tools/maintenance-schedule" }}
    secondaryCTA={{ text: "Schedule Service: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/seasonal-maintenance-hero.webp"
    badge="YEAR-ROUND PROTECTION"
  />

  <!-- Stats Section -->
  <Stats />

  <!-- Maintenance Overview -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">
            WHY SEASONAL MAINTENANCE MATTERS
          </h2>
          <p class="text-lg text-slate-600 max-w-3xl mx-auto">
            Toronto's extreme climate - from -30°C winters to intense summer storms - demands year-round attention to waterproofing systems. 
            Proper seasonal maintenance prevents 90% of waterproofing failures.
          </p>
        </div>

        <div class="grid md:grid-cols-4 gap-6 mb-12">
          <div class="bg-cyan-50 p-6 text-center border-4 border-cyan-500">
            <div class="text-4xl font-bold text-cyan-600 mb-2">90%</div>
            <h3 class="text-lg font-bold mb-1 uppercase">Failures Prevented</h3>
            <p class="text-sm text-slate-600">With proper maintenance</p>
          </div>
          
          <div class="bg-red-50 p-6 text-center border-4 border-red-500">
            <div class="text-4xl font-bold text-red-600 mb-2">120+</div>
            <h3 class="text-lg font-bold mb-1 uppercase">Freeze-Thaw Cycles</h3>
            <p class="text-sm text-slate-600">Annual system stress</p>
          </div>
          
          <div class="bg-cyan-50 p-6 text-center border-4 border-cyan-500">
            <div class="text-4xl font-bold text-cyan-600 mb-2">$500</div>
            <h3 class="text-lg font-bold mb-1 uppercase">Average Prevention Cost</h3>
            <p class="text-sm text-slate-600">vs $15,000 flood damage</p>
          </div>

          <div class="bg-amber-50 p-6 text-center border-4 border-cyan-500">
            <div class="text-4xl font-bold text-amber-500 mb-2">25+</div>
            <h3 class="text-lg font-bold mb-1 uppercase">Years System Life</h3>
            <p class="text-sm text-slate-600">With proper care</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Seasonal Maintenance Sections -->
  {Object.values(seasonalMaintenance).map((season, index) => (
    <section class={`py-16 ${index % 2 === 0 ? 'bg-slate-50' : 'bg-white'}`}>
      <div class="container mx-auto px-4">
        <div class="max-w-7xl mx-auto">
          <!-- Season Header -->
          <div class="text-center mb-12">
            <div class="text-8xl mb-4">{season.icon}</div>
            <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4 uppercase">
              {season.season} MAINTENANCE
            </h2>
            <h3 class="text-xl font-semibold text-slate-600 mb-4">{season.subtitle}</h3>
            <p class="text-lg text-slate-600 max-w-3xl mx-auto">{season.description}</p>
            <div class="w-24 h-1 bg-amber-500 mx-auto mt-6"></div>
          </div>

          <!-- Season Tasks -->
          <div class="space-y-8">
            {season.tasks.map(task => (
              <div class={`bg-white border-4 ${
                task.priority === 'CRITICAL' ? 'border-red-500' :
                task.priority === 'HIGH' ? 'border-cyan-500' : 
                'border-slate-200'
              } hover:border-slate-700 transition-colors`}>
                <div class="p-8">
                  <div class="grid lg:grid-cols-4 gap-6">
                    <!-- System Info -->
                    <div>
                      <div class={`inline-block px-3 py-1 text-xs font-bold uppercase mb-2 ${
                        task.priority === 'CRITICAL' ? 'bg-red-100 text-red-800' :
                        task.priority === 'HIGH' ? 'bg-amber-50 text-amber-700' :
                        'bg-slate-50 text-slate-800'
                      }`}>
                        {task.priority} PRIORITY
                      </div>
                      <h3 class="text-2xl font-bold text-slate-900 uppercase mb-4">
                        {task.system}
                      </h3>
                      <div class="space-y-2 text-sm">
                        <div>
                          <span class="font-semibold text-slate-500">Timeline:</span>
                          <p class="text-slate-900">{task.timeline}</p>
                        </div>
                        <div>
                          <span class="font-semibold text-slate-500">Frequency:</span>
                          <p class="text-slate-900">{task.frequency}</p>
                        </div>
                        <div>
                          <span class="font-semibold text-slate-500">DIY Level:</span>
                          <p class="text-slate-900">{task.diyLevel}</p>
                        </div>
                      </div>
                    </div>
                    
                    <!-- Task Checklist -->
                    <div class="lg:col-span-3">
                      <h4 class="text-lg font-bold text-slate-900 mb-4 uppercase">Maintenance Tasks:</h4>
                      <div class="grid md:grid-cols-2 gap-4">
                        {task.tasks.map(taskItem => (
                          <div class="flex items-start">
                            <input type="checkbox" class="mt-1 mr-3 flex-shrink-0" />
                            <span class="text-slate-600">{taskItem}</span>
                          </div>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  ))}

  <!-- Monthly Calendar -->
  <section class="py-16 bg-navy-900 text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold mb-4 uppercase">
            MONTHLY MAINTENANCE CALENDAR
          </h2>
          <p class="text-lg text-slate-300">
            Quick reference guide for year-round waterproofing maintenance in Toronto
          </p>
        </div>

        <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-6">
          {monthlyCalendar.map(month => (
            <div class="bg-navy-900 p-6 border-l-4 border-cyan-500">
              <h3 class="text-xl font-bold text-cyan-400 mb-2 uppercase">
                {month.month}
              </h3>
              <div class="text-sm font-semibold text-slate-300 mb-3">
                Priority: {month.priority}
              </div>
              
              <div class="mb-4">
                <h4 class="font-bold text-white mb-2">Key Tasks:</h4>
                <ul class="space-y-1">
                  {month.keyTasks.map(task => (
                    <li class="text-slate-300 text-sm">• {task}</li>
                  ))}
                </ul>
              </div>
              
              <div class="text-xs text-slate-400 italic">
                {month.weather}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency Preparedness -->
  <section class="py-16 bg-red-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">
            EMERGENCY PREPAREDNESS
          </h2>
          <p class="text-lg text-slate-600">
            Common waterproofing emergencies in Toronto and how to prepare for them
          </p>
        </div>

        <div class="space-y-8">
          {emergencyPrep.map(emergency => (
            <div class="bg-white border-4 border-red-500 p-8">
              <div class="grid lg:grid-cols-3 gap-8">
                <!-- Emergency Info -->
                <div>
                  <h3 class="text-2xl font-bold text-red-600 uppercase mb-2">
                    {emergency.emergency}
                  </h3>
                  <div class="text-lg font-semibold text-slate-600 mb-4">
                    Risk Level: {emergency.likelihood}
                  </div>
                </div>
                
                <!-- Preparation -->
                <div>
                  <h4 class="text-lg font-bold text-slate-900 mb-3 uppercase">Preparation:</h4>
                  <ul class="space-y-2">
                    {emergency.preparation.map(prep => (
                      <li class="text-sm text-slate-600 flex items-start">
                        <span class="text-cyan-400 mr-2 mt-1 flex-shrink-0">•</span>
                        <span>{prep}</span>
                      </li>
                    ))}
                  </ul>
                </div>
                
                <!-- Response -->
                <div>
                  <h4 class="text-lg font-bold text-slate-900 mb-3 uppercase">Emergency Response:</h4>
                  <ul class="space-y-2">
                    {emergency.response.map(response => (
                      <li class="text-sm text-slate-600 flex items-start">
                        <span class="text-red-500 mr-2 mt-1 flex-shrink-0">!</span>
                        <span>{response}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 bg-red-600 text-white p-8 text-center">
          <h3 class="text-2xl font-bold mb-4 uppercase">
            24/7 EMERGENCY SERVICE
          </h3>
          <p class="text-lg mb-4">
            Flooding emergency? Don't wait. We respond within 2 hours, 24 hours a day.
          </p>
          <a href="tel:437-545-0067" class="bg-white text-red-600 px-8 py-4 font-bold uppercase hover:bg-slate-50 transition-colors">
            EMERGENCY: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Professional Service Schedule -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-4xl font-bold text-slate-900 mb-4 uppercase">
            PROFESSIONAL SERVICE SCHEDULE
          </h2>
          <p class="text-lg text-slate-600">
            Some maintenance requires professional service to maintain warranties and ensure safety
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {professionalServices.map(service => (
            <div class="bg-slate-50 border-l-4 border-cyan-500 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-2 uppercase">
                {service.service}
              </h3>
              
              <div class="grid grid-cols-2 gap-4 mb-4 text-sm">
                <div>
                  <span class="font-semibold text-slate-500">Frequency:</span>
                  <p class="text-slate-900">{service.frequency}</p>
                </div>
                <div>
                  <span class="font-semibold text-slate-500">Best Timing:</span>
                  <p class="text-slate-900">{service.timing}</p>
                </div>
                <div>
