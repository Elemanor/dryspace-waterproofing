<script>
  // Check Coverage Search Functionality
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.querySelector('.search-input');
    const searchButton = document.querySelector('.search-button');
    
    // Service area data for coverage check
    const serviceAreas = [
      // Central Toronto
      { name: "Toronto Downtown", postalCodes: ["M4", "M5", "M6"], responseTime: "20-30 min" },
      { name: "North York", postalCodes: ["M2", "M3", "M4N", "M5M", "M6A", "M9L", "M9M"], responseTime: "25-35 min" },
      { name: "Scarborough", postalCodes: ["M1"], responseTime: "30-40 min" },
      { name: "Etobicoke", postalCodes: ["M8", "M9"], responseTime: "30-40 min" },
      { name: "East York", postalCodes: ["M4B", "M4C", "M4E", "M4G", "M4H", "M4J", "M4K", "M4L", "M4M"], responseTime: "20-30 min" },
      { name: "York", postalCodes: ["M6C", "M6E", "M6M", "M6N", "M9N"], responseTime: "25-35 min" },
      
      // GTA West
      { name: "Mississauga", postalCodes: ["L4", "L5"], responseTime: "35-45 min" },
      { name: "Brampton", postalCodes: ["L6", "L7"], responseTime: "40-50 min" },
      { name: "Oakville", postalCodes: ["L6H", "L6J", "L6K", "L6L", "L6M"], responseTime: "45-60 min" },
      { name: "Burlington", postalCodes: ["L7L", "L7M", "L7N", "L7P", "L7R", "L7S", "L7T"], responseTime: "50-60 min" },
      { name: "Milton", postalCodes: ["L9T", "L9E"], responseTime: "45-55 min" },
      { name: "Georgetown", postalCodes: ["L7G"], responseTime: "50-60 min" },
      
      // GTA East
      { name: "Markham", postalCodes: ["L3P", "L3R", "L3S", "L6B", "L6C", "L6E", "L6G"], responseTime: "35-45 min" },
      { name: "Vaughan", postalCodes: ["L4H", "L4J", "L4K", "L4L", "L6A"], responseTime: "30-40 min" },
      { name: "Richmond Hill", postalCodes: ["L4B", "L4C", "L4E", "L4S"], responseTime: "35-45 min" },
      { name: "Pickering", postalCodes: ["L1V", "L1W", "L1X", "L1Y"], responseTime: "40-50 min" },
      { name: "Ajax", postalCodes: ["L1S", "L1T", "L1Z"], responseTime: "45-55 min" },
      { name: "Whitby", postalCodes: ["L1M", "L1N", "L1P", "L1R"], responseTime: "50-60 min" },
      { name: "Oshawa", postalCodes: ["L1G", "L1H", "L1J", "L1K", "L1L"], responseTime: "55-65 min" },
      
      // GTA North
      { name: "Aurora", postalCodes: ["L4G"], responseTime: "40-50 min" },
      { name: "Newmarket", postalCodes: ["L3X", "L3Y"], responseTime: "45-55 min" },
      { name: "King City", postalCodes: ["L7B"], responseTime: "45-55 min" },
      { name: "Stouffville", postalCodes: ["L4A"], responseTime: "45-55 min" }
    ];
    
    function checkCoverage() {
      const searchTerm = searchInput.value.trim().toUpperCase();
      
      if (!searchTerm) {
        showResult('Please enter a postal code or neighborhood name', 'error');
        return;
      }
      
      let foundArea = null;
      
      // Check if it's a postal code (starts with letter, has numbers)
      if (/^[A-Z]\d/.test(searchTerm)) {
        // Extract first 2-3 characters of postal code
        const postalPrefix = searchTerm.substring(0, 3).replace(/\s/g, '');
        
        // Search for matching postal code
        foundArea = serviceAreas.find(area => 
          area.postalCodes.some(code => postalPrefix.startsWith(code))
        );
      } else {
        // Search by neighborhood name
        foundArea = serviceAreas.find(area => 
          area.name.toLowerCase().includes(searchTerm.toLowerCase())
        );
      }
      
      if (foundArea) {
        showResult(
          ` Great news! We service ${foundArea.name}. Average response time: ${foundArea.responseTime}`,
          'success',
          foundArea
        );
      } else {
        showResult(
          `We may still service your area! Please call us at 437-545-0067 to confirm coverage.`,
          'info'
        );
      }
    }
    
    function showResult(message, type, area = null) {
      // Remove existing result if any
      const existingResult = document.querySelector('.coverage-result');
      if (existingResult) {
        existingResult.remove();
      }
      
      // Create result element
      const resultDiv = document.createElement('div');
      resultDiv.className = `coverage-result ${type}`;
      resultDiv.style.cssText = `
        margin-top: 1rem;
        padding: 1rem;
        border-radius: 0.5rem;
        animation: slideIn 0.3s ease;
      `;
      
      if (type === 'success') {
        resultDiv.style.background = '#10b981';
        resultDiv.style.color = 'white';
      } else if (type === 'error') {
        resultDiv.style.background = '#ef4444';
        resultDiv.style.color = 'white';
      } else {
        resultDiv.style.background = '#3b82f6';
        resultDiv.style.color = 'white';
      }
      
      resultDiv.innerHTML = `
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <p style="margin: 0; font-weight: 500;">${message}</p>
          ${area ? `
            <a href="/contact?area=${encodeURIComponent(area.name)}" 
               style="background: white; color: #3b82f6; padding: 0.5rem 1rem; border-radius: 0.25rem; text-decoration: none; font-weight: bold;">
              Get Quote →
            </a>
          ` : ''}
        </div>
      `;
      
      // Insert after search container
      const heroSearch = document.querySelector('.hero-search');
      heroSearch.parentNode.insertBefore(resultDiv, heroSearch.nextSibling);
      
      // Auto scroll to result
      resultDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
    
    // Event listeners
    searchButton.addEventListener('click', checkCoverage);
    searchInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        checkCoverage();
      }
    });
    
    // Add animation styles
    if (!document.querySelector('#coverage-animations')) {
      const style = document.createElement('style');
      style.id = 'coverage-animations';
      style.textContent = `
        @keyframes slideIn {
          from {
            opacity: 0;
            transform: translateY(-10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }
      `;
      document.head.appendChild(style);
    }
  });
</script>