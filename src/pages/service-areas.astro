                <th class="border-2 border-slate-200 px-4 py-3 text-center uppercase">EMERGENCY SERVICE</th>
              </tr>
            </thead>
            <tbody>
              <tr class="bg-white">
                <td class="border-2 border-slate-200 px-4 py-3 font-semibold uppercase">RESPONSE TIME</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"><span class="font-bold text-amber-500">30-45 MIN</span></td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center">45-90 MIN</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"><span class="font-bold text-amber-500">&lt; 60 MIN</span></td>
              </tr>
              <tr class="bg-slate-50">
                <td class="border-2 border-slate-200 px-4 py-3 font-semibold uppercase">SERVICE HOURS</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">24/7</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">24/7</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">24/7</td>
              </tr>
              <tr class="bg-white">
                <td class="border-2 border-slate-200 px-4 py-3 font-semibold uppercase">FREE INSPECTION</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> SAME DAY</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> NEXT DAY</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> IMMEDIATE</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="border-2 border-slate-200 px-4 py-3 font-semibold uppercase">WARRANTY</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">25 YEARS</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">25 YEARS</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center font-bold">25 YEARS</td>
              </tr>
              <tr class="bg-white">
                <td class="border-2 border-slate-200 px-4 py-3 font-semibold uppercase">PRICE MATCH</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> GUARANTEED</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> GUARANTEED</td>
                <td class="border-2 border-slate-200 px-4 py-3 text-center"> GUARANTEED</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- All Service Locations Section -->
