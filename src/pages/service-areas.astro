                    <span class="text-xs font-bold text-slate-900">{area.postalCodes}</span>
                  </div>
                </div>
                <a href={`/contact?area=${area.name}`} class="block w-full py-2 bg-navy-900 text-white text-center font-bold uppercase hover:bg-navy-900 transition-colors text-sm">
                  GET {area.name.toUpperCase()} QUOTE →
                </a>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Local Expertise Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center uppercase">LOCAL TORONTO EXPERTISE THAT MAKES A DIFFERENCE</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white border-2 border-slate-200 p-6">
            <h3 class="text-lg font-bold text-slate-900 mb-3 uppercase">LAKE ONTARIO WATER TABLES</h3>
