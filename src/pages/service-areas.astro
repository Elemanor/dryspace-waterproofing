---

<PageLayout title="Service Areas Toronto GTA | Basement Waterproofing Coverage Map | Dryspace" description="Professional waterproofing services across the Greater Toronto Area. 24/7 emergency response, 25-year warranty.">
  <!-- Hero Section -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <div class="text-center">
        <h1 class="text-5xl font-bold text-white mb-4 uppercase">
          WATERPROOFING SERVICES ACROSS GREATER TORONTO
        </h1>
        <p class="text-xl text-slate-300 mb-8">24/7 EMERGENCY RESPONSE • 30-MINUTE AVERAGE RESPONSE TIME</p>
        
        <div class="max-w-2xl mx-auto mb-8">
          <div class="flex gap-4">
            <input type="text" placeholder="ENTER YOUR POSTAL CODE..." class="flex-1 px-6 py-4 border-2 border-slate-200 bg-white text-slate-900 uppercase placeholder-gray-500" />
            <button class="px-8 py-4 bg-amber-500 text-black font-bold uppercase hover:bg-amber-400 transition-colors">CHECK COVERAGE</button>
          </div>
        </div>
        
        <div class="flex justify-center gap-8 flex-wrap">
          <div class="text-cyan-400">
            <span class="font-bold">30+</span> SERVICE AREAS
          </div>
          <div class="text-cyan-400">
            <span class="font-bold">20</span> SERVICE VEHICLES
          </div>
          <div class="text-cyan-400">
            <span class="font-bold">SAME-DAY</span> SERVICE
          </div>
          <div class="text-cyan-400">
            <span class="font-bold">15,000+</span> PROJECTS
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas Grid -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-8 uppercase text-center">SERVICE AREA COVERAGE</h2>
        
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          {allServiceAreas.map(region => (
            <div class="bg-white border-2 border-slate-200 p-6">
              <h3 class="text-xl font-bold text-slate-900 mb-4 uppercase border-b-2 border-slate-200 pb-2">{region.region}</h3>
              <div class="space-y-2">
                {region.areas.map(area => (
                  <div class="flex justify-between items-center py-2 border-b border-slate-100">
                    <div>
                      <span class="font-semibold text-slate-900 uppercase">{area.name}</span>
                      {area.highlight && <span class="ml-2 px-2 py-1 bg-amber-500 text-black text-xs font-bold uppercase">PREMIUM</span>}
                    </div>
                    <div class="text-right">
                      <span class="text-sm text-slate-500 uppercase">{area.responseTime}</span>
                      <span class="text-sm text-slate-400 ml-2">({area.postalCodes})</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Emergency Response Stats -->
  <section class="py-16 bg-navy-900">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-slate-900 mb-12 text-center uppercase">FASTEST EMERGENCY RESPONSE IN THE GTA</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-8">
        <div class="bg-navy-900 border-2 border-slate-600 p-6 text-center">
          <div class="text-3xl font-bold text-cyan-400 mb-2">{emergencyStats.avgResponseTime}</div>
          <div class="text-sm text-slate-400 uppercase">Average Response</div>
        </div>
        <div class="bg-navy-900 border-2 border-slate-600 p-6 text-center">
          <div class="text-3xl font-bold text-cyan-400 mb-2">{emergencyStats.fastestResponse}</div>
          <div class="text-sm text-slate-400 uppercase">Fastest Response</div>
        </div>
        <div class="bg-navy-900 border-2 border-slate-600 p-6 text-center">
          <div class="text-3xl font-bold text-cyan-400 mb-2">{emergencyStats.technicianCount}+</div>
          <div class="text-sm text-slate-400 uppercase">Certified Technicians</div>
        </div>
        <div class="bg-navy-900 border-2 border-slate-600 p-6 text-center">
          <div class="text-3xl font-bold text-cyan-400 mb-2">{emergencyStats.vehicleCount}</div>
          <div class="text-sm text-slate-400 uppercase">Service Vehicles</div>
        </div>
      </div>
      <div class="text-center">
        <p class="text-xl text-slate-300 mb-6">BASEMENT FLOODING? WATER EMERGENCY? WE'RE ON OUR WAY!</p>
        <a href="tel:437-545-0067" class="inline-flex items-center px-8 py-4 bg-amber-500 text-black font-bold uppercase hover:bg-amber-400 transition-colors">
          <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.73 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z" fill="currentColor"/>
          </svg>
          CALL EMERGENCY LINE: 437-545-0067
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Service Areas -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <h2 class="text-3xl font-bold text-slate-900 mb-4 text-center uppercase">PRIMARY SERVICE AREAS</h2>
        <p class="text-lg text-slate-600 mb-12 text-center">CLICK ANY AREA FOR DETAILED LOCAL INFORMATION</p>
        
        <div class="grid md:grid-cols-2 gap-8">
          {featuredAreas.map((area) => (
            <div class="bg-white border-2 border-slate-200 p-6" id={area.slug}>
              <div class="border-b-2 border-slate-200 pb-4 mb-4">
                <h3 class="text-2xl font-bold text-slate-900 uppercase">{area.name}</h3>
                <div class="grid grid-cols-3 gap-4 mt-4">
                  <div>
                    <span class="text-sm text-slate-500 uppercase block">POPULATION</span>
                    <span class="text-lg font-bold text-slate-900">{area.population}</span>
                  </div>
                  <div>
                    <span class="text-sm text-slate-500 uppercase block">RESPONSE</span>
                    <span class="text-lg font-bold text-slate-900">{area.responseTime}</span>
                  </div>
                  <div>
                    <span class="text-sm text-slate-500 uppercase block">PROJECTS</span>
                    <span class="text-lg font-bold text-slate-900">{area.projects}</span>
                  </div>
                </div>
              </div>
              
              <p class="text-slate-600 mb-4">{area.description}</p>
              
              <div class="mb-4">
                <h4 class="font-bold text-slate-900 mb-2 uppercase">NEIGHBORHOODS WE SERVE:</h4>
                <div class="flex flex-wrap gap-2">
                  {area.neighborhoods.map(n => (
                    <span class="px-3 py-1 bg-slate-50 border border-slate-200 text-sm text-slate-600 uppercase">{n}</span>
                  ))}
                </div>
              </div>
              
              <div class="mb-6">
                <h4 class="font-bold text-slate-900 mb-2 uppercase">COMMON ISSUES IN {area.name.toUpperCase()}:</h4>
                <ul class="space-y-1">
                  {area.commonIssues.map(issue => (
                    <li class="text-sm text-slate-600 flex items-start">
                      <span class="mr-2 text-cyan-400">•</span>
                      <span>{issue}</span>
                    </li>
                  ))}
                </ul>
              </div>
              
              <div class="flex gap-4">
                <a href={`/locations/${area.slug}`} class="flex-1 px-4 py-3 bg-amber-500 text-black font-bold text-center uppercase hover:bg-amber-400 transition-colors">
                  VIEW {area.name.toUpperCase()} SERVICES
                </a>
                <a href="/contact" class="flex-1 px-4 py-3 border-2 border-slate-700 text-white font-bold text-center uppercase hover:bg-navy-900 hover:text-white transition-colors">
                  GET LOCAL QUOTE
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- All Service Areas Grid -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <h2 class="text-4xl font-bold text-slate-900 mb-4 text-center uppercase">COMPLETE SERVICE COVERAGE</h2>
      <p class="text-lg text-slate-600 mb-12 text-center">WE PROVIDE WATERPROOFING SERVICES TO ALL GTA COMMUNITIES</p>
      
      {allServiceAreas.map(region => (
        <div class="mb-12">
          <h3 class="text-2xl font-bold text-slate-900 mb-6 uppercase border-b-2 border-slate-200 pb-2">{region.region}</h3>
          <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-4">
            {region.areas.map(area => (
              <div class="bg-white border-2 border-slate-200 p-4 hover:border-slate-300 transition-colors" id={area.name.toLowerCase().replace(' ', '-')}>
                <div class="mb-3">
                  <h4 class="text-lg font-bold text-slate-900 uppercase">{area.name}</h4>
                  {area.highlight && <span class="inline-block mt-1 px-2 py-1 bg-amber-500 text-black text-xs font-bold uppercase">PREMIUM COVERAGE</span>}
                </div>
                <div class="space-y-2 mb-4">
                  <div class="flex justify-between items-center pb-1 border-b border-slate-100">
