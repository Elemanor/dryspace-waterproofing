---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/sections/ServiceHero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceProcess from '../../components/sections/ServiceProcess.astro';
import ServicePricing from '../../components/sections/ServicePricing.astro';
import CTABand from '../../components/sections/CTABand.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

// SEO-optimized metadata
const pageTitle = "Backwater Valve Installation Toronto | Sewer Backup Prevention | $1,350 Rebate";
const pageDescription = "Professional backwater valve installation in Toronto & GTA. Prevent sewage backup into your home. City rebates up to $1,350. Licensed plumbers, 5-year warranty. Emergency service available.";

// Service areas for local SEO
const serviceAreas = [
  "Toronto", "North York", "Scarborough", "Etobicoke",
  "Mississauga", "Brampton", "Vaughan", "Richmond Hill",
  "Markham", "Oakville", "Burlington", "Hamilton"
];

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "How much does backwater valve installation cost in Toronto?",
    answer: "Backwater valve installation in Toronto costs $2,700-$5,950 depending on the valve type and installation complexity. Manual valves cost $2,700-$3,800, automatic valves $3,800-$4,900, and smart monitoring systems $4,900-$5,950. City rebates up to $1,350 available."
  },
  {
    question: "How long does backwater valve installation take?",
    answer: "Professional backwater valve installation takes 3-4 days. Day 1: Site assessment and permits. Day 2: Excavation and preparation. Day 3: Valve installation and connections. Day 4: Testing and restoration. Most disruption occurs on days 2-3 with basement floor excavation."
  },
  {
    question: "Do I need a backwater valve in Toronto?",
    answer: "Yes, backwater valves are required by Ontario Building Code for basement fixtures below street level and strongly recommended in Toronto due to combined sewer overflows occurring 15-20 times annually. They prevent sewage backup that can cause $27,000-$81,000 in damage."
  },
  {
    question: "What are the benefits of automatic vs manual backwater valves?",
    answer: "Automatic backwater valves ($3,800-$4,900) operate without human intervention using float mechanisms, providing 24/7 protection. Manual valves ($2,700-$3,800) require homeowner activation but cost less. Smart valves ($4,900-$5,950) add WiFi monitoring and mobile app alerts."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Manual Backwater Valve",
    price: "$2,700-$3,800",
    description: "Manual operation, flood indicator, professional installation, 5-year warranty"
  },
  {
    name: "Automatic Gate Valve System",
    price: "$3,800-$4,900",
    description: "Automatic closure, zero maintenance, float-operated mechanism, 7-year warranty"
  },
  {
    name: "Smart Monitoring Valve",
    price: "$4,900-$5,950",
    description: "WiFi alerts, mobile app monitoring, emergency notifications, 10-year warranty"
  }
];

// Toronto-specific sewer backup risks
const sewerRisks = [
  {
    issue: "Combined Sewer Overflows",
    frequency: "15-20 times/year",
    risk_areas: ["Downtown", "The Beach", "Leslieville", "Liberty Village"],
    consequence: "Raw sewage enters homes through floor drains",
    solution: "Backwater valve prevents reverse flow during city overflows"
  },
  {
    issue: "Spring Thaw Flooding",
    frequency: "March-April annually",
    risk_areas: ["Ravine properties", "Low-lying areas", "Older neighborhoods"],
    consequence: "Overwhelmed storm sewers backup into basements",
    solution: "Automatic valve closes when flow reverses direction"
  },
  {
    issue: "Heavy Rainfall Events",
    frequency: "100-year storms now every 5 years",
    risk_areas: ["All areas with basement connections"],
    consequence: "$27,000-$81,000 in sewage damage per incident",
    solution: "Smart valve provides early warning and protection"
  }
];

// Installation process steps for ServiceProcess component
const processSteps = [
  {
    number: 1,
    title: "Site Assessment & Permits",
    description: "Video inspection of sewer line, locate drain connections, assess valve placement options, and apply for city permits."
  },
  {
    number: 2,
    title: "Excavation & Preparation",
    description: "Break basement floor at optimal location, excavate 4'x4'x4' pit, expose main sewer line, install temporary pumping."
  },
  {
    number: 3,
    title: "Valve Installation",
    description: "Cut into main sewer line, install valve body with proper grading, connect piping, install access chamber and cover."
  },
  {
    number: 4,
    title: "Testing & Restoration",
    description: "Flood test valve operation, video inspection, restore basement floor with concrete, schedule city inspection."
  }
];

// Pricing tiers for ServicePricing component
const pricingTiers = [
  {
    name: "Manual Backwater Valve",
    price: "$2,700-$3,800",
    description: "Best for standard protection",
    features: [
      "Manual shut-off mechanism",
      "Clear access port",
      "Flood indicator",
      "Professional installation",
      "5-year warranty"
    ]
  },
  {
    name: "Automatic Gate Valve",
    price: "$3,800-$4,900",
    description: "Best for maximum convenience",
    features: [
      "Automatic closure during backflow",
      "Zero maintenance required",
      "Float-operated mechanism",
      "Backup manual override",
      "7-year warranty"
    ],
    popular: true
  },
  {
    name: "Smart Monitoring Valve",
    price: "$4,900-$5,950",
    description: "Best for complete peace of mind",
    features: [
      "WiFi alert system",
      "Mobile app monitoring",
      "Automatic operation",
      "Emergency notifications",
      "10-year warranty"
    ]
  }
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>

  <!-- Service Schema for SEO -->
  <ServiceSchema
    serviceName="Backwater Valve Installation"
    description="Professional backwater valve installation to prevent sewage backup in Toronto and GTA. Licensed plumbers, city permits, rebates up to $1,350 available."
    priceRange="$2,700-$5,950"
    offers={serviceOffers}
    faqs={serviceFAQs}
    areaServed={serviceAreas}
  />

  <!-- Hero Section -->
  <ServiceHero
    title="Backwater Valve Installation Toronto"
    description="Stop sewage backup before it destroys your basement. Professional backwater valve installation with $1,350 city rebate. Licensed plumbers, 5-year warranty, emergency service available."
    priceRange="$2,700-$5,950"
    duration="3-4 days"
    rebate="$1,350 City Rebate Available"
    backgroundImage="/images/backwatervalve.webp"
    breadcrumbs={[
      { label: "Services", href: "/services" },
      { label: "Backwater Valve Installation" }
    ]}
  />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Critical Warning Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Critical Alert"
        title="Toronto's Sewage Backup Crisis Demands Immediate Action"
        description="Combined sewer overflows happen 15-20 times per year. Without protection, raw sewage enters your basement through floor drains."
        centered={true}
      />

      <p class="speakable"><strong>Backwater valve installation in Toronto costs $1,800–$3,200 and prevents sewer backflow into your basement during heavy storms — required by Toronto's updated plumbing code and eligible for city rebates up to $1,250.</strong></p>

      <!-- Sewage Backup Statistics -->
      <div class="bg-gradient-to-r from-red-600 to-red-700 rounded-2xl shadow-card p-8 mb-12">
        <div class="grid md:grid-cols-4 gap-6 text-center text-white">
          <div>
            <p class="text-4xl font-bold mb-2">31%</p>
            <p class="text-sm uppercase tracking-wide text-red-100">Toronto homes use combined sewers</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-2">15-20</p>
            <p class="text-sm uppercase tracking-wide text-red-100">Sewer overflows annually</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-2">$81,000</p>
            <p class="text-sm uppercase tracking-wide text-red-100">Average sewage damage cost</p>
          </div>
          <div>
            <p class="text-4xl font-bold mb-2">48hrs</p>
            <p class="text-sm uppercase tracking-wide text-red-100">Health hazard exposure limit</p>
          </div>
        </div>
      </div>

      <!-- Sewage Backup Risks -->
      <div class="space-y-6 max-w-5xl mx-auto">
        {sewerRisks.map(risk => (
          <div class="bg-white border border-slate-200 rounded-xl shadow-card p-8 hover:shadow-card-hover transition-all">
            <div class="flex flex-wrap justify-between items-start gap-4 mb-6">
              <h3 class="text-xl font-bold text-slate-900">{risk.issue}</h3>
              <span class="rounded-full bg-red-600 text-white px-4 py-1.5 text-sm font-semibold">
                {risk.frequency}
              </span>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-3">High Risk Areas:</p>
                <ul class="space-y-2 text-slate-700 mb-6">
                  {risk.risk_areas.map(area => (
                    <li class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                      </svg>
                      {area}
                    </li>
                  ))}
                </ul>

                <p class="text-sm font-semibold text-slate-500 uppercase tracking-wider mb-2">Consequence:</p>
                <p class="text-slate-900 font-medium">{risk.consequence}</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-6 bg-cyan-50/50 rounded-r-lg py-4">
                <p class="text-sm font-semibold text-cyan-700 uppercase tracking-wider mb-3">Our Solution:</p>
                <p class="text-slate-900 font-medium leading-relaxed">{risk.solution}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing Options -->
  <ServicePricing
    title="Backwater Valve System Options"
    tiers={pricingTiers}
  />

  <!-- Legal Requirements Section -->
  <section class="section-padding bg-navy-900 text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <SectionHeader
          label="Compliance"
          title="Why Backwater Valves Are Legally Required"
          centered={true}
          dark={true}
        />

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white/5 backdrop-blur rounded-xl border border-white/10 p-8">
            <h3 class="text-xl font-bold mb-6 text-cyan-400">Ontario Building Code Section 7.6.5</h3>
            <ul class="space-y-3 text-slate-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Required where fixtures are below street level
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Must be installed on building drain
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Located in accessible area
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Professional installation mandatory
              </li>
            </ul>
          </div>

          <div class="bg-white/5 backdrop-blur rounded-xl border border-white/10 p-8">
            <h3 class="text-xl font-bold mb-6 text-cyan-400">City of Toronto Requirements</h3>
            <ul class="space-y-3 text-slate-300">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Permit required for all installations
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Licensed plumber must perform work
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Inspection required before closing walls
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-cyan-400 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                Annual maintenance recommended
              </li>
            </ul>
          </div>
        </div>

        <!-- Professional Standards -->
        <div class="mt-12 bg-amber-500 rounded-xl p-8 text-navy-900">
          <h3 class="text-2xl font-bold mb-8 text-center">Professional Installation Standards</h3>
          <div class="grid md:grid-cols-3 gap-8">
            <div>
              <h4 class="font-bold text-lg mb-4">Materials Used</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  CSA approved backwater valves only
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Schedule 40 PVC pipe connections
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Watertight access chambers
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Corrosion-resistant hardware
                </li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-4">Installation Requirements</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Proper slope maintenance (1:100)
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Minimum 6" clearance around valve
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Accessible for maintenance
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Flood testing before closure
                </li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold text-lg mb-4">Quality Assurance</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Video inspection documentation
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Flow testing verification
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  City compliance inspection
                </li>
                <li class="flex items-start gap-2">
                  <svg class="w-4 h-4 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  5-year warranty coverage
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process -->
  <ServiceProcess
    label="Installation Timeline"
    title="Professional 4-Day Installation Process"
    steps={processSteps}
  />

  <!-- City Rebate Program -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Save Money"
        title="Save $1,350 With City of Toronto Rebate"
        description="We handle all paperwork for the Basement Flooding Protection Subsidy Program"
        centered={true}
      />

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto mb-12">
        <!-- Rebate Requirements -->
        <div class="bg-white border border-slate-200 rounded-xl shadow-card p-8">
          <h3 class="text-xl font-bold text-slate-900 mb-6">Rebate Qualification</h3>

          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-700">Property must be in flood-prone area</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-slate-700">Professional installation required</span>
