          <div class="grid md:grid-cols-2 gap-8">
            <div>
              <h4 class="font-bold mb-4">Immediate Benefits</h4>
              <ul class="space-y-2">
                <li>✓ Legal lower level suite enabled</li>
                <li>✓ $2,200+/month rental potential</li>
                <li>✓ Code compliance achieved</li>
                <li>✓ Enhanced fire safety</li>
                <li>✓ Natural light & ventilation</li>
              </ul>
            </div>
            
            <div>
              <h4 class="font-bold mb-4">Long-term Value</h4>
              <ul class="space-y-2">
                <li>✓ 5-10% property value increase</li>
                <li>✓ Faster property sale</li>
