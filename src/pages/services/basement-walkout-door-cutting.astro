                <li>✓ Home office separate entrance</li>
                <li>✓ Improved lower level functionality</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Project Examples -->
        <div class="mb-12">
          <h3 class="text-2xl font-bold mb-6">Recent Walkout Projects</h3>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-white rounded-lg shadow-lg overflow-hidden">
              <div class="p-6">
                <h4 class="font-bold text-xl mb-2">North York Legal Suite Entrance</h4>
                <p class="text-slate-500 mb-4">
