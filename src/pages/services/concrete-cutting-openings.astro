---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/sections/ServiceHero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceProcess from '../../components/sections/ServiceProcess.astro';
import ServicePricing from '../../components/sections/ServicePricing.astro';
import CTABand from '../../components/sections/CTABand.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import BeforeAfterGallery from '../../components/BeforeAfterGallery.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import TechnicalDrawings from '../../components/TechnicalDrawings.astro';
import ContactForm from '../../components/ContactForm.astro';
import ServiceImageGallery from '../../components/ServiceImageGallery.astro';

// SEO-optimized metadata focused on service
const pageTitle = "Concrete Wall Cutting Toronto | $2,800-$15,000 | Door & Window Openings";
const pageDescription = "Precision concrete cutting for door and window openings in foundation walls. Diamond blade sawing, engineered lintels, full permit handling. Call 437-545-0067.";

// Service areas list
const serviceAreas = [
  "Toronto",
  "Scarborough",
  "Etobicoke",
  "North York",
  "Mississauga",
  "Brampton",
  "Vaughan",
  "Markham",
  "Oakville",
  "Burlington",
  "Richmond Hill",
  "Ajax",
  "Pickering",
  "Oshawa"
];

// What We Cut - Common Projects
const cuttingProjects = [
  {
    name: "NEW BASEMENT DOOR",
    description: "Add a separate entrance for a basement apartment or side access. Most popular for second units under O.Reg 384/22.",
    icon: "door_front",
    cost: "$3,500 - $6,000",
    link: null
  },
  {
    name: "EGRESS WINDOW ENLARGEMENT",
    description: "Enlarge existing small window to code-compliant egress size for legal bedrooms.",
    icon: "window",
    cost: "$2,500 - $4,500",
    link: "/services/egress-windows"
  },
  {
    name: "NEW WINDOW OPENING",
    description: "Cut a brand-new window where there wasn't one. Adds light, ventilation, and value.",
    icon: "add_box",
    cost: "$3,000 - $5,500",
    link: null
  },
  {
    name: "GARAGE-TO-BASEMENT DOORWAY",
    description: "Connect your attached garage to the basement. Very common renovation.",
    icon: "garage",
    cost: "$3,500 - $6,500",
    link: null
  },
  {
    name: "INTERIOR WALL OPENING",
    description: "Cut through concrete or block interior walls for open concept or pass-throughs.",
    icon: "meeting_room",
    cost: "$2,000 - $4,000",
    link: null
  },
  {
    name: "WALKOUT DOOR CONVERSION",
    description: "Cut full-height door opening in foundation wall for walk-out access.",
    icon: "stairs",
    cost: "$8,000 - $15,000",
    link: "/services/basement-walkout-door-cutting"
  },
  {
    name: "HVAC / UTILITY PENETRATIONS",
    description: "Precise circular or rectangular cuts for ducts, pipes, vents, dryer exhausts.",
    icon: "hvac",
    cost: "$300 - $800 per hole",
    link: null
  },
  {
    name: "WINDOW WELL ACCESS",
    description: "Cut and enlarge for larger window wells to meet egress requirements.",
    icon: "foundation",
    cost: "$2,500 - $5,000",
    link: null
  }
];

// Cutting Methods
const cuttingMethods = [
  {
    name: "Diamond Blade Wall Sawing",
    description: "Primary method for door and window openings. Hydraulic or electric wall saw with diamond-tipped blade cuts clean, straight lines through concrete up to 24\" thick.",
    bestFor: "Large rectangular openings (doors, windows)",
    features: [
      "Minimal vibration — won't damage surrounding structure",
      "Water-cooled blade controls dust",
      "Cuts through rebar cleanly",
      "Precise within 1/8\" tolerance"
    ]
  },
  {
    name: "Diamond Core Drilling",
    description: "Circular cuts for pipes, vents, utility penetrations. Sizes from 1\" to 18\" diameter with precise placement within 1/4\" of target.",
    bestFor: "HVAC ducts, plumbing, electrical conduit, dryer vents",
    features: [
      "Clean circular holes",
      "No cracking or chipping",
      "Water-cooled operation",
      "Accurate placement"
    ]
  },
  {
    name: "Controlled Demolition (Breaker)",
    description: "Used only when precision isn't critical (interior block walls, rough openings). Electric breaker — NOT a sledgehammer. Combined with diamond cutting for clean edges.",
    bestFor: "Removing entire wall sections, block wall removal",
    features: [
      "Faster for large sections",
      "Cost-effective for rough work",
      "Combined with precision cutting",
      "Interior walls only"
    ]
  }
];

// Wall Material Comparison Table
const wallComparison = [
  {
    factor: "Cutting method",
    pouredConcrete: "Diamond wall saw",
    concreteBlock: "Saw + controlled demo",
    stoneRubble: "Careful demolition"
  },
  {
    factor: "Lintel type",
    pouredConcrete: "Steel angle or C-channel",
    concreteBlock: "Steel lintel in bond beam",
    stoneRubble: "Custom steel frame"
  },
  {
    factor: "Difficulty",
    pouredConcrete: "Standard",
    concreteBlock: "Moderate",
    stoneRubble: "High"
  },
  {
    factor: "Dust level",
    pouredConcrete: "Moderate (water-cooled)",
    concreteBlock: "Higher (hollow blocks)",
    stoneRubble: "Highest"
  },
  {
    factor: "Cost multiplier",
    pouredConcrete: "1.0x (baseline)",
    concreteBlock: "0.8-0.9x",
    stoneRubble: "1.3-1.5x"
  },
  {
    factor: "Common in",
    pouredConcrete: "Homes built 1970s+",
    concreteBlock: "Homes built 1950s-1980s",
    stoneRubble: "Pre-1950s homes"
  },
  {
    factor: "Rebar?",
    pouredConcrete: "Yes (must cut through)",
    concreteBlock: "Vertical rebar in cells",
    stoneRubble: "None (masonry mortar)"
  }
];

// Pricing breakdown
const pricingBreakdown = [
  {
    service: "Door opening in poured concrete (standard 36\"x80\")",
    cost: "$3,500 - $6,000",
    includes: "Cutting, lintel, engineering, permit, debris removal"
  },
  {
    service: "Door opening in block wall",
    cost: "$2,800 - $5,000",
    includes: "Cutting, lintel, engineering, permit, debris removal"
  },
  {
    service: "Window enlargement (existing to egress)",
    cost: "$2,500 - $4,500",
    includes: "Cutting, lintel, debris, prep for window install"
  },
  {
    service: "New window opening (no existing)",
    cost: "$3,000 - $5,500",
    includes: "Cutting, lintel, engineering, permit, debris"
  },
  {
    service: "Garage-to-basement doorway",
    cost: "$3,500 - $6,500",
    includes: "Often requires fire-rated door + frame"
  },
  {
    service: "Interior concrete wall opening",
    cost: "$2,000 - $4,000",
    includes: "Simpler — no exterior waterproofing needed"
  },
  {
    service: "Utility penetration (core drill)",
    cost: "$300 - $800 per hole",
    includes: "Size dependent (4\"-12\" typical)"
  },
  {
    service: "Full walkout conversion",
    cost: "$8,000 - $15,000",
    includes: "Large opening + retaining walls + drainage"
  },
  {
    service: "Engineering drawings",
    cost: "$1,000 - $2,500",
    includes: "P.Eng stamped structural drawings"
  },
  {
    service: "Building permit",
    cost: "$400 - $800",
    includes: "Municipality dependent"
  }
];

// Price factors
const priceFactors = [
  "Wall material: poured concrete costs more to cut than block",
  "Wall thickness: 10\" wall = more blade time than 8\"",
  "Rebar density: heavily reinforced walls slow cutting significantly",
  "Access: exterior excavation needed for below-grade openings",
  "Location: interior walls simpler than exterior foundation walls",
  "Finishing level: rough opening only vs. complete door/window install"
];

// Trust points
const trustPoints = [
  {
    title: "Waterproofing expertise",
    description: "We seal every exterior opening properly. Window/door installers often skip this → leaks within a year."
  },
  {
    title: "Structural engineering in-house",
    description: "P.Eng designs every lintel. No guessing."
  },
  {
    title: "Dust control",
    description: "Negative air, water-cooled blades, poly containment. Your home stays livable."
  },
  {
    title: "Permit handling",
    description: "Full permit application and inspection coordination included."
  },
  {
    title: "One contractor",
    description: "Cutting + lintel + waterproofing + window/door install. No juggling trades."
  },
  {
    title: "Debris hauled away",
    description: "Concrete removal and disposal included in every quote."
  }
];

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "Can you cut through a foundation wall without it collapsing?",
    answer: "Yes, with proper engineering and temporary shoring. Every opening gets a steel lintel designed by a P.Eng to carry the load that the concrete used to carry. We've cut thousands of openings safely. The lintel is installed immediately after cutting and before removing the concrete section. This maintains structural integrity throughout the process."
  },
  {
    question: "How much dust will there be?",
    answer: "We use water-cooled diamond blades and full dust containment. Expect some fine dust despite precautions, but nothing like dry cutting or breaking. We seal the work area with poly sheeting and negative air pressure. After the job, we clean thoroughly with HEPA vacuums. Most clients continue living in the home during installation."
  },
  {
    question: "Do I need a permit to cut a door in my basement wall?",
    answer: "Yes. Any opening in a foundation wall is structural work requiring a building permit and engineered drawings. Working without a permit can mean fines, forced closure, insurance issues, and problems when you sell the home. DrySpace handles all permit applications and engineering as part of our service — this is included in our pricing."
  },
  {
    question: "Can I cut an opening in a wall with rebar?",
    answer: "Yes. Diamond blades cut through rebar. It slows the process and adds some cost, but it's standard. We scan walls first with Ground Penetrating Radar (GPR) to map rebar location and density. This helps us plan the cutting sequence and estimate timing accurately. Cutting through rebar requires specialized diamond blade segments and more frequent blade changes."
  },
  {
    question: "How long before I can install the door or window?",
    answer: "The opening is ready immediately after the lintel is installed and inspected. You can install the door/window unit same day or have your finishing contractor do it later. The lintel provides full structural support as soon as it's grouted in place. Most homeowners wait for the building inspector sign-off before proceeding with final finishes."
  },
  {
    question: "What happens to the concrete you remove?",
    answer: "We cut it into manageable sections, carry it out, and haul it to a recycling facility. Concrete disposal is included in our pricing — no surprise fees. A typical door opening generates about 800-1,200 lbs of concrete debris. We protect your floors with plywood and carpet runners during removal. Most concrete is crushed and recycled as aggregate for new construction."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Door Opening in Poured Concrete",
    price: "$3,500-$6,000",
    description: "Complete door cutout with diamond sawing, steel lintel, engineering, permit handling, and debris removal."
  },
  {
    name: "Window Enlargement",
    price: "$2,500-$4,500",
    description: "Enlarge existing window to egress code requirements. Includes cutting, lintel, and debris removal."
  },
  {
    name: "Walkout Conversion Package",
    price: "$8,000-$15,000",
    description: "Full walkout door installation with large opening, retaining walls, drainage, and full waterproofing."
  }
];

// Installation process steps
const processSteps = [
  {
    title: "Site Assessment (Free)",
    description: "Identify wall type (poured concrete, block, stone). Measure wall thickness (typically 8-10\" residential). Locate rebar pattern and utilities (electrical, plumbing, gas). Assess exterior conditions (grade level, drainage, window wells). Ground Penetrating Radar (GPR) scan if needed to find rebar/utilities.",
    duration: "1 hour"
  },
  {
    title: "Structural Engineering",
    description: "P.Eng designs lintel size and bearing requirements. Calculates vertical load (from above) and lateral load (soil pressure). Specifies steel angle, C-channel, or W-beam lintel. Determines bearing pad requirements at each side of opening. Engineering drawings for permit submission.",
    duration: "1-2 weeks"
  },
  {
    title: "Permit Application",
    description: "Building permit required for any structural opening. DrySpace handles full application. Some municipalities also require a plumbing permit if cutting near drains.",
    duration: "2-4 weeks"
  },
  {
    title: "Preparation (Day 1 morning)",
    description: "Protect floors, walls, and belongings with poly sheeting. Set up dust containment barriers (negative air pressure if occupied). Mark cut lines precisely with laser level. Verify utility locations with live scanning.",
    duration: "2-3 hours"
  },
  {
    title: "Cutting (Day 1)",
    description: "Diamond blade wall saw creates clean cuts. Water-cooled blade suppresses dust. Cuts made in sequence to maintain wall stability. Concrete sections removed in manageable pieces (not one giant slab). Typical door opening: 3-4 hours. Window: 2-3 hours.",
    duration: "3-4 hours"
  },
  {
    title: "Lintel Installation (Day 1-2)",
    description: "Steel lintel set into prepared bearing pockets above opening. Grouted/mortared into wall with bearing plates. Minimum 8\" bearing on each side of opening (more for wider openings). Lintel carries the load that the removed concrete used to carry.",
    duration: "3-4 hours"
  },
  {
    title: "Finishing (Day 2)",
    description: "Frame opening for door or window installation. Waterproof exterior side with membrane and flashing. Install door/window unit (or leave prepped for your contractor). Patch and seal any exterior gaps. Install window well if below grade.",
    duration: "4-6 hours"
  },
  {
    title: "Inspection & Cleanup",
    description: "Municipal inspector verifies structural work. Remove all dust containment and protection. Haul away concrete debris (included in price). 25-year warranty on structural work and waterproofing.",
    duration: "1 hour"
  }
];

// Pricing tiers
const pricingTiers = [
  {
    name: "Interior Wall Opening",
    price: "$2,000-$4,000",
    features: [
      "Interior wall cutting only",
      "No exterior waterproofing",
      "Steel lintel installation",
      "Engineering included",
      "10-year warranty"
    ],
    description: "Best for open concept renovations"
  },
  {
    name: "New Door or Window Opening",
    price: "$3,500-$6,000",
    features: [
      "Diamond wall sawing",
      "Steel lintel + engineering",
      "Full permit handling",
      "Exterior waterproofing",
      "25-year warranty"
    ],
    description: "Most common installation",
    recommended: true
  },
  {
    name: "Walkout Conversion Package",
    price: "$8,000-$15,000",
    features: [
      "Large opening cutting",
      "Heavy-duty lintel",
      "Retaining wall work",
      "Full drainage system",
      "25-year warranty"
    ],
    description: "For full walkout access",
    premium: true
  }
];

// Common Combinations
const commonCombinations = [
  {
    name: "Cutout + Egress Window",
    description: "Most popular. Cut opening + install code-compliant window + window well.",
    price: "$5,000 - $8,000",
    link: "/services/egress-windows"
  },
  {
    name: "Cutout + Second Unit Entrance",
    description: "Separate door for basement apartment under O.Reg 384/22.",
    price: "$6,000 - $10,000",
    link: "/services/legal-basement-conversion"
  },
  {
    name: "Cutout + Underpinning",
    description: "Opening up walls while lowering the floor for ceiling height.",
    price: "$15,000 - $30,000",
    link: "/services/underpinning"
  },
  {
    name: "Cutout + Beam Installation",
    description: "Remove interior load-bearing wall + cut exterior opening.",
    price: "$8,000 - $15,000",
    link: "/services/load-bearing-beam-installation"
  },
  {
    name: "Multiple Openings Package",
    description: "Discount for 2+ openings in same project. Save 15-20%.",
    price: "Custom quote",
    link: null
  }
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>

  <!-- ServiceSchema Component -->
  <ServiceSchema
    serviceName="Concrete Wall Cutting & Door/Window Openings Toronto"
    description={pageDescription}
    priceRange="$2,800-$15,000"
    areaServed={serviceAreas}
    offers={serviceOffers}
    faqs={serviceFAQs}
  />

  <!-- Hero Section -->
  <ServiceHero
    title="Concrete Cutting & Wall Openings Toronto & GTA"
    description="Precision door and window cutouts in foundation walls. Diamond-blade sawing, structural lintels, and full permit handling — clean, fast, engineered."
    priceRange="$2,800-$15,000"
    duration="1-2 days"
    rebate="Engineering Included"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Concrete Cutting" }
    ]}
  />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Answer Capsule -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="speakable"><strong>Concrete cutting for wall openings in Toronto costs $2,000–$8,000 per opening including engineering, lintel installation, and finishing — essential for basement walkouts, windows, and doorways.</strong></p>
    </div>
  </section>

  <!-- What We Cut Section -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Common Projects"
          title="What We Cut"
          description="Door and window openings for every basement renovation"
          centered={true}
        />

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          {cuttingProjects.map(project => (
            <div class="bg-white rounded-lg shadow-card hover:shadow-card-hover transition-all duration-300 p-6">
              <div class="bg-cyan-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-cyan-600 text-3xl" style="font-variation-settings: 'FILL' 1">{project.icon}</span>
              </div>
              <h3 class="text-headline text-navy-900 mb-2">{project.name}</h3>
              <p class="text-slate-700 mb-4 text-sm">{project.description}</p>
              <p class="font-bold text-cyan-600 text-lg mb-3">{project.cost}</p>
              {project.link && (
                <a href={project.link} class="text-cyan-600 font-bold text-sm hover:text-cyan-700 inline-flex items-center">
                  Learn More
                  <span class="material-symbols-outlined ml-1 text-sm">arrow_forward</span>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Cutting Methods Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Our Methods"
          title="How We Cut Concrete"
          description="Precision cutting techniques for every situation"
          centered={true}
        />

        <div class="grid md:grid-cols-3 gap-6">
          {cuttingMethods.map(method => (
            <div class="bg-white rounded-lg shadow-card hover:shadow-card-hover transition-all duration-300 p-8 border-2 border-slate-200">
              <h3 class="text-headline text-navy-900 mb-4">{method.name}</h3>
              <p class="text-slate-700 mb-6">{method.description}</p>

              <div class="mb-6">
                <p class="section-label-pill bg-cyan-100 text-cyan-700 inline-block mb-2">Best For</p>
                <p class="text-navy-900 font-semibold">{method.bestFor}</p>
              </div>

              <ul class="space-y-3">
                {method.features.map(feature => (
                  <li class="flex items-start">
                    <span class="material-symbols-outlined text-cyan-500 mr-3 text-sm" style="font-variation-settings: 'FILL' 1">check_circle</span>
                    <span class="text-slate-700 text-sm">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Engineering Section -->
  <section class="section-padding bg-gradient-to-br from-navy-900 to-navy-800 text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Structural Safety"
          title="The Engineering Behind Every Cut"
          description="Why this isn't DIY"
          centered={true}
          dark={true}
        />

        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <div class="bg-white/10 backdrop-blur rounded-lg shadow-card p-8">
            <h3 class="text-headline mb-6">Every Foundation Wall is Structural</h3>

            <div class="space-y-4">
              <div class="border-l-4 border-amber-400 pl-4 py-2">
                <h4 class="font-bold text-display">It Holds Up Your House</h4>
                <p class="text-slate-300 text-sm">Foundation walls carry vertical loads from above (floor joists, walls, roof)</p>
              </div>

              <div class="border-l-4 border-amber-400 pl-4 py-2">
                <h4 class="font-bold text-display">Cutting Removes Load-Bearing Material</h4>
                <p class="text-slate-300 text-sm">Must be replaced with a steel or concrete lintel</p>
              </div>

              <div class="border-l-4 border-amber-400 pl-4 py-2">
                <h4 class="font-bold text-display">Below-Grade Walls Resist Soil Pressure</h4>
                <p class="text-slate-300 text-sm">Lateral forces from outside soil push against foundation</p>
              </div>

              <div class="border-l-4 border-amber-400 pl-4 py-2">
                <h4 class="font-bold text-display">Engineering Accounts for BOTH Loads</h4>
                <p class="text-slate-300 text-sm">Vertical weight + horizontal soil pressure</p>
              </div>
            </div>
          </div>

          <div class="bg-white/10 backdrop-blur rounded-lg shadow-card p-8">
            <h3 class="text-headline mb-6">DrySpace Engineering Process</h3>

            <div class="space-y-6">
              <div>
                <div class="flex items-center mb-2">
                  <span class="material-symbols-outlined text-cyan-400 mr-3" style="font-variation-settings: 'FILL' 1">engineering</span>
                  <h4 class="font-bold text-display text-cyan-400">P.Eng Structural Drawings</h4>
                </div>
                <p class="text-slate-200 text-sm">Professional Engineer designs every opening</p>
              </div>

              <div>
                <div class="flex items-center mb-2">
                  <span class="material-symbols-outlined text-cyan-400 mr-3" style="font-variation-settings: 'FILL' 1">calculate</span>
                  <h4 class="font-bold text-display text-cyan-400">Load Calculations</h4>
                </div>
                <p class="text-slate-200 text-sm">Wall thickness, load above, opening width, soil pressure</p>
              </div>

              <div>
                <div class="flex items-center mb-2">
                  <span class="material-symbols-outlined text-cyan-400 mr-3" style="font-variation-settings: 'FILL' 1">square_foot</span>
                  <h4 class="font-bold text-display text-cyan-400">Lintel Design</h4>
                </div>
                <p class="text-slate-200 text-sm">Steel angle, C-channel, or W-beam specification</p>
              </div>

              <div>
                <div class="flex items-center mb-2">
                  <span class="material-symbols-outlined text-cyan-400 mr-3" style="font-variation-settings: 'FILL' 1">foundation</span>
                  <h4 class="font-bold text-display text-cyan-400">Bearing Requirements</h4>
                </div>
                <p class="text-slate-200 text-sm">Minimum 8\" bearing on each side (more for wider openings)</p>
              </div>
            </div>

            <div class="bg-gradient-to-r from-red-600 to-red-700 rounded-lg p-6 text-center mt-8">
              <span class="material-symbols-outlined text-5xl mb-3" style="font-variation-settings: 'FILL' 1">warning</span>
              <p class="font-bold text-display">Undersized or missing lintels = wall failure, cracking, or collapse over time</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process -->
  <ServiceProcess
    steps={processSteps}
    title="Our Concrete Cutting Process"
    label="8-Step Process"
  />

  <!-- Pricing Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Transparent Pricing"
          title="Concrete Cutting Costs in the GTA"
          description="All-inclusive pricing with no hidden fees"
          centered={true}
        />

        <div class="overflow-x-auto rounded-lg shadow-card mb-8">
          <table class="w-full">
            <thead>
              <tr class="bg-gradient-to-r from-navy-900 to-navy-800 text-white">
                <th class="p-4 text-left text-display">Opening Type</th>
                <th class="p-4 text-center text-display">Cost Range</th>
                <th class="p-4 text-left text-display">Includes</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              {pricingBreakdown.map((item, index) => (
