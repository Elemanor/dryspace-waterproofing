];

// Finish options
const finishOptions = [
  {
    name: "Broom Finish",
    description: "Standard non-slip texture. Best for driveways, walkways, garage pads. Most affordable. Looks clean and professional.",
    bestFor: "Driveways, garages, walkways",
    priceLevel: "Standard",
    maintenance: "None",
