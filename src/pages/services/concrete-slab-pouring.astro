  },
  {
    project: "Patio (broom finish)",
    size: "200-400 sq ft",
    cost: "$2,500 - $5,000",
    pricePerSqFt: "$10-15/sq ft"
  },
  {
    project: "Patio (stamped)",
    size: "200-400 sq ft",
    cost: "$4,000 - $8,000",
    pricePerSqFt: "$18-25/sq ft"
  },
  {
    project: "Driveway",
    size: "400-600 sq ft",
    cost: "$5,000 - $10,000",
    pricePerSqFt: "$10-15/sq ft"
  },
  {
    project: "Walkway (standard)",
    size: "50-150 sq ft",
    cost: "$1,000 - $3,000",
