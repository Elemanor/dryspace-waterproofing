      "Decorative stone exposed",
      "Excellent slip resistance",
      "Very durable finish",
      "Natural look and feel"
    ],
    premium: true
  }
];

// Pricing breakdown
const pricingBreakdown = [
  {
    project: "Basement floor (new pour after underpinning)",
    size: "500-800 sq ft",
    cost: "$4,000 - $7,000",
    pricePerSqFt: "$8-12/sq ft"
  },
  {
