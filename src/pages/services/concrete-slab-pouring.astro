];

// Slab specifications by type
const slabSpecifications = [
  {
    slabType: "Basement floor",
    thickness: "4\" (100mm)",
    concreteStrength: "30 MPa",
    reinforcement: "WWM or rebar",
    subBase: "4\" granular",
    vapourBarrier: "Yes (required)"
  },
  {
    slabType: "Garage pad",
    thickness: "5-6\" (125-150mm)",
