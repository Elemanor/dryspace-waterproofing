  },
  {
    project: "Concrete steps (3-5 steps)",
    size: "—",
    cost: "$1,500 - $3,500",
    pricePerSqFt: "Per project"
  },
  {
    project: "Pad footing",
    size: "Per footing",
    cost: "$500 - $1,500",
    pricePerSqFt: "Each"
  }
];

// Common combinations
const commonCombinations = [
  {
    title: "Underpinning + New Floor",
    description: "Lower basement for ceiling height + pour new slab",
    link: "/services/underpinning",
    savings: "Save 15-20% combined"
  },
  {
    title: "Waterproofing + Floor Replace",
    description: "Interior drainage system + new slab with proper vapour barrier",
    link: "/services/interior-waterproofing",
    savings: "One contractor, one warranty"
  },
  {
    title: "Slab + In-Floor Heating",
    description: "PEX tubing embedded in slab for radiant heat",
    link: "#",
    savings: "Installed during pour"
  },
  {
    title: "Garage Pad + Driveway",
    description: "Pour both together, save on concrete delivery",
    link: "#",
    savings: "Volume concrete discount"
  },
  {
    title: "Foundation Walls + Slab",
    description: "New construction below grade (basement extensions)",
    link: "/services/footings-foundations",
    savings: "Complete foundation package"
  }
];

// Trust points
const trustPoints = [
  {
    title: "We never skip sub-base",
    description: "4-6\" compacted granular base on every slab - this is where cheap contractors cut corners"
  },
  {
    title: "Vapour barrier standard",
    description: "6-mil poly on every basement floor prevents moisture migration and mold"
  },
  {
    title: "Proper reinforcement",
    description: "WWM or rebar grid placed on chairs - not laid flat on the ground"
  },
  {
    title: "Control joints planned",
    description: "Max 10' spacing or 2:1 ratio to prevent random cracking"
  },
  {
    title: "2,000+ slabs poured",
    description: "Experience with every soil condition and foundation type in the GTA"
  },
  {
    title: "Full warranty",
    description: "Written warranty covers materials, workmanship, and structural integrity"
  }
];

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "How long before I can walk on new concrete?",
    answer: "24-48 hours for foot traffic. 7 days for heavy items or vehicles. Full cure strength is reached at 28 days. We apply curing compound or cover with poly to ensure proper hydration. Rushing the curing process leads to weaker concrete and surface dusting."
  },
  {
    question: "Do I need a permit for a concrete slab?",
    answer: "Interior basement floor: usually no permit required. Driveway or sidewalk touching city property: yes, you need an entrance permit. Garage pad: sometimes, depends on municipality. Patio/walkway: typically no permit. We'll advise during your free assessment what permits (if any) are needed for your specific project."
  },
  {
    question: "Can you pour concrete in winter?",
    answer: "Yes, with precautions. We use heated blankets, hoarding tents, and high-early concrete with accelerators for faster curing. Winter pours cost 15-25% more due to heating and protection requirements. Best season for concrete work is April through November when temperatures are consistently above 5°C."
  },
  {
    question: "Why did my old basement floor crack?",
    answer: "Usually poor sub-base preparation, no control joints, or settlement. Sometimes tree roots or plumbing leaks washing away soil underneath. Cheap contractors pour directly on dirt - that's the #1 cause of cracked slabs. We always excavate, install proper granular base, compact it with a machine, and plan control joint layout BEFORE pouring."
  },
  {
    question: "Should I get stamped or regular concrete for my patio?",
    answer: "Stamped looks premium but costs 2x more ($18-25/sq ft vs $10-15/sq ft) and needs resealing every 2-3 years. Broom finish is durable, maintenance-free, and still looks professional. Exposed aggregate is a good middle ground - attractive, slip-resistant, and more durable than stamped. Choose based on your budget and maintenance tolerance."
  },
  {
    question: "What's the difference between 30 MPa and 32 MPa concrete?",
    answer: "MPa = megapascals, a measure of compressive strength. 30 MPa is standard residential concrete for basement floors, patios, walkways - strong enough for foot traffic and furniture. 32 MPa is used for driveways and garage pads that support vehicle loads. Higher MPa concrete is stronger, more durable, and slightly more expensive. The right spec depends on the application."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Basement Floor Pour",
    price: "$4,000-$7,000",
    description: "New basement floor with vapour barrier, reinforcement, and proper sub-base. 500-800 sq ft typical."
  },
  {
    name: "Garage Pad",
    price: "$2,500-$7,000",
    description: "Single or double car garage pad. 5-6\" thick, reinforced for vehicle loads."
  },
  {
    name: "Patio Slab",
    price: "$2,500-$8,000",
    description: "Concrete patio with choice of finish: broom, stamped, or exposed aggregate."
  }
];

// Concrete process steps
const processSteps = [
  {
    title: "Site Assessment & Measurement (Free)",
    description: "Measure area and check grades. Assess existing conditions (old slab, soil, drainage). Determine drainage requirements and slope needs. Soil/sub-base evaluation for settlement risk.",
    duration: "30-60 minutes"
  },
  {
    title: "Excavation & Sub-Base Preparation",
    description: "Excavate to required depth (varies by slab type). Compact native soil with machine. Install granular base: 4-6\" of 3/4\" clear stone or granular A, machine compacted. Proper sub-base is 90% of a good slab - this is where cheap contractors cut corners.",
    duration: "3-6 hours"
  },
  {
    title: "Drainage & Utilities",
    description: "Rough-in floor drains, sump pit, weeping tile connections. Stub up plumbing for future bathroom/kitchen if planned. Install in-floor heating tubing (PEX) if requested. All drainage connected before concrete is poured.",
    duration: "2-4 hours"
  },
  {
    title: "Vapour Barrier",
    description: "6-mil polyethylene vapour barrier over entire sub-base. Overlapped 12\" at seams, sealed with tape. Prevents moisture migration through slab - critical for finished basements. Many contractors skip this → leads to damp floors, mold under flooring, efflorescence on walls.",
    duration: "1-2 hours"
  },
  {
    title: "Reinforcement",
    description: "Welded wire mesh (WWM 6x6 W1.4/W1.4) for standard slabs. Rebar grid (10M @ 12\" O.C. both ways) for garage/driveway. Rebar placed on chairs to maintain proper position in slab. Fibre-reinforced concrete available as supplement (not replacement) for mesh.",
    duration: "2-3 hours"
  },
  {
    title: "Forming",
    description: "Build perimeter forms to exact grade with laser level. Control joint layout planned (max 10' spacing or 2:1 length-to-width ratio). Expansion joints where slab meets walls, columns, or other slabs. Forms must be level and straight.",
    duration: "2-4 hours"
  },
  {
    title: "Pour & Finish",
    description: "30 MPa concrete (standard) or 32 MPa (garage/driveway). Pump or wheelbarrow delivery depending on access. Screed to level, bull float for initial finish. Final finish options: smooth trowel, broom, stamped, exposed aggregate. Control joints cut within 12-24 hours after pour.",
    duration: "4-8 hours"
  },
  {
    title: "Curing & Protection",
    description: "Curing compound applied OR wet cure with poly cover for 7 days. No foot traffic for 24-48 hours. No vehicles for 7 days minimum. Full strength at 28 days. Seal coat recommended at 28 days for garages/driveways to protect against salt and oil.",
    duration: "7-28 days"
  }
];

// Pricing tiers
const pricingTiers = [
  {
    name: "Basement Floor",
    price: "$4,000-$7,000",
    features: [
      "500-800 sq ft typical",
      "4\" thick, 30 MPa concrete",
      "Vapour barrier included",
      "WWM or rebar reinforcement",
      "Proper sub-base prep",
      "Smooth trowel finish"
    ],
    description: "Most common residential pour",
    recommended: true
  },
  {
    name: "Garage Pad",
    price: "$2,500-$7,000",
    features: [
      "Single or double car",
      "5-6\" thick, 32 MPa concrete",
      "Rebar grid reinforcement",
      "Sloped to drain",
      "Non-slip broom finish",
      "Heavy-duty for vehicles"
    ],
    description: "Engineered for vehicle loads"
  },
  {
    name: "Stamped Patio",
    price: "$4,000-$8,000",
    features: [
      "200-400 sq ft typical",
      "Custom pattern selection",
      "Integral colour options",
      "Sealer coat included",
      "Looks like natural stone",
      "3-year warranty on finish"
    ],
    description: "Premium decorative finish",
    premium: true
  }
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>

  <!-- ServiceSchema Component -->
  <ServiceSchema
    serviceName="Concrete Slab Pouring Toronto"
    description={pageDescription}
    priceRange="$8-$25/sq ft"
    areaServed={serviceAreas}
    offers={serviceOffers}
    faqs={serviceFAQs}
  />

  <!-- Hero Section -->
  <ServiceHero
    title="Concrete Slab Pouring & Finishing Toronto & GTA"
    description="New basement floors, garage pads, patios, walkways, and pad footings. Machine-finished, reinforced, and built to last. Free assessment."
    priceRange="$8-$25/sq ft"
    duration="1-3 days"
    rebate="All Seasons"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Concrete Slab Pouring" }
    ]}
  />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- What We Pour Section -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Project Types"
          title="What We Pour"
          description="8 types of concrete slabs for residential & commercial"
          centered={true}
        />

        <div class="grid md:grid-cols-2 gap-6">
          {projectTypes.map(project => (
            <div class={`bg-white rounded-lg shadow-card hover:shadow-card-hover transition-all duration-300 relative overflow-hidden ${
              project.typical ? 'ring-2 ring-cyan-500' : ''
            }`}>
              {project.typical && (
                <div class="absolute top-0 left-0 right-0 bg-gradient-to-r from-cyan-500 to-cyan-600 text-white px-4 py-2 text-center">
                  <span class="text-display font-bold">MOST COMMON</span>
                </div>
              )}

              <div class={`p-8 ${project.typical ? 'pt-16' : ''}`}>
                <h3 class="text-headline text-navy-900 mb-2">{project.name}</h3>
                <p class="text-slate-700 mb-6">{project.description}</p>

                <ul class="space-y-3 mb-6">
                  {project.features.map(feature => (
                    <li class="flex items-start">
                      <span class="material-symbols-outlined text-cyan-500 mr-3" style="font-variation-settings: 'FILL' 1">check_circle</span>
                      <span class="text-slate-700">{feature}</span>
                    </li>
                  ))}
                </ul>

                <div class="border-t-2 border-slate-200 pt-4">
                  <p class="section-label-pill bg-slate-200 text-slate-700 inline-block mb-2">Best For</p>
                  <p class="text-navy-900 font-semibold">{project.bestFor}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Concrete Process -->
  <ServiceProcess
    steps={processSteps}
    title="Our Concrete Slab Pouring Process"
    label="8-Step Process"
  />

  <!-- Slab Specifications Table -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Technical Specifications"
          title="Slab Specifications by Type"
          description="Engineered specifications for each application"
          centered={true}
        />

        <div class="overflow-x-auto rounded-lg shadow-card mb-8">
          <table class="w-full">
            <thead>
              <tr class="bg-gradient-to-r from-navy-900 to-navy-800 text-white">
                <th class="p-4 text-left text-display">Slab Type</th>
                <th class="p-4 text-center text-display">Thickness</th>
                <th class="p-4 text-center text-display">Concrete Strength</th>
                <th class="p-4 text-center text-display">Reinforcement</th>
                <th class="p-4 text-center text-display">Sub-Base</th>
                <th class="p-4 text-center text-display">Vapour Barrier</th>
              </tr>
            </thead>
            <tbody class="bg-white">
              {slabSpecifications.map((spec, index) => (
                <tr class={index % 2 === 0 ? 'border-b border-slate-200' : 'border-b border-slate-200 bg-slate-50'}>
                  <td class="p-4 font-bold text-display text-navy-900">{spec.slabType}</td>
                  <td class="p-4 text-center text-slate-700">{spec.thickness}</td>
                  <td class="p-4 text-center text-slate-700">{spec.concreteStrength}</td>
                  <td class="p-4 text-center text-slate-700">{spec.reinforcement}</td>
                  <td class="p-4 text-center text-slate-700">{spec.subBase}</td>
                  <td class="p-4 text-center font-bold text-cyan-600">{spec.vapourBarrier}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <div class="bg-amber-50 border-2 border-amber-500 rounded-lg p-8">
          <div class="flex items-start">
            <span class="material-symbols-outlined text-amber-600 text-5xl mr-6" style="font-variation-settings: 'FILL' 1">info</span>
            <div>
              <h3 class="text-headline text-navy-900 mb-3">These Specs Are Non-Negotiable</h3>
              <p class="text-slate-700 mb-3">
                These specifications are based on <strong>Ontario Building Code</strong>, soil engineering best practices, and 20+ years of experience pouring slabs in GTA soil conditions.
              </p>
              <p class="text-slate-700">
                Any contractor who suggests thinner slabs, weaker concrete, or skipping the sub-base or vapour barrier is trying to cut corners. That slab WILL crack, heave, or fail prematurely.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Finish Options -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Surface Finishes"
          title="Concrete Finish Options"
          description="Choose the right finish for your application and budget"
          centered={true}
        />

        <div class="grid md:grid-cols-2 gap-6">
          {finishOptions.map(finish => (
            <div class={`bg-white rounded-lg shadow-card hover:shadow-card-hover transition-all duration-300 relative overflow-hidden ${
              finish.premium ? 'ring-2 ring-amber-500' : ''
            }`}>
              {finish.premium && (
                <div class="absolute top-0 left-0 right-0 bg-gradient-to-r from-amber-500 to-amber-600 text-white px-4 py-2 text-center">
                  <span class="text-display font-bold">PREMIUM FINISH</span>
                </div>
              )}

              <div class={`p-8 ${finish.premium ? 'pt-16' : ''}`}>
                <h3 class="text-headline text-navy-900 mb-2">{finish.name}</h3>
                <p class="text-2xl font-bold text-cyan-600 mb-4">{finish.priceLevel}</p>
                <p class="text-slate-700 mb-6">{finish.description}</p>

                <ul class="space-y-3 mb-6">
                  {finish.features.map(feature => (
                    <li class="flex items-start">
                      <span class="material-symbols-outlined text-cyan-500 mr-3" style="font-variation-settings: 'FILL' 1">check_circle</span>
                      <span class="text-slate-700">{feature}</span>
                    </li>
                  ))}
                </ul>

                <div class="grid grid-cols-2 gap-4 border-t-2 border-slate-200 pt-4">
                  <div>
