// What we pour - project types
const projectTypes = [
  {
    name: "NEW BASEMENT FLOOR",
    description: "New basement floor after underpinning, waterproofing, or flood damage. Includes vapour barrier, wire mesh/rebar, in-floor drainage rough-in.",
