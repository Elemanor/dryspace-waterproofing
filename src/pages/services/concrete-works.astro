  <!-- JavaScript for Calculator -->
  <script>
    function calculateSlabCost() {
      const area = parseFloat(document.getElementById('slabArea').value) || 500;
      const thickness = parseFloat(document.getElementById('slabThickness').value) || 4;
      
      let pricePerSqFt;
      if (thickness === 4) {
        pricePerSqFt = 10;
      } else if (thickness === 6) {
        pricePerSqFt = 12;
      } else {
        pricePerSqFt = 15;
      }
      
      const totalCost = area * pricePerSqFt;
      
      document.getElementById('slabCostDisplay').textContent = `$${totalCost.toLocaleString()} - $${(totalCost * 1.3).toLocaleString()}`;
      document.getElementById('slabCostResult').classList.remove('hidden');
    }
  </script>
