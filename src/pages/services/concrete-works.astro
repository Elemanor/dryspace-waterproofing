---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroSection from '../../components/widgets/Hero.astro';
import ConcreteServices from '../../components/react/ConcreteServices';
import ConcreteCalculator from '../../components/react/ConcreteCalculator';
import NBCWaterTableSoilMovement from '../../components/NBCWaterTableSoilMovement.astro';
import NBCLateralPressure from '../../components/NBCLateralPressure.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import ContactForm from '../../components/ContactForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const meta = {
  title: "Professional Concrete Works Toronto | Slabs, Walls, Driveways & Stamped Concrete",
  description: "Expert concrete contractors in Toronto. Specializing in concrete slabs, walls, block walls, sidewalks, patios, walkways, driveways, and decorative stamped concrete. 25-year warranty.",
  keywords: "concrete contractors Toronto, concrete slabs, concrete walls, block walls, sidewalks, concrete patios, walkways, driveways, stamped concrete, decorative concrete",
  canonical: "https://dryspacegroup.com/services/concrete-works"
};

// Service areas for local SEO
const serviceAreas = [
  "Toronto", "North York", "Scarborough", "Etobicoke", 
  "Mississauga", "Brampton", "Vaughan", "Richmond Hill",
  "Markham", "Oakville", "Burlington", "Hamilton"
];

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "How much do concrete works cost in Toronto?",
    answer: "Concrete work pricing varies by project type: basement slabs $8-12/sq ft, garage floors $12-18/sq ft, driveways $12-18/sq ft, patios $10-15/sq ft, stamped concrete $17-25/sq ft, and retaining walls $250-750/linear ft. Final cost depends on size, complexity, and finishing requirements."
  },
  {
    question: "How long do concrete projects take to complete?",
    answer: "Most residential concrete projects take 2-5 days: slabs and patios 2-3 days, driveways 3-4 days, retaining walls 3-7 days depending on height and engineering requirements. Stamped concrete adds 1-2 days for decorative work. Weather and curing time may extend schedules."
  },
  {
    question: "Do concrete works require permits in Toronto?",
    answer: "Yes, most concrete work requires building permits: all foundation work, retaining walls over 4 feet, driveways connecting to city roads, and structural slabs. We handle all permit applications, engineering drawings, and city inspections as part of our comprehensive service."
  },
  {
    question: "What warranty do you provide on concrete work?",
    answer: "We provide a 25-year structural warranty on all concrete work, covering material defects, workmanship issues, and structural integrity. Decorative finishes have a 5-year warranty. All warranties are transferable and backed by our $5 million liability insurance coverage."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Concrete Slabs & Floors",
    price: "$8-15/sq ft",
    description: "Basement floors, garage slabs, heated floor systems with professional installation"
  },
  {
    name: "Driveways & Patios",
    price: "$10-18/sq ft",
    description: "Durable outdoor concrete with decorative options and proper drainage"
  },
  {
    name: "Stamped Decorative Concrete",
    price: "$17-25/sq ft",
    description: "Custom patterns, colors, and finishes with protective sealing"
  }
];
---

<PageLayout {...meta}>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Concrete Works" }
      ]}
    />
  </div>

<!-- Add Service Schema -->
  <ServiceSchema
    serviceName="Concrete Works"
    description="Professional concrete contractors specializing in slabs, walls, driveways, patios, stamped concrete, and retaining walls in Toronto and GTA. NBC compliant with 25-year warranty."
    priceRange="$8-25/sq ft"
    offers={serviceOffers}
    faqs={serviceFAQs}
    areaServed={serviceAreas}
  />
  <HeroSection
    title="Professional Concrete Works"
    subtitle="Complete Concrete Solutions for Residential & Commercial Properties"
    backgroundImage="/images/concrete-works-hero.webp"
    ctaText="Get Free Quote"
    ctaLink="/free-inspection"
  />

  <!-- Service Overview -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Toronto's Trusted Concrete Contractors</h2>
        <p class="text-xl text-slate-500 max-w-3xl mx-auto">
          From foundation slabs to decorative stamped patios, we deliver superior concrete work with 25-year structural warranties. Licensed, insured, and City of Toronto approved.
        </p>
      </div>

      <!-- Key Services Grid -->
      <div class="grid md:grid-cols-4 gap-6 mb-12">
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Structural Concrete</h3>
          <p class="text-slate-500 text-sm">Foundations, walls, slabs</p>
        </div>
        
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Outdoor Living</h3>
          <p class="text-slate-500 text-sm">Patios, walkways, pools</p>
        </div>
        
        <div class="text-center">
          <div class="bg-purple-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Decorative Concrete</h3>
          <p class="text-slate-500 text-sm">Stamped, colored, exposed</p>
        </div>
        
        <div class="text-center">
          <div class="bg-orange-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">24/7 Emergency</h3>
          <p class="text-slate-500 text-sm">Repairs & replacements</p>
        </div>
      </div>
    </div>
  </section>

  <!-- NBC Concrete Specifications Section -->
  <section class="py-16 bg-cyan-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl font-bold mb-8 text-center">NBC 9.3.1 Concrete Specifications Compliance</h2>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4 text-cyan-600">Compressive Strength Requirements</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b">
                <th class="text-left py-2">Application</th>
                <th class="text-right py-2">Min. Strength</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="py-2">Walls, Columns, Footings</td>
                <td class="text-right font-bold">15 MPa</td>
              </tr>
              <tr class="border-b">
                <td class="py-2">Interior Floors</td>
                <td class="text-right font-bold">20 MPa</td>
              </tr>
              <tr class="border-b">
                <td class="py-2">Garage/Carport Floors</td>
                <td class="text-right font-bold">32 MPa</td>
              </tr>
              <tr>
                <td class="py-2">Exterior Steps</td>
                <td class="text-right font-bold">32 MPa</td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4 text-cyan-600">Water/Cement Ratios</h3>
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b">
                <th class="text-left py-2">Application</th>
                <th class="text-right py-2">Max W/C Ratio</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b">
                <td class="py-2">Foundations & Walls</td>
                <td class="text-right font-bold">0.70</td>
              </tr>
              <tr class="border-b">
                <td class="py-2">Interior Floors</td>
                <td class="text-right font-bold">0.65</td>
              </tr>
              <tr>
                <td class="py-2">Garage Floors & Steps</td>
                <td class="text-right font-bold">0.45</td>
              </tr>
            </tbody>
          </table>
          <p class="text-xs text-slate-500 mt-3">Per NBC Table 9.3.1.7</p>
        </div>
      </div>

      <div class="bg-amber-50 border-2 border-amber-400 rounded-lg p-6 mb-8">
        <h3 class="text-xl font-bold mb-4 flex items-center">
          <span class="text-2xl mr-3">❄️</span>
          Cold Weather Concrete Requirements (NBC 9.3.1.9)
        </h3>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h4 class="font-bold mb-2">When Air Temperature < 5°C (41°F):</h4>
            <ul class="space-y-2 text-sm">
              <li>• Concrete temp: 10-25°C during mixing/placing</li>
              <li>• Maintain ≥10°C for 72 hours after placing</li>
              <li>• No frozen materials in mix</li>
              <li>• Protected curing required</li>
            </ul>
          </div>
          <div>
            <h4 class="font-bold mb-2">Air Entrainment Requirements:</h4>
            <ul class="space-y-2 text-sm">
              <li>• Garage/carport floors: 5-8% air content</li>
              <li>• Exterior steps: 5-8% air content</li>
              <li>• Protects against freeze-thaw cycles</li>
              <li>• Required for de-icing salt resistance</li>
            </ul>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white rounded-lg p-6 border-2 border-slate-100">
          <h4 class="font-bold mb-3 text-lg">Aggregate Requirements</h4>
          <ul class="text-sm space-y-2">
            <li>• Max size: 1/5 form width</li>
            <li>• Max size: 1/3 slab thickness</li>
            <li>• Well-graded for density</li>
            <li>• Free from organics</li>
          </ul>
        </div>
        
        <div class="bg-white rounded-lg p-6 border-2 border-slate-100">
          <h4 class="font-bold mb-3 text-lg">Curing Standards</h4>
          <ul class="text-sm space-y-2">
            <li>• Minimum 7 days moist cure</li>
            <li>• 28-day strength testing</li>
            <li>• No load before full cure</li>
            <li>• Forms remain until set</li>
          </ul>
        </div>
        
        <div class="bg-white rounded-lg p-6 border-2 border-slate-100">
          <h4 class="font-bold mb-3 text-lg">Quality Control</h4>
          <ul class="text-sm space-y-2">
            <li>• Slump testing on-site</li>
            <li>• Cylinder samples taken</li>
            <li>• CSA A23.1 compliance</li>
            <li>• No site water addition</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Concrete Slabs Section -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Concrete Slabs & Floors</h2>
          <p class="text-slate-500 mb-6">
            Professional concrete slab installation for basements, garages, additions, and commercial spaces. We ensure proper grading, vapor barriers, and reinforcement for lasting durability. All work meets NBC Part 9 specifications.
          </p>
          
          <div class="space-y-4 mb-8">
            <h3 class="font-bold text-xl">Our Slab Services:</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Basement Floor Slabs</strong> - 4-6" reinforced, 20 MPa minimum
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Garage Floor Slabs</strong> - Heavy-duty 6", 32 MPa, 5-8% air entrainment
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Heated Floor Systems</strong> - In-floor radiant heating installation
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Polish & Epoxy Finishes</strong> - Decorative and protective coatings
                </div>
              </li>
            </ul>
          </div>
          
          <div class="bg-cyan-50 border-l-4 border-cyan-600 p-4">
            <p class="font-semibold">Starting at $8-12 per sq ft • 25-year warranty</p>
          </div>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h3 class="text-xl font-bold mb-4">Quick Slab Cost Estimate</h3>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium mb-2">Area (sq ft)</label>
              <input type="number" id="slabArea" class="w-full px-4 py-2 border rounded-lg" value="500" min="100">
            </div>
            <div>
              <label class="block text-sm font-medium mb-2">Thickness</label>
              <select id="slabThickness" class="w-full px-4 py-2 border rounded-lg">
                <option value="4">4 inches (basement)</option>
                <option value="6">6 inches (garage)</option>
                <option value="8">8 inches (commercial)</option>
              </select>
            </div>
            <button onclick="calculateSlabCost()" class="w-full bg-cyan-600 text-white py-3 rounded-lg font-semibold hover:bg-cyan-700">
              Calculate Cost
            </button>
            <div id="slabCostResult" class="hidden">
              <div class="bg-slate-50 rounded-lg p-4">
                <p class="text-sm text-slate-500">Estimated Cost:</p>
                <p class="text-2xl font-bold text-cyan-600" id="slabCostDisplay"></p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Concrete Walls Section -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <div class="bg-slate-50 rounded-lg p-8">
            <h3 class="text-xl font-bold mb-6">Wall Types & Applications</h3>
            
            <div class="space-y-6">
              <div class="border-l-4 border-cyan-600 pl-4">
                <h4 class="font-bold mb-2">Poured Concrete Walls</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Foundation walls (8-10" thick, 15 MPa min)</li>
                  <li>• Retaining walls (4-12' height)</li>
                  <li>• Privacy walls (6-8" decorative)</li>
                  <li>• 0.70 max water/cement ratio</li>
                </ul>
              </div>
              
              <div class="border-l-4 border-cyan-600 pl-4">
                <h4 class="font-bold mb-2">Concrete Block Walls</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Standard blocks (8x8x16")</li>
                  <li>• Reinforced with rebar</li>
                  <li>• Core-filled for strength</li>
                  <li>• Decorative block options</li>
                </ul>
              </div>
              
              <div class="border-l-4 border-purple-600 pl-4">
                <h4 class="font-bold mb-2">ICF Walls (Insulated)</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Superior insulation (R-22+)</li>
                  <li>• Sound dampening</li>
                  <li>• Energy efficient</li>
                  <li>• Disaster resistant</li>
                </ul>
              </div>
            </div>
            
            <div class="mt-6 p-4 bg-amber-50 rounded-lg">
              <p class="text-sm">
                <strong>Free Engineering:</strong> All retaining walls over 4' include professional engineering at no extra cost
              </p>
            </div>
          </div>
        </div>
        
        <div class="order-1 md:order-2">
          <h2 class="text-3xl font-bold mb-6">Concrete & Block Walls</h2>
          <p class="text-slate-500 mb-6">
            Expert installation of poured concrete walls, concrete block walls, and ICF systems. From foundation walls to decorative garden walls, we ensure structural integrity and aesthetic appeal.
          </p>
          
          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-slate-50 rounded-lg p-4 text-center">
              <div class="text-3xl font-bold text-cyan-600">500+</div>
              <div class="text-sm text-slate-500">Walls Built</div>
            </div>
            <div class="bg-slate-50 rounded-lg p-4 text-center">
              <div class="text-3xl font-bold text-cyan-600">100%</div>
              <div class="text-sm text-slate-500">Code Compliant</div>
            </div>
          </div>
          
          <a href="/free-inspection" class="inline-block bg-cyan-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-cyan-700">
            Get Wall Quote →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Retaining Walls Section -->
  <section class="py-16 bg-cyan-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Retaining Wall Solutions</h2>
        <p class="text-xl text-slate-500 max-w-3xl mx-auto">
          Professional retaining wall design and construction for residential and commercial properties. 
          Engineered solutions for slopes, grade changes, and erosion control.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 items-center mb-12">
        <div>
          <h3 class="text-2xl font-bold mb-6">Retaining Wall Types</h3>
          
          <div class="space-y-4">
            <div class="bg-white rounded-lg p-6 shadow-md">
              <h4 class="font-bold text-lg mb-3 text-cyan-600">Gravity Walls (Up to 4')</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Mass concrete or concrete block construction</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Relies on weight for stability</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Cost-effective for shorter walls</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Starting at $250/linear foot</span>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-6 shadow-md">
              <h4 class="font-bold text-lg mb-3 text-cyan-600">Cantilever Walls (4-10')</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Reinforced concrete with L-shaped footing</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>P.Eng structural design included</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Efficient for medium heights</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Starting at $500/linear foot</span>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-lg p-6 shadow-md">
              <h4 class="font-bold text-lg mb-3 text-purple-600">Counterfort Walls (10'+)</h4>
              <ul class="space-y-2 text-sm">
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Buttressed design for tall walls</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Maximum structural efficiency</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Commercial & infrastructure projects</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-600 mr-2">✓</span>
                  <span>Custom engineered pricing</span>
                </li>
              </ul>
            </div>
          </div>
        </div>

        <div>
          <div class="bg-gradient-to-br from-blue-600 to-purple-600 text-white rounded-lg p-8">
            <h3 class="text-2xl font-bold mb-6">Engineering & Design Features</h3>
            
