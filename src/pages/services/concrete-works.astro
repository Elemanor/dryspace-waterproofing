      <div class="bg-white rounded-lg shadow-xl p-8 max-w-2xl mx-auto">
        <h3 class="text-2xl font-bold mb-6 text-center">Retaining Wall Cost Estimator</h3>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-semibold mb-2">Wall Height (feet)</label>
            <select id="wallHeight" class="w-full px-4 py-2 border rounded-lg">
              <option value="3">3 feet</option>
              <option value="4">4 feet</option>
              <option value="6">6 feet</option>
              <option value="8">8 feet</option>
              <option value="10">10 feet</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-semibold mb-2">Wall Length (feet)</label>
            <input type="number" id="wallLength" class="w-full px-4 py-2 border rounded-lg" value="50" min="10">
          </div>
          
          <div>
            <label class="block text-sm font-semibold mb-2">Wall Type</label>
            <select id="wallType" class="w-full px-4 py-2 border rounded-lg">
              <option value="gravity">Gravity Wall (up to 4')</option>
              <option value="cantilever">Cantilever Wall (4-10')</option>
              <option value="counterfort">Counterfort Wall (10'+)</option>
            </select>
          </div>
          
          <button onclick="calculateRetainingWallCost()" class="w-full bg-cyan-600 text-white py-3 rounded-lg font-semibold hover:bg-cyan-700">
            Calculate Estimate
          </button>
          
          <div id="wallCostResult" class="hidden">
            <div class="bg-cyan-50 rounded-lg p-6">
              <p class="text-sm text-slate-500 mb-2">Estimated Cost Range:</p>
              <p class="text-3xl font-bold text-cyan-600" id="wallCostDisplay"></p>
              <p class="text-xs text-slate-400 mt-2">*Includes materials, labor, drainage, and engineering (if required)</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    function calculateRetainingWallCost() {
      const height = parseFloat(document.getElementById('wallHeight').value);
      const length = parseFloat(document.getElementById('wallLength').value);
      const type = document.getElementById('wallType').value;
      
      let costPerFoot = 250;
      
      if (type === 'gravity') {
        costPerFoot = height <= 3 ? 250 : 350;
      } else if (type === 'cantilever') {
        costPerFoot = 450 + (height - 4) * 50;
      } else if (type === 'counterfort') {
        costPerFoot = 750 + (height - 10) * 100;
      }
      
      const totalCost = costPerFoot * length;
      const minCost = totalCost * 0.9;
      const maxCost = totalCost * 1.1;
      
      document.getElementById('wallCostDisplay').textContent = 
        `$${minCost.toLocaleString()} - $${maxCost.toLocaleString()}`;
      document.getElementById('wallCostResult').classList.remove('hidden');
    }
  </script>

