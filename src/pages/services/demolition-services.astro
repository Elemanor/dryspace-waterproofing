---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroSection from '../../components/widgets/Hero.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const meta = {
  title: "Professional Demolition Services Toronto | Complete & Selective Demo | Asbestos Removal",
  description: "Licensed demolition contractors in Toronto. Complete building demolition, selective interior demo, asbestos abatement, concrete removal. Fully insured with proper permits and waste disposal.",
  keywords: "demolition Toronto, selective demolition, asbestos removal, building demolition, interior demolition, concrete demolition, hazardous material removal, demolition contractors",
  canonical: "https://dryspacewaterproofing.ca/services/demolition-services"
};

// Service-specific FAQs
const demolitionFAQs = [
  {
    question: "How much does demolition cost in Toronto?",
    answer: "Demolition costs vary by project scope: Complete house demolition ranges $16,000-50,000, selective interior demolition $5-15/sq ft, asbestos removal $17-25/sq ft, and concrete breaking $5-15/sq ft. Factors include building size, materials, hazmat presence, permits, and disposal requirements. We provide free detailed quotes including all costs."
  },
  {
    question: "How long does a typical demolition project take?",
    answer: "Timeline depends on project complexity: Complete building demolition takes 3-7 days, interior gutting 2-5 days, selective wall removal 1-2 days, and asbestos abatement 2-5 days. Factors affecting timeline include permits, weather, hazmat removal, and site access. We provide realistic schedules with each quote."
  },
  {
    question: "What are the benefits of professional demolition services?",
    answer: "Professional demolition ensures safety compliance, proper permits, hazmat identification and removal, efficient material recycling (85% rate), proper waste disposal, structural engineering consultation, dust control, and comprehensive insurance coverage. Our licensed team handles all regulations and documentation."
  },
  {
    question: "When do I need professional demolition services?",
    answer: "Professional demolition is required for: complete building removal, asbestos-containing materials, load-bearing wall modifications, concrete/masonry structures, projects requiring permits, occupied building renovations, hazmat situations, and when insurance coverage is needed. DIY demolition often violates codes and insurance policies."
  }
];

// Service offers (pricing tiers)
const demolitionOffers = [
  {
    name: "Selective Interior Demolition",
    price: "$5-15/sq ft",
    description: "Interior wall removal, kitchen/bathroom gutting, flooring removal, drywall demo. Includes dust control, debris removal, and site cleanup. Perfect for renovations and remodeling projects."
  },
  {
    name: "Complete Building Demolition",
    price: "$16,000-50,000",
    description: "Full structure removal including permits, utility disconnection, hazmat survey, systematic demolition, foundation removal, site grading, and complete cleanup. All-inclusive service."
  },
  {
    name: "Hazardous Material Abatement",
    price: "$17-25/sq ft",
    description: "Licensed Type 3 asbestos removal, lead paint abatement, mold remediation, containment setup, air monitoring, safe disposal, and clearance testing by certified professionals."
  }
];
---

<PageLayout {...meta}>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Demolition Services" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Professional Demolition Services"
    description="Licensed demolition contractors providing complete building demolition, selective interior demo, asbestos abatement, and concrete removal in Toronto. Fully insured with proper permits and waste disposal."
    priceRange="$5-50,000"
    areaServed={['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'North York', 'Scarborough']}
    offers={demolitionOffers}
    faqs={demolitionFAQs}
  />
  <HeroSection
    title="Professional Demolition Services"
    subtitle="Licensed & Insured Demolition Contractors for Safe, Efficient Removal"
    backgroundImage="/images/demolition-hero.webp"
    ctaText="Get Demolition Quote"
    ctaLink="/free-inspection"
  />

  <!-- Service Overview -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Complete Demolition Solutions</h2>
        <p class="text-xl text-slate-500 max-w-3xl mx-auto">
          From complete building demolition to selective interior removal, we handle all demolition projects with safety, efficiency, and environmental responsibility. Licensed, bonded, and fully insured.
        </p>
      </div>

      <!-- Safety Certifications Banner -->
      <div class="bg-cyan-50 border-2 border-cyan-600 rounded-lg p-6 mb-12">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div class="flex items-start gap-4">
            <div class="bg-cyan-600 text-white rounded-full p-3">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-bold text-cyan-800 mb-1">Fully Licensed & Certified</h3>
              <p class="text-cyan-700">WSIB Coverage • $5M Liability • Asbestos Certified • City Licensed</p>
            </div>
          </div>
          <div class="flex gap-3">
            <div class="text-center">
              <div class="text-2xl font-bold text-cyan-700">25yr+</div>
              <div class="text-sm text-slate-500">Experience</div>
            </div>
            <div class="text-center">
              <div class="text-2xl font-bold text-cyan-700">100%</div>
              <div class="text-sm text-slate-500">Safety Record</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Service Categories -->
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="bg-red-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Complete Demolition</h3>
          <p class="text-slate-500 text-sm">Full building teardown with site clearing</p>
        </div>
        
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Selective Demo</h3>
          <p class="text-slate-500 text-sm">Interior walls, floors, specific areas</p>
        </div>
        
        <div class="text-center">
          <div class="bg-amber-50 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Asbestos Removal</h3>
          <p class="text-slate-500 text-sm">Safe abatement by certified professionals</p>
        </div>
        
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <svg class="w-10 h-10 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Waste Management</h3>
          <p class="text-slate-500 text-sm">Recycling & proper disposal</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Complete Building Demolition -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Complete Building Demolition</h2>
          <p class="text-slate-500 mb-6">
            Professional top-to-bottom demolition services for residential and commercial structures. We handle everything from permits to final site clearing, ensuring safe and efficient complete removal.
          </p>
          
          <div class="space-y-4 mb-8">
            <h3 class="font-bold text-xl">Our Complete Demo Process:</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Permits & Planning</strong>
                  <p class="text-sm text-slate-500">City permits, utility disconnections, neighbor notifications</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Hazardous Material Survey</strong>
                  <p class="text-sm text-slate-500">Asbestos, lead paint, and other hazmat identification</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Systematic Demolition</strong>
                  <p class="text-sm text-slate-500">Top-down approach for maximum safety and efficiency</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Foundation Removal</strong>
                  <p class="text-sm text-slate-500">Complete basement and foundation excavation</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="bg-cyan-50 border-l-4 border-cyan-600 p-4">
            <p class="font-semibold">Complete Demo: $16,000-50,000 • 3-7 days • All permits included</p>
          </div>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h3 class="text-xl font-bold mb-6">Building Types We Demolish</h3>
          
          <div class="space-y-4">
            <div class="border-b pb-4">
              <h4 class="font-bold mb-2">Residential Structures</h4>
              <ul class="text-sm text-slate-500 space-y-1">
                <li>• Single-family homes</li>
                <li>• Garages and sheds</li>
                <li>• Additions and decks</li>
                <li>• Mobile homes</li>
              </ul>
            </div>
            
            <div class="border-b pb-4">
              <h4 class="font-bold mb-2">Commercial Buildings</h4>
              <ul class="text-sm text-slate-500 space-y-1">
                <li>• Office buildings (up to 3 stories)</li>
                <li>• Retail spaces</li>
                <li>• Warehouses</li>
                <li>• Industrial facilities</li>
              </ul>
            </div>
            
            <div>
              <h4 class="font-bold mb-2">Specialized Structures</h4>
              <ul class="text-sm text-slate-500 space-y-1">
                <li>• Swimming pools</li>
                <li>• Concrete structures</li>
                <li>• Chimneys and towers</li>
                <li>• Underground tanks</li>
              </ul>
            </div>
          </div>
          
          <button class="w-full bg-cyan-600 text-white py-3 rounded-lg font-semibold hover:bg-cyan-700 mt-6">
            Get Demolition Quote
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Selective Demolition -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <div class="bg-slate-50 rounded-lg p-8">
            <h3 class="text-xl font-bold mb-6">Selective Demo Services</h3>
            
            <div class="space-y-6">
              <div>
                <h4 class="font-bold mb-3">Interior Demolition</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Non-load bearing walls</li>
                  <li>• Kitchen & bathroom gutting</li>
                  <li>• Flooring removal</li>
                  <li>• Ceiling & drywall removal</li>
                  <li>• Staircase removal</li>
                </ul>
              </div>
              
              <div>
                <h4 class="font-bold mb-3">Structural Modifications</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Load-bearing wall removal</li>
                  <li>• Window & door openings</li>
                  <li>• Floor system modifications</li>
                  <li>• Beam & column removal</li>
                  <li>• Foundation alterations</li>
                </ul>
              </div>
              
              <div>
                <h4 class="font-bold mb-3">Exterior Selective Demo</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Deck & porch removal</li>
                  <li>• Siding stripping</li>
                  <li>• Roof section removal</li>
                  <li>• Chimney demolition</li>
                  <li>• Concrete cutting</li>
                </ul>
              </div>
            </div>
            
            <div class="mt-6 p-4 bg-amber-50 rounded-lg">
              <p class="text-sm">
                <strong>Dust Control:</strong> HEPA filtration, plastic barriers, and negative air pressure for occupied buildings
              </p>
            </div>
          </div>
        </div>
        
        <div class="order-1 md:order-2">
          <h2 class="text-3xl font-bold mb-6">Selective & Interior Demolition</h2>
          <p class="text-slate-500 mb-6">
            Precise removal of specific building components while preserving surrounding structures. Perfect for renovations, remodeling, and building modifications where only certain areas need demolition.
          </p>
          
          <div class="bg-cyan-50 rounded-lg p-6 mb-8">
            <h4 class="font-bold mb-3">Why Choose Selective Demo?</h4>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-cyan-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Cost-effective for renovations
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-cyan-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Minimal disruption to occupied spaces
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-cyan-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Preserves valuable materials
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-cyan-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Precise structural modifications
              </li>
            </ul>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-lg p-4 text-center shadow">
              <div class="text-2xl font-bold text-cyan-600">$50-150</div>
              <div class="text-sm text-slate-500">Per square foot</div>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow">
              <div class="text-2xl font-bold text-cyan-600">1-5 days</div>
              <div class="text-sm text-slate-500">Typical timeline</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Asbestos Removal -->
  <section class="py-16 bg-red-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="bg-red-100 border-2 border-red-600 rounded-lg p-8 mb-12">
        <div class="flex items-start gap-4">
          <div class="bg-red-600 text-white rounded-full p-3">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
          </div>
          <div>
            <h2 class="text-3xl font-bold text-red-900 mb-2">Asbestos & Hazardous Material Removal</h2>
            <p class="text-red-800 font-semibold">
              Licensed Type 3 asbestos abatement contractor. Full containment, air monitoring, and safe disposal following Ontario Regulation 278/05.
            </p>
          </div>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <!-- Asbestos Services -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4">Asbestos Abatement</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start">
              <span class="text-red-600 mr-2">•</span>
              <div>
                <strong>Vermiculite insulation</strong>
                <p class="text-slate-500">Attic and wall cavity removal</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-2">•</span>
              <div>
                <strong>Pipe & boiler insulation</strong>
                <p class="text-slate-500">Mechanical system abatement</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-2">•</span>
              <div>
                <strong>Floor tiles & mastic</strong>
                <p class="text-slate-500">9x9 and 12x12 VAT removal</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-2">•</span>
              <div>
                <strong>Ceiling tiles & texture</strong>
                <p class="text-slate-500">Popcorn ceiling removal</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-red-600 mr-2">•</span>
              <div>
                <strong>Siding & roofing</strong>
                <p class="text-slate-500">Transite and shingle removal</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Lead & Mold -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4">Lead & Mold Remediation</h3>
          <ul class="space-y-3 text-sm">
            <li class="flex items-start">
              <span class="text-amber-500 mr-2">•</span>
              <div>
                <strong>Lead paint removal</strong>
                <p class="text-slate-500">RRP certified procedures</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-amber-500 mr-2">•</span>
              <div>
                <strong>Lead pipe replacement</strong>
                <p class="text-slate-500">Water service upgrades</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-amber-500 mr-2">•</span>
              <div>
                <strong>Mold remediation</strong>
                <p class="text-slate-500">HEPA containment & removal</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-amber-500 mr-2">•</span>
              <div>
                <strong>Contaminated soil</strong>
                <p class="text-slate-500">Excavation and disposal</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="text-amber-500 mr-2">•</span>
              <div>
                <strong>PCB materials</strong>
                <p class="text-slate-500">Caulking and ballast removal</p>
              </div>
            </li>
          </ul>
        </div>

        <!-- Safety Process -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <h3 class="text-xl font-bold mb-4">Our Safety Process</h3>
          <ol class="space-y-3 text-sm">
            <li class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs mr-2 flex-shrink-0">1</span>
              <div>
                <strong>Testing & Assessment</strong>
                <p class="text-slate-500">Lab analysis and scope development</p>
              </div>
            </li>
            <li class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs mr-2 flex-shrink-0">2</span>
              <div>
                <strong>Containment Setup</strong>
                <p class="text-slate-500">Negative air pressure barriers</p>
              </div>
