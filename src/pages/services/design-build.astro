        <div class="max-w-4xl mx-auto">
          <h2 class="text-3xl font-bold mb-12 text-center">Our Design-Build Process</h2>
          
          <div class="space-y-6">
            <div class="flex items-start">
              <div class="bg-purple-600 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">
