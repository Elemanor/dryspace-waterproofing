---
import Layout from '../../layouts/Layout.astro';
import ContactCTA from '../../components/sections/CTA.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

const title = "Turnkey Design-Build Solutions | Office Fit-Out | Toronto";
const description = "Complete turnkey design-build services in Toronto. Office fit-outs, commercial renovations, basement conversions. From concept to completion - one contract, one team.";

// Service-specific FAQs for ServiceSchema
const designBuildFAQs = [
  {
    question: "How much do design-build services cost in Toronto?",
    answer: "Design-build costs vary by project type: Office fit-outs $85-150/sq ft, retail renovations $100-200/sq ft, restaurant buildouts $150-300/sq ft, basement conversions $54,000-150,000, and residential additions $200-400/sq ft. Costs include design, permits, construction, project management, and warranties. Fixed-price contracts eliminate change order surprises."
  },
  {
    question: "How long does a design-build project take?",
    answer: "Design-build timeline depends on scope: Office fit-outs 6-12 weeks, retail renovations 8-16 weeks, restaurant construction 12-20 weeks, basement conversions 6-12 weeks. Design-build process saves 20-30% time compared to traditional design-bid-build by overlapping design and construction phases. Timeline includes permits and approvals."
  },
  {
    question: "What are the benefits of design-build services?",
    answer: "Design-build offers single point accountability, faster project delivery (20-30% time savings), cost certainty with fixed pricing, streamlined communication, integrated team collaboration, reduced change orders, quality assurance, and comprehensive warranties. One contract covers entire project from concept to completion."
  },
  {
    question: "When should I choose design-build services?",
    answer: "Design-build is ideal for: complex projects requiring coordination, fast-track schedules, projects with fixed budgets, commercial renovations, office fit-outs, retail buildouts, restaurant construction, and when you want single-source accountability. Perfect when design and construction expertise must work together from day one."
  }
];

// Service offers (pricing tiers)
const designBuildOffers = [
  {
    name: "Office Fit-Out Solutions",
    price: "$85-150/sq ft",
    description: "Complete office transformation including space planning, partition walls, MEP systems, flooring, ceiling, custom millwork, technology integration, and after-hours scheduling to minimize business disruption."
  },
  {
    name: "Commercial Renovation",
    price: "$100-300/sq ft",
    description: "Full commercial buildouts including retail spaces, restaurants, medical offices, and specialty facilities. Design, permits, construction, MEP systems, finishes, and compliance with accessibility and fire codes."
  },
  {
    name: "Turnkey Project Management",
    price: "Custom Quote",
    description: "End-to-end project delivery with integrated design team, construction management, permit coordination, trade scheduling, quality control, and single-source warranty. Fixed-price contracts with guaranteed timelines."
  }
];
---

<Layout title={title} description={description}>
  <ServiceSchema 
    serviceName="Turnkey Design-Build Solutions"
    description="Complete turnkey design-build services in Toronto including office fit-outs, commercial renovations, and basement conversions. Integrated design and construction teams deliver faster, more cost-effective solutions with single-source accountability."
    priceRange="$85-400/sq ft"
    areaServed={['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'North York', 'Scarborough']}
    offers={designBuildOffers}
    faqs={designBuildFAQs}
  />
  <main>
    <!-- Hero Section -->
    <section class="relative py-20 bg-gradient-to-b from-purple-50 to-white">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Turnkey Design-Build Solutions
          </h1>
          <p class="text-xl text-slate-500 mb-8">
            From Concept to Completion - One Team, One Contract, One Vision
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-purple-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-purple-700 transition">
              Start Your Project
            </a>
            <a href="tel:437-545-0067" class="border-2 border-purple-600 text-purple-600 px-8 py-3 rounded-lg font-semibold hover:bg-purple-50 transition">
              📞 437-545-0067
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Design-Build Advantage -->
    <section class="py-16 bg-slate-50">
