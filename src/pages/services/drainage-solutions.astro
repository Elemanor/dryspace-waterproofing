---
import PageLayout from "../../layouts/PageLayout.astro";
import ServiceHero from "../../components/sections/ServiceHero.astro";
import TrustBar from "../../components/sections/TrustBar.astro";
import ServiceProcess from "../../components/sections/ServiceProcess.astro";
import ServicePricing from "../../components/sections/ServicePricing.astro";
import CTABand from "../../components/sections/CTABand.astro";
import SectionHeader from "../../components/sections/SectionHeader.astro";
import ServiceSchema from "../../components/ServiceSchema.astro";
import InternalLinks from "../../components/InternalLinks.astro";

const serviceFAQs = [
  {
    question: "What is the difference between French drains and weeping tile?",
    answer: "French drains and weeping tile are essentially the same system - perforated pipes that collect and redirect water. The term 'weeping tile' is more common in Canada, while 'French drain' is used internationally. Both systems use 4-inch perforated pipe surrounded by gravel to manage groundwater."
  },
  {
    question: "How much does drainage system installation cost in Toronto?",
    answer: "Interior water removal systems cost $150-200 per linear foot, while exterior French drains range from $85-150 per linear foot. Complete system installation for an average home ranges from $8,650-25,000 depending on the type and complexity."
  },
  {
    question: "Do I need interior or exterior drainage?",
    answer: "Exterior water removal is ideal for new construction or major renovations as it stops water before entering. Interior systems work year-round without excavation and are perfect for existing homes. Many properties benefit from both systems working together."
  },
  {
    question: "How long do drainage systems last?",
    answer: "Properly installed water removal systems last 30-75 years. Interior systems typically last 50+ years, while exterior French drains can last 75+ years with proper maintenance. Regular inspection and cleaning extends system life."
  }
];

const serviceOffers = [
  {
    name: "Interior Weeping Tile System",
    price: "$8,650-15,000",
    description: "Complete interior perimeter system with sump pump"
  },
  {
    name: "Exterior French Drain",
    price: "$11,000-25,000",
    description: "Full exterior foundation water management system"
  },
  {
    name: "Surface Grading & Water Management",
    price: "$5,400-15,000",
    description: "Landscape grading with catch basins and collection swales"
  }
];

const processSteps = [
  {
    title: "Site Assessment",
    description: "Evaluate water sources, soil conditions, existing drainage, and determine optimal solution"
  },
  {
    title: "System Design",
    description: "Calculate pipe sizing, slopes, outlet locations, and integration with existing systems"
  },
  {
    title: "Professional Installation",
    description: "Excavation, pipe laying, gravel placement, connections, and proper backfilling"
  },
  {
    title: "Testing & Inspection",
    description: "Flow testing, camera inspection, municipal approval where required"
  },
  {
    title: "Site Restoration",
    description: "Landscape repair, concrete replacement, final grading, and cleanup"
  }
];

const pricingTiers = [
  {
    name: "Interior Weeping Tile System",
    price: "$8,650-15,000",
    description: "Complete interior perimeter system with sump pump",
    features: [
      "Perimeter drainage installation",
      "Sump pump integration",
      "Year-round installation",
      "Minimal landscape disruption"
    ]
  },
  {
    name: "Exterior French Drain",
    price: "$11,000-25,000",
    description: "Full exterior foundation water management",
    features: [
      "Footing-level drainage",
      "4\" Big-O perforated pipe",
      "Gravel & fabric surround",
      "Daylight or sump outlet"
    ],
    highlighted: true
  },
  {
    name: "Surface Grading & Control",
    price: "$5,400-15,000",
    description: "Landscape grading with catch basins",
    features: [
      "5% slope from foundation",
      "Drainage swales",
      "Catch basin installation",
      "Erosion control"
    ]
  }
];
---

<PageLayout
  title="Water Management Solutions Toronto | French Drains, Weeping Tile | DrySpace"
  description="Complete water management solutions including French drains, weeping tile, foundation systems, surface runoff control. NBC compliant installation. Free estimates."
>
  <!-- Schema Markup -->
  <ServiceSchema
    serviceName="Water Management Solutions"
    description="Professional water management system installation including French drains, weeping tile, foundation systems, and surface runoff control in Toronto and GTA"
    priceRange="$5,400-$27,000"
    offers={serviceOffers}
    faqs={serviceFAQs}
  />

  <ServiceHero
    title="Complete Water Management Solutions"
    description="French Drains • Weeping Tile • Foundation & Surface Drainage"
    priceRange="$5,400-$27,000"
    duration="2-5 days"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Drainage Solutions" }
    ]}
  />

  <TrustBar />

  <!-- Answer Capsule -->
  <section class="py-8 bg-white">
    <div class="container mx-auto px-4 max-w-4xl text-center">
      <p class="speakable"><strong>Drainage system installation in Toronto costs $5,000–$15,000 for French drains and weeping tile, redirecting groundwater away from foundations — the most cost-effective long-term solution for recurring basement moisture.</strong></p>
    </div>
  </section>

  <main class="section-padding">
    <!-- Overview Section -->
    <section class="container mx-auto mb-20">
      <SectionHeader
        label="Water Management"
        title="Professional Water Removal Systems for Every Need"
        description="Whether you need interior systems, exterior French drains, foundation weeping tile, or surface runoff control, we provide comprehensive solutions that meet NBC requirements and protect your property from water damage."
        centered={true}
      />

      <div class="grid md:grid-cols-4 gap-6 mt-12">
        <div class="bg-slate-50 rounded-xl p-6 shadow-card hover:shadow-card-hover transition-shadow">
          <div class="text-4xl mb-3 text-cyan-500">
            <span class="material-symbols-outlined" style="font-size: 48px; font-variation-settings: 'FILL' 1;">home</span>
          </div>
          <h3 class="font-semibold text-lg mb-2 text-navy-900">Interior Systems</h3>
          <p class="text-sm text-slate-600">Basement perimeter drains</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 shadow-card hover:shadow-card-hover transition-shadow">
          <div class="text-4xl mb-3 text-cyan-500">
            <span class="material-symbols-outlined" style="font-size: 48px; font-variation-settings: 'FILL' 1;">yard</span>
          </div>
          <h3 class="font-semibold text-lg mb-2 text-navy-900">Exterior Systems</h3>
          <p class="text-sm text-slate-600">French drains & weeping tile</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 shadow-card hover:shadow-card-hover transition-shadow">
          <div class="text-4xl mb-3 text-amber-500">
            <span class="material-symbols-outlined" style="font-size: 48px; font-variation-settings: 'FILL' 1;">foundation</span>
          </div>
          <h3 class="font-semibold text-lg mb-2 text-navy-900">Foundation</h3>
          <p class="text-sm text-slate-600">NBC compliant systems</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-6 shadow-card hover:shadow-card-hover transition-shadow">
          <div class="text-4xl mb-3 text-cyan-500">
            <span class="material-symbols-outlined" style="font-size: 48px; font-variation-settings: 'FILL' 1;">water_drop</span>
          </div>
          <h3 class="font-semibold text-lg mb-2 text-navy-900">Surface Water</h3>
          <p class="text-sm text-slate-600">Grading & catch basins</p>
        </div>
      </div>
    </section>

    <!-- Drainage Types Section -->
    <section class="container mx-auto mb-20">
      <SectionHeader
        label="Our Solutions"
        title="Water Removal Solutions"
        centered={true}
      />

      <!-- Interior Drainage -->
      <div class="mb-12">
        <div class="bg-gradient-to-br from-cyan-50 to-slate-50 rounded-2xl p-8 shadow-card">
          <h3 class="text-headline mb-6 text-navy-900">Interior Water Removal Systems</h3>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Interior Weeping Tile System</h4>
              <p class="text-slate-700 mb-4">
                Perimeter system installed inside lower level along foundation walls. Collects water and directs to sump pump.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>No exterior excavation required</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Year-round installation possible</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Integrated with sump pump system</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Minimal disruption to landscaping</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$150-200 per linear foot</div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Lower Level Floor Drains</h4>
              <p class="text-slate-700 mb-4">
                Strategic collection points for laundry, mechanical rooms, and general lower level moisture control.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>P-trap installation for sewer gas prevention</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Backwater valve options</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Connection to sanitary or storm systems</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>NBC 9.16.3 compliant installation</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$850-1,500 per drain</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Exterior Drainage -->
      <div class="mb-12">
        <div class="bg-gradient-to-br from-slate-50 to-cyan-50 rounded-2xl p-8 shadow-card">
          <h3 class="text-headline mb-6 text-navy-900">Exterior Water Removal Systems</h3>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">French Drain / Exterior Weeping Tile</h4>
              <p class="text-slate-700 mb-4">
                Perforated pipe system installed at foundation footing level to intercept and redirect groundwater.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>4" perforated Big-O pipe with filter sock</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>3/4" clear gravel surround</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Landscape fabric separation layer</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Daylight outlet or sump connection</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$85-150 per linear foot</div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Curtain Drains</h4>
              <p class="text-slate-700 mb-4">
                Interceptor drains installed uphill from structures to divert surface and subsurface water.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>2-6 feet deep trenches</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Continuous grade to outlet</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Non-perforated outlet pipe</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Effective for sloped properties</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$50-100 per linear foot</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Foundation Drainage -->
      <div class="mb-12">
        <div class="bg-gradient-to-br from-amber-50 to-slate-50 rounded-2xl p-8 shadow-card">
          <h3 class="text-headline mb-6 text-navy-900">Foundation Water Removal (NBC 9.14 Compliant)</h3>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Perimeter Foundation Drains</h4>
              <p class="text-slate-700 mb-4">
                Code-required drainage at foundation footings for all new construction and major renovations.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Minimum 100mm (4") diameter pipe</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Slope 1:100 minimum to outlet</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Granular drainage layer 150mm thick</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Cleanout access every 30m</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-amber-500 text-lg">$100-175 per linear foot</div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Window Well Drains</h4>
              <p class="text-slate-700 mb-4">
                Specialized drainage for basement window wells to prevent water accumulation and infiltration.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Connected to weeping tile system</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>6" gravel base minimum</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Galvanized steel or plastic wells</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-amber-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Optional covers for rain protection</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-amber-500 text-lg">$550-1,000 per well</div>
            </div>
          </div>
        </div>
      </div>

      <!-- Surface Drainage -->
      <div class="mb-12">
        <div class="bg-gradient-to-br from-cyan-50 to-amber-50 rounded-2xl p-8 shadow-card">
          <h3 class="text-headline mb-6 text-navy-900">Surface Water Control</h3>

          <div class="grid md:grid-cols-2 gap-8">
            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Landscape Grading & Swales</h4>
              <p class="text-slate-700 mb-4">
                Proper ground slope and drainage channels to direct water away from structures.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>5% minimum slope away from foundation</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Drainage swales for water collection</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Sodding or seeding for erosion control</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Integration with storm systems</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$17-30 per square foot</div>
            </div>

            <div class="bg-white rounded-xl p-6 shadow-card">
              <h4 class="font-bold text-lg mb-3 text-navy-900">Catch Basins & Storm Drains</h4>
              <p class="text-slate-700 mb-4">
                Collection points for surface water with connection to municipal storm or on-site management.
              </p>
              <ul class="space-y-2 text-sm text-slate-600">
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Heavy-duty grates for traffic areas</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Sediment traps for debris</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>4-6" outlet pipes</span>
                </li>
                <li class="flex items-start">
                  <span class="material-symbols-outlined text-cyan-500 mr-2 text-lg" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                  <span>Anti-freeze considerations</span>
                </li>
              </ul>
              <div class="mt-4 font-semibold text-cyan-500 text-lg">$1,600-3,000 per basin</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Specifications -->
    <section class="container mx-auto mb-20">
      <SectionHeader
        label="Code Compliance"
        title="NBC Water Management Requirements"
        centered={true}
      />

      <div class="bg-slate-50 rounded-2xl p-8 shadow-card">
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="font-bold text-xl mb-6 text-navy-900">NBC 9.14 Foundation Water Removal</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <span class="text-cyan-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.2.1:</strong> Water removal required where exterior grade is higher than interior</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.3.1:</strong> Minimum 100mm diameter perforated pipe</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.3.3:</strong> Top of pipe below bottom of floor slab</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.4.1:</strong> Granular water removal layer requirements</span>
              </li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="font-bold text-xl mb-6 text-navy-900">NBC 9.14.6 Surface Water Control</h3>
            <ul class="space-y-4">
              <li class="flex items-start">
                <span class="text-amber-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.6.1:</strong> Surface grading 5% minimum for 1.5m</span>
              </li>
              <li class="flex items-start">
                <span class="text-amber-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.6.2:</strong> Catch basins where required</span>
              </li>
              <li class="flex items-start">
                <span class="text-amber-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.6.3:</strong> Window well water removal provisions</span>
              </li>
              <li class="flex items-start">
                <span class="text-amber-500 mr-3 font-bold text-lg">§</span>
                <span class="text-slate-700"><strong class="text-navy-900">9.14.6.4:</strong> Downspout extensions 1.8m minimum</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Comparison Table -->
    <section class="container mx-auto mb-20">
      <SectionHeader
        label="Compare Systems"
        title="Water Management System Comparison"
        centered={true}
      />

      <div class="overflow-x-auto bg-white rounded-2xl shadow-card">
        <table class="min-w-full">
          <thead class="bg-navy-900 text-white">
            <tr>
              <th class="px-6 py-4 text-left font-semibold">System Type</th>
              <th class="px-6 py-4 text-left font-semibold">Best For</th>
              <th class="px-6 py-4 text-left font-semibold">Installation</th>
              <th class="px-6 py-4 text-center font-semibold">Cost Range</th>
              <th class="px-6 py-4 text-center font-semibold">Lifespan</th>
            </tr>
          </thead>
