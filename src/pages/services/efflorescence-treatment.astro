---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Efflorescence Treatment" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Efflorescence Removal & Treatment"
    description="Professional efflorescence removal and moisture control in Toronto. Eliminate white powder deposits and prevent recurrence with comprehensive waterproofing solutions."
    priceRange="$1,600-$4,300"
    offers={serviceOffers}
    faqs={schemaFAQs}
  />
  <!-- Hero Section -->
  <Hero 
    title="Efflorescence Treatment"
    subtitle="Remove white powder deposits and treat the underlying moisture problem permanently."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/Efflorescence.webp"
    badge="Permanent Solution"
  />

  <!-- Stats -->
  <Stats />

  <!-- Features -->
  <Features 
    title="Why Choose Our Service"
    subtitle="Professional solutions backed by experience and warranty"
    features={serviceFeatures}
    columns={3}
  />

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ -->
  <FAQ 
    title="Common Questions"
    subtitle="Everything you need to know about our service"
    faqs={serviceFAQs}
    columns={1}
  />

  <!-- Internal Links -->
  <InternalLinks 
    category="waterproofing"
    currentPage="efflorescence-treatment"
    limit={5}
  />

  <!-- CTA -->
  <CTA 
    title="Ready to Get Started?"
    subtitle="Schedule your free inspection today and protect your home."
    primaryCTA={{ text: "Schedule Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    background="gradient"
  />
</PageLayout>