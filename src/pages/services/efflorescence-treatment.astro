import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const pageTitle = "Efflorescence Removal Toronto | White Powder on Walls";
const pageDescription = "Efflorescence removal in Toronto. Eliminate white powder on basement walls. Treat the root cause, prevent recurrence. Professional solutions. 25-year warranty. Free inspection.";

// Service-specific features
const serviceFeatures = [
  {
    icon: '',
    title: 'Moisture Elimination',
    description: 'Industry-leading solution with proven results and long-term protection.',
    highlight: true
  },
  {
    icon: '',
    title: 'Competitive Pricing',
    description: 'Fair, transparent pricing. $1,100-3,000. Financing available.',
    highlight: true
  },
  {
    icon: '',
    title: '25-Year Warranty',
    description: 'Transferable warranty that adds value to your home.',
    highlight: true
  },
  {
    icon: '',
    title: 'Fast Service',
    description: 'Quick response times with professional installation.'
  },
  {
    icon: '‍',
    title: 'Licensed & Insured',
    description: 'Fully licensed, bonded, and insured for your protection.'
  },
  {
    icon: '',
    title: '24/7 Support',
    description: 'Emergency service and ongoing support whenever you need it.'
  }
];

