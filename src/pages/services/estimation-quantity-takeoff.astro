---
import Layout from '../../layouts/Layout.astro';
import ContactCTA from '../../components/sections/CTA.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

const title = "Construction Estimation & Quantity Takeoff Services | Toronto";
const description = "Professional construction estimation and quantity takeoff services in Toronto. Accurate material takeoffs, cost estimation, bid preparation, value engineering. Digital takeoffs with Bluebeam & PlanSwift.";

// Service-specific FAQs for ServiceSchema
const estimationFAQs = [
  {
    question: "How much do construction estimation services cost in Toronto?",
    answer: "Construction estimation costs depend on project complexity: Quantity takeoffs from $550 per project, cost estimation 2-3% of project value, bid preparation from $1,600 per bid, change order pricing $150-300/hour. Factors include project size, trade complexity, timeline, and detail level required. We offer competitive rates with 98% accuracy guarantee."
  },
  {
    question: "How long do quantity takeoffs and estimates take?",
    answer: "Timeline varies by project scope: Simple residential takeoffs 1-2 days, commercial projects 3-5 days, complex developments 1-2 weeks. Rush service available with 24-48 hour turnaround. We provide detailed schedules and progress updates throughout the estimation process."
  },
  {
    question: "What are the benefits of professional estimation services?",
    answer: "Professional estimation provides 98% accuracy, competitive bid preparation, value engineering opportunities, cost control, risk mitigation, detailed documentation, software efficiency, trade expertise, and time savings. Our estimates help contractors win more bids and improve project profitability."
  },
  {
    question: "When do I need professional estimation and takeoff services?",
    answer: "Professional estimation is essential for: competitive bidding, complex projects, time-sensitive proposals, accurate material ordering, change order pricing, value engineering studies, budget planning, and when internal resources are limited. Critical for maintaining profitability and winning bids."
  }
];

// Service offers (pricing tiers)
const estimationOffers = [
  {
    name: "Quantity Takeoff Services",
    price: "From $550",
    description: "Material quantities, labor hours calculation, equipment requirements, detailed measurements, area and volume calculations, and count itemization using advanced digital takeoff software."
  },
  {
    name: "Complete Cost Estimation",
    price: "2-3% of project value",
    description: "Detailed cost breakdowns including material pricing, labor costs, subcontractor pricing, overhead and profit calculations, contingency planning, and competitive market analysis."
  },
  {
    name: "Professional Bid Preparation",
    price: "From $1,600",
    description: "Complete bid packages with scope of work writing, tender document review, competitive analysis, submission formatting, and clarification support to win more contracts."
  }
];
---

<Layout title={title} description={description}>
  <ServiceSchema 
    serviceName="Construction Estimation & Quantity Takeoff Services"
    description="Professional construction estimation and quantity takeoff services in Toronto with 98% accuracy. Digital takeoffs, cost estimation, bid preparation, and value engineering using advanced software and decades of construction experience."
    priceRange="$550-15,000+"
    areaServed={['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'North York', 'Scarborough']}
    offers={estimationOffers}
    faqs={estimationFAQs}
  />
  <main>
    <!-- Hero Section -->
    <section class="relative py-20 bg-gradient-to-b from-indigo-50 to-white">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            Professional Estimation & Quantity Takeoff Services
          </h1>
          <p class="text-xl text-slate-500 mb-8">
            Accurate Cost Estimates & Material Takeoffs for Construction Projects
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-cyan-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-cyan-700 transition">
              Get Estimate Quote
            </a>
            <a href="tel:437-545-0067" class="border-2 border-indigo-600 text-cyan-600 px-8 py-3 rounded-lg font-semibold hover:bg-cyan-50 transition">
              📞 437-545-0067
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview Section -->
    <section class="py-16 bg-slate-50">
