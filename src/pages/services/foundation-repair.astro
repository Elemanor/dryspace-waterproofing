---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/sections/ServiceHero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceProcess from '../../components/sections/ServiceProcess.astro';
import ServicePricing from '../../components/sections/ServicePricing.astro';
import CTABand from '../../components/sections/CTABand.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import BeforeAfterGallery from '../../components/BeforeAfterGallery.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import TechnicalDrawings from '../../components/TechnicalDrawings.astro';
import ContactForm from '../../components/ContactForm.astro';
import ServiceImageGallery from '../../components/ServiceImageGallery.astro';
import SubsidyTeaser from '../../components/SubsidyTeaser.astro';
import PermitTeaser from '../../components/PermitTeaser.astro';
import CostCalculator from '../../components/CostCalculator.astro';
import NBCWaterTableSoilMovement from '../../components/NBCWaterTableSoilMovement.astro';
import NBCSoilBearingSpecs from '../../components/NBCSoilBearingSpecs.astro';
import NBCLateralPressure from '../../components/NBCLateralPressure.astro';

// SEO-optimized metadata focused on repair methods
const pageTitle = "Foundation Repair | Structural Solutions | DrySpace";
const pageDescription = "Structural crack repair & building support solutions. Epoxy injection, carbon fiber, wall anchors. 25-year warranty. Call 437-545-0067.";

// Repair methods and techniques
const repairMethods = [
  "Epoxy Injection",
  "Polyurethane Injection",
  "Carbon Fiber Straps",
  "Wall Anchors",
  "Steel I-Beams",
  "Helical Piers",
  "Push Piers"
];

// Common structural problems in Toronto
const structuralProblems = [
  {
    type: "STRUCTURAL CRACKS",
    severity: "CRITICAL",
    description: "Cracks wider than 1/4 inch indicate structural movement",
    solution: "Carbon fiber reinforcement or steel piers"
  },
  {
    type: "STRUCTURAL SETTLEMENT",
    severity: "SEVERE",
    description: "Uneven floors, sticking doors, gaps around windows",
    solution: "Push piers or helical piers to stabilize"
  },
  {
    type: "BOWING WALLS",
    severity: "DANGEROUS",
    description: "Walls curving inward from hydrostatic pressure",
    solution: "Wall anchors or carbon fiber straps"
  },
  {
    type: "WATER INFILTRATION",
    severity: "PROGRESSIVE",
    description: "Water entering through structural cracks",
    solution: "Crack injection and exterior moisture barriers"
  }
];

// Pricing information
const pricingInfo = {
  crackRepair: "$550-$1,600 per crack",
  settlement: "$16,000-$43,000",
  bowingWalls: "$5,400-$16,000",
  fullStructural: "$32,000-$76,000"
};

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "How much does structural repair cost in Toronto?",
    answer: "Structural repair costs vary widely: crack repair $550-$1,600, settlement repair $16,000-$43,000, bowing wall repair $5,400-$16,000, and full building support repair $32,000-$76,000. Costs depend on damage severity, repair method, and structural requirements."
  },
  {
    question: "How long does structural repair take?",
    answer: "Structural repair timelines vary by scope: minor crack repairs take 1 day, wall anchoring takes 2-3 days, pier installation takes 4-6 days, and full building support repairs can take 1-2 weeks. We provide detailed timelines during assessment."
  },
  {
    question: "What are signs I need structural repair?",
    answer: "Warning signs include cracks wider than 1/4 inch, uneven floors, sticking doors/windows, gaps around windows, bowing walls, water infiltration, and visible settlement. These problems worsen rapidly and require immediate professional assessment."
  },
  {
    question: "Do you provide engineering certifications for structural repairs?",
    answer: "Yes! All major building support repairs include structural engineer reports, load calculations, soil analysis, and as-built drawings. Our licensed P.Eng certifies all work for permits, insurance, and resale requirements."
  },
  {
    question: "What warranty do you offer on structural repair?",
    answer: "We provide a 25-year structural warranty on pier systems, lifetime installation warranty, and 100% transferable coverage. Our warranties add value to your home and provide long-term peace of mind."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Structural Crack Repair",
    price: "$550-$1,600",
    description: "Professional crack injection using polyurethane or epoxy for structural and water-related cracks."
  },
  {
    name: "Structural Stabilization",
    price: "$16,000-$43,000",
    description: "Push pier or helical pier systems to permanently stabilize settling structures with engineering certification."
  },
  {
    name: "Complete Structural Rebuild",
    price: "$32,000-$76,000",
    description: "Full structural replacement with underpinning, moisture protection, and upgrades for severely compromised bases."
  }
];

// Process steps
const processSteps = [
  {
    number: "01",
    title: "Structural Assessment",
    description: "Licensed engineer inspection with laser measurements, crack width monitoring, soil analysis, and photo documentation. Engineering calculations and repair plan development."
  },
  {
    number: "02",
    title: "Site Preparation",
    description: "Utility marking, careful excavation to foundation, soil removal, foundation cleaning, and hydraulic equipment setup with safety barriers."
  },
  {
    number: "03",
    title: "Pier Installation",
    description: "Drive piers to bedrock or load-bearing strata, verify depth with pressure gauges, install bracket assemblies, and connect to structural base."
  },
  {
    number: "04",
    title: "Lifting & Stabilization",
    description: "Synchronized hydraulic lifting with continuous laser monitoring, crack closure observation, final positioning, and permanent locking."
  },
  {
    number: "05",
    title: "Waterproofing",
    description: "Crack sealing and injection, membrane application, drainage improvement, proper backfill grading, and landscape restoration."
  },
  {
    number: "06",
    title: "Documentation",
    description: "Final measurements, photo documentation, warranty registration, maintenance instructions, and engineer's certificate for permits."
  }
];

// Pricing tiers
const pricingTiers = [
  {
    name: "Crack Repair",
    price: "$550-$1,600",
    description: "Professional crack injection for structural and water-related cracks",
    features: [
      "Polyurethane or epoxy injection",
      "Structural crack stabilization",
      "Water leak prevention",
      "5-year warranty",
      "Single crack repair"
    ]
  },
  {
    name: "Bowing Wall Repair",
    price: "$5,400-$16,000",
    description: "Wall anchor or carbon fiber systems for bowing walls",
    features: [
      "Wall anchor installation",
      "Carbon fiber reinforcement",
      "Prevents further bowing",
      "15-year warranty",
      "Engineer certification"
    ],
    popular: true
  },
  {
    name: "Foundation Stabilization",
    price: "$16,000-$43,000",
    description: "Push pier or helical pier systems for settling foundations",
    features: [
      "Push pier or helical pier system",
      "Hydraulic lifting to original position",
      "Permanent stabilization",
      "25-year structural warranty",
      "Full P.Eng certification"
    ]
  }
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>

  <!-- ServiceSchema Component -->
  <ServiceSchema
    serviceName="Foundation Repair Toronto"
    description={pageDescription}
    priceRange="$550-$76,000"
    areaServed={repairMethods}
    offers={serviceOffers}
    faqs={serviceFAQs}
  />

  <!-- Hero Section -->
  <ServiceHero
    title="STRUCTURAL REPAIR TORONTO"
    description="Licensed structural engineers. Permanent solutions for cracks, settlement, and structural damage. 25-year transferable warranty. Emergency response 24/7."
    priceRange="$550-$76,000"
    duration="1-14 days"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Foundation Repair" }
    ]}
  />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Critical Foundation Problems Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Critical Issues"
        title="Critical Structural Problems We Fix"
        description="Toronto's extreme weather and clay soil cause serious structural issues. Don't wait - building support problems worsen rapidly."
        centered={true}
      />

      <!-- Problem Cards -->
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        {structuralProblems.map(problem => (
          <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-card hover:shadow-card-hover transition-shadow">
            <div class="flex justify-between items-start mb-4">
              <h3 class="text-headline text-slate-900 uppercase">{problem.type}</h3>
              <span class={`px-3 py-1 text-white font-bold uppercase text-sm rounded-lg ${
                problem.severity === 'CRITICAL' ? 'bg-red-600' :
                problem.severity === 'SEVERE' ? 'bg-orange-600' :
                problem.severity === 'DANGEROUS' ? 'bg-red-700' :
                'bg-amber-500'
              }`}>
                {problem.severity}
              </span>
            </div>
            <p class="text-slate-600 mb-4 leading-relaxed">{problem.description}</p>
            <div class="border-t border-slate-200 pt-4">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">PROFESSIONAL SOLUTION:</p>
              <p class="text-slate-900 font-semibold">{problem.solution}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Warning Box -->
      <div class="bg-red-600 text-white rounded-xl p-8 text-center shadow-card">
        <p class="text-2xl font-bold uppercase mb-4">
          WARNING: STRUCTURAL PROBLEMS NEVER IMPROVE ON THEIR OWN
        </p>
        <p class="text-lg mb-6">
          Delaying repairs leads to exponentially higher costs and potential structural failure
        </p>
        <a href="tel:437-545-0067" class="btn-primary inline-block bg-white text-red-600 hover:bg-slate-50">
          CALL FOR EMERGENCY ASSESSMENT: 437-545-0067
        </a>
      </div>
    </div>
  </section>

  <!-- Toronto's Unique Foundation Challenges -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Local Conditions"
          title="Why Toronto Building Structures Fail"
          description="Understanding local conditions is critical for proper repair"
          centered={true}
        />

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Local Conditions -->
          <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-6 uppercase">Toronto's Destructive Forces</h3>

            <div class="space-y-6">
              <div>
                <h4 class="font-bold text-slate-900 uppercase mb-2">Expansive Clay Soil</h4>
                <p class="text-slate-600 leading-relaxed">Toronto's clay soil expands up to 40% when wet and contracts when dry, creating massive pressure on structures. This constant movement causes cracks, settlement, and structural damage.</p>
              </div>

              <div>
                <h4 class="font-bold text-slate-900 uppercase mb-2">Freeze-Thaw Cycles</h4>
                <p class="text-slate-600 leading-relaxed">With 100+ freeze-thaw cycles annually, water in structural cracks expands when frozen, widening cracks by up to 30% each winter.</p>
              </div>

              <div>
                <h4 class="font-bold text-slate-900 uppercase mb-2">High Water Table</h4>
                <p class="text-slate-600 leading-relaxed">Areas near Lake Ontario and the Don River have water tables as shallow as 4 feet, creating constant hydrostatic pressure of up to 600 lbs per square foot.</p>
              </div>

              <div>
                <h4 class="font-bold text-slate-900 uppercase mb-2">Aging Infrastructure</h4>
                <p class="text-slate-600 leading-relaxed">60% of Toronto homes were built before 1980 with structural standards that don't meet modern requirements. Original moisture protection has failed.</p>
              </div>
            </div>
          </div>

          <!-- Neighborhood-Specific Issues -->
          <div class="bg-white border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-6 uppercase">Neighborhood-Specific Risks</h3>

            <div class="space-y-4">
              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">The Beaches / East York</h4>
                <p class="text-slate-600">Sandy soil, high water table, flood risk</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">North York / Willowdale</h4>
                <p class="text-slate-600">Clay soil, poor drainage, settlement issues</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">Etobicoke / Mimico</h4>
                <p class="text-slate-600">Creek proximity, erosion, lateral pressure</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">Scarborough Bluffs</h4>
                <p class="text-slate-600">Slope instability, erosion, foundation shift</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">High Park / Roncesvalles</h4>
                <p class="text-slate-600">Old foundations, tree roots, settlement</p>
              </div>

              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-slate-900">Downtown Core</h4>
                <p class="text-slate-600">Construction vibration, utility leaks, aged concrete</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NBC Soil and Water Table Requirements -->
  <section class="section-padding bg-cyan-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          title="Structural Engineering Requirements"
          description="All structural repairs must account for soil conditions, water table levels, and potential soil movement according to NBC 9.4.4 specifications. Our engineers assess these critical factors before any repair work."
          centered={true}
        />

        <!-- Soil Bearing Capacity -->
        <NBCSoilBearingSpecs showCalculations={false} />

        <!-- Water Table and Soil Movement -->
        <NBCWaterTableSoilMovement showPyrite={true} application="foundation" />

        <!-- Lateral Earth Pressure Requirements -->
        <NBCLateralPressure wallType="structural" showCalculations={true} />

        <div class="mt-8 grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="font-bold text-lg mb-3 text-red-600">Critical for Toronto</h3>
            <ul class="text-sm space-y-2 text-slate-600">
              <li>• Clay soil expansion/contraction</li>
              <li>• High water table near lake</li>
              <li>• 1.2m minimum depth requirement</li>
              <li>• Frost protection to 1.5m</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="font-bold text-lg mb-3 text-amber-500">Site Assessment</h3>
            <ul class="text-sm space-y-2 text-slate-600">
              <li>• Soil testing to 2× footing width</li>
              <li>• Water table monitoring</li>
              <li>• Tree root analysis</li>
              <li>• Pyrite contamination testing</li>
            </ul>
          </div>

          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="font-bold text-lg mb-3 text-cyan-500">Engineering Solutions</h3>
            <ul class="text-sm space-y-2 text-slate-600">
              <li>• Helical piers for weak soil</li>
              <li>• Drainage for water table</li>
              <li>• Underpinning for settlement</li>
              <li>• P.Eng certified designs</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Foundation Repair Methods -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Repair Methods"
          title="Structural Repair Methods"
          description="Licensed engineers determine the right solution for permanent repair"
          centered={true}
        />

        <!-- Repair Methods Grid -->
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <!-- Push Pier System -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-4 uppercase">Push Pier System</h3>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">BEST FOR:</p>
              <p class="text-slate-900">Foundation settlement, sinking foundations</p>
            </div>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">HOW IT WORKS:</p>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Steel piers driven to bedrock (40-80 feet deep)</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Hydraulic lifting to original position</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Permanent stabilization guaranteed</span>
                </li>
              </ul>
            </div>
            <div class="border-t border-slate-200 pt-4">
              <p class="font-bold text-slate-900">COST: $1,600-$3,200 PER PIER</p>
              <p class="text-slate-600">Average home needs 8-12 piers</p>
            </div>
          </div>

          <!-- Helical Pier System -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-4 uppercase">Helical Pier System</h3>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">BEST FOR:</p>
              <p class="text-slate-900">Light structures, new construction, additions</p>
            </div>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">HOW IT WORKS:</p>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Screw-like piers installed with minimal excavation</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Immediate load bearing capacity</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Less disruptive than push piers</span>
                </li>
              </ul>
            </div>
            <div class="border-t border-slate-200 pt-4">
              <p class="font-bold text-slate-900">COST: $1,300-$2,700 PER PIER</p>
              <p class="text-slate-600">Typical project needs 6-10 piers</p>
            </div>
          </div>

          <!-- Wall Anchor System -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-4 uppercase">Wall Anchor System</h3>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">BEST FOR:</p>
              <p class="text-slate-900">Bowing walls, lateral pressure, wall cracks</p>
            </div>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">HOW IT WORKS:</p>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Steel anchors installed in stable soil</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Connected to wall plates inside basement</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Gradually straightens walls over time</span>
                </li>
              </ul>
            </div>
            <div class="border-t border-slate-200 pt-4">
              <p class="font-bold text-slate-900">COST: $550-$750 PER ANCHOR</p>
              <p class="text-slate-600">Most walls need 4-8 anchors</p>
            </div>
          </div>

          <!-- Carbon Fiber Reinforcement -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-4 uppercase">Carbon Fiber Straps</h3>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">BEST FOR:</p>
              <p class="text-slate-900">Minor bowing, crack stabilization, preventive</p>
            </div>
            <div class="mb-6">
              <p class="text-sm uppercase font-bold text-slate-500 mb-2">HOW IT WORKS:</p>
              <ul class="space-y-2 text-slate-600">
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>10x stronger than steel when cured</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Epoxy-bonded to wall surface</span>
                </li>
                <li class="flex items-start">
                  <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                  <span>Minimal intrusion, can be painted</span>
                </li>
              </ul>
            </div>
            <div class="border-t border-slate-200 pt-4">
              <p class="font-bold text-slate-900">COST: $300-$450 PER STRAP</p>
              <p class="text-slate-600">Average wall needs 3-5 straps</p>
            </div>
          </div>
        </div>

        <!-- Crack Injection Methods -->
        <div class="bg-amber-500 rounded-xl p-8 shadow-card">
          <h3 class="text-headline text-navy-900 mb-6 uppercase text-center">Crack Repair Methods</h3>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="bg-white rounded-xl p-6">
              <h4 class="font-bold text-slate-900 uppercase mb-3">Polyurethane Injection</h4>
              <p class="text-slate-600 mb-3 leading-relaxed">For active water leaks. Expands to seal crack completely.</p>
              <p class="font-bold text-slate-900">$550-$850 per crack</p>
            </div>
            <div class="bg-white rounded-xl p-6">
              <h4 class="font-bold text-slate-900 uppercase mb-3">Epoxy Injection</h4>
              <p class="text-slate-600 mb-3 leading-relaxed">For structural cracks. Restores concrete strength.</p>
              <p class="font-bold text-slate-900">$650-$1,100 per crack</p>
            </div>
            <div class="bg-white rounded-xl p-6">
              <h4 class="font-bold text-slate-900 uppercase mb-3">Hydraulic Cement</h4>
              <p class="text-slate-600 mb-3 leading-relaxed">For minor surface cracks. Quick temporary fix.</p>
              <p class="font-bold text-slate-900">$300-$550 per crack</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <ServiceProcess
    steps={processSteps}
    title="OUR STRUCTURAL REPAIR PROCESS"
    label="Engineered Solutions"
  />

  <!-- Investment & ROI Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Investment"
          title="Structural Repair Investment & ROI"
          description="Professional repair protects your largest investment and increases home value"
          centered={true}
        />

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Cost Breakdown -->
          <div class="bg-slate-50 border border-slate-200 rounded-xl p-8 shadow-card">
            <h3 class="text-headline text-slate-900 mb-6 uppercase">Typical Project Costs</h3>

            <div class="space-y-4 mb-6">
              <div class="flex justify-between items-center pb-2 border-b border-slate-200">
                <span class="font-bold uppercase text-slate-900">MINOR CRACK REPAIR</span>
                <span class="font-bold text-slate-900">{pricingInfo.crackRepair}</span>
              </div>
              <div class="flex justify-between items-center pb-2 border-b border-slate-200">
                <span class="font-bold uppercase text-slate-900">SETTLEMENT REPAIR</span>
                <span class="font-bold text-slate-900">{pricingInfo.settlement}</span>
              </div>
              <div class="flex justify-between items-center pb-2 border-b border-slate-200">
