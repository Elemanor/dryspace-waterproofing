                    <strong>Issue Resolution:</strong> Rapid problem solving, alternatives
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="text-purple-500 mr-2">✓</span>
                  <div>
                    <strong>Documentation:</strong> Daily logs, inspection reports
                  </div>
                </li>
              </ul>
            </div>

            <div class="bg-white rounded-lg shadow-lg p-6">
              <h3 class="text-xl font-bold mb-4 text-orange-600">Post-Construction</h3>
              <ul class="space-y-3">
                <li class="flex items-start">
                  <span class="text-orange-500 mr-2">✓</span>
                  <div>
                    <strong>Final Inspections:</strong> Municipal & quality checks
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="text-orange-500 mr-2">✓</span>
                  <div>
                    <strong>Deficiency Resolution:</strong> Punch list completion
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="text-orange-500 mr-2">✓</span>
                  <div>
                    <strong>Warranty Support:</strong> 2-year workmanship warranty
                  </div>
                </li>
                <li class="flex items-start">
                  <span class="text-orange-500 mr-2">✓</span>
                  <div>
                    <strong>Documentation:</strong> As-built drawings, warranties, manuals
                  </div>
