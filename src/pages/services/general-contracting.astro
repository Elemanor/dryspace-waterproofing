---
import Layout from '../../layouts/Layout.astro';
import ContactCTA from '../../components/sections/CTA.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

const title = "General Contracting & Project Management | Toronto | Dryspace";
const description = "Full-service general contracting in Toronto. Complete project management, multi-trade coordination, turnkey solutions for waterproofing, foundations, and renovations.";

// Service-specific FAQs for ServiceSchema
const contractingFAQs = [
  {
    question: "How much does general contracting cost in Toronto?",
    answer: "General contracting costs vary by project scope: Basement renovations $54,000-150,000, foundation projects $27,000-75,000, structural work $22,000-60,000, complete home additions $108,000-300,000. Costs include project management (10-15%), permits, inspections, all trades coordination, materials, and warranties. We provide fixed-price contracts with no hidden fees."
  },
  {
    question: "How long do general contracting projects take?",
    answer: "Timeline depends on project complexity: Basement renovations 4-8 weeks, foundation repairs 2-4 weeks, structural modifications 3-6 weeks, home additions 3-6 months. Includes planning, permits, construction, inspections, and completion. Weather, permit approval, and change orders can affect timeline. We provide detailed schedules with milestone tracking."
  },
  {
    question: "What are the benefits of hiring a general contractor?",
    answer: "General contractors provide single point of contact, trade coordination, permit management, code compliance, quality control, insurance coverage, warranty protection, schedule management, and cost control. Our licensed professionals ensure projects are completed safely, on time, and on budget with comprehensive documentation and support."
  },
  {
    question: "When do I need a general contractor?",
    answer: "General contractors are essential for: multi-trade projects, structural work, basement renovations, home additions, foundation repairs, projects requiring permits, commercial construction, and complex renovations. Required when coordinating multiple trades, managing budgets, ensuring code compliance, and providing warranty protection."
  }
];

// Service offers (pricing tiers)
const contractingOffers = [
  {
    name: "Project Management Services",
    price: "10-15% of project cost",
    description: "Complete project coordination including trade scheduling, permit management, quality control, progress reporting, and client communication. Single point of contact for all project aspects."
  },
  {
    name: "Design-Build Services",
    price: "Custom Quote",
    description: "Integrated design and construction services with architect coordination, engineering, permits, construction, and project management. Streamlined process from concept to completion with fixed-price contracts."
  },
  {
    name: "Turnkey Construction",
    price: "$54,000-300,000+",
    description: "Complete construction solutions including planning, permits, all trades, materials, inspections, and warranties. Comprehensive project delivery with 20+ years experience and $5M liability coverage."
  }
];
---

<Layout title={title} description={description}>
  <ServiceSchema 
    serviceName="General Contracting & Project Management"
    description="Full-service general contracting in Toronto with complete project management, multi-trade coordination, and turnkey construction solutions. Licensed, insured, and experienced with residential, commercial, and institutional projects."
    priceRange="$22,000-300,000+"
    areaServed={['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'North York', 'Scarborough']}
    offers={contractingOffers}
    faqs={contractingFAQs}
  />
  <main>
    <!-- Hero Section -->
    <section class="relative py-20 bg-gradient-to-b from-blue-50 to-white">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-6">
            General Contracting & Project Management
          </h1>
          <p class="text-xl text-slate-500 mb-8">
            Complete Turnkey Solutions from Foundation to Finish
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-cyan-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-cyan-700 transition">
              Start Your Project
            </a>
            <a href="tel:437-545-0067" class="border-2 border-cyan-600 text-cyan-600 px-8 py-3 rounded-lg font-semibold hover:bg-cyan-50 transition">
              📞 437-545-0067
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview Section -->
    <section class="py-16 bg-slate-50">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <div class="bg-white rounded-lg shadow-lg p-8 border-l-4 border-cyan-500">
            <h2 class="text-2xl font-bold mb-6">Complete Project Solutions</h2>
            
            <p class="text-slate-600 mb-6">
              As a full-service general contractor, Dryspace Waterproofing manages every aspect of your project from 
              initial consultation to final inspection. Our experienced project managers coordinate all trades, ensure 
              code compliance, and deliver projects on time and budget.
            </p>

            <div class="grid md:grid-cols-3 gap-6">
              <div class="text-center">
                <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
                  <span class="text-3xl">📋</span>
                </div>
                <h3 class="font-bold mb-2">Single Point of Contact</h3>
                <p class="text-sm text-slate-500">One project manager for all trades and coordination</p>
              </div>

              <div class="text-center">
                <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
                  <span class="text-3xl">🏗️</span>
                </div>
                <h3 class="font-bold mb-2">Licensed & Insured</h3>
                <p class="text-sm text-slate-500">$5M liability, WSIB coverage, licensed trades</p>
              </div>

              <div class="text-center">
                <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
                  <span class="text-3xl">✅</span>
                </div>
                <h3 class="font-bold mb-2">Quality Guarantee</h3>
                <p class="text-sm text-slate-500">Comprehensive warranties on all work performed</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="py-16">
      <div class="container mx-auto px-6">
        <div class="max-w-6xl mx-auto">
          <h2 class="text-3xl font-bold mb-12 text-center">General Contracting Services</h2>
          
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            <div class="bg-white rounded-lg shadow-lg p-6">
