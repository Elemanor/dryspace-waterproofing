    <!-- CTA Section -->
    <section class="py-16 bg-cyan-600 text-white">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center">
          <h2 class="text-3xl font-bold mb-6">Ready to Start Your Project?</h2>
          <p class="text-xl mb-8">
            From planning to completion, we manage every detail of your construction project.
            Get a free consultation and detailed project estimate today.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="bg-white text-cyan-600 px-8 py-3 rounded-lg font-semibold hover:bg-slate-50 transition">
              Get Free Estimate
            </a>
            <a href="/free-inspection" class="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-cyan-700 transition">
              Schedule Consultation
            </a>
          </div>
        </div>
