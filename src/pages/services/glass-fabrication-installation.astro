---
import Layout from '../../layouts/Layout.astro';
import ContactCTA from '../../components/sections/CTA.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

const title = "Glass Fabrication & Installation | Windows, Partitions, Shower Glass | Toronto";
const description = "Custom glass fabrication and installation in Toronto. Office partitions, shower enclosures, windows, storefronts, glass doors. Commercial and residential glass solutions.";

// Service Schema Data
const serviceName = "Glass Fabrication & Installation";
const priceRange = "$550-$2,700";
const offers = [
  {
    name: "Basic Glass Installation",
    price: "$550-$1,100",
    description: "Single pane windows, simple shower doors, basic mirrors. Includes measurement, fabrication, and professional installation."
  },
  {
    name: "Premium Glass Systems",
    price: "$1,300-$2,200",
    description: "Office partitions, frameless shower enclosures, custom glass doors. Premium hardware and advanced fabrication."
  },
  {
    name: "Commercial Glass Solutions",
    price: "$1,600-$2,700",
    description: "Storefront systems, curtain walls, specialty safety glass. Includes engineering, permits, and code compliance."
  }
];

const faqs = [
  {
    question: "How much does custom glass fabrication cost in Toronto?",
    answer: "Glass fabrication costs vary by project: basic residential windows $550-1,000, shower enclosures $850-2,500, office partitions $150-300 per sq ft, and commercial storefront $200-400 per sq ft. Final pricing depends on glass type, thickness, hardware, and installation complexity."
  },
  {
    question: "How long does glass fabrication and installation take?",
    answer: "Timeline depends on project scope: simple replacements 1-3 days, shower enclosures 3-7 days, office partitions 1-2 weeks, and large commercial projects 2-6 weeks. Custom fabrication typically adds 5-10 business days to the timeline."
  },
  {
    question: "What are the benefits of professional glass installation?",
    answer: "Professional installation ensures proper measurements, code compliance, safety standards, warranty coverage, and longevity. Our certified glaziers handle permits, use proper sealants, and provide 2-10 year warranties depending on the application."
  },
  {
    question: "When should I choose custom glass fabrication over standard options?",
    answer: "Choose custom fabrication for non-standard sizes, specialty applications, unique shapes, safety requirements, energy efficiency needs, or when matching existing architectural elements. Custom solutions ensure perfect fit and optimal performance."
  }
];
---

<Layout title={title} description={description}>
  <ServiceSchema 
