---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Hero from "../../components/Hero.astro";
import Footer from "../../components/Footer.astro";
import CTASection from '../../components/sections/CTA.astro';
import ServiceSchema from "../../components/ServiceSchema.astro";
import InternalLinks from "../../components/InternalLinks.astro";

// Service Schema Data
const serviceName = "Glass Guards & Safety Glass Systems";
const description = "NBC compliant glass guards and safety glass systems. Heat strengthened laminated glass, tempered safety glass railings. Professional installation in Toronto GTA.";
const priceRange = "$400-$700";
const offers = [
  {
    name: "Standard Safety Glass Guards",
    price: "$400-$550/linear foot",
    description: "Heat soaked tempered glass guards for areas >50mm from floor edge. 10-12mm thickness, wind load rated, NBC compliant installation."
  },
  {
    name: "Premium Laminated Glass Guards",
    price: "$500-$650/linear foot",
    description: "Heat strengthened laminated glass for floor edges. 10mm+10mm configuration, SGP interlayer, remains in frame when broken."
  },
  {
    name: "Custom Safety Glass Systems",
    price: "$550-$700/linear foot",
    description: "Specialty applications including pool guards, stair railings, commercial systems. Engineering support, P.Eng stamped drawings available."
  }
];

const faqs = [
  {
    question: "How much do glass guards cost in Toronto?",
    answer: "Glass guard installation costs $400-650 per linear foot depending on glass type and location. Standard tempered glass guards cost $400-500/ft, while heat strengthened laminated glass for floor edges costs $500-600/ft. Complex installations and engineering requirements may increase costs."
  },
  {
    question: "How long does glass guard installation take?",
    answer: "Installation timeline varies by project size: residential balcony guards 2-3 days, stairway systems 3-5 days, commercial installations 1-2 weeks. Custom fabrication adds 7-14 days. Weather conditions may affect exterior installation schedules."
  },
  {
    question: "What are the benefits of NBC compliant glass guards?",
    answer: "NBC compliant glass guards provide superior safety, meet building codes, pass municipal inspections, maintain property value, offer 10-year warranties, and eliminate liability concerns. They're engineered for wind loads and impact resistance per Canadian standards."
  },
  {
    question: "When do I need heat strengthened laminated vs tempered glass?",
    answer: "NBC Section 2.1.1 requires heat strengthened laminated glass for guards within 50mm of floor edges (balconies, terraces). Heat soaked tempered glass is required for guards >50mm from edges. The type ensures proper safety performance if glass breaks."
  }
];
---

<Layout
  title="Glass Guards & Safety Glass | NBC Compliant | DrySpace"
  description="Heat strengthened laminated glass guards, tempered safety glass railings. NBC 2.1.1 & DIN EN 14179-1 certified. Professional installation in Toronto GTA."
>
  <ServiceSchema 
    serviceName={serviceName}
    description={description}
    priceRange={priceRange}
    offers={offers}
    faqs={faqs}
  />
  <Navbar />
  <Hero
    title="Glass Guards & Safety Glass Systems"
    subtitle="NBC Compliant Heat Strengthened Laminated & Tempered Glass Solutions"
    backgroundImage="/images/dryspace_hero_desktop.webp"
  />

  <main class="container mx-auto px-6 py-12">
    <!-- Compliance Banner -->
    <div class="bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg p-8 mb-12">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-bold mb-4">100% NBC & DIN EN Compliant Glass Guards</h2>
        <p class="text-xl mb-6">All our glass guard systems meet or exceed National Building Code Section 2.1.1 and DIN EN 14179-1 standards</p>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white/10 rounded-lg p-4">
            <div class="text-2xl font-bold">NBC 2.1.1</div>
            <div>Safety Glass Standards</div>
          </div>
          <div class="bg-white/10 rounded-lg p-4">
            <div class="text-2xl font-bold">DIN EN 14179-1</div>
            <div>Heat Soak Testing</div>
          </div>
          <div class="bg-white/10 rounded-lg p-4">
            <div class="text-2xl font-bold">CSA A500</div>
            <div>Building Guards</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Glass Types Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Professional Glass Guard Solutions</h2>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <!-- Heat Strengthened Laminated Glass -->
        <div class="bg-gradient-to-br from-orange-50 to-orange-100 rounded-lg p-8">
          <h3 class="text-2xl font-bold mb-4 text-orange-800">Heat Strengthened Laminated Glass</h3>
          <p class="text-slate-600 mb-6">Premium safety glass for guards at floor edges and high-risk areas. Designed to remain in frame even if broken.</p>
          
          <div class="bg-white rounded-lg p-6 mb-6">
            <h4 class="font-bold mb-3">Technical Specifications:</h4>
            <ul class="space-y-2">
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">✓</span>
                <span><strong>Strength:</strong> 2x stronger than annealed glass (24-52 MPa)</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">✓</span>
                <span><strong>Interlayer:</strong> 0.76mm minimum PVB or SGP</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">✓</span>
                <span><strong>Thickness:</strong> 10mm + 10mm standard configuration</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">✓</span>
                <span><strong>Break Pattern:</strong> Large fragments stay bonded</span>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">✓</span>
                <span><strong>Post-Break:</strong> Remains in frame per NBC 2.1.1.2</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-orange-200 rounded-lg p-4">
            <p class="font-semibold text-orange-900">Required for: Guards within 50mm of floor edge</p>
            <p class="text-2xl font-bold text-orange-900 mt-2">$200-350/sq ft installed</p>
          </div>
        </div>

        <!-- Heat Soaked Tempered Glass -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg p-8">
          <h3 class="text-2xl font-bold mb-4 text-cyan-800">Heat Soaked Tempered Glass</h3>
          <p class="text-slate-600 mb-6">Thermally toughened safety glass with heat soak testing to eliminate spontaneous breakage risk.</p>
          
          <div class="bg-white rounded-lg p-6 mb-6">
            <h4 class="font-bold mb-3">Technical Specifications:</h4>
            <ul class="space-y-2">
              <li class="flex items-start">
                <span class="text-cyan-600 mr-2">✓</span>
                <span><strong>Strength:</strong> 4-5x stronger than annealed (120-200 MPa)</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-600 mr-2">✓</span>
                <span><strong>Heat Soak:</strong> DIN EN 14179-1 certified process</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-600 mr-2">✓</span>
                <span><strong>Thickness:</strong> 6mm minimum, typically 10-12mm</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-600 mr-2">✓</span>
                <span><strong>Break Pattern:</strong> Small cubical fragments</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-600 mr-2">✓</span>
                <span><strong>NiS Risk:</strong> &lt;0.0001% after heat soaking</span>
              </li>
            </ul>
          </div>
          
          <div class="bg-cyan-100 rounded-lg p-4">
            <p class="font-semibold text-cyan-900">Required for: Guards >50mm from floor edge</p>
            <p class="text-2xl font-bold text-cyan-900 mt-2">$150-250/sq ft installed</p>
          </div>
        </div>
      </div>

      <!-- NBC Compliance Table -->
      <div class="bg-slate-50 rounded-lg p-8 mb-12">
        <h3 class="text-2xl font-bold mb-6 text-center">NBC Table 2.1.1.1 - Glass Selection Requirements</h3>
        <div class="overflow-x-auto">
          <table class="min-w-full bg-white rounded-lg overflow-hidden shadow-lg">
            <thead class="bg-navy-900 text-white">
              <tr>
                <th class="px-6 py-4 text-left">Location of Glass in Guard</th>
                <th class="px-6 py-4 text-left">Type of Glass Required</th>
                <th class="px-6 py-4 text-left">Our Solution</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="px-6 py-4">Glass located beyond edge of floor or within 50mm of edge</td>
                <td class="px-6 py-4 font-semibold text-orange-600">Heat Strengthened Laminated Glass</td>
                <td class="px-6 py-4">10mm+10mm HSL with SGP interlayer</td>
              </tr>
              <tr class="bg-slate-50">
                <td class="px-6 py-4">Glass located more than 50mm inward from edge of floor</td>
                <td class="px-6 py-4 font-semibold text-cyan-600">Heat Soaked Tempered Glass</td>
                <td class="px-6 py-4">12mm HST DIN EN 14179-1 certified</td>
              </tr>
              <tr>
                <td class="px-6 py-4">Glass located more than 150mm inward from edge of floor</td>
                <td class="px-6 py-4 font-semibold text-cyan-600">Heat Soaked Tempered or Tempered >6mm</td>
                <td class="px-6 py-4">10mm fully tempered safety glass</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Applications Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Glass Guard Applications</h2>
      
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Balcony Guards -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="h-48 bg-gradient-to-br from-blue-400 to-blue-600 flex items-center justify-center">
            <span class="text-6xl text-white">🏢</span>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-xl mb-3">Balcony & Terrace Guards</h3>
            <ul class="text-slate-500 space-y-2 mb-4">
              <li>• Frameless glass railings</li>
              <li>• Spigot or base shoe mounting</li>
              <li>• Wind load rated to 1.5 kPa</li>
              <li>• Heights 42" or 48" available</li>
            </ul>
            <div class="text-orange-600 font-bold">$450-600/linear foot</div>
          </div>
        </div>

        <!-- Stairway Guards -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="h-48 bg-gradient-to-br from-green-400 to-green-600 flex items-center justify-center">
            <span class="text-6xl text-white">🪜</span>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-xl mb-3">Stairway & Landing Guards</h3>
            <ul class="text-slate-500 space-y-2 mb-4">
              <li>• Custom angles and transitions</li>
              <li>• Handrail integrated options</li>
              <li>• Anti-slip handrail surfaces</li>
              <li>• Child-safe spacing compliant</li>
            </ul>
            <div class="text-orange-600 font-bold">$400-500/linear foot</div>
          </div>
        </div>

        <!-- Pool Guards -->
        <div class="bg-white rounded-lg shadow-lg overflow-hidden">
          <div class="h-48 bg-gradient-to-br from-cyan-400 to-cyan-600 flex items-center justify-center">
            <span class="text-6xl text-white">🏊</span>
          </div>
          <div class="p-6">
            <h3 class="font-bold text-xl mb-3">Pool & Spa Enclosures</h3>
            <ul class="text-slate-500 space-y-2 mb-4">
              <li>• Self-closing gate systems</li>
              <li>• 48" minimum height</li>
              <li>• Climb-resistant design</li>
              <li>• Municipal bylaw compliant</li>
            </ul>
            <div class="text-orange-600 font-bold">$500-650/linear foot</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Standards Section -->
    <section class="mb-16">
      <div class="bg-gradient-to-r from-gray-100 to-gray-200 rounded-lg p-8">
        <h2 class="text-3xl font-bold mb-8 text-center">Technical Standards & Testing</h2>
        
        <div class="grid md:grid-cols-2 gap-8">
          <!-- DIN EN 14179-1 Heat Soak Process -->
          <div class="bg-white rounded-lg p-6">
            <h3 class="font-bold text-xl mb-4 text-cyan-600">DIN EN 14179-1 Heat Soak Process</h3>
            <p class="text-slate-500 mb-4">Our heat soaked tempered glass undergoes rigorous testing to eliminate nickel sulfide inclusions:</p>
            <ol class="space-y-3">
              <li class="flex">
                <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center mr-3 flex-shrink-0">1</span>
                <div>
                  <strong>Initial Tempering:</strong> Glass heated to 620°C and rapidly cooled
                </div>
              </li>
              <li class="flex">
                <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center mr-3 flex-shrink-0">2</span>
                <div>
                  <strong>Heat Soak Testing:</strong> Held at 290°C ± 10°C for 2 hours minimum
                </div>
              </li>
              <li class="flex">
                <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center mr-3 flex-shrink-0">3</span>
                <div>
                  <strong>NiS Detection:</strong> Any glass with inclusions breaks during test
                </div>
              </li>
              <li class="flex">
                <span class="bg-cyan-600 text-white rounded-full w-6 h-6 flex items-center justify-center mr-3 flex-shrink-0">4</span>
                <div>
                  <strong>Certification:</strong> Only passing glass receives DIN certification
                </div>
              </li>
            </ol>
          </div>

          <!-- Structural Design Requirements -->
          <div class="bg-white rounded-lg p-6">
            <h3 class="font-bold text-xl mb-4 text-orange-600">NBC Structural Requirements</h3>
            <p class="text-slate-500 mb-4">All glass guards designed to NBC Part 4 Division B standards:</p>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">📐</span>
                <div>
                  <strong>Live Load:</strong> 0.5 kN concentrated or 1.0 kN/m linear
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">💨</span>
                <div>
                  <strong>Wind Load:</strong> As per local requirements (typically 1.0-1.5 kPa)
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">📏</span>
                <div>
                  <strong>Deflection:</strong> L/180 under live load, L/240 combined
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">🔧</span>
                <div>
                  <strong>Connections:</strong> No direct metal-to-glass contact permitted
                </div>
              </li>
              <li class="flex items-start">
                <span class="text-orange-600 mr-2">🌡️</span>
                <div>
                  <strong>Thermal:</strong> Allowance for ±30°C temperature differential
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Safety Features Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Advanced Safety Features</h2>
      
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🛡️</span>
          </div>
          <h3 class="font-bold mb-2">Impact Resistant</h3>
          <p class="text-sm text-slate-500">Withstands 400 ft-lbs impact per ANSI Z97.1</p>
        </div>
        <div class="text-center">
          <div class="bg-cyan-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">🔒</span>
          </div>
          <h3 class="font-bold mb-2">Fall Protection</h3>
          <p class="text-sm text-slate-500">Engineered to prevent falls from height</p>
        </div>
        <div class="text-center">
          <div class="bg-orange-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">👁️</span>
          </div>
          <h3 class="font-bold mb-2">Visibility Markers</h3>
          <p class="text-sm text-slate-500">Etched or film markers at required heights</p>
        </div>
        <div class="text-center">
          <div class="bg-purple-100 rounded-full w-20 h-20 flex items-center justify-center mx-auto mb-4">
            <span class="text-3xl">📋</span>
          </div>
          <h3 class="font-bold mb-2">Certified & Tested</h3>
          <p class="text-sm text-slate-500">All products tested to CSA & ANSI standards</p>
        </div>
      </div>
    </section>

    <!-- Installation Process -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Professional Installation Process</h2>
      
      <div class="max-w-4xl mx-auto">
        <div class="space-y-6">
          <div class="flex items-start">
            <div class="bg-orange-500 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">1</div>
            <div>
              <h3 class="font-bold text-lg mb-2">Site Assessment & Code Review</h3>
              <p class="text-slate-500">Detailed measurement, structural evaluation, and NBC compliance verification</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-orange-500 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">2</div>
            <div>
              <h3 class="font-bold text-lg mb-2">Glass Type Selection</h3>
              <p class="text-slate-500">Choose appropriate glass based on NBC Table 2.1.1.1 location requirements</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-orange-500 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">3</div>
            <div>
              <h3 class="font-bold text-lg mb-2">Custom Fabrication</h3>
              <p class="text-slate-500">Precision cutting, edge treatment, heat strengthening/tempering, DIN testing</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-orange-500 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">4</div>
            <div>
              <h3 class="font-bold text-lg mb-2">Professional Installation</h3>
              <p class="text-slate-500">Certified installers, engineered mounting systems, quality assurance</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-orange-500 text-white rounded-full w-10 h-10 flex items-center justify-center mr-4 flex-shrink-0">5</div>
            <div>
              <h3 class="font-bold text-lg mb-2">Inspection & Certification</h3>
              <p class="text-slate-500">Final testing, municipal inspection, warranty documentation</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Why Choose Us -->
    <section class="mb-16">
      <div class="bg-gradient-to-br from-blue-600 to-blue-700 text-white rounded-lg p-12">
        <h2 class="text-3xl font-bold mb-8 text-center">Why Choose DrySpace for Glass Guards?</h2>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <div class="text-center">
            <div class="text-4xl mb-4">🏆</div>
            <h3 class="font-bold text-xl mb-2">NBC Certified</h3>
            <p>100% compliant with National Building Code requirements</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-4">🔬</div>
            <h3 class="font-bold text-xl mb-2">DIN EN Testing</h3>
            <p>All tempered glass heat soak tested to German DIN standards</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-4">👷</div>
            <h3 class="font-bold text-xl mb-2">Expert Installers</h3>
            <p>Factory-trained technicians with 15+ years experience</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-4">📐</div>
            <h3 class="font-bold text-xl mb-2">Engineering Support</h3>
            <p>P.Eng stamped drawings available for permits</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-4">🛡️</div>
            <h3 class="font-bold text-xl mb-2">10-Year Warranty</h3>
            <p>Comprehensive warranty on glass and installation</p>
          </div>
          <div class="text-center">
            <div class="text-4xl mb-4">💰</div>
            <h3 class="font-bold text-xl mb-2">Competitive Pricing</h3>
            <p>Direct manufacturer relationships for best value</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="mb-16">
      <h2 class="text-3xl font-bold mb-8 text-center">Frequently Asked Questions</h2>
      
      <div class="max-w-3xl mx-auto space-y-6">
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="font-bold text-lg mb-2">What's the difference between heat strengthened and tempered glass?</h3>
          <p class="text-slate-500">Heat strengthened glass is 2x stronger than regular glass and breaks into large pieces that stay in the frame. Tempered glass is 4-5x stronger and breaks into small, safe cubes. NBC requires heat strengthened laminated for floor edges and tempered for other locations.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="font-bold text-lg mb-2">Why is heat soaking important for tempered glass?</h3>
          <p class="text-slate-500">Heat soaking eliminates the risk of spontaneous breakage from nickel sulfide inclusions. The DIN EN 14179-1 process reduces failure risk from 1 in 1000 to less than 1 in 10,000, critical for overhead and guard applications.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="font-bold text-lg mb-2">Can existing railings be upgraded with glass panels?</h3>
          <p class="text-slate-500">Often yes, but the existing structure must be evaluated for the additional wind loads. We provide engineering assessments and can reinforce existing frames or recommend full replacement when necessary.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="font-bold text-lg mb-2">How thick does guard glass need to be?</h3>
          <p class="text-slate-500">NBC requires minimum 6mm for tempered glass guards. However, based on height, wind loads, and span, we typically use 10-12mm tempered or 10mm+10mm laminated configurations.</p>
        </div>
        
        <div class="bg-white rounded-lg shadow-md p-6">
          <h3 class="font-bold text-lg mb-2">Do glass guards require regular maintenance?</h3>
          <p class="text-slate-500">Glass guards are very low maintenance. Annual inspection of hardware and sealants is recommended. Cleaning is simple with standard glass cleaners. Our installations include a maintenance guide.</p>
        </div>
      </div>
    </section>

    <!-- Internal Links Section -->
    <InternalLinks category="construction" currentPage="glass-guards-safety" />

    <!-- Call to Action -->
    <div class="bg-orange-500 text-white rounded-lg p-12 text-center">
      <h2 class="text-3xl font-bold mb-4">Get Your Free Glass Guard Consultation</h2>
      <p class="text-xl mb-8">NBC compliant solutions • DIN certified glass • Professional installation</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="tel:437-545-0067" class="bg-white text-orange-500 px-8 py-4 rounded-lg font-bold text-lg hover:bg-slate-50 transition">
          📞 Call 437-545-0067
        </a>
        <a href="/contact" class="bg-orange-600 text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-orange-700 transition">
          Get Free Quote
        </a>
      </div>
    </div>
  </main>

  <CTASection />
  <Footer />
</Layout>