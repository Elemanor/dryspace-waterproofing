import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const pageTitle = "Hydrostatic Pressure Relief Toronto | Foundation Pressure";
const pageDescription = "Hydrostatic pressure relief in Toronto. Drainage systems, relief wells, permanent foundation solutions. Prevent wall bowing & cracking. 25-year warranty. Free estimate.";

// Service-specific features
const serviceFeatures = [
  {
    icon: '',
