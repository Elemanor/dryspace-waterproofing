---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Hydrostatic Pressure Relief" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Hydrostatic Pressure Relief"
    description="Professional hydrostatic pressure relief systems in Toronto. Eliminate foundation water pressure with drainage solutions, relief wells, and comprehensive waterproofing."
    priceRange="$6,500-$16,000"
    offers={serviceOffers}
    faqs={schemaFAQs}
  />
  <!-- Hero Section -->
  <Hero 
    title="Hydrostatic Pressure Relief"
    subtitle="Eliminate water pressure on foundation walls. Professional drainage and relief systems."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/waterp on the floor.webp"
    badge="Pressure Elimination"
  />

  <!-- Stats -->
  <Stats />

  <!-- Features -->
  <Features 
    title="Why Choose Our Service"
    subtitle="Professional solutions backed by experience and warranty"
    features={serviceFeatures}
    columns={3}
  />

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ -->
  <FAQ 
    title="Common Questions"
    subtitle="Everything you need to know about our service"
    faqs={serviceFAQs}
    columns={1}
  />

  <!-- Internal Links -->
  <InternalLinks 
    category="waterproofing"
    currentPage="hydrostatic-pressure-relief"
    limit={5}
  />

  <!-- CTA -->
  <CTA 
    title="Ready to Get Started?"
    subtitle="Schedule your free inspection today and protect your home."
    primaryCTA={{ text: "Schedule Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    background="gradient"
  />
</PageLayout>