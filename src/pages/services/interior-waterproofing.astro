---
import PageLayout from '../../layouts/PageLayout.astro';
import ServiceHero from '../../components/sections/ServiceHero.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceProcess from '../../components/sections/ServiceProcess.astro';
import ServicePricing from '../../components/sections/ServicePricing.astro';
import CTABand from '../../components/sections/CTABand.astro';
import SectionHeader from '../../components/sections/SectionHeader.astro';
import ProblemIdentifier from '../../components/ProblemIdentifier.astro';
import SubsidyTeaser from '../../components/SubsidyTeaser.astro';
import PermitTeaser from '../../components/PermitTeaser.astro';
import CostCalculator from '../../components/CostCalculator.astro';
import BeforeAfterGallery from '../../components/BeforeAfterGallery.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import TechnicalDrawings from '../../components/TechnicalDrawings.astro';
import ContactForm from '../../components/ContactForm.astro';
import ServiceImageGallery from '../../components/ServiceImageGallery.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';

// SEO-optimized metadata focused on service details
const pageTitle = "Interior Waterproofing | No Excavation | DrySpace";
const pageDescription = "Interior moisture control without excavation. French drain & sump pump systems. 25-year warranty. One-day installation. Call 437-545-0067.";

// Service focus - technical details only
const serviceMethods = [
  "French Drain Installation",
  "Sump Pump System",
  "Weeping Tile Replacement",
  "Vapor Barrier Installation",
  "Water Management Channel"
];

// Pricing information
const pricingInfo = {
  range: "$95-$125 per linear foot",
  average: "$3,800-$8,650",
  factors: [
    "Lower level perimeter size",
    "Sump pump system type",
    "Water management tile requirements",
    "Floor restoration needs"
  ]
};

// Service FAQs for schema
const serviceFAQs = [
  {
    question: "How much does interior moisture control cost?",
    answer: "Indoor water management systems cost $95-$125 per linear foot, with most projects ranging from $3,800-$8,650. The cost depends on lower level perimeter size, sump pump system type, runoff control requirements, and floor restoration needs. Check our cost calculator for a detailed estimate."
  },
  {
    question: "How long does interior moisture control installation take?",
    answer: "Most indoor water management projects are completed in 1-2 days. Day 1 involves concrete removal and excavation, while Day 2 includes system installation and floor restoration. This timeline minimizes disruption to your home."
  },
  {
    question: "What's the difference between indoor and outdoor moisture control?",
    answer: "Indoor water management systems cost 60-70% less than outdoor solutions ($3,800-$8,650 vs $16,000-$27,000), require no excavation, can be installed year-round, and offer easier maintenance access. They're 95% effective compared to outdoor's 99% effectiveness."
  },
  {
    question: "Do indoor water management systems come with a warranty?",
    answer: "Yes! We provide a lifetime transferable warranty on indoor water management systems, including the sump pump, runoff control components, and installation workmanship. This warranty adds value to your home and transfers to new owners."
  },
  {
    question: "Can indoor water management systems be installed in winter?",
    answer: "Absolutely! Indoor water management systems can be installed in any weather condition, including harsh winters. Since all work is done inside your lower level, frozen ground and harsh weather don't affect the installation process."
  }
];

// Service offers for schema
const serviceOffers = [
  {
    name: "Basic Indoor System",
    price: "$3,800-$5,400",
    description: "Indoor water management system with single sump pump, vapor barrier, and concrete restoration for small to medium lower levels."
  },
  {
    name: "Premium Indoor System",
    price: "$6,500-$8,650",
    description: "Complete indoor water management with dual sump pumps, battery backup, advanced moisture control, and full perimeter protection."
  },
  {
    name: "Commercial Indoor System",
    price: "$8,650-$16,000",
    description: "Heavy-duty indoor water management for large lower levels with multiple zones, commercial-grade pumps, and comprehensive monitoring."
  }
];

// Process steps for ServiceProcess component
const processSteps = [
  {
    number: "1",
    title: "Concrete Removal",
    description: "18-inch floor perimeter removal with laser-level precision and dust control systems"
  },
  {
    number: "2",
    title: "Excavation & Preparation",
    description: "Hand excavation to footing level, sump pit formation, and base slope preparation"
  },
  {
    number: "3",
    title: "System Installation",
    description: "Water management tile, clean stone backfill, sump pump and battery backup installation"
  },
  {
    number: "4",
    title: "Restoration & Testing",
    description: "Vapor barrier installation, concrete floor restoration, system testing and warranty registration"
  }
];

// Pricing tiers for ServicePricing component
const pricingTiers = [
  {
    name: "Basic Indoor System",
    price: "$3,800-$5,400",
    description: "Essential protection for small to medium basements",
    features: [
      "Single sump pump system",
      "Vapor barrier installation",
      "Concrete floor restoration",
      "Standard discharge line",
      "Lifetime warranty"
    ]
  },
  {
    name: "Premium Indoor System",
    price: "$6,500-$8,650",
    description: "Complete protection with backup systems",
    popular: true,
    features: [
      "Dual sump pump system",
      "Battery backup system",
      "Advanced vapor barrier",
      "Full perimeter protection",
      "Enhanced discharge routing",
      "Lifetime transferable warranty"
    ]
  },
  {
    name: "Commercial Indoor System",
    price: "$8,650-$16,000",
    description: "Heavy-duty systems for large spaces",
    features: [
      "Commercial-grade pumps",
      "Multiple zone protection",
      "Comprehensive monitoring",
      "Advanced backup systems",
      "Priority service support",
      "Extended warranty coverage"
    ]
  }
];
---

<PageLayout
  title={pageTitle}
  description={pageDescription}
  showAnnouncement={true}
>

  <!-- ServiceSchema Component -->
  <ServiceSchema
    serviceName="Interior Waterproofing Toronto"
    description={pageDescription}
    priceRange="$3,800-$8,650"
    areaServed={serviceMethods}
    offers={serviceOffers}
    faqs={serviceFAQs}
  />

  <!-- Hero Section -->
  <ServiceHero
    title="INDOOR WATER MANAGEMENT SYSTEMS TORONTO"
    description="Affordable basement water management from inside. Indoor water control systems, sump pumps, and moisture barriers. No excavation required. Lifetime warranty included."
    priceRange="Starts at $3,800"
    duration="1-2 day installation"
    rebate="Up to $3,700 available"
    backgroundImage="/images/dryspace_hero_desktop.webp"
    breadcrumbs={[
      { label: "Home", href: "/" },
      { label: "Services", href: "/services" },
      { label: "Interior Waterproofing" }
    ]}
  />

  <!-- Trust Bar -->
  <TrustBar />

  <!-- Problem Identifier Section -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Warning Signs"
        title="Signs You Need Indoor Water Management"
        description="Cost-effective solution for managing basement water issues"
        centered={true}
      />
      <ProblemIdentifier />
    </div>
  </section>

  <!-- Service Details Section -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="grid md:grid-cols-2 gap-8">
          <!-- What's Included -->
          <div class="bg-white rounded-2xl shadow-card border border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">What's Included</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Indoor perimeter water management system</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Sump pump and basin installation</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Weeping tile connection</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Vapor barrier installation</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Floor concrete restoration</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Battery backup system</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Discharge line to exterior</span>
              </li>
              <li class="flex items-start">
                <span class="text-cyan-500 font-bold mr-3 text-xl">■</span>
                <span class="text-slate-700">Lifetime transferable warranty</span>
              </li>
            </ul>
          </div>

          <!-- Why Indoor Water Management Method -->
          <div class="bg-white rounded-2xl shadow-card border border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">Why Indoor Water Management Method</h3>
            <div class="space-y-4">
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Most Affordable</h4>
                <p class="text-slate-700">60-70% less expensive than outdoor water sealing with excellent results.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">No Excavation</h4>
                <p class="text-slate-700">Completed from inside - no damage to landscaping or driveways.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Year-Round Installation</h4>
                <p class="text-slate-700">Can be installed in any weather condition, even in winter.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Fast Completion</h4>
                <p class="text-slate-700">Most projects completed in 1-2 days with minimal disruption.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Key Benefits -->
        <div class="mt-12 bg-gradient-cta rounded-2xl shadow-card p-8">
          <h3 class="text-headline text-white mb-6 text-center">Key Benefits Of Indoor Water Management</h3>
          <div class="grid md:grid-cols-3 gap-6">
            <div class="text-center">
              <p class="text-4xl font-bold text-white mb-2">70%</p>
              <p class="text-white uppercase">Cost Savings</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-white mb-2">1-2</p>
              <p class="text-white uppercase">Days to Complete</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold text-white mb-2">Lifetime</p>
              <p class="text-white uppercase">Warranty</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Timeline -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Our Process"
        title="Indoor Water Management Installation Process"
        description="Quick installation with minimal disruption to your home"
        centered={true}
      />
      <ServiceProcess steps={processSteps} />

      <!-- Service Image Gallery -->
      <div class="mt-12">
        <ServiceImageGallery service="interior-waterproofing" />
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <ServicePricing
    title="Affordable Pricing"
    tiers={pricingTiers}
  />

  <!-- Interior Drainage Technology -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Technology"
          title="Interior Drainage Technology"
          description="Advanced systems for comprehensive basement water management"
          centered={true}
        />

        <!-- System Components -->
        <div class="grid md:grid-cols-2 gap-8 mb-12">
          <div class="bg-slate-50 rounded-2xl shadow-card border-4 border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">Perimeter Water Management System</h3>
            <div class="space-y-4">
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Water Management Tile Installation</h4>
                <p class="text-slate-700">4-6 inch perforated PVC pipe installed at footing level, surrounded by clean stone for optimal water collection and flow.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Vapor Barrier System</h4>
                <p class="text-slate-700">6-mil polyethylene vapor barrier installed on structure walls to prevent moisture penetration and direct water to water management system.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Sump Pit & Pump</h4>
                <p class="text-slate-700">Professional-grade sump pump with backup system removes collected water, preventing lower level flooding and moisture issues.</p>
              </div>
            </div>
          </div>

          <div class="bg-slate-50 rounded-2xl shadow-card border-4 border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">Advanced Features</h3>
            <div class="space-y-4">
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Battery Backup System</h4>
                <p class="text-slate-700">Automatic battery backup ensures continuous operation during power outages, critical for storm season protection.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Waterguard® Integration</h4>
                <p class="text-slate-700">Patent-pending WaterGuard system captures wall and footing leaks, with special ports for easy maintenance access.</p>
              </div>
              <div>
                <h4 class="font-bold text-navy-900 uppercase mb-2">Floor Restoration</h4>
                <p class="text-slate-700">Complete concrete floor restoration with proper slope to water management system, creating seamless, professional finish.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Performance Data -->
        <div class="bg-gradient-hero rounded-2xl shadow-card text-white p-8">
          <h3 class="text-headline uppercase mb-6 text-center">Indoor System Performance</h3>
          <div class="grid md:grid-cols-4 gap-6">
            <div class="text-center">
              <p class="text-4xl font-bold mb-2">95%</p>
              <p class="uppercase font-semibold">Effective water management</p>
              <p class="text-cyan-200 text-sm">Proven track record</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold mb-2">24/7</p>
              <p class="uppercase font-semibold">Continuous protection</p>
              <p class="text-cyan-200 text-sm">With backup systems</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold mb-2">1-2</p>
              <p class="uppercase font-semibold">Days installation</p>
              <p class="text-cyan-200 text-sm">Minimal disruption</p>
            </div>
            <div class="text-center">
              <p class="text-4xl font-bold mb-2">Lifetime</p>
              <p class="uppercase font-semibold">Warranty coverage</p>
              <p class="text-cyan-200 text-sm">Transferable protection</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Toronto Basement Conditions -->
  <section class="section-padding bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Local Expertise"
          title="Why Indoor Systems Work Locally"
          description="Designed specifically for local unique lower level conditions"
          centered={true}
        />

        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-white rounded-2xl shadow-card border-4 border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">Local Advantages</h3>
            <div class="space-y-4">
              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-navy-900">Clay Soil Compatibility</h4>
                <p class="text-slate-700">Indoor systems aren't affected by local expansive clay soil movement, ensuring consistent performance.</p>
              </div>
              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-navy-900">Year-Round Installation</h4>
                <p class="text-slate-700">Can be installed in winter when exterior excavation is impossible due to frozen ground conditions.</p>
              </div>
              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-navy-900">Basement Access</h4>
                <p class="text-slate-700">Optimal for local typical lower level layouts with sufficient ceiling height and accessibility.</p>
              </div>
              <div class="border-l-4 border-cyan-500 pl-4">
                <h4 class="font-bold uppercase text-navy-900">Water Table Management</h4>
                <p class="text-slate-700">Effectively handles local variable water table levels with continuous sump pump operation.</p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-2xl shadow-card border-4 border-slate-200 p-8">
            <h3 class="text-headline text-navy-900 mb-6">Local Lower Level Types</h3>
            <div class="space-y-4">
              <div>
                <h4 class="font-bold uppercase mb-2 text-navy-900">1940s-1960s Homes</h4>
                <p class="text-slate-700 mb-2">Stone structures with mortar joints, indoor systems ideal for managing seepage.</p>
                <p class="text-sm text-cyan-600">✓ Perfect candidate for indoor moisture control</p>
              </div>
              <div>
                <h4 class="font-bold uppercase mb-2 text-navy-900">1970s-1990s Homes</h4>
                <p class="text-slate-700 mb-2">Poured concrete structures, indoor systems complement existing building.</p>
                <p class="text-sm text-cyan-600">✓ Excellent performance with proper installation</p>
              </div>
              <div>
                <h4 class="font-bold uppercase mb-2 text-navy-900">2000s+ Homes</h4>
                <p class="text-slate-700 mb-2">Modern structures benefit from indoor systems for additional protection.</p>
                <p class="text-sm text-cyan-600">✓ Preventive measure for long-term protection</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Interior vs Exterior Comparison -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <SectionHeader
          label="Compare Options"
          title="Indoor Vs Outdoor Moisture Control"
          description="Detailed comparison to help you choose the right solution"
          centered={true}
        />

        <div class="overflow-x-auto mb-8 rounded-2xl shadow-card">
          <table class="w-full border-2 border-slate-200">
            <thead>
              <tr class="bg-navy-900 text-white">
                <th class="p-4 text-left uppercase">Factor</th>
                <th class="p-4 text-center uppercase">Indoor</th>
                <th class="p-4 text-center uppercase">Outdoor</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-slate-200">
                <td class="p-4 font-bold text-navy-900">Cost</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">$3,800-$8,650</td>
                <td class="p-4 text-center text-slate-700">$16,000-$27,000</td>
              </tr>
              <tr class="border-b border-slate-200 bg-slate-50">
                <td class="p-4 font-bold text-navy-900">Installation Time</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">1-2 days</td>
                <td class="p-4 text-center text-slate-700">3-5 days</td>
              </tr>
              <tr class="border-b border-slate-200">
                <td class="p-4 font-bold text-navy-900">Effectiveness</td>
                <td class="p-4 text-center text-slate-700">95%</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">99%</td>
              </tr>
              <tr class="border-b border-slate-200 bg-slate-50">
                <td class="p-4 font-bold text-navy-900">Disruption to Property</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">Minimal</td>
                <td class="p-4 text-center text-slate-700">Significant excavation</td>
              </tr>
              <tr class="border-b border-slate-200">
                <td class="p-4 font-bold text-navy-900">Warranty</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">Lifetime transferable</td>
                <td class="p-4 text-center text-slate-700">25 Years</td>
              </tr>
              <tr class="border-b border-slate-200 bg-slate-50">
                <td class="p-4 font-bold text-navy-900">Seasonal Limitations</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">None - year round</td>
                <td class="p-4 text-center text-slate-700">Winter restrictions</td>
              </tr>
              <tr class="border-b border-slate-200">
                <td class="p-4 font-bold text-navy-900">Maintenance Access</td>
                <td class="p-4 text-center bg-cyan-50 text-navy-900">Easy interior access</td>
                <td class="p-4 text-center text-slate-700">Requires excavation</td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Decision Matrix -->
        <div class="bg-amber-500 rounded-2xl shadow-card p-8">
          <h3 class="text-headline text-navy-900 uppercase mb-6 text-center">When To Choose Indoor Water Management</h3>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h4 class="font-bold uppercase mb-3 text-navy-900">Ideal Situations:</h4>
              <ul class="space-y-2 text-navy-900">
                <li>• Budget-conscious homeowners seeking effective protection</li>
                <li>• Properties with established landscaping to preserve</li>
                <li>• Winter emergency situations requiring immediate solution</li>
                <li>• Homes with difficult outdoor access or space constraints</li>
                <li>• Lower levels with adequate ceiling height (7+ feet)</li>
                <li>• Properties where outdoor work isn't feasible</li>
              </ul>
            </div>
            <div>
              <h4 class="font-bold uppercase mb-3 text-navy-900">Consider Outdoor If:</h4>
              <ul class="space-y-2 text-navy-900">
                <li>• New construction or major renovation project</li>
                <li>• Severe foundation structural issues present</li>
                <li>• Unlimited budget for maximum protection</li>
                <li>• Outdoor excavation already planned</li>
                <li>• Lower level ceiling height too low for indoor work</li>
                <li>• Complete outdoor protection desired</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Installation Process Detail -->
  <section class="section-padding bg-navy-900 text-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-12">
          <span class="section-label-pill">Day-by-Day</span>
          <h2 class="text-display mb-4">
            Detailed Installation Process
          </h2>
          <p class="text-lg text-slate-300">
            Professional indoor water management installation methodology
          </p>
        </div>

        <div class="space-y-8">
          <div class="bg-slate-800 rounded-2xl border-l-8 border-cyan-500 p-8">
            <div class="flex items-start flex-col md:flex-row gap-6">
              <div class="bg-cyan-500 text-navy-900 font-bold text-3xl px-6 py-4 rounded-xl min-w-fit">
                Day 1
              </div>
              <div class="flex-1">
                <h3 class="text-headline mb-4">Preparation & Concrete Removal</h3>
                <div class="grid md:grid-cols-2 gap-6">
                  <div>
                    <p class="font-bold text-slate-400 uppercase mb-3">Morning (4 Hours):</p>
                    <ul class="space-y-2 text-slate-300">
                      <li>• Lower level protection and content covering</li>
                      <li>• Laser level marking for cutting lines</li>
                      <li>• 18-inch concrete floor removal along perimeter</li>
                      <li>• Dust control with industrial vacuum systems</li>
                      <li>• Debris removal and disposal</li>
                    </ul>
                  </div>
                  <div>
                    <p class="font-bold text-slate-400 uppercase mb-3">Afternoon (4 Hours):</p>
                    <ul class="space-y-2 text-slate-300">
                      <li>• Hand excavation to foundation footing level</li>
                      <li>• Existing tile inspection and connection</li>
                      <li>• Sump pit excavation and formation</li>
                      <li>• Base preparation with proper slope</li>
