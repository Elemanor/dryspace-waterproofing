import TechnicalDrawings from '../../components/TechnicalDrawings.astro';
import ContactForm from '../../components/ContactForm.astro';
import ServiceImageGallery from '../../components/ServiceImageGallery.astro';

// SEO-optimized metadata focused on service
const pageTitle = "Load-Bearing Beam Installation Toronto | $5,000-$15,000 | Engineered Solutions";
const pageDescription = "Remove basement walls safely with engineered steel beam installation. Full permit handling, structural engineering, 25-year warranty. Call 437-545-0067.";

// Service areas list
const serviceAreas = [
  "Toronto",
  "Scarborough",
  "Etobicoke",
  "North York",
  "Mississauga",
  "Brampton",
  "Vaughan",
  "Markham",
  "Oakville",
  "Burlington",
  "Richmond Hill",
  "Ajax",
  "Pickering",
  "Oshawa"
];

// Load-bearing vs non-load-bearing identification
const identificationTable = [
  {
    sign: "Wall runs perpendicular to floor joists",
    loadBearing: "Yes - Likely",
    nonLoadBearing: "No"
  },
  {
    sign: "Wall directly below upper floor wall",
    loadBearing: "Yes - Very Likely",
    nonLoadBearing: "No"
  },
  {
    sign: "Wall sits on concrete footing/foundation",
    loadBearing: "Yes - Likely",
    nonLoadBearing: "Sometimes"
  },
  {
    sign: "Wall in center of house",
    loadBearing: "Yes - Very Likely",
    nonLoadBearing: "No"
  },
  {
    sign: "Wall runs parallel to joists",
    loadBearing: "No",
    nonLoadBearing: "Yes - Likely"
  },
  {
    sign: "Wall built with 2x3 or single top plate",
    loadBearing: "No",
    nonLoadBearing: "Yes - Likely"
  },
  {
    sign: "Wall doesn't align with anything above",
    loadBearing: "No",
    nonLoadBearing: "Yes - Likely"
  },
  {
    sign: "Newer partition wall (post-1990)",
    loadBearing: "Maybe",
    nonLoadBearing: "Yes - Likely"
  }
];

// Types of beams we install
const beamTypes = [
  {
    name: "STEEL I-BEAM (W-SHAPE)",
    description: "Most common for residential basements. Wide-flange steel beam handles longest spans and heaviest loads.",
    bestFor: "Open concept, large spans (12-20+ feet)",
    price: "$3,000 - $8,000",
    features: [
      "W8x, W10x, W12x sizes available",
      "Strongest option for residential",
      "Can be hidden in ceiling framing",
      "Handles multi-story loads",
      "Longest service life (100+ years)"
    ],
    recommended: true
  },
  {
    name: "STEEL FLUSH BEAM",
    description: "Beam sits within joist depth, maintaining full ceiling height. Critical for basements with low ceilings.",
    bestFor: "Low ceiling basements, finished ceilings",
    price: "$4,000 - $10,000",
    features: [
      "Maximizes headroom preservation",
      "Requires joist notching/modification",
      "More labour intensive installation",
      "Best for 6'6\"-7' ceiling heights",
      "Multiple smaller beams sometimes used"
    ]
  },
  {
    name: "LVL BEAM (ENGINEERED WOOD)",
    description: "Laminated veneer lumber beam. Lighter than steel, easier to install in tight spaces.",
    bestFor: "Moderate spans (8-14 feet), wood-frame additions",
    price: "$2,000 - $5,000",
    features: [
      "Multiple plies of laminated veneer",
      "Easier to cut and modify on-site",
      "Good for medium span applications",
      "Less expensive than steel",
      "Limited span compared to steel"
    ]
  },
  {
    name: "STEEL POST / LALLY COLUMN",
    description: "Adjustable or fixed steel columns supporting beams. Replace deteriorated posts or add mid-span support.",
    bestFor: "Mid-span support, replacing old columns",
    price: "$800 - $2,000 per column",
    features: [
      "Adjustable or fixed height options",
      "Requires concrete pad footings",
      "24\"x24\"x12\" minimum footing size",
      "Galvanized or painted finish",
      "Can be wrapped/finished for aesthetics"
    ]
  }
];

// Pricing breakdown
const pricingBreakdown = [
  {
    service: "Single beam + 2 columns (up to 14' span)",
    cost: "$5,000 - $10,000",
    includes: "Engineering, permit, beam, columns, footings, install"
  },
  {
    service: "Single beam + 2 columns (14-20' span)",
    cost: "$8,000 - $15,000",
    includes: "Larger beam, deeper footings, more shoring"
  },
  {
    service: "Double beam / flush beam",
    cost: "$10,000 - $18,000",
    includes: "Two beams for wider spans or flush ceiling"
  },
  {
    service: "Column replacement (per column)",
    cost: "$1,500 - $3,000",
    includes: "New column, footing, connections"
  },
  {
    service: "Beam + underpinning combo",
    cost: "$35,000 - $65,000",
    includes: "Full basement lowering + open concept"
  },
  {
