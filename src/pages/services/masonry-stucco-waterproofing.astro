---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Masonry Stucco Waterproofing" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Masonry & Stucco Waterproofing"
    description="Professional masonry waterproofing in Toronto. Breathable sealers, tuckpointing, and restoration for brick, stone, and stucco surfaces."
    priceRange="$8-$20 per sq ft"
    offers={serviceOffers}
    faqs={schemaFAQs}
  />
  <!-- Hero Section -->
  <Hero 
    title="Masonry & Stucco Waterproofing"
    subtitle="Protect brick, stone, and stucco from water damage. Breathable sealers and repairs."
    primaryCTA={{ text: "Get Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    backgroundImage="/images/spalling.webp"
    badge="Preserve & Protect"
  />

  <!-- Stats -->
  <Stats />

  <!-- Features -->
  <Features 
    title="Why Choose Our Service"
    subtitle="Professional solutions backed by experience and warranty"
    features={serviceFeatures}
    columns={3}
  />

  <!-- Process -->
  <Process />

  <!-- Testimonials -->
  <Testimonials />

  <!-- FAQ -->
  <FAQ 
    title="Common Questions"
    subtitle="Everything you need to know about our service"
    faqs={serviceFAQs}
    columns={1}
  />

  <!-- Internal Links -->
  <InternalLinks 
    category="waterproofing"
    currentPage="masonry-stucco-waterproofing"
    limit={5}
  />

  <!-- CTA -->
  <CTA 
    title="Ready to Get Started?"
    subtitle="Schedule your free inspection today and protect your home."
    primaryCTA={{ text: "Schedule Free Inspection", href: "/free-inspection" }}
    secondaryCTA={{ text: "Call: 437-545-0067", href: "tel:437-545-0067" }}
    background="gradient"
  />
</PageLayout>