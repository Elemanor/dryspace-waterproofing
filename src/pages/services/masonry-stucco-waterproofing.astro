import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const pageTitle = "Masonry Waterproofing Toronto | Brick & Stucco Sealing";
const pageDescription = "Waterproof brick, stone, stucco walls. Breathable sealers, tuckpointing, parging. Preserve and protect.";

