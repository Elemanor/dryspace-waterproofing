    description="Professional installation ensures maximum water management and structural protection"
    steps={[
      {
        number: 1,
        title: "Site Analysis & Design Planning",
        description: "Comprehensive assessment of your property's drainage patterns and structural protection needs.",
        details: [
          "Soil permeability testing and analysis",
          "Water flow pattern mapping",
          "Foundation vulnerability assessment", 
          "Drainage integration planning",
          "Custom paving design with CAD drawings"
        ]
      },
      {
        number: 2,
        title: "Excavation & Base Preparation",
        description: "Precise excavation and preparation of specialized base layers for optimal water infiltration.",
        details: [
          "Utility locates and safety preparation",
          "Precise excavation to required depth",
          "Geotextile fabric installation",
          "Graded aggregate base installation",
          "Compaction and grade verification"
        ]
      },
      {
        number: 3,
        title: "Permeable Base System Installation",
        description: "Installation of engineered base system designed for maximum water storage and infiltration.",
        details: [
          "Open-graded stone reservoir installation",
          "Underdrain system connection (if required)",
          "Bedding sand layer preparation",
          "Grade verification with laser levels",
          "Quality control and base testing"
        ]
      },
      {
        number: 4,
        title: "Permeable Paver Installation", 
        description: "Professional installation of permeable pavers with proper joint spacing for optimal performance.",
        details: [
          "Precise paver laying with gap spacing",
          "Pattern alignment and grade maintenance",
          "Edge restraint installation",
          "Joint filling with permeable aggregate",
          "Surface compaction and finishing"
        ]
      },
      {
        number: 5,
        title: "System Testing & Quality Assurance",
        description: "Comprehensive testing to ensure optimal water management performance and foundation protection.",
        details: [
          "Water infiltration rate testing",
          "Surface drainage verification",
          "Joint stability assessment",
          "Final grade and slope confirmation",
          "25-year warranty documentation"
        ]
      }
    ]}
  />

  <section class="py-20 bg-cyan-50">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Permeable Surface Solutions for Foundation Protection</h2>
        <p class="text-xl text-slate-500">Complete water management systems that protect your foundation while enhancing your property.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-cyan-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 9l3 3m0 0l-3 3m3-3H8m13 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-3">Permeable Driveways</h3>
          <p class="text-slate-500 mb-4">Replace traditional concrete driveways with permeable pavers that filter water away from your foundation.</p>
          <ul class="text-sm text-slate-500 space-y-1">
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> 90% runoff reduction</li>
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> 25-year durability</li>
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> Multiple design options</li>
