          <ul class="text-sm text-slate-500 space-y-1">
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> No standing water</li>
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> Slip resistance</li>
            <li class="flex items-center gap-2"><span class="text-cyan-600">✓</span> Quick drying</li>
          </ul>
        </div>

        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
