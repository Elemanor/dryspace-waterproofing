---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Stats from '../../components/sections/Stats.astro';
import ProblemIdentifier from '../../components/ProblemIdentifier.astro';
import SubsidyTeaser from '../../components/SubsidyTeaser.astro';
import PermitTeaser from '../../components/PermitTeaser.astro';
import CostCalculator from '../../components/CostCalculator.astro';
import Process from '../../components/sections/Process.astro';
import BeforeAfterGallery from '../../components/BeforeAfterGallery.astro';
import WhyChooseUs from '../../components/WhyChooseUs.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import TechnicalDrawings from '../../components/TechnicalDrawings.astro';
import FAQ from '../../components/FAQ.astro';
import ContactForm from '../../components/ContactForm.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

// SEO-optimized metadata for permeable paving
const pageTitle = "Permeable Paving & Water Management Toronto | Structure Protection Driveways | Eco-Friendly";
const pageDescription = "Professional permeable paving in Toronto & GTA. Eco-friendly driveways, walkways & patios that protect your foundation from moisture pooling. Sustainable water management solutions. Licensed & insured. Call 437-545-0067.";

// Service areas for local SEO
const serviceAreas = [
  "Toronto", "North York", "Scarborough", "Etobicoke", 
  "Mississauga", "Brampton", "Vaughan", "Richmond Hill",
  "Markham", "Oakville", "Burlington", "Hamilton"
];

// Service-specific FAQs with cost, timeline, benefits, process information
const serviceFAQs = [
  {
    question: "How much does permeable paving cost in Toronto?",
    answer: "Permeable surfaces cost in Toronto range from $20-$44/sq ft depending on system complexity: Basic permeable pavers: $20-$30/sq ft including excavation, base, and installation, Premium interlocking systems: $27-$37/sq ft with enhanced water management and decorative options, Commercial-grade systems: $32-$44/sq ft with heavy-duty base and load capacity. Complete residential driveway projects typically cost $13,000-$49,000. While more expensive than traditional concrete initially, permeable systems provide long-term value through foundation protection and reduced water removal infrastructure needs."
  },
  {
    question: "How long does permeable paving installation take?",
    answer: "Installation timeline varies by project scope: Site assessment and design: 2-3 days including soil testing and water flow analysis, Excavation and base preparation: 3-5 days for proper depth and drainage layers, Permeable paver installation: 2-4 days depending on area size and pattern complexity, System testing and finishing: 1-2 days for infiltration testing and joint filling. Total project timeline is typically 2-3 weeks from start to completion. Weather conditions may affect scheduling, with optimal installation during dry periods from spring through fall."
  },
  {
    question: "What are the benefits of permeable paving for Toronto properties?",
    answer: "Permeable paving provides significant advantages: Foundation protection: 85-95% reduction in surface runoff prevents water pooling against foundations, Storm management: Systems handle 5-10 inches/hour rainfall, exceeding Toronto's extreme weather events, Winter benefits: Reduces ice formation and handles freeze-thaw cycles better than solid concrete, Environmental impact: Reduces urban runoff, supports groundwater recharge, Property value: 8-15% increase from sustainable infrastructure and improved drainage, Durability: 25-30 year lifespan with minimal maintenance requirements, Aesthetics: Multiple design options and patterns available for enhanced curb appeal."
  },
  {
    question: "When should I consider permeable paving for my property?",
    answer: "Permeable paving is ideal in several scenarios: Foundation water issues: Properties experiencing basement moisture, foundation leaks, or poor drainage, Driveway replacement: When existing concrete/asphalt needs renewal, upgrade to permeable for long-term benefits, New construction: Integrate permeable paving during initial development for optimal foundation protection, Environmental goals: Properties pursuing sustainable practices, LEED certification, or green building standards, Heavy rainfall areas: Properties in flood-prone areas or with inadequate stormwater management, Spring planning optimal for summer/fall installation when weather conditions are favorable."
  }
];

// Service offers with 3 pricing tiers
const serviceOffers = [
  {
    name: "Residential Permeable Driveway",
    price: "$16,000-$27,000",
    description: "Complete permeable driveway installation (500-800 sq ft) with engineered base system, quality pavers, and foundation protection integration. Includes 25-year warranty."
  },
  {
    name: "Complete Property Solution",
    price: "$27,000-$49,000",
    description: "Comprehensive permeable paving for driveway, walkways, and patio areas with integrated water management systems. Includes design service, multiple paver options, and smart drainage integration."
  },
  {
    name: "Commercial Permeable System",
    price: "$49,000-$108,000",
    description: "Heavy-duty permeable paving for commercial properties including parking areas and access roads. Engineered for commercial loads with advanced drainage systems and long-term maintenance program."
  }
];

---

<PageLayout 
  title={pageTitle}
  description={pageDescription}
  canonical="https://dryspacewaterproofing.ca/services/permeable-paving-water-management"
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Permeable Paving Water Management" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Permeable Paving & Water Management Toronto"
    description={pageDescription}
    priceRange="$16,000-$108,000"
    offers={serviceOffers}
    faqs={serviceFAQs}
  />
  <Hero 
    title="Permeable Paving & Water Management Toronto"
    subtitle="Eco-Friendly Driveways & Walkways That Protect Your Foundation"
    description="Prevent basement flooding with permeable paving solutions that allow moisture to filter through instead of pooling around your structure. Beautiful, sustainable, and protective."
    primaryButton="Get Free Surface Quote"
    primaryButtonLink="/free-inspection"
    secondaryButton="Call 437-545-0067"
    secondaryButtonLink="tel:4375450067"
    image="/images/permeable-paving-hero.webp"
    imageAlt="Permeable paver driveway allowing water to filter through, protecting Toronto home foundation"
    breadcrumbs={[
      { text: 'Home', href: '/' },
      { text: 'Services', href: '/services' },
      { text: 'Permeable Paving & Water Management', href: '/services/permeable-paving-water-management' }
    ]}
  />

  <Stats 
    stats={[
      { value: "90%", label: "Runoff Reduction Rate" },
      { value: "800+", label: "Permeable Installations Completed" },
      { value: "25-Year", label: "Paver System Warranty" },
      { value: "10\"", label: "Rainfall Per Hour Capacity" }
    ]}
  />

  <ProblemIdentifier 
    title="Is Surface Water Runoff Threatening Your Foundation?"
    problems={[
      {
        icon: "🌊",
        title: "Driveway Water Pooling", 
        description: "Traditional solid driveways direct all rainfall toward your home's base, overwhelming drainage systems."
      },
      {
        icon: "❄️",
        title: "Ice Dams & Flooding",
        description: "Impermeable surfaces create ice dams in winter and contribute to spring flooding around foundations."
      },
      {
        icon: "🚰", 
        title: "Storm Water Overwhelm",
        description: "Heavy Toronto rainfall creates surface floods that pool against basement walls."
      },
      {
        icon: "🏠",
        title: "Foundation Hydrostatic Pressure", 
        description: "Moisture accumulation around structures increases pressure and causes basement leaks."
      },
      {
        icon: "🌍",
        title: "Environmental Impact",
        description: "Non-permeable surfaces contribute to urban runoff and strain city storm water systems."
      },
      {
        icon: "💸",
        title: "Higher Insurance Claims",
        description: "Properties with poor water management face higher basement flooding insurance claims."
      }
    ]}
    ctaText="Get Free Permeable Surface Quote"
    ctaLink="/free-inspection"
  />

  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold text-slate-900 mb-4">Why Toronto Homes Need Permeable Systems</h2>
        <p class="text-xl text-slate-500 max-w-3xl mx-auto">Traditional impermeable driveways and walkways create moisture management problems that threaten your structure and lower level.</p>
      </div>

      <div class="grid lg:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6">The Traditional Surface Problem</h3>
          <div class="space-y-4">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-red-600 text-sm font-semibold">✗</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Complete Surface Runoff</h4>
                <p class="text-slate-500">Solid concrete and asphalt direct ALL rainfall toward your home's foundation, overwhelming drainage systems.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-red-600 text-sm font-semibold">✗</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Ice Formation</h4>
                <p class="text-slate-500">Impermeable surfaces create ice dams and contribute to dangerous winter conditions around your home.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-red-600 text-sm font-semibold">✗</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Foundation Pressure</h4>
                <p class="text-slate-500">Moisture accumulation increases hydrostatic pressure against lower-level walls, causing leaks and damage.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-red-600 text-sm font-semibold">✗</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Environmental Impact</h4>
                <p class="text-slate-500">Non-permeable surfaces contribute to urban flooding and strain Toronto's storm water infrastructure.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="bg-cyan-50 p-8 rounded-lg">
          <h3 class="text-xl font-bold text-slate-900 mb-4">Permeable Surface Solution</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-cyan-600 text-sm font-semibold">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">90% Runoff Reduction</h4>
                <p class="text-sm text-slate-500">Water filters through pavers into ground, dramatically reducing surface runoff.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-cyan-600 text-sm font-semibold">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">10\" Rainfall Capacity</h4>
                <p class="text-sm text-slate-500">Handles extreme weather events far beyond Toronto's heaviest storms.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-cyan-600 text-sm font-semibold">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Foundation Protection</h4>
                <p class="text-sm text-slate-500">Reduces hydrostatic pressure and prevents lower level flooding.</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-6 h-6 bg-cyan-100 rounded-full flex items-center justify-center flex-shrink-0 mt-1">
                <span class="text-cyan-600 text-sm font-semibold">✓</span>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900">Winter Performance</h4>
                <p class="text-sm text-slate-500">Reduces ice formation and handles freeze-thaw cycles better than concrete.</p>
              </div>
            </div>
          </div>
          <div class="mt-6 p-4 bg-cyan-50 rounded-lg">
