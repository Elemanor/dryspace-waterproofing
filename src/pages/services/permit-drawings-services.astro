---
import PageLayout from '../../layouts/PageLayout.astro';
import HeroSection from '../../components/widgets/Hero.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const meta = {
  title: "Permit Acquisition & Technical Drawings Toronto | Building Permits & Engineering",
  description: "Professional permit services and technical drawings for demolition, drainage, and underpinning projects. Licensed engineers, expedited City of Toronto permits, architectural drawings.",
  keywords: "building permits Toronto, demolition permits, underpinning permits, drainage permits, technical drawings, architectural drawings, permit expediting, City of Toronto permits",
  canonical: "https://dryspacegroup.com/services/permit-drawings-services"
};

// Service-specific FAQs
const permitFAQs = [
  {
    question: "How much do permit drawings and permits cost in Toronto?",
    answer: "Permit costs vary by project: Underpinning permits $3,800-5,500, demolition permits $1,600-3,500, storm connection permits $2,200-3,500, site grading plans $1,600-2,500, and minor building permits $550-1,000. Includes professional drawings, engineering stamps, city submission, and one revision round. Complete packages include unlimited revisions and expedited processing."
  },
  {
    question: "How long does the permit process take in Toronto?",
    answer: "Permit timelines depend on complexity: Minor building permits 2-3 days, interior demolition 3-5 days, site grading plans 3-5 days, storm connections 5-10 days, complete demolition 5-15 days, and underpinning permits 7-10 days. We achieve 98% first-time approval with 5-day average turnaround through proper preparation and City relationships."
  },
  {
    question: "What are the benefits of professional permit services?",
    answer: "Professional permit services ensure code compliance, faster approvals, proper documentation, liability coverage, engineering stamps, City relationship management, and stress-free process. Our P.Eng certified engineers provide 98% first-time approval rate, fixed pricing, and comprehensive support from application to final inspection."
  },
  {
    question: "When do I need professional permit drawings and services?",
    answer: "Professional permits are required for: structural modifications, underpinning/basement lowering, complete demolition, storm sewer connections, site grading changes, load-bearing wall removal, and any construction requiring engineering. DIY permit applications often face delays, rejections, and costly revisions due to code complexities and documentation requirements."
  }
];

// Service offers (pricing tiers)
const permitOffers = [
  {
    name: "Basic Permit Package",
    price: "$550-3,500",
    description: "Technical drawings, permit application, city submission, and one revision round. Perfect for straightforward projects requiring standard permits and documentation."
  },
  {
    name: "Complete Permit Package",
    price: "$1,100-5,500",
    description: "Everything in Basic plus engineering stamps, expedited processing, unlimited revisions, and inspection coordination. Includes P.Eng certification and guaranteed approval support."
  },
  {
    name: "Fast-Track Permit Service",
    price: "+25-50% Premium",
    description: "Rush processing with same-day submission, direct City contact, priority review, and 24-hour emergency service. Guaranteed timeline with dedicated permit specialist support."
  }
];
---

<PageLayout {...meta}>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Permit Drawings Services" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Permit Acquisition & Technical Drawings"
    description="Professional permit services and technical drawings for demolition, drainage, and underpinning projects. Licensed P.Eng engineers, expedited City of Toronto permits, and architectural drawings with 98% first-time approval rate."
    priceRange="$550-5,500"
    areaServed={['Toronto', 'Mississauga', 'Brampton', 'Vaughan', 'Markham', 'Richmond Hill', 'North York', 'Scarborough']}
    offers={permitOffers}
    faqs={permitFAQs}
  />
  <HeroSection
    title="Permit Acquisition & Technical Drawings"
    subtitle="Complete Permit Services from Drawings to Approval"
    backgroundImage="/images/permits-hero.webp"
    ctaText="Start Permit Process"
    ctaLink="/free-inspection"
  />

  <!-- Service Overview -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-bold mb-4">Professional Permit & Drawing Services</h2>
        <p class="text-xl text-slate-500 max-w-3xl mx-auto">
          We handle the entire permit process from initial drawings to final approval. Our licensed engineers and permit specialists ensure your project meets all City of Toronto requirements, saving you time and avoiding costly delays.
        </p>
      </div>

      <!-- Success Metrics -->
      <div class="bg-cyan-50 border-2 border-cyan-600 rounded-lg p-6 mb-12">
        <div class="grid md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="text-3xl font-bold text-cyan-700">1,200+</div>
            <div class="text-sm text-slate-500">Permits Approved</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-cyan-700">98%</div>
            <div class="text-sm text-slate-500">First-Time Approval</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-cyan-700">5-10 Days</div>
            <div class="text-sm text-slate-500">Average Approval</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-cyan-700">P.Eng</div>
            <div class="text-sm text-slate-500">Licensed Engineers</div>
          </div>
        </div>
      </div>

      <!-- Service Categories -->
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-50 rounded-lg p-6">
          <div class="bg-cyan-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Underpinning Permits</h3>
          <p class="text-slate-500 mb-4">
            Complete structural engineering and permit package for basement lowering projects.
          </p>
          <ul class="text-sm space-y-1">
            <li>• Structural drawings</li>
            <li>• Engineer's report</li>
            <li>• Excavation plans</li>
            <li>• Shoring details</li>
            <li>• Inspection scheduling</li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-lg p-6">
          <div class="bg-red-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Demolition Permits</h3>
          <p class="text-slate-500 mb-4">
            Fast-track demolition permits with all required documentation and notifications.
          </p>
          <ul class="text-sm space-y-1">
            <li>• Site survey</li>
            <li>• Utility disconnections</li>
            <li>• Neighbor notifications</li>
            <li>• Environmental clearance</li>
            <li>• Hoarding permits</li>
          </ul>
        </div>

        <div class="bg-slate-50 rounded-lg p-6">
          <div class="bg-cyan-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Drainage Permits</h3>
          <p class="text-slate-500 mb-4">
            Storm water management and drainage system permits with engineered solutions.
          </p>
          <ul class="text-sm space-y-1">
            <li>• Site grading plans</li>
            <li>• Storm calculations</li>
            <li>• Catch basin details</li>
            <li>• Connection permits</li>
            <li>• TRCA approval</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Underpinning Permits Detail -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold mb-6">Underpinning Permits & Engineering</h2>
          <p class="text-slate-500 mb-6">
            Underpinning requires comprehensive engineering and multiple City inspections. Our P.Eng certified engineers prepare complete permit packages that ensure first-time approval and smooth project execution.
          </p>
          
          <div class="space-y-4 mb-8">
            <h3 class="font-bold text-xl">Complete Underpinning Package Includes:</h3>
            <ul class="space-y-3">
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Structural Engineering Drawings</strong>
                  <p class="text-sm text-slate-500">Detailed plans showing excavation sequence, shoring, and new foundation</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Load Calculations & Analysis</strong>
                  <p class="text-sm text-slate-500">Complete structural analysis with safety factors and load paths</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Section Details & Specifications</strong>
                  <p class="text-sm text-slate-500">Concrete specs, rebar schedules, waterproofing details</p>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-6 h-6 text-cyan-600 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <strong>Party Wall Agreements</strong>
                  <p class="text-sm text-slate-500">Neighbor notifications and agreements for attached properties</p>
                </div>
              </li>
            </ul>
          </div>
          
          <div class="bg-cyan-50 border-l-4 border-cyan-600 p-4">
            <p class="font-semibold">Underpinning Permit Package: $3,800-5,500</p>
            <p class="text-sm text-slate-500 mt-1">Includes all drawings, engineering, and City submission</p>
          </div>
        </div>
        
        <div class="bg-white rounded-lg shadow-lg p-8">
          <h3 class="text-xl font-bold mb-6">Underpinning Permit Process</h3>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">1</span>
              <div>
                <h4 class="font-semibold">Site Assessment</h4>
                <p class="text-sm text-slate-500">Survey existing conditions, soil report</p>
                <p class="text-xs text-cyan-600 mt-1">1-2 days</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">2</span>
              <div>
                <h4 class="font-semibold">Engineering Design</h4>
                <p class="text-sm text-slate-500">Create structural drawings and calculations</p>
                <p class="text-xs text-cyan-600 mt-1">3-5 days</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">3</span>
              <div>
                <h4 class="font-semibold">City Submission</h4>
                <p class="text-sm text-slate-500">Submit complete package to Building Department</p>
                <p class="text-xs text-cyan-600 mt-1">Same day</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">4</span>
              <div>
                <h4 class="font-semibold">Review & Approval</h4>
                <p class="text-sm text-slate-500">City review and permit issuance</p>
                <p class="text-xs text-cyan-600 mt-1">5-10 business days</p>
              </div>
            </div>
            
            <div class="flex items-start">
              <span class="bg-cyan-600 text-white rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3 flex-shrink-0">5</span>
              <div>
                <h4 class="font-semibold">Inspection Scheduling</h4>
                <p class="text-sm text-slate-500">Coordinate required inspections</p>
                <p class="text-xs text-cyan-600 mt-1">Throughout project</p>
              </div>
            </div>
          </div>
          
          <div class="mt-6 p-4 bg-amber-50 rounded-lg">
            <p class="text-sm font-semibold">Required Inspections:</p>
            <ul class="text-xs mt-2 space-y-1">
              <li>• Excavation inspection</li>
              <li>• Footing inspection (each pour)</li>
              <li>• Wall inspection</li>
              <li>• Backfill inspection</li>
              <li>• Final inspection</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Demolition Permits Detail -->
  <section class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div class="order-2 md:order-1">
          <div class="bg-slate-50 rounded-lg p-8">
            <h3 class="text-xl font-bold mb-6">Demolition Permit Requirements</h3>
            
            <div class="space-y-6">
              <div>
                <h4 class="font-bold mb-3">Complete Demolition</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Building permit application</li>
                  <li>• Site plan and survey</li>
                  <li>• Utility disconnect letters</li>
                  <li>• Rodent control declaration</li>
                  <li>• Environmental clearance</li>
                  <li>• Tree removal permit (if required)</li>
                  <li>• Heritage clearance (if applicable)</li>
                </ul>
              </div>
              
              <div>
                <h4 class="font-bold mb-3">Interior/Selective Demo</h4>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Floor plans showing demo areas</li>
                  <li>• Structural review for load-bearing</li>
                  <li>• Dust control plan</li>
                  <li>• Waste disposal plan</li>
                  <li>• Asbestos survey (if required)</li>
                </ul>
              </div>
            </div>
            
            <div class="mt-6 p-4 bg-red-50 rounded-lg">
              <p class="text-sm">
                <strong>Fast Track Available:</strong> Same-day permit for qualifying projects
              </p>
            </div>
          </div>
        </div>
        
        <div class="order-1 md:order-2">
          <h2 class="text-3xl font-bold mb-6">Demolition Permits</h2>
          <p class="text-slate-500 mb-6">
            Demolition permits require careful coordination of multiple departments and utilities. We handle all aspects including utility disconnections, environmental clearances, and neighbor notifications.
          </p>
          
          <div class="bg-red-50 rounded-lg p-6 mb-8">
            <h4 class="font-bold mb-3">What We Handle:</h4>
            <ul class="space-y-2 text-slate-600">
              <li class="flex items-center">
                <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Toronto Hydro disconnection
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Enbridge gas disconnection
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Water service capping
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                Hoarding permit if required
              </li>
              <li class="flex items-center">
                <svg class="w-5 h-5 text-red-600 mr-2" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                30-day neighbor notification
              </li>
            </ul>
          </div>
          
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-lg p-4 text-center shadow">
              <div class="text-2xl font-bold text-red-600">$1,600-3,500</div>
              <div class="text-sm text-slate-500">Complete demo permit</div>
            </div>
            <div class="bg-white rounded-lg p-4 text-center shadow">
              <div class="text-2xl font-bold text-cyan-600">5-15 days</div>
              <div class="text-sm text-slate-500">Typical approval</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Drainage Permits Detail -->
  <section class="py-16 bg-slate-50">
    <div class="container mx-auto px-4 max-w-6xl">
      <h2 class="text-3xl font-bold text-center mb-12">Drainage & Storm Water Permits</h2>
      
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <!-- Storm Connection -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="bg-cyan-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 16h4m10 0h4"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Storm Sewer Connection</h3>
          <p class="text-slate-500 mb-4">
            New connections to City storm sewers require engineered drawings and capacity analysis.
          </p>
          <ul class="text-sm space-y-1 mb-4">
            <li>• Connection detail drawings</li>
            <li>• Flow calculations</li>
            <li>• Inverts and grades</li>
            <li>• Backflow prevention</li>
            <li>• Inspection chambers</li>
          </ul>
          <div class="font-bold text-cyan-600">$2,200-3,500</div>
        </div>

        <!-- Site Grading -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="bg-cyan-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-cyan-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Site Grading Plan</h3>
          <p class="text-slate-500 mb-4">
            Comprehensive grading plans showing drainage patterns and storm water management.
          </p>
          <ul class="text-sm space-y-1 mb-4">
            <li>• Topographic survey</li>
            <li>• Proposed contours</li>
            <li>• Drainage arrows</li>
            <li>• Swale details</li>
            <li>• Lot grading certificate</li>
          </ul>
          <div class="font-bold text-cyan-600">$1,600-2,500</div>
        </div>

        <!-- TRCA Permits -->
        <div class="bg-white rounded-lg shadow-lg p-6">
          <div class="bg-purple-100 rounded-full w-16 h-16 flex items-center justify-center mb-4">
            <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">TRCA/Conservation</h3>
          <p class="text-slate-500 mb-4">
            Properties in regulated areas require additional environmental approvals.
          </p>
          <ul class="text-sm space-y-1 mb-4">
            <li>• Flood plain analysis</li>
            <li>• Erosion control plan</li>
            <li>• Environmental impact</li>
            <li>• Restoration plan</li>
            <li>• Monitoring reports</li>
          </ul>
          <div class="font-bold text-purple-600">$3,200-5,000</div>
        </div>
