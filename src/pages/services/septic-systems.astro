---
import PageLayout from '../../layouts/PageLayout.astro';
import Hero from '../../components/sections/Hero.astro';
import Features from '../../components/sections/Features.astro';
import Process from '../../components/sections/Process.astro';
import Gallery from '../../components/sections/Gallery.astro';
import FAQ from '../../components/sections/FAQ.astro';
import Testimonials from '../../components/sections/Testimonials.astro';
import CTA from '../../components/sections/CTA.astro';
import Stats from '../../components/sections/Stats.astro';
import ServiceSchema from '../../components/ServiceSchema.astro';
import InternalLinks from '../../components/InternalLinks.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const pageTitle = "Septic Systems Toronto | Installation & Maintenance | Rural Properties";
const pageDescription = "Professional septic system installation and maintenance for rural and suburban Toronto properties. Complete design, permitting, and ongoing service for all septic needs.";

// Septic-focused features
const septicFeatures = [
  {
    icon: '🏡',
    title: 'Rural Property Specialists',
    description: 'Expert septic solutions for rural and suburban properties throughout the GTA.',
    highlight: true
  },
  {
    icon: '⚙️',
    title: 'Complete System Design',
    description: 'Custom septic system design based on soil conditions and property requirements.',
    highlight: true
  },
  {
    icon: '📋',
    title: 'Permitting Included',
    description: 'We handle all permits and inspections required by local health departments.',
    highlight: true
  },
  {
    icon: '🔧',
    title: 'Installation & Maintenance',
    description: 'Full-service installation and ongoing maintenance programs.'
  },
  {
    icon: '🌿',
    title: 'Eco-Friendly Solutions',
    description: 'Environmentally responsible septic systems protecting groundwater.'
  },
  {
    icon: '📞',
    title: '24/7 Emergency Service',
    description: 'Emergency septic repairs and pumping services available.'
  }
];

// Septic process steps
const septicProcessSteps = [
  {
    number: '01',
    title: 'Site Assessment & Soil Testing',
    description: 'Comprehensive evaluation of your property including soil percolation tests, groundwater levels, and municipal requirements.',
    icon: '🔍',
    duration: '1-2 days'
  },
  {
    number: '02',
    title: 'System Design & Permitting',
    description: 'Custom septic system design based on household size, soil conditions, and local regulations. We handle all permit applications.',
    icon: '📐',
    duration: '2-4 weeks'
  },
  {
    number: '03',
    title: 'Excavation & Installation',
    description: 'Professional excavation and installation of septic tank, distribution box, and leach field using modern equipment.',
    icon: '🚜',
    duration: '2-5 days'
  },
  {
    number: '04',
    title: 'Connection & Testing',
    description: 'Connect system to your home, install all piping, and conduct thorough testing to ensure proper operation.',
    icon: '🔧',
    duration: '1 day'
  },
  {
    number: '05',
    title: 'Inspection & Approval',
    description: 'Coordinate health department inspections and obtain final approvals for system operation.',
    icon: '✅',
    duration: '1 week'
  },
  {
    number: '06',
    title: 'Maintenance Program Setup',
    description: 'Establish ongoing maintenance schedule and provide homeowner education for optimal system performance.',
    icon: '📅',
    duration: 'Ongoing'
  }
];

// Service-specific FAQs with cost, timeline, benefits, process information
const septicFAQs = [
  {
    question: "How much do septic systems cost in Toronto area?",
    answer: "Septic system costs vary by complexity and site conditions: Basic conventional systems: $13,000-$22,000 including tank, leach field, and standard installation, Pump systems: $19,000-$30,000 for properties with elevation challenges or poor drainage, Advanced treatment systems: $27,000-$49,000 for environmentally sensitive areas or poor soil conditions, Replacement systems: $16,000-$38,000 depending on existing infrastructure reuse. All prices include permits, inspections, and connections. We provide detailed quotes after site assessment and soil testing."
  },
  {
    question: "How long does septic system installation take?",
    answer: "Installation timeline varies by system complexity: Site assessment and soil testing: 1-2 days including percolation tests and health department requirements, Permit applications: 2-4 weeks for health department and building permit approvals, Excavation and installation: 3-7 days depending on system size and site conditions, Inspection and approval: 1-2 weeks for final health department approval and connection permits. Total timeline typically 6-10 weeks from initial assessment to completion. Weather conditions and permit processing may extend timelines."
  },
  {
    question: "What are the benefits of professional septic installation?",
    answer: "Professional septic installation provides crucial advantages: Regulatory compliance: All permits, inspections, and code requirements handled properly, Proper sizing: System designed for household size and soil conditions to ensure longevity, Quality materials: Commercial-grade tanks, piping, and components for 25-30 year lifespan, Environmental protection: Proper installation prevents groundwater contamination and surface water issues, Warranty coverage: Installation warranty and ongoing maintenance support, Long-term value: Properly installed systems require minimal maintenance and avoid costly repairs or replacements."
  },
  {
    question: "When do I need a septic system for my property?",
    answer: "Septic systems are required in several situations: New rural construction: Properties not connected to municipal sewage systems require private septic systems, System failure: Existing septic systems that are backing up, failing inspections, or contaminating soil/groundwater, Property expansion: Adding bedrooms or bathrooms may require septic system upgrades or replacements, Real estate transactions: Failed septic inspections during property sales require system repairs or replacement, Environmental compliance: Properties with aging systems may need upgrades to meet current environmental standards. Best to plan septic installation during dry weather (spring through fall)."
  }
];

// Service offers with 3 pricing tiers
const serviceOffers = [
  {
    name: "Conventional Septic System",
    price: "$13,000-$22,000",
    description: "Complete conventional septic system for rural properties including tank, leach field, permits, and inspections. Ideal for properties with good soil drainage and adequate space."
  },
  {
    name: "Pump System Installation",
    price: "$19,000-$30,000",
    description: "Advanced septic system with pump chamber for challenging sites, sloped properties, or high groundwater areas. Includes all permits, professional installation, and backup alarm systems."
  },
  {
    name: "Advanced Treatment System",
    price: "$27,000-$49,000",
    description: "Enhanced treatment septic systems for environmentally sensitive areas or poor soil conditions. Includes advanced treatment components, monitoring systems, and comprehensive maintenance program."
  }
];

// Septic statistics
const septicStats = [
  { number: '25+', label: 'Years Experience', description: 'Installing septic systems in GTA' },
  { number: '500+', label: 'Systems Installed', description: 'Rural properties served' },
  { number: '100%', label: 'Permit Success', description: 'All installations approved' },
  { number: '24/7', label: 'Emergency Service', description: 'Available for urgent repairs' }
];

---

<PageLayout 
  title={pageTitle} 
  description={pageDescription}
>
  
  <!-- Breadcrumbs -->
  <div class="container mx-auto px-4 mt-4">
    <Breadcrumbs 
      items={[
        { name: "Home", url: "/" },
        { name: "Services", url: "/services" },
        { name: "Septic Systems" }
      ]}
    />
  </div>

<ServiceSchema 
    serviceName="Septic Systems Installation Toronto"
    description="Professional septic system installation and maintenance for rural properties with complete design, permitting, and service throughout the Greater Toronto Area."
    priceRange="$13,000-$49,000"
    offers={serviceOffers}
    faqs={septicFAQs}
  />
  <Hero
    title="Septic Systems for Rural Toronto Properties"
    subtitle="Installation • Maintenance • Emergency Repair"
    description="Complete septic system solutions for rural and suburban properties throughout the GTA. From initial design and permitting to installation and ongoing maintenance."
    primaryCTA="Get Free Site Assessment"
    secondaryCTA="Call 437-545-0067"
    backgroundImage="/images/services/septic-systems-hero.webp"
    features={[
      "Complete System Design",
      "All Permits Handled",
      "Installation & Maintenance", 
      "Emergency Repair Service"
    ]}
  />

  <Stats 
    title="Proven Septic System Expertise"
    subtitle="Serving rural Toronto properties for over 25 years"
    stats={septicStats}
    backgroundClass="bg-dryspace-earth-50"
  />

  <Features
    title="Complete Septic System Services"
    subtitle="From design to maintenance"
    description="Comprehensive septic solutions for rural and suburban properties not connected to municipal sewage systems throughout the Greater Toronto Area."
    features={septicFeatures}
    layout="grid"
  />

  <!-- Service Areas Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-dryspace-earth-500 mb-6">
            Rural GTA Service Areas
          </h2>
          <p class="text-xl text-slate-500">
            Professional septic services throughout rural Toronto and surrounding communities
          </p>
        </div>
        
        <div class="grid lg:grid-cols-3 gap-8">
          <div class="bg-dryspace-earth-50 p-8 rounded-lg">
            <h3 class="text-2xl font-bold mb-4 text-dryspace-earth-500">North of Toronto</h3>
            <ul class="space-y-2 text-slate-500">
              <li>• King Township</li>
              <li>• Aurora rural areas</li>
              <li>• Newmarket outskirts</li>
              <li>• East Gwillimbury</li>
              <li>• Whitchurch-Stouffville</li>
            </ul>
          </div>
          
          <div class="bg-dryspace-water-50 p-8 rounded-lg">
            <h3 class="text-2xl font-bold mb-4 text-dryspace-earth-500">West of Toronto</h3>
            <ul class="space-y-2 text-slate-500">
              <li>• Caledon rural properties</li>
              <li>• Mono Township</li>
              <li>• Orangeville area</li>
              <li>• Shelburne region</li>
              <li>• Adjala-Tosorontio</li>
            </ul>
          </div>
          
          <div class="bg-dryspace-accent-50 p-8 rounded-lg">
            <h3 class="text-2xl font-bold mb-4 text-dryspace-earth-500">East of Toronto</h3>
            <ul class="space-y-2 text-slate-500">
              <li>• Pickering rural areas</li>
              <li>• Uxbridge Township</li>
              <li>• Scugog rural properties</li>
              <li>• Brock Township</li>
              <li>• Clarington outskirts</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Process
    title="Complete Septic Installation Process"
    subtitle="From assessment to final approval"
    description="Our comprehensive approach ensures proper septic system installation that meets all regulatory requirements and provides reliable long-term performance."
    steps={septicProcessSteps}
    layout="vertical"
  />

  <!-- System Types Section -->
  <section class="py-20 bg-dryspace-earth-50">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl lg:text-4xl font-bold text-dryspace-earth-500 mb-6">
            Septic System Types We Install
          </h2>
          <p class="text-xl text-slate-500">
            Choosing the right septic system based on your property and soil conditions
          </p>
        </div>
        
        <div class="space-y-8">
          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-dryspace-accent-500 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xl">🏠</span>
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-3 text-dryspace-earth-500">Conventional Septic Systems</h3>
                <p class="text-slate-500 mb-4">
                  Traditional systems with septic tank and gravity-fed leach field. Ideal for properties with good soil drainage and adequate space.
                </p>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Most cost-effective option</li>
                  <li>• Suitable for most soil types</li>
                  <li>• Low maintenance requirements</li>
                  <li>• Proven long-term performance</li>
                </ul>
              </div>
            </div>
          </div>
          
          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-dryspace-water-500 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xl">⚡</span>
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-3 text-dryspace-earth-500">Pump Systems</h3>
                <p class="text-slate-500 mb-4">
                  Systems with pump chambers for properties with challenging topography or high groundwater levels.
                </p>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Suitable for sloped properties</li>
                  <li>• Overcomes elevation challenges</li>
                  <li>• Reliable pump technology</li>
                  <li>• Backup alarm systems</li>
                </ul>
              </div>
            </div>
          </div>
          
          <div class="bg-white p-8 rounded-lg shadow-lg">
            <div class="flex items-start space-x-4">
              <div class="w-12 h-12 bg-dryspace-earth-500 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="text-white text-xl">🌱</span>
              </div>
              <div>
                <h3 class="text-2xl font-bold mb-3 text-dryspace-earth-500">Advanced Treatment Systems</h3>
                <p class="text-slate-500 mb-4">
                  Enhanced treatment systems for challenging sites or environmentally sensitive areas requiring higher treatment levels.
                </p>
                <ul class="text-sm text-slate-500 space-y-1">
                  <li>• Enhanced wastewater treatment</li>
                  <li>• Suitable for poor soil conditions</li>
                  <li>• Environmental protection</li>
                  <li>• Required monitoring systems</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQ
    title="Septic Systems FAQs"
    subtitle="Common questions about septic installation and maintenance"
    faqs={septicFAQs}
    schema={true}
  />

  <Testimonials
    title="Rural Property Owners Choose Our Septic Expertise"
    subtitle="Real experiences from GTA rural property owners"
    testimonials={[
      {
        name: "John MacKenzie",
        location: "King Township",
        rating: 5,
        text: "Excellent septic installation on our rural property. They handled all permits, coordinated inspections, and the system works perfectly. Professional team throughout the process.",
        service: "Septic Installation"
      },
      {
        name: "Sarah Johnson", 
        location: "Caledon",
        rating: 5,
        text: "Our old septic was failing and they provided a complete replacement. Fair pricing, quality work, and great communication. The new system has been trouble-free for 3 years.",
        service: "Septic Replacement"
      },
      {
        name: "Mike Chen",
        location: "Uxbridge", 
        rating: 5,
        text: "Emergency septic repair on a weekend - they came out quickly and fixed the problem. Now we use their maintenance program to prevent future issues. Highly recommend.",
        service: "Emergency Repair"
      }
    ]}
  />

  <Gallery
    title="Septic System Installation Gallery"
    subtitle="Professional septic installations throughout the GTA"
    description="See our expert septic system installations on rural properties"
    images={[
      { src: "/images/gallery/septic-excavation.webp", alt: "Septic system excavation", caption: "Professional excavation for septic tank installation" },
      { src: "/images/gallery/septic-tank-install.webp", alt: "Septic tank installation", caption: "Modern septic tank placement and connections" },
      { src: "/images/gallery/leach-field-construction.webp", alt: "Leach field construction", caption: "Leach field construction with proper drainage" },
      { src: "/images/gallery/completed-septic-system.webp", alt: "Completed septic system", caption: "Completed septic system ready for final inspection" }
    ]}
  />

  <!-- Internal Links -->
  <InternalLinks 
    category="construction"
    currentPage="septic-systems"
    limit={6}
  />

  <CTA
    title="Expert Septic Solutions for Your Rural Property"
    subtitle="Complete installation and maintenance services"
    description="Whether you need a new septic system installation, emergency repair, or ongoing maintenance, we provide comprehensive solutions for rural Toronto properties."
    primaryCTA="Schedule Free Site Assessment"
    primaryCTALink="tel:437-545-0067"
    secondaryCTA="Learn About Maintenance Plans"
    features={[
      "Free property assessment and soil testing",
      "All permits and inspections handled", 
      "Professional installation and maintenance",
      "24/7 emergency repair service available"
    ]}
    urgent={false}
  />
</PageLayout>