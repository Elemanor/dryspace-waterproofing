          <strong>$50 off</strong> the kit.
        </p>

        <form id="waitlistFormBottom" class="max-w-md mx-auto flex gap-2">
          <input
            type="email"
            name="email"
            placeholder="Enter your email"
            required
            class="flex-1 rounded-lg border-2 border-slate-200 px-4 py-3 text-slate-900 placeholder:text-slate-400 focus:border-cyan-500 focus:ring-2 focus:ring-cyan-500/20 focus:outline-none transition-all"
          />
          <button
            type="submit"
            class="rounded-lg bg-cyan-500 px-6 py-3 font-semibold text-white hover:bg-cyan-600 transition-colors whitespace-nowrap"
          >
            Join Waitlist
          </button>
