        <p class="text-xs text-slate-400 mt-3">No spam. Unsubscribe anytime.</p>
      </div>
    </div>
  </section>

  <ContactForm />

  <script>
    // Handle both waitlist forms
    document.querySelectorAll('#waitlistForm, #waitlistFormBottom').forEach(form => {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const email = form.querySelector('input[name="email"]').value;
        const btn = form.querySelector('button[type="submit"]');
        const originalText = btn.textContent;

        btn.textContent = 'Added!';
        btn.classList.add('bg-green-500');
        btn.classList.remove('bg-cyan-500');
        form.querySelector('input[name="email"]').value = '';

        setTimeout(() => {
          btn.textContent = originalText;
          btn.classList.remove('bg-green-500');
          btn.classList.add('bg-cyan-500');
        }, 3000);
      });
    });
  </script>
