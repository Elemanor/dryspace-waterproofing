---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout title="Smart Monitor for Property Managers & Business | DrySpace" description="Monitor 1-1000 basements from one dashboard. Bulk pricing, tenant portals, insurance partnerships, and municipal flood monitoring. Built for property managers, insurers, and contractors.">
  <!-- Hero Section -->
  <section class="bg-navy-900 text-white py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="inline-block px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full text-cyan-400 text-sm font-semibold mb-6">
          COMING 2027
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold mb-6 leading-tight">
          Built for Business
        </h1>
        <p class="text-xl text-slate-300 mb-8 leading-relaxed">
          From a single rental property to a 500-unit portfolio. Monitor every basement from one dashboard with bulk pricing, tenant access, and automated compliance reporting.
        </p>
        <a href="/smart-monitor" class="inline-flex items-center text-cyan-400 hover:text-cyan-300 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back to Smart Monitor
        </a>
      </div>
    </div>
  </section>

  <!-- Who It's For Section -->
  <section class="bg-white py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Who It's For
        </h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Enterprise monitoring solutions for property managers, insurers, and contractors
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        <!-- Property Managers Card -->
        <div class="bg-white border-2 border-slate-200 rounded-2xl p-8 hover:border-cyan-500 hover:shadow-xl transition-all">
          <div class="w-14 h-14 bg-cyan-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy-900 mb-4">Property Managers</h3>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Monitor 10-500+ units from one dashboard</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Per-unit alerts and thresholds</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Tenant read-only portal</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Maintenance scheduling from sensor data</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Monthly compliance reports per property</span>
            </li>
          </ul>
        </div>

        <!-- Insurance Companies Card -->
        <div class="bg-white border-2 border-slate-200 rounded-2xl p-8 hover:border-cyan-500 hover:shadow-xl transition-all">
          <div class="w-14 h-14 bg-cyan-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy-900 mb-4">Insurance Companies</h3>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>White-label monitoring for policyholders</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Real-time risk scoring per property</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Claims evidence: timestamped sensor logs</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Portfolio-wide flood risk analytics</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Premium discount program integration</span>
            </li>
          </ul>
        </div>

        <!-- Waterproofing Contractors Card -->
        <div class="bg-white border-2 border-slate-200 rounded-2xl p-8 hover:border-cyan-500 hover:shadow-xl transition-all">
          <div class="w-14 h-14 bg-cyan-500 rounded-xl flex items-center justify-center mb-6">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-navy-900 mb-4">Waterproofing Contractors</h3>
          <ul class="space-y-3 text-slate-700">
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Offer monitoring as a post-install service</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Revenue share on subscriptions</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Remote diagnostics before truck rolls</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Automated maintenance reminders (drives callbacks)</span>
            </li>
            <li class="flex items-start">
              <svg class="w-5 h-5 text-cyan-500 mr-3 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
              </svg>
              <span>Customer retention tool</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Multi-Property Dashboard Mockup -->
  <section class="bg-slate-50 py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Multi-Property Dashboard
        </h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Monitor your entire portfolio from a single command center
        </p>
      </div>

      <div class="bg-navy-900 rounded-2xl overflow-hidden shadow-2xl">
        <div class="flex h-[600px]">
          <!-- Sidebar: Property List -->
          <div class="w-80 bg-[#0f1419] border-r border-slate-800 p-4 overflow-y-auto">
            <div class="mb-4">
              <h3 class="text-white font-semibold text-sm uppercase tracking-wide mb-3">Properties</h3>
            </div>
            <div class="space-y-2">
              <!-- Property 1 -->
              <div class="bg-[#1a1f26] hover:bg-[#242a33] rounded-lg p-3 cursor-pointer transition-colors border-l-4 border-green-500">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-green-500"></div>
                      <span class="text-white font-medium text-sm">123 Main St</span>
                    </div>
                    <p class="text-slate-400 text-xs">Toronto, ON</p>
                  </div>
                  <span class="text-xs text-green-400 bg-green-500/10 px-2 py-1 rounded">Online</span>
                </div>
              </div>

              <!-- Property 2 -->
              <div class="bg-[#1a1f26] hover:bg-[#242a33] rounded-lg p-3 cursor-pointer transition-colors border-l-4 border-green-500">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-green-500"></div>
                      <span class="text-white font-medium text-sm">45 Oak Ave</span>
                    </div>
                    <p class="text-slate-400 text-xs">Mississauga, ON</p>
                  </div>
                  <span class="text-xs text-green-400 bg-green-500/10 px-2 py-1 rounded">Online</span>
                </div>
              </div>

              <!-- Property 3 - Warning -->
              <div class="bg-[#1a1f26] hover:bg-[#242a33] rounded-lg p-3 cursor-pointer transition-colors border-l-4 border-yellow-500">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-yellow-500"></div>
                      <span class="text-white font-medium text-sm">789 Elm Rd</span>
                    </div>
                    <p class="text-slate-400 text-xs">Brampton, ON</p>
                    <p class="text-yellow-400 text-xs mt-1">Humidity warning</p>
                  </div>
                  <span class="text-xs text-yellow-400 bg-yellow-500/10 px-2 py-1 rounded">Warning</span>
                </div>
              </div>

              <!-- Property 4 -->
              <div class="bg-[#1a1f26] hover:bg-[#242a33] rounded-lg p-3 cursor-pointer transition-colors border-l-4 border-green-500">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-green-500"></div>
                      <span class="text-white font-medium text-sm">12 Pine Ct</span>
                    </div>
                    <p class="text-slate-400 text-xs">Vaughan, ON</p>
                  </div>
                  <span class="text-xs text-green-400 bg-green-500/10 px-2 py-1 rounded">Online</span>
                </div>
              </div>

              <!-- Property 5 - Critical -->
              <div class="bg-[#1a1f26] hover:bg-[#242a33] rounded-lg p-3 cursor-pointer transition-colors border-l-4 border-red-500">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-2 mb-1">
                      <div class="w-2 h-2 rounded-full bg-red-500 animate-pulse"></div>
                      <span class="text-white font-medium text-sm">567 Cedar Ln</span>
                    </div>
                    <p class="text-slate-400 text-xs">Markham, ON</p>
                    <p class="text-red-400 text-xs mt-1">Pump alert</p>
                  </div>
                  <span class="text-xs text-red-400 bg-red-500/10 px-2 py-1 rounded">Critical</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Main Area: Stats & Alerts -->
          <div class="flex-1 p-6 overflow-y-auto">
            <!-- Summary Stats -->
            <div class="grid grid-cols-4 gap-4 mb-8">
              <div class="bg-[#1a1f26] rounded-lg p-4 border border-slate-800">
                <div class="text-slate-400 text-xs uppercase tracking-wide mb-1">Total Properties</div>
                <div class="text-white text-3xl font-bold">47</div>
              </div>
              <div class="bg-[#1a1f26] rounded-lg p-4 border border-slate-800">
                <div class="text-slate-400 text-xs uppercase tracking-wide mb-1">Online</div>
                <div class="text-green-400 text-3xl font-bold">45</div>
              </div>
              <div class="bg-[#1a1f26] rounded-lg p-4 border border-slate-800">
                <div class="text-slate-400 text-xs uppercase tracking-wide mb-1">Warnings</div>
                <div class="text-yellow-400 text-3xl font-bold">3</div>
              </div>
              <div class="bg-[#1a1f26] rounded-lg p-4 border border-slate-800">
                <div class="text-slate-400 text-xs uppercase tracking-wide mb-1">Critical</div>
                <div class="text-red-400 text-3xl font-bold">1</div>
              </div>
            </div>

            <!-- Recent Alerts -->
            <div>
              <h3 class="text-white font-semibold text-lg mb-4">Recent Alerts</h3>
              <div class="space-y-3">
                <!-- Alert 1 - Critical -->
                <div class="bg-[#1a1f26] rounded-lg p-4 border-l-4 border-red-500">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <svg class="w-5 h-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-white font-medium">Pump Alert</span>
                        <span class="text-red-400 text-sm">CRITICAL</span>
                      </div>
                      <p class="text-slate-400 text-sm">567 Cedar Ln, Markham - Pump not responding</p>
                      <p class="text-slate-500 text-xs mt-1">2 minutes ago</p>
                    </div>
                  </div>
                </div>

                <!-- Alert 2 - Warning -->
                <div class="bg-[#1a1f26] rounded-lg p-4 border-l-4 border-yellow-500">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-white font-medium">High Humidity</span>
                        <span class="text-yellow-400 text-sm">WARNING</span>
                      </div>
                      <p class="text-slate-400 text-sm">789 Elm Rd, Brampton - Humidity 78%</p>
                      <p class="text-slate-500 text-xs mt-1">45 minutes ago</p>
                    </div>
                  </div>
                </div>

                <!-- Alert 3 - Info -->
                <div class="bg-[#1a1f26] rounded-lg p-4 border-l-4 border-cyan-500">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <svg class="w-5 h-5 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-white font-medium">System Online</span>
                        <span class="text-cyan-400 text-sm">INFO</span>
                      </div>
                      <p class="text-slate-400 text-sm">234 Maple Dr, Richmond Hill - All systems normal</p>
                      <p class="text-slate-500 text-xs mt-1">2 hours ago</p>
                    </div>
                  </div>
                </div>

                <!-- Alert 4 - Warning -->
                <div class="bg-[#1a1f26] rounded-lg p-4 border-l-4 border-yellow-500">
                  <div class="flex items-start justify-between">
                    <div class="flex-1">
                      <div class="flex items-center gap-2 mb-1">
                        <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-white font-medium">Maintenance Due</span>
