---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout
  title="Cloud Dashboard - DrySpace Smart Monitor"
  description="Real-time basement monitoring from any device. Live sensor data, historical trends, pump analytics, and instant alerts — all in one dashboard."
>
  <!-- Hero -->
  <section class="bg-navy-900 py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="flex flex-col items-center text-center">
        <!-- Coming Soon Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-500/10 border border-cyan-500/30 rounded-full mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          <span class="text-sm font-semibold text-cyan-400">Coming Soon</span>
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold text-white mb-6">
          Cloud Dashboard
        </h1>

        <p class="text-lg md:text-xl text-slate-300 max-w-3xl mb-8">
          Real-time basement monitoring from any device. Live sensor data, historical trends, pump analytics, and instant alerts — all in one dashboard.
        </p>

        <a
          href="/smart-monitor"
          class="inline-flex items-center gap-2 text-cyan-400 hover:text-cyan-300 transition-colors"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
          </svg>
          Back to Smart Monitor
        </a>
      </div>
    </div>
  </section>

  <!-- Dashboard Preview -->
  <section class="bg-white py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-cyan-500 mb-4">Live Preview</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Your Basement Command Center
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          A real-time view of your basement health. Access from desktop, tablet, or mobile — anytime, anywhere.
        </p>
      </div>

      <!-- Browser Frame Mockup -->
      <div class="rounded-2xl overflow-hidden shadow-2xl border border-slate-200">
        <!-- Browser Chrome -->
        <div class="bg-slate-200 px-4 py-3 flex items-center gap-2 border-b border-slate-300">
          <div class="flex gap-2">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
          </div>
          <div class="flex-1 text-center">
            <div class="inline-block bg-white rounded px-4 py-1 text-xs text-slate-600">
              monitor.dryspace.ca/dashboard
            </div>
          </div>
        </div>

        <!-- Dashboard Content -->
        <div class="bg-[#0f1419] p-6 md:p-8">
          <!-- Top Bar -->
          <div class="flex flex-wrap items-center justify-between gap-4 mb-8 pb-6 border-b border-slate-700">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-lg bg-cyan-500/20 flex items-center justify-center">
                <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                </svg>
              </div>
              <div>
                <h3 class="text-white font-semibold text-sm">DrySpace Monitor</h3>
                <p class="text-slate-400 text-xs">v1.0.0</p>
              </div>
            </div>

            <div class="hidden md:block text-slate-300 text-sm font-medium">
              123 Main St, Toronto
            </div>

            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
              </span>
              <span class="text-sm text-green-400 font-medium">Online</span>
            </div>
          </div>

          <!-- Stat Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
            <!-- Sump Level -->
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-slate-400 text-xs font-medium uppercase tracking-wide">Sump Level</span>
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
              </div>
              <div class="text-3xl font-bold text-white mb-1">12.3 cm</div>
              <div class="text-xs text-green-400 font-medium">Normal</div>
            </div>

            <!-- Humidity -->
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-slate-400 text-xs font-medium uppercase tracking-wide">Humidity</span>
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
              </div>
              <div class="text-3xl font-bold text-white mb-1">54%</div>
              <div class="text-xs text-green-400 font-medium">Safe</div>
            </div>

            <!-- Temperature -->
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-slate-400 text-xs font-medium uppercase tracking-wide">Temperature</span>
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
              </div>
              <div class="text-3xl font-bold text-white mb-1">18.2°C</div>
              <div class="text-xs text-green-400 font-medium">Normal</div>
            </div>

            <!-- Pump Cycles -->
            <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-4">
              <div class="flex items-center justify-between mb-2">
                <span class="text-slate-400 text-xs font-medium uppercase tracking-wide">Pump Today</span>
                <div class="w-2 h-2 rounded-full bg-green-500"></div>
              </div>
              <div class="text-3xl font-bold text-white mb-1">7 cycles</div>
              <div class="text-xs text-green-400 font-medium">Normal</div>
            </div>
          </div>

          <!-- Chart Area -->
          <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6 mb-8">
            <div class="flex items-center justify-between mb-6">
              <h3 class="text-white font-semibold">Pump Activity — Last 7 Days</h3>
              <div class="text-xs text-slate-400">Daily Cycles</div>
            </div>

            <!-- Simple CSS Bar Chart -->
            <div class="flex items-end justify-between gap-2 h-48">
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 41.67%;"></div>
                <span class="text-xs text-slate-400">Mon</span>
                <span class="text-xs text-white font-medium">5</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 66.67%;"></div>
                <span class="text-xs text-slate-400">Tue</span>
                <span class="text-xs text-white font-medium">8</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 100%;"></div>
                <span class="text-xs text-slate-400">Wed</span>
                <span class="text-xs text-white font-medium">12</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 58.33%;"></div>
                <span class="text-xs text-slate-400">Thu</span>
                <span class="text-xs text-white font-medium">7</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 33.33%;"></div>
                <span class="text-xs text-slate-400">Fri</span>
                <span class="text-xs text-white font-medium">4</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 50%;"></div>
                <span class="text-xs text-slate-400">Sat</span>
                <span class="text-xs text-white font-medium">6</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-cyan-500/30 hover:bg-cyan-500/50 transition-colors rounded-t" style="height: 58.33%;"></div>
                <span class="text-xs text-slate-400">Sun</span>
                <span class="text-xs text-white font-medium">7</span>
              </div>
            </div>
          </div>

          <!-- Recent Alerts -->
          <div class="bg-slate-800/50 border border-slate-700 rounded-xl p-6">
            <h3 class="text-white font-semibold mb-4">Recent Alerts</h3>
            <div class="space-y-3">
              <div class="flex items-start gap-3 p-3 rounded-lg bg-slate-900/50 border border-slate-700/50">
                <div class="w-2 h-2 rounded-full bg-green-500 mt-1.5 flex-shrink-0"></div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-slate-400 mb-1">Mar 22, 2:14 PM</div>
                  <div class="text-sm text-slate-200">Pump activated, level dropped 8cm in 45s — Normal</div>
                </div>
              </div>

              <div class="flex items-start gap-3 p-3 rounded-lg bg-slate-900/50 border border-yellow-500/20">
                <div class="w-2 h-2 rounded-full bg-yellow-500 mt-1.5 flex-shrink-0"></div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-slate-400 mb-1">Mar 20, 11:30 PM</div>
                  <div class="text-sm text-slate-200">Humidity reached 62% — Window ventilation recommended</div>
                </div>
              </div>

              <div class="flex items-start gap-3 p-3 rounded-lg bg-slate-900/50 border border-slate-700/50">
                <div class="w-2 h-2 rounded-full bg-green-500 mt-1.5 flex-shrink-0"></div>
                <div class="flex-1 min-w-0">
                  <div class="text-sm text-slate-400 mb-1">Mar 18, 6:00 AM</div>
                  <div class="text-sm text-slate-200">Daily health check passed — All systems normal</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Features -->
  <section class="bg-slate-50 py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-cyan-500 mb-4">Capabilities</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Everything You Need to Know
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Professional-grade monitoring tools designed for homeowners.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Live Data -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Live Data</h3>
          <p class="text-slate-600">
            Sensor readings update every 30 seconds. No refresh needed.
          </p>
        </div>

        <!-- Historical Trends -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Historical Trends</h3>
          <p class="text-slate-600">
            12 months of data. Zoom into any hour, day, or week.
          </p>
        </div>

        <!-- Pump Analytics -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Pump Analytics</h3>
          <p class="text-slate-600">
            Cycles per day, average runtime, duty cycle trending, failure prediction.
          </p>
        </div>

        <!-- Smart Alerts -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Smart Alerts</h3>
          <p class="text-slate-600">
            Configurable thresholds. SMS + push. Escalation rules (alert spouse if no response in 5 min).
          </p>
        </div>

        <!-- Weather Correlation -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Weather Correlation</h3>
          <p class="text-slate-600">
            Auto-fetches Environment Canada forecasts. Warns before storms hit.
          </p>
        </div>

        <!-- Insurance Reports -->
        <div class="bg-white rounded-xl p-6 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-navy-900 mb-2">Insurance Reports</h3>
          <p class="text-slate-600">
            One-click PDF export. Timestamped logs proving continuous monitoring.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Alert System -->
  <section class="bg-white py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-cyan-500 mb-4">Intelligent Alerts</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Four-Tier Alert System
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Not all alerts are created equal. Our system escalates based on severity — so you're informed, not overwhelmed.
        </p>
      </div>

      <div class="max-w-3xl mx-auto">
        <!-- Alert Tiers -->
        <div class="relative">
          <!-- Vertical Line -->
          <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-slate-200"></div>

          <!-- Normal -->
          <div class="relative flex gap-6 mb-12">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-green-500 flex items-center justify-center text-white font-bold shadow-lg z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-bold text-navy-900 mb-2">Normal</h3>
              <p class="text-slate-600 mb-2">"All readings within safe range"</p>
              <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                Dashboard only
              </div>
            </div>
          </div>

          <!-- Warning -->
          <div class="relative flex gap-6 mb-12">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-yellow-500 flex items-center justify-center text-white font-bold shadow-lg z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-bold text-navy-900 mb-2">Warning</h3>
              <p class="text-slate-600 mb-2">"Humidity above 58% / Water level rising"</p>
              <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                Push notification
              </div>
            </div>
          </div>

          <!-- Urgent -->
          <div class="relative flex gap-6 mb-12">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-orange-500 flex items-center justify-center text-white font-bold shadow-lg z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-bold text-navy-900 mb-2">Urgent</h3>
              <p class="text-slate-600 mb-2">"Pump running >3 min / Humidity >65%"</p>
              <div class="flex flex-wrap gap-2">
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  SMS
                </div>
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  Push
                </div>
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  Dashboard
                </div>
              </div>
            </div>
          </div>

          <!-- Critical -->
          <div class="relative flex gap-6">
            <div class="flex-shrink-0 w-12 h-12 rounded-full bg-red-600 flex items-center justify-center text-white font-bold shadow-lg z-10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
              </svg>
            </div>
            <div class="flex-1 pt-2">
              <h3 class="text-xl font-bold text-navy-900 mb-2">Critical</h3>
              <p class="text-slate-600 mb-2">"Flood detected / Pump failure / Radon >200 Bq/m³"</p>
              <div class="flex flex-wrap gap-2">
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  SMS
                </div>
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  Push
                </div>
                <div class="inline-block px-3 py-1 bg-slate-100 rounded-full text-sm text-slate-700">
                  Phone call
                </div>
                <div class="inline-block px-3 py-1 bg-amber-100 rounded-full text-sm text-amber-700 font-medium">
                  Emergency dispatch option
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Multi-Property -->
  <section class="bg-slate-50 py-20 md:py-28">
    <div class="container mx-auto px-4 max-w-6xl">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-[0.15em] text-cyan-500 mb-4">For Property Managers</p>
        <h2 class="text-3xl md:text-4xl font-bold text-navy-900 mb-4">
          Manage 1-100 Properties
        </h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          Built for landlords and property managers who need to monitor multiple basements from one account.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-xl p-8 shadow-sm border border-slate-200">
          <div class="w-12 h-12 rounded-lg bg-cyan-500/10 flex items-center justify-center mb-4">
