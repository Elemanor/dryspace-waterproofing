  function showSolutions(problemType) {
    const solutionData = solutions[problemType];
    const solutionsSection = document.getElementById('solutions-display');
    const solutionsGrid = document.getElementById('solutions-grid');
    const solutionsTitle = document.getElementById('solutions-title');
    const comparisonBody = document.getElementById('comparison-body');

    // Update title
    solutionsTitle.textContent = solutionData.title;

    // Clear previous content
    solutionsGrid.innerHTML = '';
    comparisonBody.innerHTML = '';

    // Generate solution cards
    solutionData.solutions.forEach(solution => {
      const card = `
        <div class="bg-white rounded-lg shadow-lg p-6 border-l-4 border-cyan-600">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-xl font-bold text-slate-900">${solution.name}</h3>
            <span class="bg-${solution.priority.toLowerCase() === 'critical' ? 'red' : solution.priority.toLowerCase() === 'high' ? 'orange' : 'blue'}-100 text-${solution.priority.toLowerCase() === 'critical' ? 'red' : solution.priority.toLowerCase() === 'high' ? 'orange' : 'blue'}-800 text-xs px-2 py-1 rounded font-semibold">${solution.priority.toUpperCase()}</span>
          </div>
          <p class="text-slate-500 mb-4">${solution.description}</p>
          <div class="space-y-2 mb-6">
            <div class="flex justify-between">
              <span class="text-sm text-slate-400">Effectiveness:</span>
              <span class="font-semibold text-cyan-600">${solution.effectiveness}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-slate-400">Cost Range:</span>
              <span class="font-semibold">${solution.cost}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-slate-400">Timeline:</span>
              <span class="font-semibold">${solution.timeline}</span>
            </div>
            <div class="flex justify-between">
              <span class="text-sm text-slate-400">Warranty:</span>
              <span class="font-semibold text-cyan-600">${solution.warranty}</span>
            </div>
          </div>
          <button class="w-full bg-cyan-600 text-white py-2 rounded-lg hover:bg-cyan-700 transition-colors">
            Learn More
          </button>
        </div>
      `;
      solutionsGrid.innerHTML += card;

      // Add to comparison table
      const row = `
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm font-medium text-slate-900">${solution.name}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-cyan-600 font-semibold">${solution.effectiveness}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-slate-900">${solution.durability}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-slate-900">${solution.cost}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-slate-900">${solution.timeline}</div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="text-sm text-cyan-600 font-semibold">${solution.warranty}</div>
          </td>
        </tr>
      `;
      comparisonBody.innerHTML += row;
    });

    // Show solutions section
    solutionsSection.classList.remove('hidden');
    solutionsSection.scrollIntoView({ behavior: 'smooth' });
  }

  function hideContent() {
    const solutionsSection = document.getElementById('solutions-display');
    solutionsSection.classList.add('hidden');
    document.getElementById('problem-navigator').scrollIntoView({ behavior: 'smooth' });
  }
</script>