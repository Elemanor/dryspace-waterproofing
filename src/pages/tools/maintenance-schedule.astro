---
import Hero from '../../components/sections/Hero.astro';
import Stats from '../../components/sections/Stats.astro';
import PageLayout from '../../layouts/PageLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<PageLayout 
  title="Waterproofing Maintenance Schedule Generator | Custom Calendar | Dryspace"
  description="Generate a personalized maintenance schedule for your waterproofing system. Get reminders for sump pump, drainage, and foundation maintenance. Save thousands in repairs."
>
  <main class="flex-grow">
    <section class="bg-slate-50 text-slate-900 py-16">
      <div class="max-w-6xl mx-auto px-4">
        <h1 class="text-4xl md:text-5xl font-bold mb-6">
          Waterproofing Maintenance Schedule Generator
        </h1>
        <p class="text-xl mb-8 text-slate-300 max-w-3xl">
          Create a personalized maintenance calendar for your waterproofing system. 
          Proper maintenance extends system life by 10-15 years and prevents 90% of failures.
        </p>
        <div class="flex flex-wrap gap-4">
          <div class="bg-white/10 backdrop-blur px-4 py-2 ">
            <span>Save $5,000+ in Repairs</span>
          </div>
          <div class="bg-white/10 backdrop-blur px-4 py-2 ">
            <span>Prevent System Failures</span>
          </div>
          <div class="bg-white/10 backdrop-blur px-4 py-2 ">
            <span>Maintain Warranty</span>
          </div>
        </div>
      </div>
    </section>

    <section class="py-12">
      <div class="max-w-6xl mx-auto px-4">
        <!-- Cost Savings Alert -->
        <div class="bg-cyan-50 border-2 border-yellow-200  p-6 mb-8">
          <h2 class="text-xl font-bold text-cyan-700 mb-3"> Maintenance = Major Savings</h2>
          <div class="grid md:grid-cols-3 gap-4">
            <div>
              <div class="text-2xl font-bold text-cyan-400">$150/year</div>
              <p class="text-sm text-slate-600">Average maintenance cost</p>
            </div>
            <div>
              <div class="text-2xl font-bold text-red-600">$5,000</div>
              <p class="text-sm text-slate-600">Average repair from neglect</p>
            </div>
            <div>
              <div class="text-2xl font-bold text-slate-900">33:1 ROI</div>
              <p class="text-sm text-slate-600">Return on maintenance</p>
            </div>
          </div>
        </div>

        <div class="bg-white   p-8">
          <h2 class="text-2xl font-bold mb-6">Generate Your Custom Maintenance Schedule</h2>
          
          <form id="scheduleGenerator" class="space-y-6">
            <!-- System Type -->
            <div class="border-b pb-6">
              <h3 class="text-lg font-bold mb-4">Step 1: Your Waterproofing System</h3>
              <p class="text-sm text-slate-500 mb-4">Check all components you have:</p>
              
              <div class="grid md:grid-cols-2 gap-4">
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="sump-pump" class="mt-1 mr-3" checked />
                  <div>
                    <div class="font-medium">Sump Pump System</div>
                    <div class="text-sm text-slate-500">Primary pump with pit</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="battery-backup" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Battery Backup</div>
                    <div class="text-sm text-slate-500">Backup pump with battery</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="interior-drainage" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Interior Drainage</div>
                    <div class="text-sm text-slate-500">French drain/weeping tile</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="exterior-membrane" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Exterior Waterproofing</div>
                    <div class="text-sm text-slate-500">Membrane and drainage</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="backwater-valve" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Backwater Valve</div>
                    <div class="text-sm text-slate-500">Sewer backup prevention</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="window-wells" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Window Wells</div>
                    <div class="text-sm text-slate-500">With drains</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="dehumidifier" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Dehumidifier</div>
                    <div class="text-sm text-slate-500">Moisture control system</div>
                  </div>
                </label>
                
                <label class="flex items-start p-3 border-2 border-slate-200 hover:bg-slate-50 cursor-pointer">
                  <input type="checkbox" name="system" value="gutters" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Gutters & Downspouts</div>
                    <div class="text-sm text-slate-500">Roof drainage system</div>
                  </div>
                </label>
              </div>
            </div>

            <!-- Installation Date -->
            <div class="border-b pb-6">
              <h3 class="text-lg font-bold mb-4">Step 2: System Age</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium mb-2">System Installation Date</label>
                  <input 
                    type="month" 
                    name="installDate" 
                    class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500"
                    required
                  />
                  <p class="text-xs text-slate-400 mt-1">When was your system installed?</p>
                </div>
                
                <div>
                  <label class="block text-sm font-medium mb-2">Last Professional Service</label>
                  <input 
                    type="month" 
                    name="lastService" 
                    class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500"
                  />
                  <p class="text-xs text-slate-400 mt-1">Leave blank if never serviced</p>
                </div>
              </div>
            </div>

            <!-- Property Details -->
            <div class="border-b pb-6">
              <h3 class="text-lg font-bold mb-4">Step 3: Property Details</h3>
              <div class="grid md:grid-cols-3 gap-4">
                <div>
                  <label class="block text-sm font-medium mb-2">Foundation Type</label>
                  <select name="foundation" class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500" required>
                    <option value="poured">Poured Concrete</option>
                    <option value="block">Cement Block</option>
                    <option value="stone">Stone/Rubble</option>
                    <option value="brick">Brick</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium mb-2">Soil Type</label>
                  <select name="soil" class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500" required>
                    <option value="clay">Clay (High Risk)</option>
                    <option value="sand">Sand (Medium Risk)</option>
                    <option value="gravel">Gravel (Low Risk)</option>
                    <option value="mixed">Mixed/Unknown</option>
                  </select>
                </div>
                
                <div>
                  <label class="block text-sm font-medium mb-2">Trees Near Foundation</label>
                  <select name="trees" class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500" required>
                    <option value="none">None</option>
                    <option value="small">Small Trees (15+ ft away)</option>
                    <option value="large">Large Trees (<15 ft away)</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Risk Factors -->
            <div class="border-b pb-6">
              <h3 class="text-lg font-bold mb-4">Step 4: Risk Factors (Check all that apply)</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <label class="flex items-start">
                  <input type="checkbox" name="risk" value="flooding-history" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Previous Flooding</div>
                    <div class="text-sm text-slate-500">Had water issues before</div>
                  </div>
                </label>
                
                <label class="flex items-start">
                  <input type="checkbox" name="risk" value="high-water-table" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">High Water Table</div>
                    <div class="text-sm text-slate-500">Near lake/river/ravine</div>
                  </div>
                </label>
                
                <label class="flex items-start">
                  <input type="checkbox" name="risk" value="old-system" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">System 10+ Years Old</div>
                    <div class="text-sm text-slate-500">Requires extra attention</div>
                  </div>
                </label>
                
                <label class="flex items-start">
                  <input type="checkbox" name="risk" value="power-outages" class="mt-1 mr-3" />
                  <div>
                    <div class="font-medium">Frequent Power Outages</div>
                    <div class="text-sm text-slate-500">Area prone to outages</div>
                  </div>
                </label>
              </div>
            </div>

            <!-- Contact Preferences -->
            <div class="border-b pb-6">
              <h3 class="text-lg font-bold mb-4">Step 5: Reminder Preferences (Optional)</h3>
              <div class="grid md:grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium mb-2">Email for Reminders</label>
                  <input 
                    type="email" 
                    name="email" 
                    placeholder="your@email.com"
                    class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500"
                  />
                  <p class="text-xs text-slate-400 mt-1">We'll send maintenance reminders</p>
                </div>
                
                <div>
                  <label class="block text-sm font-medium mb-2">Preferred Season for Annual Service</label>
                  <select name="season" class="w-full px-4 py-2 border-2 border-slate-200 focus:ring-2 focus:ring-orange-500">
                    <option value="spring">Spring (Recommended)</option>
                    <option value="summer">Summer</option>
                    <option value="fall">Fall</option>
                    <option value="winter">Winter</option>
                  </select>
                </div>
              </div>
            </div>

            <button 
              type="submit" 
              class="w-full bg-orange-500 text-white font-bold py-4 px-6  hover:bg-orange-600 transition duration-300 text-lg"
            >
              Generate My Maintenance Schedule
            </button>
          </form>

          <!-- Results Section -->
          <div id="scheduleResults" class="hidden mt-8">
            <div class="bg-slate-50 text-slate-900  p-6 mb-8">
              <h3 class="text-2xl font-bold mb-2">Your Personalized Maintenance Schedule</h3>
              <p>Based on your system components and risk factors, here's your optimal maintenance plan:</p>
            </div>

            <!-- Monthly Tasks -->
            <div class="bg-white border-2 border-slate-200 p-6 mb-6">
              <h4 class="text-xl font-bold mb-4 text-slate-900"> Monthly Tasks (5 minutes)</h4>
              <div id="monthlyTasks" class="space-y-3"></div>
            </div>

            <!-- Quarterly Tasks -->
            <div class="bg-white border-2 border-slate-200 p-6 mb-6">
              <h4 class="text-xl font-bold mb-4 text-cyan-400"> Quarterly Tasks (30 minutes)</h4>
              <div id="quarterlyTasks" class="space-y-3"></div>
            </div>

            <!-- Semi-Annual Tasks -->
            <div class="bg-white border-2 border-slate-200 p-6 mb-6">
              <h4 class="text-xl font-bold mb-4 text-orange-600"> Semi-Annual Tasks (1 hour)</h4>
              <div id="semiAnnualTasks" class="space-y-3"></div>
            </div>

            <!-- Annual Tasks -->
            <div class="bg-white border-2 border-slate-200 p-6 mb-6">
              <h4 class="text-xl font-bold mb-4 text-red-600"> Annual Professional Service</h4>
              <div id="annualTasks" class="space-y-3"></div>
            </div>

            <!-- Calendar View -->
            <div class="bg-slate-50  p-6 mb-6">
              <h4 class="text-xl font-bold mb-4"> Your 12-Month Calendar</h4>
              <div class="grid grid-cols-3 md:grid-cols-4 gap-4" id="calendarView"></div>
            </div>

            <!-- Cost Breakdown -->
            <div class="bg-white border-2 border-slate-200 p-6 mb-6">
              <h4 class="text-xl font-bold mb-4"> Annual Maintenance Investment</h4>
              <div id="costBreakdown" class="space-y-2"></div>
              <div class="mt-4 p-4 bg-cyan-50 rounded">
                <p class="text-sm text-cyan-700">
                  <strong>Savings Alert:</strong> This maintenance schedule will save you an estimated 
                  <span id="savingsAmount" class="font-bold">$5,000-10,000</span> over 10 years by preventing major repairs.
                </p>
              </div>
            </div>

            <!-- Warning Signs -->
            <div class="bg-red-50 border-2 border-red-200  p-6 mb-6">
              <h4 class="text-xl font-bold mb-4 text-red-600"> Call Immediately If You Notice:</h4>
              <ul class="space-y-2" id="warningSignsList"></ul>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4">
              <button onclick="window.print()" class="bg-slate-600 text-white font-bold py-3 px-6  hover:bg-slate-700 transition duration-300">
                 Print Schedule
              </button>
              <button onclick="downloadCalendar()" class="bg-amber-500 text-slate-900 font-bold py-3 px-6  hover:bg-amber-500 transition duration-300">
                 Add to Calendar
              </button>
              <a href="/contact" class="bg-orange-500 text-white font-bold py-3 px-6  hover:bg-orange-600 transition duration-300 text-center">
                 Book Professional Service
              </a>
            </div>
          </div>
        </div>

        <!-- Maintenance Guide -->
        <div class="mt-12 bg-white   p-8">
          <h2 class="text-2xl font-bold mb-6">Complete Maintenance Task Guide</h2>
          
          <div class="space-y-8">
            <!-- Sump Pump Maintenance -->
            <div class="border-l-4 border-slate-400 pl-6">
              <h3 class="text-xl font-bold mb-3">Sump Pump Maintenance</h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">MONTHLY (5 min)</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Pour 5 gallons of water into pit to test pump activation</li>
                    <li>• Listen for unusual sounds (grinding, clicking)</li>
                    <li>• Check discharge pipe for proper flow</li>
                    <li>• Verify GFCI outlet hasn't tripped</li>
                  </ul>
                </div>
                
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">QUARTERLY (30 min)</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Remove pump and clean inlet screen</li>
                    <li>• Test battery backup system (unplug main pump)</li>
                    <li>• Check battery voltage (should be 13.0-13.5V)</li>
                    <li>• Clean sump pit of debris</li>
                    <li>• Test check valve for proper sealing</li>
                  </ul>
                </div>
                
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">ANNUALLY (Professional)</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Deep clean and inspect impeller</li>
                    <li>• Test amp draw and flow rate</li>
                    <li>• Replace battery if needed (3-5 year lifespan)</li>
                    <li>• Inspect and clean discharge line</li>
                    <li>• Update warranty documentation</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Drainage System Maintenance -->
            <div class="border-l-4 border-cyan-500 pl-6">
              <h3 class="text-xl font-bold mb-3">Drainage System Maintenance</h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">QUARTERLY</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Check interior drain openings for blockages</li>
                    <li>• Inspect visible pipes for damage</li>
                    <li>• Test floor drains with water</li>
                    <li>• Look for sediment buildup</li>
                  </ul>
                </div>
                
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">ANNUALLY</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Professional camera inspection of drain tiles</li>
                    <li>• Flush system with high-pressure water</li>
                    <li>• Check slope and flow rate</li>
                    <li>• Clear any root intrusions</li>
                  </ul>
                </div>
              </div>
            </div>

            <!-- Foundation Maintenance -->
            <div class="border-l-4 border-orange-500 pl-6">
              <h3 class="text-xl font-bold mb-3">Foundation & Exterior Maintenance</h3>
              
              <div class="space-y-4">
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">MONTHLY</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Visual inspection for new cracks</li>
                    <li>• Check for water stains or efflorescence</li>
                    <li>• Monitor existing sealed cracks</li>
                  </ul>
                </div>
                
                <div>
                  <h4 class="font-bold text-sm text-slate-500 mb-2">SEMI-ANNUALLY</h4>
                  <ul class="space-y-1 text-slate-600">
                    <li>• Check grade slope away from foundation</li>
                    <li>• Clean gutters and downspouts</li>
                    <li>• Inspect window wells and drains</li>
                    <li>• Trim vegetation near foundation</li>
                    <li>• Check exterior membrane (if visible)</li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Cost of Neglect -->
        <div class="mt-8 bg-red-50  p-8">
          <h2 class="text-2xl font-bold mb-6 text-red-600">The Real Cost of Skipping Maintenance</h2>
          
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="font-bold mb-3">Common Failures from Neglect:</h3>
              <ul class="space-y-2 text-slate-600">
                <li>• Sump pump failure during storm: <strong>$10,000-25,000</strong></li>
                <li>• Clogged drainage system: <strong>$3,000-5,000</strong></li>
                <li>• Battery backup failure: <strong>$5,000-15,000</strong></li>
                <li>• Backwater valve seizure: <strong>$15,000-30,000</strong></li>
                <li>• Foundation crack expansion: <strong>$2,000-8,000</strong></li>
              </ul>
            </div>
            
            <div>
              <h3 class="font-bold mb-3">Insurance Implications:</h3>
              <ul class="space-y-2 text-slate-600">
                <li>• Many policies require proof of maintenance</li>
                <li>• Claims can be denied for "lack of maintenance"</li>
                <li>• Deductibles often $5,000+ for water damage</li>
                <li>• Premiums increase 25-50% after claims</li>
                <li>• Some insurers drop coverage after 2 claims</li>
              </ul>
            </div>
          </div>
          
          <div class="mt-6 p-4 bg-white rounded">
            <p class="text-center font-bold text-lg">
              Regular maintenance costs <span class="text-cyan-400">$150-300/year</span><br>
              One failure costs <span class="text-red-600">$5,000-30,000</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <ContactForm />
  </main>

  <script>
    document.getElementById('scheduleGenerator').addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Get selected systems
      const systems = Array.from(document.querySelectorAll('input[name="system"]:checked'))
        .map(cb => cb.value);
      
      // Get risk factors
      const risks = Array.from(document.querySelectorAll('input[name="risk"]:checked'))
        .map(cb => cb.value);
      
      // Get other values
      const foundation = document.querySelector('select[name="foundation"]').value;
      const soil = document.querySelector('select[name="soil"]').value;
      const installDate = document.querySelector('input[name="installDate"]').value;
      
      // Generate monthly tasks
      let monthlyTasks = [];
      if (systems.includes('sump-pump')) {
        monthlyTasks.push(' Test sump pump with 5 gallons of water');
        monthlyTasks.push(' Check for unusual pump sounds');
        monthlyTasks.push(' Verify discharge pipe flow');
      }
      if (systems.includes('battery-backup')) {
        monthlyTasks.push(' Check battery charge indicator');
      }
      monthlyTasks.push(' Visual inspection for water/moisture');
      monthlyTasks.push(' Check for new foundation cracks');
      
      // Generate quarterly tasks
      let quarterlyTasks = [];
      if (systems.includes('sump-pump')) {
        quarterlyTasks.push(' Clean pump inlet screen');
        quarterlyTasks.push(' Test float switch operation');
        quarterlyTasks.push(' Clean sump pit of debris');
      }
      if (systems.includes('battery-backup')) {
        quarterlyTasks.push(' Test battery backup (unplug main pump)');
        quarterlyTasks.push(' Check battery voltage (13.0-13.5V)');
      }
      if (systems.includes('interior-drainage')) {
        quarterlyTasks.push(' Check drain openings for blockages');
      }
      if (systems.includes('backwater-valve')) {
        quarterlyTasks.push(' Inspect and clean backwater valve');
      }
      
      // Generate semi-annual tasks
      let semiAnnualTasks = [];
      semiAnnualTasks.push(' Check grade slope around foundation');
      if (systems.includes('gutters')) {
        semiAnnualTasks.push(' Clean gutters and downspouts');
        semiAnnualTasks.push(' Ensure downspouts extend 6+ feet');
      }
      if (systems.includes('window-wells')) {
        semiAnnualTasks.push(' Clean window well drains');
        semiAnnualTasks.push(' Check window well covers');
      }
      if (systems.includes('dehumidifier')) {
        semiAnnualTasks.push(' Clean dehumidifier filter and coils');
      }
      semiAnnualTasks.push(' Inspect and seal any new cracks');
      
      // Generate annual tasks
      let annualTasks = [];
      annualTasks.push(' Professional system inspection and service');
      if (systems.includes('sump-pump')) {
        annualTasks.push(' Professional pump testing and cleaning');
      }
      if (systems.includes('battery-backup')) {
        annualTasks.push(' Battery load test (replace if >3 years)');
      }
      if (systems.includes('interior-drainage')) {
        annualTasks.push(' Camera inspection of drain tiles');
      }
      if (systems.includes('exterior-membrane')) {
        annualTasks.push(' Inspect visible membrane and sealants');
      }
      annualTasks.push(' Update warranty documentation');
      
      // Display tasks
      document.getElementById('monthlyTasks').innerHTML = monthlyTasks.map(task => 
        `<div class="flex items-start"><span class="mr-2">•</span><span>${task}</span></div>`
      ).join('');
      
      document.getElementById('quarterlyTasks').innerHTML = quarterlyTasks.map(task => 
        `<div class="flex items-start"><span class="mr-2">•</span><span>${task}</span></div>`
      ).join('');
      
      document.getElementById('semiAnnualTasks').innerHTML = semiAnnualTasks.map(task => 
        `<div class="flex items-start"><span class="mr-2">•</span><span>${task}</span></div>`
      ).join('');
      
      document.getElementById('annualTasks').innerHTML = annualTasks.map(task => 
        `<div class="flex items-start"><span class="mr-2">•</span><span>${task}</span></div>`
      ).join('');
      
      // Generate calendar view
      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
      let calendarHTML = '';
      months.forEach((month, index) => {
        let tasks = ['Monthly check'];
        if (index % 3 === 0) tasks.push('Quarterly service');
        if (index === 3 || index === 9) tasks.push('Semi-annual');
        if (index === 4) tasks.push('ANNUAL SERVICE');
        
        calendarHTML += `
          <div class="bg-white border-2 border-slate-200rounded p-3">
            <div class="font-bold text-sm mb-1">${month}</div>
            <div class="text-xs text-slate-500">${tasks.join(', ')}</div>
          </div>
        `;
      });
      document.getElementById('calendarView').innerHTML = calendarHTML;
      
      // Cost breakdown
      let costs = [
        { item: 'DIY Monthly Tasks', cost: '$0', frequency: '12x/year' },
        { item: 'DIY Quarterly Tasks', cost: '$0', frequency: '4x/year' },
        { item: 'Annual Professional Service', cost: '$200-300', frequency: '1x/year' }
      ];
      
      if (systems.includes('battery-backup')) {
        costs.push({ item: 'Battery Replacement', cost: '$150-200', frequency: 'Every 3-5 years' });
      }
      
      document.getElementById('costBreakdown').innerHTML = costs.map(item => 
        `<div class="flex justify-between">
          <span>${item.item} (${item.frequency})</span>
          <span class="font-bold">${item.cost}</span>
        </div>`
      ).join('');
      
      // Warning signs based on system
      let warningSignsList = [
        'Pump running constantly (>2 min cycles)',
        'Water in basement after rain',
        'Musty smell or visible mold',
        'New or expanding cracks',
        'Pump making grinding/unusual sounds'
      ];
      
      if (risks.includes('flooding-history')) {
        warningSignsList.push('Any sign of water during storms');
      }
      if (soil === 'clay') {
        warningSignsList.push('Foundation wall bowing or movement');
      }
      
      document.getElementById('warningSignsList').innerHTML = warningSignsList.map(sign => 
        `<li class="text-red-700">• ${sign}</li>`
      ).join('');
      
      // Calculate savings
      let savingsAmount = '$5,000-10,000';
      if (risks.length > 2 || soil === 'clay') {
        savingsAmount = '$10,000-20,000';
      }
      document.getElementById('savingsAmount').textContent = savingsAmount;
      
      // Show results
      document.getElementById('scheduleResults').classList.remove('hidden');
      document.getElementById('scheduleResults').scrollIntoView({ behavior: 'smooth' });
    });
    
    function downloadCalendar() {
      // This would generate an .ics file in a real implementation
      alert('Calendar file will be sent to your email if provided');
    }
  </script>

  
