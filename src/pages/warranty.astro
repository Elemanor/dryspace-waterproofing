---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/sections/SectionHeader.astro';
import CTABand from '../components/sections/CTABand.astro';
import TrustBar from '../components/sections/TrustBar.astro';
---

<PageLayout
  title="25-Year Waterproofing Warranty | Industry-Leading Coverage | Dryspace"
  description="Industry-leading 25-year transferable warranty on all waterproofing work. Comprehensive coverage, annual inspections, and full peace of mind. Learn about warranty terms, coverage details, and claim process."
>
  <!-- Hero Section -->
  <section class="relative section-padding overflow-hidden bg-gradient-to-br from-navy-900 via-navy-800 to-navy-900">
    <div class="absolute inset-0 opacity-10">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 2px 2px, rgba(6, 182, 212, 0.15) 1px, transparent 0); background-size: 48px 48px;"></div>
    </div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-4xl mx-auto text-center reveal">
        <div class="section-label-pill mb-6">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          Industry-Leading Protection
        </div>

        <h1 class="text-headline mb-6">
          25-Year Transferable Warranty
        </h1>

        <p class="text-xl text-slate-300 leading-relaxed mb-12 max-w-3xl mx-auto">
          Sleep soundly knowing your waterproofing investment is protected by our industry-leading 25-year transferable warranty. We stand behind our work with comprehensive coverage, annual inspections, and a proven track record of reliability.
        </p>

        <!-- Feature Badges -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-12">
          <div class="card-base bg-white/5 backdrop-blur-sm border-cyan-500/20 text-center p-4">
            <div class="text-3xl font-bold text-cyan-500 mb-2">25</div>
            <div class="text-sm text-slate-300">Year Coverage</div>
          </div>
          <div class="card-base bg-white/5 backdrop-blur-sm border-cyan-500/20 text-center p-4">
            <svg class="w-8 h-8 text-amber-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/>
            </svg>
            <div class="text-sm text-slate-300">Fully Transferable</div>
          </div>
          <div class="card-base bg-white/5 backdrop-blur-sm border-cyan-500/20 text-center p-4">
            <svg class="w-8 h-8 text-cyan-500 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
            </svg>
            <div class="text-sm text-slate-300">Annual Inspections</div>
          </div>
          <div class="card-base bg-white/5 backdrop-blur-sm border-cyan-500/20 text-center p-4">
            <div class="text-3xl font-bold text-amber-500 mb-2">$5M</div>
            <div class="text-sm text-slate-300">Insurance Backed</div>
          </div>
        </div>

        <div class="flex flex-wrap justify-center gap-4">
          <a href="/free-inspection" class="btn-primary">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Get Warranty-Backed Quote
          </a>
          <a href="tel:437-545-0067" class="btn-secondary bg-white/10 border-white/20 text-white hover:bg-white hover:text-navy-900">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Call: 437-545-0067
          </a>
        </div>
      </div>
    </div>
  </section>

  <TrustBar />

  <!-- Coverage Cards Section -->
  <section class="section-padding bg-background">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Comprehensive Protection"
        title="What's Covered"
        description="Our industry-leading warranty provides complete protection for your waterproofing investment"
      />

      <div class="grid md:grid-cols-3 gap-8 max-w-7xl mx-auto">
        <!-- Exterior Waterproofing -->
        <div class="card-interactive reveal group">
          <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>

          <h3 class="text-2xl font-bold text-navy-900 mb-4">Exterior Waterproofing</h3>

          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Waterproof membranes & coatings</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Drainage systems & weeping tiles</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Excavation & restoration work</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">All specialty waterproofing products</span>
            </li>
          </ul>

          <div class="pt-6 border-t border-slate-200">
            <div class="text-sm font-semibold text-cyan-600 mb-1">100% Material Replacement</div>
            <div class="text-sm text-slate-500">Any defective materials replaced at no cost</div>
          </div>
        </div>

        <!-- Interior Systems -->
        <div class="card-interactive reveal group" style="animation-delay: 0.1s">
          <div class="w-16 h-16 bg-gradient-to-br from-amber-500 to-amber-600 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>

          <h3 class="text-2xl font-bold text-navy-900 mb-4">Interior Systems</h3>

          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Sump pumps & backup systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">French drain & collection systems</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Backwater valves & connections</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Crack injection & sealants</span>
            </li>
          </ul>

          <div class="pt-6 border-t border-slate-200">
            <div class="text-sm font-semibold text-amber-600 mb-1">Complete Workmanship Guarantee</div>
            <div class="text-sm text-slate-500">All labor defects corrected at our expense</div>
          </div>
        </div>

        <!-- Foundation Repair -->
        <div class="card-interactive reveal group" style="animation-delay: 0.2s">
          <div class="w-16 h-16 bg-gradient-to-br from-navy-600 to-navy-700 rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>

          <h3 class="text-2xl font-bold text-navy-900 mb-4">Foundation Repair</h3>

          <ul class="space-y-3 mb-6">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Foundation structural integrity</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Underpinning & benching work</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Wall stabilization & support</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-cyan-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-600">Settlement & crack repair</span>
            </li>
          </ul>

          <div class="pt-6 border-t border-slate-200">
            <div class="text-sm font-semibold text-navy-600 mb-1">Performance Promise</div>
            <div class="text-sm text-slate-500">Your basement stays dry or we make it right</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="section-padding bg-white">
    <div class="container mx-auto px-4">
      <SectionHeader
        label="Industry Comparison"
        title="Why Our Warranty is Superior"
        description="Compare our industry-leading warranty against typical waterproofing warranties"
      />

      <div class="max-w-5xl mx-auto reveal">
        <div class="card-base overflow-hidden">
          <!-- Table Header -->
          <div class="grid grid-cols-3 bg-gradient-to-r from-navy-900 to-navy-800">
            <div class="p-6 text-left">
              <div class="text-white font-bold text-lg">Feature</div>
            </div>
            <div class="p-6 text-center border-l border-white/10">
              <div class="text-slate-300 font-semibold mb-1">Industry Average</div>
              <div class="text-xs text-slate-400">Standard Coverage</div>
            </div>
            <div class="p-6 text-center border-l border-amber-500/50 bg-gradient-to-br from-amber-500/20 to-amber-600/20">
              <div class="text-amber-400 font-bold mb-1">Dryspace Warranty</div>
              <div class="text-xs text-amber-300">Premium Protection</div>
            </div>
          </div>

          <!-- Table Rows -->
          <div class="divide-y divide-slate-200">
            <!-- Row 1 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Warranty Duration</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="text-slate-600 font-medium mb-1">5-10 Years</div>
                <div class="text-xs text-slate-400">Limited time coverage</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="text-cyan-600 font-bold text-lg mb-1">25 Years</div>
                <div class="text-xs text-slate-600">Industry-leading duration</div>
              </div>
            </div>

            <!-- Row 2 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Transferability</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-slate-600 font-medium">Non-Transferable</span>
                </div>
                <div class="text-xs text-slate-400 mt-1">Warranty voids on sale</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-5 h-5 text-cyan-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-cyan-600 font-bold">Fully Transferable</span>
                </div>
                <div class="text-xs text-slate-600 mt-1">Adds value to home sale</div>
              </div>
            </div>

            <!-- Row 3 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Annual Inspections</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-5 h-5 text-slate-400" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-slate-600 font-medium">Not Included</span>
                </div>
                <div class="text-xs text-slate-400 mt-1">Customer responsibility</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="flex items-center justify-center gap-2">
                  <svg class="w-5 h-5 text-cyan-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-cyan-600 font-bold">Included Free</span>
                </div>
                <div class="text-xs text-slate-600 mt-1">Professional annual checkups</div>
              </div>
            </div>

            <!-- Row 4 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Materials Warranty</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="text-slate-600 font-medium mb-1">Materials Only</div>
                <div class="text-xs text-slate-400">Labor charges apply</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="text-cyan-600 font-bold mb-1">Materials + Labor</div>
                <div class="text-xs text-slate-600">Complete coverage included</div>
              </div>
            </div>

            <!-- Row 5 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Emergency Service</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="text-slate-600 font-medium mb-1">Business Hours</div>
                <div class="text-xs text-slate-400">Limited availability</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="text-cyan-600 font-bold mb-1">24/7 Response</div>
                <div class="text-xs text-slate-600">Emergency hotline available</div>
              </div>
            </div>

            <!-- Row 6 -->
            <div class="grid grid-cols-3 hover:bg-slate-50 transition-colors">
              <div class="p-6 font-semibold text-navy-900">Insurance Backed</div>
              <div class="p-6 text-center border-l border-slate-200">
                <div class="text-slate-600 font-medium mb-1">$1M or Less</div>
                <div class="text-xs text-slate-400">Basic business insurance</div>
              </div>
              <div class="p-6 text-center border-l border-slate-200 bg-gradient-to-br from-amber-50 to-amber-100/50">
                <div class="text-cyan-600 font-bold text-lg mb-1">$5M Coverage</div>
                <div class="text-xs text-slate-600">Comprehensive protection</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Claims Process Timeline -->
  <section class="section-padding bg-gradient-to-br from-slate-50 to-slate-100">
    <div class="container mx-auto px-4">
      <SectionHeader
